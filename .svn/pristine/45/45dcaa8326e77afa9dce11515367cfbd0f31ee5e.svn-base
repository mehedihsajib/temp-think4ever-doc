                    <!-- FAQ Section -->
                    <section id="mt_faq_accordion" class="doc-section faq-section" aria-labelledby="section-faq">
                        <h2 id="section-faq" class="doc-section-title">Frequently Asked Questions</h2>
                        <div class="faq-item">
                            <button class="faq-question" aria-expanded="false" aria-controls="faq-1">
                                <span>How far back can I view my transaction history?</span>
                                <i class="fa fa-chevron-down faq-chevron" aria-hidden="true"></i>
                            </button>
                            <div id="faq-1" class="faq-answer" role="region">
                                <div class="faq-answer-inner">
                                    You can view up to 24 months of transaction history directly in the app. For older
                                    records, contact our support team to request archived data exports.
                                </div>
                            </div>
                        </div>
                        <div class="faq-item">
                            <button class="faq-question" aria-expanded="false" aria-controls="faq-2">
                                <span>Why is my transaction still showing as "Pending"?</span>
                                <i class="fa fa-chevron-down faq-chevron" aria-hidden="true"></i>
                            </button>
                            <div id="faq-2" class="faq-answer" role="region">
                                <div class="faq-answer-inner">
                                    Transactions typically move from Pending to Completed within 1-5 minutes. If a
                                    transaction remains pending for more than 30 minutes, it may indicate a processing
                                    issue. Check your internet connection and try refreshing. If the issue persists,
                                    contact support with the transaction ID.
                                </div>
                            </div>
                        </div>
                        <div class="faq-item">
                            <button class="faq-question" aria-expanded="false" aria-controls="faq-3">
                                <span>Can I refund a transaction after the 90-day window?</span>
                                <i class="fa fa-chevron-down faq-chevron" aria-hidden="true"></i>
                            </button>
                            <div id="faq-3" class="faq-answer" role="region">
                                <div class="faq-answer-inner">
                                    In-app refunds are limited to 90 days. For refunds beyond this period, you'll need
                                    to contact our support team who can process exceptional refunds on a case-by-case
                                    basis. Additional verification may be required.
                                </div>
                            </div>
                        </div>
                        <div class="faq-item">
                            <button class="faq-question" aria-expanded="false" aria-controls="faq-4">
                                <span>How long does it take for a refund to appear in the customer's account?</span>
                                <i class="fa fa-chevron-down faq-chevron" aria-hidden="true"></i>
                            </button>
                            <div id="faq-4" class="faq-answer" role="region">
                                <div class="faq-answer-inner">
                                    Refunds to MPay wallets are typically instant. Bank account refunds may take 1-3
                                    business days depending on the customer's bank. The customer will receive a
                                    notification once the refund is processed on our end.
                                </div>
                            </div>
                        </div>
                        <div class="faq-item">
                            <button class="faq-question" aria-expanded="false" aria-controls="faq-5">
                                <span>Can I export transactions through an API?</span>
                                <i class="fa fa-chevron-down faq-chevron" aria-hidden="true"></i>
                            </button>
                            <div id="faq-5" class="faq-answer" role="region">
                                <div class="faq-answer-inner">
                                    Yes! MPay provides a REST API for programmatic access to transaction data. Visit our
                                    <strong>API Documentation</strong> for details on available endpoints,
                                    authentication, and rate limits. API access requires a Business or Enterprise plan.
                                </div>
                            </div>
                        </div>
                        <div class="faq-item">
                            <button class="faq-question" aria-expanded="false" aria-controls="faq-6">
                                <span>Why is there a difference between the transaction amount and my settlement
                                    deposit?</span>
                                <i class="fa fa-chevron-down faq-chevron" aria-hidden="true"></i>
                            </button>
                            <div id="faq-6" class="faq-answer" role="region">
                                <div class="faq-answer-inner">
                                    The difference is typically due to processing fees, which are deducted before
                                    settlement. The Net Amount shown in each transaction reflects the amount after fees.
                                    Your settlement report provides a detailed breakdown of gross amounts, fees, and net
                                    deposits for each batch.
                                </div>
                            </div>
                        </div>
                    </section>
