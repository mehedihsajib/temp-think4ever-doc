    <link rel="stylesheet" href="assets/css/global.css">
    <link rel="stylesheet" href="assets/css/merchant_transactions.css">
    <style>
        /* Basic reset for preview consistency */
        body {
            margin: 0;
            padding: 0;
            font-family: sans-serif;
        }
    </style>
</head>

<body>

    <div class="merchant-transactions-page">
        <!-- Skip to content -->
        <a href="#main-content" class="sr-only"
            style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;"
            onfocus="this.style.position='static';this.style.width='auto';this.style.height='auto';"
            onblur="this.style.position='absolute';this.style.width='1px';this.style.height='1px';">
            Skip to main content </a>
        <!-- Site Header -->
        <header class="modern-header" id="consumerHeader">
        </header>
        <div class="docs-layout">
            <!-- Mobile sidebar toggle -->
            <button class="cgs-sidebar-toggle" id="cgsSidebarToggle" aria-label="Toggle navigation menu"
                aria-expanded="false">
                <i class="fa fa-bars"></i>
            </button>
            <!-- Sidebar overlay -->
            <div class="cgs-sidebar-overlay" id="cgsSidebarOverlay"></div>
            <!-- Sidebar -->
            <div id="merchantSidebar">

            </div>

            <!-- Main Content Area -->
            <div class="docs-main">
                <main id="main-content" class="docs-content">
                    <!-- Mobile sidebar toggle -->
                    <button class="mobile-sidebar-toggle" aria-label="Toggle navigation sidebar">
                        <i class="fa fa-bars" aria-hidden="true"></i> Menu
                    </button>
                    <!-- Breadcrumb -->
                    <nav id="mt_breadcrumb" class="breadcrumb" aria-label="Breadcrumb">
                        <a onclick="load_page('index')">Docs</a>
                        <span class="breadcrumb-separator"><i class="fa fa-chevron-right" aria-hidden="true"></i></span>
                        <a onclick="load_page('merchant_docs_home')">Merchant</a>
                        <span class="breadcrumb-separator"><i class="fa fa-chevron-right" aria-hidden="true"></i></span>
                        <span class="breadcrumb-current">Transaction Management</span>
                    </nav>
                    <!-- Page Title -->
                    <h1 id="mt_title" class="doc-page-title">Transaction Management</h1>
                    <p class="doc-page-subtitle">
                        Learn how to view, filter, and manage all your transactions. Export reports for accounting,
                        process refunds, and understand settlement cycles. </p>
                    <!-- Section: Transaction History -->
                    <section id="mt_content_history" class="doc-section" aria-labelledby="section-history">
                        <h2 id="section-history" class="doc-section-title">Transaction History</h2>
                        <p>
                            The Transaction History screen provides a comprehensive view of all payments received
                            through your MPay Merchant Wallet. You can access it from the main dashboard by tapping the
                            <strong>Transactions</strong> tab. </p>
                        <h3>Accessing Your Transactions</h3>
                        <ol class="steps">
                            <li class="step">
                                <span class="step-number">1</span>
                                <div class="step-title">Open the mPay Merchant App</div>
                                <div class="step-content">Launch the app and sign in if you haven't already.</div>
                            </li>
                            <li class="step">
                                <span class="step-number">2</span>
                                <div class="step-title">Navigate to Transaction History</div>
                                <div class="step-content">Tap the <code>History</code> icon in the bottom navigation
                                    bar.
                                </div>
                            </li>
                            <li class="step">
                                <span class="step-number">3</span>
                                <div class="step-title">Browse Your History</div>
                                <div class="step-content">Transactions are listed in reverse chronological order with
                                    the most recent appearing first.</div>
                            </li>
                        </ol>
                        <h3>Filtering & Searching</h3>
                        <p>
                            Use the filter bar at the top of the transaction list to narrow down results. You can
                            combine multiple filters simultaneously. </p>
                        <!-- Filter bar mockup -->
                        <div class="filter-bar-mockup">
                            <div class="filter-item">
                                <i class="fa fa-calendar" aria-hidden="true"></i>
                                <span class="filter-item-label">Date Range:</span>
                                <span>Last 30 days</span>
                            </div>
                            <div class="filter-item">
                                <i class="fa fa-filter" aria-hidden="true"></i>
                                <span class="filter-item-label">Status:</span>
                                <span>All</span>
                            </div>
                            <div class="filter-item">
                                <i class="fa fa-credit-card" aria-hidden="true"></i>
                                <span class="filter-item-label">Type:</span>
                                <span>Scan to Pay</span>
                            </div>
                            <div class="filter-item">
                                <i class="fa fa-search" aria-hidden="true"></i>
                                <span>Search by ID, amount...</span>
                            </div>
                            <button class="filter-btn" aria-label="Apply filters">
                                <i class="fa fa-check" aria-hidden="true"></i> Apply
                            </button>
                        </div>
                        <p>Available filter options include:</p>
                        <ul>
                            <li>
                                <strong>Date Range</strong> — Select predefined ranges (Today, This Week, This Month) or
                                set a custom date range.
                            </li>
                            <li>
                                <strong>Transaction Status</strong> — Filter by Completed, Pending, Failed, or Refunded.
                            </li>
                            <li>
                                <strong>Payment Type</strong> — QR Code, NFC, or All.
                            </li>
                            <li>
                                <strong>Amount Range</strong> — Set minimum and maximum amount thresholds.
                            </li>
                            <li>
                                <strong>Search</strong> — Search by transaction ID, customer name, or reference number.
                            </li>
                        </ul>
                        <div class="callout callout-info">
                            <div class="callout-icon">
                                <i class="fa fa-lightbulb" aria-hidden="true"></i>
                            </div>
                            <div class="callout-content">
                                <strong>Pro Tip</strong>
                                You can save frequently used filter combinations as presets. Tap the bookmark icon in
                                the filter bar to save your current filters.

                            </div>
                        </div>
                    </section>
                    <!-- Section: Transaction Details -->
                    <section id="mt_content_details" class="doc-section" aria-labelledby="section-details">
                        <h2 id="section-details" class="doc-section-title">Transaction Details</h2>
                        <p>
                            Tap any transaction in your history list to view its complete details. Each transaction
                            record contains comprehensive information about the payment. </p>
                        <!-- Transaction card mockup -->
                        <div class="txn-card-mockup" aria-label="Example transaction detail card">
                            <div class="txn-card-header">
                                <span class="txn-card-id">#TXN-2025-00847</span>
                                <span class="status-badge status-completed"><i class="fa fa-check-circle"
                                        aria-hidden="true"></i> Completed</span>
                            </div>
                            <div style="text-align:center;padding:12px 0;">
                                <div class="txn-card-amount">XCG 124.50</div>
                            </div>
                            <div class="txn-card-row">
                                <span class="txn-card-label">Transaction Type</span>
                                <span class="txn-card-value"><i class="fa fa-qrcode" aria-hidden="true"
                                        style="margin-right:4px;"></i> QR Code</span>
                            </div>
                            <div class="txn-card-row">
                                <span class="txn-card-label">Customer Name</span>
                                <span class="txn-card-value">John D.</span>
                            </div>
                            <div class="txn-card-row">
                                <span class="txn-card-label">Date & Time</span>
                                <span class="txn-card-value">Mar 11, 2025 · 2:34 PM</span>
                            </div>
                            <div class="txn-card-row">
                                <span class="txn-card-label">Fee</span>
                                <span class="txn-card-value">&nbsp;XCG1.87</span>
                            </div>
                            <div class="txn-card-row">
                                <span class="txn-card-label">Net Amount</span>
                                <span class="txn-card-value" style="font-weight:700;color:#1e3a8a;">XCG 122.63</span>
                            </div>
                        </div>
                        <h3>Transaction Detail Fields</h3>
                        <p>The full transaction detail view includes the following information:</p>
                        <ul>
                            <li>
                                <strong>Transaction ID</strong> — Unique identifier for the transaction (format:
                                <code>TXN-YYYY-XXXXX</code>)
                            </li>
                            <li>
                                <strong>Amount</strong> — The gross payment amount
                            </li>
                            <li>
                                <strong>Fee</strong> — Processing fee deducted from the transaction
                            </li>
                            <li>
                                <strong>Net Amount</strong> — Amount you receive after fees
                            </li>
                            <li>
                                <strong>Payment Type</strong>&nbsp;&#8212; Scan to Pay, Pay Bills etc
                            </li>
                            <li>
                                <strong>Customer Info</strong> — Customer name (if available) and wallet reference
                            </li>
                            <li>
                                <strong>Timestamp</strong> — Exact date and time of the transaction
                            </li>
                            <li>
                                <strong>Reference Number</strong> &#8212; For Bill Payments
                            </li>
                        </ul>
                    </section>
                    <!-- Section: Refunds & Reversals -->
                    <section id="mt_content_refunds" class="doc-section" aria-labelledby="section-refunds">
                        <div class="callout callout-warning">
                            <div class="callout-icon">
                                <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
                            </div>
                            <div class="callout-content">
                                <strong>Important</strong>
                                Refunds cannot be reversed once initiated. The original processing fee is not refunded.
                                Double-check the amount before confirming.
                            </div>
                        </div>
                        <div class="callout callout-danger">
                            <div class="callout-icon">
                                <i class="fa fa-ban" aria-hidden="true"></i>
                            </div>
                            <div class="callout-content">
                                <strong>Refund Not Available?</strong>
                                Refunds are not available for transactions older than 90 days, transactions that are
                                still in "Pending" status, or transactions that have already been fully refunded.
                            </div>
                        </div>
                    </section>
