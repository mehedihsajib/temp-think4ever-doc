<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title data-i18n="merchant_home.title">Merchant Wallet Docs - Home</title>
    <link href="css/theme.css" rel="stylesheet" type="text/css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="assets/css/global.css">
    <link rel="stylesheet" href="assets/css/merchant_docs_home.css">
    <style>
        /* Basic reset for preview consistency */
        body {
            margin: 0;
            padding: 0;
            font-family: sans-serif;
        }
    </style>
</head>

<body>
    <header class="modern-header" id="consumerHeader">
    </header>
    <div class="merchant-docs-home">
        <!-- Skip to content -->
        <a href="#md-main" class="sr-only"
            style="position:absolute;top:-9999px;left:-9999px;z-index:100;padding:8px 16px;background:#2563eb;color:#fff;text-decoration:none;border-radius:4px;"
            onfocus="this.style.position='fixed';this.style.top='8px';this.style.left='8px';"
            onblur="this.style.position='absolute';this.style.top='-9999px';" data-i18n="skip_to_main">Skip to main content</a>
        <!-- Mobile sidebar toggle -->
        <button class="cgs-sidebar-toggle" id="cgsSidebarToggle" aria-label="Toggle navigation menu"
            aria-expanded="false">
            <i class="fa fa-bars"></i>
        </button>
        <!-- Sidebar overlay -->
        <div class="cgs-sidebar-overlay" id="cgsSidebarOverlay"></div>
        <!-- Sidebar -->
        <div id="merchantSidebar">

        </div>
        <!-- Main Content -->
        <main class="md-main-content" id="md-main">
            <div class="md-content-inner">
                <!-- Version Banner -->
                <div class="md-version-banner" id="mdHomeVersionBanner" role="status">
                    <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
                    <span data-i18n-html="merchant_home.version_banner.text">You are viewing documentation for <strong>MPay Merchant Wallet v2.4</strong>. Looking for a
                        different version? <a onclick="load_page('changelog_page')" tabindex="0">View
                            changelog</a></span>
                    <span class="md-version-badge" data-i18n="merchant_home.version_banner.badge">Latest</span>
                </div>
                <!-- Breadcrumb -->
                <nav class="md-breadcrumb" id="mdHomeBreadcrumb" aria-label="Breadcrumb">
                    <a onclick="load_page('index')" tabindex="0" data-i18n="merchant_home.breadcrumb.docs">Docs</a>
                    <span class="separator" aria-hidden="true"><i class="fa-solid fa-chevron-right"></i></span>
                    <span class="current" data-i18n="merchant_home.breadcrumb.current">Merchant Wallet</span>
                </nav>
                <!-- Page Title -->
                <h1 class="md-page-title" id="mdHomeTitle" data-i18n="merchant_home.title">Merchant Wallet Documentation</h1>
                <p class="md-page-subtitle" data-i18n="merchant_home.subtitle">Everything you need to set up, configure, and manage your MPay Merchant
                    Wallet.</p>
                <div class="md-title-divider"></div>
                <!-- Overview Section -->
                <section class="md-overview-section" id="mdHomeOverview" aria-labelledby="overview-heading">
                    <h2 class="md-section-title" id="overview-heading" data-i18n="merchant_home.overview.title">Overview</h2>
                    <p class="md-overview-text" data-i18n="merchant_home.overview.p1">The mPay Merchant Wallet is a powerful mobile payment acceptance
                        solution designed for businesses of all sizes. Accept payments seamlessly through QR codes, NFC
                        tap-to-pay, and direct wallet transfers &#8212; all from your smartphone.</p>
                    <p class="md-overview-text" data-i18n="merchant_home.overview.p2">
                        With the Merchant Wallet, you can manage your transactions, generate detailed reports, configure
                        payment preferences, and provide your customers with a fast, secure checkout experience. </p>
                    <ul class="md-features-list">
                        <li class="md-feature-item">
                            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
                            <span data-i18n="merchant_home.overview.feature1">Accept QR code payments instantly</span>
                        </li>
                        <li class="md-feature-item">
                            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
                            <span data-i18n="merchant_home.overview.feature2">NFC tap-to-pay contactless payments</span>
                        </li>
                        <li class="md-feature-item">
                            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
                            <span data-i18n="merchant_home.overview.feature3">Real-time transaction monitoring</span>
                        </li>
                        <li class="md-feature-item">
                            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
                            <span data-i18n="merchant_home.overview.feature4">Detailed sales reports &amp; analytics</span>
                        </li>
                        <li class="md-feature-item">
                            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
                            <span data-i18n="merchant_home.overview.feature5">Multi-currency support</span>
                        </li>
                        <li class="md-feature-item">
                            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
                            <span data-i18n="merchant_home.overview.feature6">Bank-grade security &amp; encryption</span>
                        </li>
                        <li class="md-feature-item">
                            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
                            <span data-i18n="merchant_home.overview.feature7">Customizable business profile</span>
                        </li>
                        <li class="md-feature-item">
                            <i class="fa-solid fa-check-circle" aria-hidden="true"></i>
                            <span data-i18n="merchant_home.overview.feature8">Export transactions (CSV, PDF)</span>
                        </li>
                    </ul>
                    <div class="md-callout info">
                        <i class="fa-solid fa-lightbulb" aria-hidden="true"></i>
                        <div data-i18n-html="merchant_home.overview.info_callout">
                            <strong>New to mPay?</strong> Start with our <a
                                onclick="load_page('merchant_getting_started')" tabindex="0">Getting Started guide</a>
                            to download the app and set up your first merchant account in minutes.
                        </div>
                    </div>
                </section>
                <!-- Quick Start Steps -->
                <section class="md-overview-section" aria-labelledby="quickstart-heading">
                    <h2 class="md-section-title" id="quickstart-heading" data-i18n="merchant_home.quick_start.title">Quick Start</h2>
                    <p class="md-overview-text" data-i18n="merchant_home.quick_start.subtitle">Get up and running in four easy steps:</p>
                    <div class="md-quick-steps">
                        <div class="md-step">
                            <div class="md-step-number">1</div>
                            <div class="md-step-content">
                                <h4 data-i18n="merchant_home.quick_start.step1.title">Download &amp; Install</h4>
                                <p data-i18n="merchant_home.quick_start.step1.desc">Get the MPay Merchant Wallet from the App Store or Google Play.</p>
                            </div>
                        </div>

                        <div class="md-step">
                            <div class="md-step-number">2</div>
                            <div class="md-step-content">
                                <h4 data-i18n="merchant_home.quick_start.step2.title">Create Your Account</h4>
                                <p data-i18n="merchant_home.quick_start.step2.desc">Register with your business details and complete the business profile.</p>
                            </div>
                        </div>
                        <div class="md-step">
                            <div class="md-step-number">3</div>
                            <div class="md-step-content">
                                <h4 data-i18n="merchant_home.quick_start.step3.title">Complete the Verification process</h4>
                                <p data-i18n="merchant_home.quick_start.step3.desc">Submit pertinent business documents and wait for profile to get verified.</p>
                            </div>
                        </div>
                        <div class="md-step">
                            <div class="md-step-number">4</div>
                            <div class="md-step-content">
                                <h4 data-i18n="merchant_home.quick_start.step4.title">Start Accepting Payments</h4>
                                <p data-i18n="merchant_home.quick_start.step4.desc">You're ready! Accept your first payment and manage transactions effortlessly.</p>
                            </div>
                        </div>
                    </div>
                </section>
                <!-- Documentation Sections Cards -->
                <section class="md-cards-section" aria-labelledby="explore-heading">
                    <h2 class="md-section-title" id="explore-heading" data-i18n="merchant_home.explore.title">Explore Documentation</h2>
                    <p class="md-overview-text" data-i18n="merchant_home.explore.subtitle">Dive into detailed guides for every feature of the Merchant Wallet.</p>
                    <div class="md-cards-grid">
                        <!-- Getting Started - Highlighted Card -->
                        <div class="md-getting-started-card" id="mdHomeGettingStartedLink" tabindex="0" role="link"
                            aria-label="Getting Started - Download, install, and set up the Merchant Wallet"
                            data-i18n-attr="aria-label:merchant_home.explore.getting_started.desc">
                            <div class="md-getting-started-icon">
                                <i class="fa-solid fa-rocket" aria-hidden="true"></i>
                            </div>
                            <div class="md-getting-started-content">
                                <h3 data-i18n="merchant_home.explore.getting_started.title">Getting Started</h3>
                                <p data-i18n="merchant_home.explore.getting_started.desc">Download, install, and set up the Merchant Wallet. Perfect for first-time users.</p>
                            </div>
                            <div class="md-getting-started-arrow">
                                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                            </div>
                        </div>
                        <!-- Account Setup -->
                        <div class="md-nav-card" id="mdHomeAccountLink" data-navigate="merchant_account_setup"
                            tabindex="0" role="link" aria-label="Account Setup & Verification"
                            data-i18n-attr="aria-label:merchant_home.explore.account.title">
                            <div class="md-nav-card-icon">
                                <i class="fa-solid fa-user-check" aria-hidden="true"></i>
                            </div>
                            <div class="md-nav-card-title">
                                <span data-i18n="merchant_home.explore.account.title">Account Setup &amp; Verification</span>
                                <span class="arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></span>
                            </div>
                            <p class="md-nav-card-desc" data-i18n="merchant_home.explore.account.desc">Register your business, complete KYC verification, and set up
                                your merchant profile.</p>
                        </div>
                        <!-- QR Code Payments -->
                        <div class="md-nav-card" id="mdHomeQrLink" data-navigate="merchant_qr_payments" tabindex="0"
                            role="link" aria-label="QR Code Payments"
                            data-i18n-attr="aria-label:merchant_home.explore.qr.title">
                            <div class="md-nav-card-icon">
                                <i class="fa-solid fa-qrcode" aria-hidden="true"></i>
                            </div>
                            <div class="md-nav-card-title">
                                <span data-i18n="merchant_home.explore.qr.title">QR Code Payments</span>
                                <span class="arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></span>
                            </div>
                            <p class="md-nav-card-desc" data-i18n="merchant_home.explore.qr.desc">Generate, display, and manage QR codes for easy customer
                                payments.</p>
                        </div>
                        <!-- NFC Payments -->
                        <div class="md-nav-card" id="mdHomeNfcLink" data-navigate="merchant_nfc_payments" tabindex="0"
                            role="link" aria-label="NFC Payments"
                            data-i18n-attr="aria-label:merchant_home.explore.nfc.title">
                            <div class="md-nav-card-icon">
                                <i class="fa-solid fa-wifi" aria-hidden="true"></i>
                            </div>
                            <div class="md-nav-card-title">
                                <span data-i18n="merchant_home.explore.nfc.title">NFC Payments</span>
                                <span class="arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></span>
                            </div>
                            <p class="md-nav-card-desc" data-i18n="merchant_home.explore.nfc.desc">Enable and configure NFC tap-to-pay for fast contactless
                                transactions.</p>
                        </div>
                        <!-- Transaction Management -->
                        <div class="md-nav-card" id="mdHomeTransactionsLink" data-navigate="merchant_transactions"
                            tabindex="0" role="link" aria-label="Transaction Management"
                            data-i18n-attr="aria-label:merchant_home.explore.transactions.title">
                            <div class="md-nav-card-icon">
                                <i class="fa-solid fa-receipt" aria-hidden="true"></i>
                            </div>
                            <div class="md-nav-card-title">
                                <span data-i18n="merchant_home.explore.transactions.title">Transaction Management</span>
                                <span class="arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></span>
                            </div>
                            <p class="md-nav-card-desc" data-i18n="merchant_home.explore.transactions.desc">View, search, filter, and export your payment transactions and
                                reports.</p>
                        </div>
                        <!-- Settings -->
                        <div class="md-nav-card" id="mdHomeSettingsLink" data-navigate="merchant_settings" tabindex="0"
                            role="link" aria-label="Settings & Configuration"
                            data-i18n-attr="aria-label:merchant_home.explore.settings.title">
                            <div class="md-nav-card-icon">
                                <i class="fa-solid fa-gear" aria-hidden="true"></i>
                            </div>
                            <div class="md-nav-card-title">
                                <span data-i18n="merchant_home.explore.settings.title">Settings &amp; Configuration</span>
                                <span class="arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></span>
                            </div>
                            <p class="md-nav-card-desc" data-i18n="merchant_home.explore.settings.desc">Configure notifications, security settings, payment preferences,
                                and more.</p>
                        </div>
                        <!-- Troubleshooting -->
                        <div class="md-nav-card" id="mdHomeTroubleshootingLink" data-navigate="merchant_troubleshooting"
                            tabindex="0" role="link" aria-label="Troubleshooting"
                            data-i18n-attr="aria-label:merchant_home.explore.troubleshooting.title">
                            <div class="md-nav-card-icon">
                                <i class="fa-solid fa-life-ring" aria-hidden="true"></i>
                            </div>
                            <div class="md-nav-card-title">
                                <span data-i18n="merchant_home.explore.troubleshooting.title">Troubleshooting</span>
                                <span class="arrow" aria-hidden="true"><i class="fa-solid fa-arrow-right"></i></span>
                            </div>
                            <p class="md-nav-card-desc" data-i18n="merchant_home.explore.troubleshooting.desc">Find solutions to common issues, error codes, and contact
                                support.</p>
                        </div>
                    </div>
                </section>
                <!-- Prev/Next Navigation -->
                <nav class="md-prev-next" id="mdHomePrevNext" aria-label="Page navigation">
                    <div class="md-prev-next-card prev" aria-hidden="true">
                        <!-- No previous page -->
                    </div>
                    <div class="md-prev-next-card next" data-navigate="merchant_getting_started" tabindex="0"
                        role="link" aria-label="Next: Getting Started"
                        data-i18n-attr="aria-label:merchant_home.pagination.next_title">
                        <span class="md-prev-next-label">
                            <span data-i18n="merchant_home.pagination.next">Next</span> <i class="fa-solid fa-arrow-right" aria-hidden="true"></i> </span>
                        <p class="md-prev-next-title" data-i18n="merchant_home.pagination.next_title">Getting Started</p>
                    </div>
                </nav>
            </div>
        </main>
        <!-- Scroll to Top -->
        <button class="md-scroll-top" id="mdScrollTop" aria-label="Scroll to top">
            <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
        </button>
    </div>
    <div id="docFooter"></div>
    <script src="assets/js/i18n.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.I18n) {
                window.I18n.init();
            }
        });
    </script>
    <script src="assets/js/navigation.js"></script>
    <script src="assets/js/merchant_docs_home.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
</body>

</html>