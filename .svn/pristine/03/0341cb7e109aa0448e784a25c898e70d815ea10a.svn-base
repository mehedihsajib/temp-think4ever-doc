                <!-- Main Content Area -->
                <div class="docs-main">
                    <div class="docs-content" id="mnfc-main-content">
                        <!-- Breadcrumb -->
                        <nav class="breadcrumb" id="mnfc_breadcrumb" aria-label="Breadcrumb">
                            <a onclick="load_page('landing_page')">Docs</a>
                            <span class="separator"><i class="fa fa-chevron-right"></i></span>
