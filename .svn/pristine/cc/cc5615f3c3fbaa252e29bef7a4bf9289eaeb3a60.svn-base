  "troubleshooting": {
    "breadcrumb": {
      "docs": "Documentazione",
      "consumer": "Privato",
      "current": "Risoluzione Problemi"
    },
    "title": "Risoluzione Problemi",
    "subtitle": "Trova soluzioni ai problemi comuni, comprendi i codici di errore e impara a risolvere i problemi con il tuo MPay Consumer Wallet.",
    "search_placeholder": "Cerca problemi, codici di errore e FAQ...",
    "diagnostic": {
      "title": "Strumento di Diagnostica Rapida",
      "intro": "Esegui un rapido controllo per identificare potenziali problemi con la configurazione del tuo wallet. Questa diagnostica verifica i punti di configurazione comuni.",
      "check_internet": "Connettività Internet",
      "check_version": "Versione app aggiornata",
      "check_permissions": "Permessi richiesti concessi",
      "check_nfc": "Hardware NFC disponibile",
      "check_storage": "Spazio di archiviazione sufficiente",
      "btn": "Esegui Diagnostica",
      "running": "In corso..."
    },
    "common_issues": {
      "title": "Problemi Comuni",
      "desc": "Di seguito sono riportati i problemi riscontrati più frequentemente e le relative soluzioni passo-passo.",
      "issue1": {
        "title": "Impossibile connettersi al server",
        "summary": "L'app mostra \"Errore di connessione\" o impiega troppo tempo per caricarsi.",
        "causes": "Possibili Cause",
        "cause1": "Connessione Internet instabile (Wi-Fi o dati mobili)",
        "cause2": "I server di MPay Network potrebbero essere in manutenzione",
        "cause3": "Interferenza VPN o proxy",
        "cause4": "Versione app obsoleta",
        "solution": "Soluzione",
        "step1": "Controlla la tua connessione Internet aprendo una pagina web nel browser.",
        "step2": "Attiva e disattiva la modalità aereo, quindi riprova.",
        "step3": "Disabilita temporaneamente eventuali servizi VPN o proxy.",
        "step4": "Aggiorna l'app MPay Consumer Wallet dal tuo app store.",
        "step5": "Se il problema persiste, controlla la <a href=\"#\" style=\"color:#2563eb;\">Pagina di Stato MPay</a> per incidenti in corso.",
        "callout": "La manutenzione del server dura tipicamente 15-30 minuti ed è programmata durante le ore non di punta (2:00 — 4:00 ora locale)."
      },
      "issue2": {
        "title": "Codice QR non scansionato",
        "summary": "La fotocamera non riesce a rilevare o leggere i codici QR degli esercenti.",
        "causes": "Possibili Cause",
        "cause1": "Permesso fotocamera non concesso all'app",
        "cause2": "Scarse condizioni di illuminazione",
        "cause3": "Codice QR danneggiato o sfocato",
        "cause4": "L'obiettivo della fotocamera è sporco o ostruito",
        "solution": "Soluzione",
        "step1": "Vai su <strong>Impostazioni → Permessi App</strong> e assicurati che l'accesso alla fotocamera sia abilitato per MPay.",
        "step2": "Pulisci l'obiettivo della fotocamera con un panno morbido.",
        "step3": "Assicura un'illuminazione adeguata — usa l'interruttore della torcia nella vista scanner.",
        "step4": "Tieni il telefono fermo, a circa 15-30 cm dal codice QR.",
        "step5": "Se il codice QR è su uno schermo, riduci il riflesso dello schermo regolando l'angolazione.",
        "callout": "Se il codice QR sembra danneggiato o corrotto, chiedi all'esercente di generarne uno nuovo."
      },
      "issue3": {
        "title": "Pagamento NFC non riuscito",
        "summary": "Il tap-to-pay non viene rilevato o la transazione non viene completata.",
        "causes": "Possibili Cause",
        "cause1": "NFC disabilitato sul tuo dispositivo",
        "cause2": "La cover del telefono blocca l'antenna NFC",
        "cause3": "Dispositivo non posizionato correttamente sul terminale",
        "cause4": "Saldo wallet insufficiente",
        "solution": "Soluzione",
        "step1": "Abilita l'NFC nelle Impostazioni del telefono: <span class=\"ctr-code\">Impostazioni → Dispositivi collegati → NFC</span>",
        "step2": "Rimuovi cover spesse o accessori metallici che potrebbero bloccare l'NFC.",
        "step3": "Tieni il retro del telefono appoggiato sul terminale per 2-3 secondi.",
        "step4": "Assicurati che il tuo wallet abbia saldo sufficiente per la transazione.",
        "callout": "La posizione dell'antenna NFC varia in base al modello di telefono. La maggior parte dei telefoni Android ce l'ha nella parte medio-superiore posteriore. Gli iPhone usano il bordo superiore."
      },
      "issue4": {
        "title": "Accesso biometrico non funzionante",
        "summary": "Il riconoscimento dell'impronta digitale o facciale non riesce ad autenticarsi.",
        "causes": "Possibili Cause",
        "cause1": "Dati biometrici cambiati sul dispositivo (nuova impronta aggiunta)",
        "cause2": "Sensore hardware biometrico sporco o danneggiato",
        "cause3": "Permesso biometrico revocato per l'app",
        "solution": "Soluzione",
        "step1": "Accedi utilizzando il tuo codice PIN come alternativa.",
        "step2": "Vai su <strong>Impostazioni MPay → Sicurezza → Accesso Biometrico</strong> e riabilitalo.",
        "step3": "Se richiesto, registra nuovamente i tuoi dati biometrici.",
        "step4": "Pulisci il sensore di impronte digitali o assicurati che il riconoscimento facciale abbia una linea di vista libera."
      },
      "issue5": {
        "title": "Trasferimento P2P bloccato o in attesa",
        "summary": "Denaro inviato ma il destinatario non lo ha ricevuto.",
        "causes": "Possibili Cause",
        "cause1": "Congestione della rete che causa ritardi",
        "cause2": "L'account del destinatario potrebbe avere restrizioni",
        "cause3": "L'importo della transazione supera i limiti giornalieri",
        "cause4": "Revisione di conformità per importi elevati",
        "solution": "Soluzione",
        "step1": "Controlla lo stato della transazione in <strong>Attività → Cronologia Transazioni</strong>.",
        "step2": "Se lo stato è \"In elaborazione\", attendi fino a 30 minuti per il completamento.",
        "step3": "Se lo stato è \"In attesa di revisione\", la tua transazione è in fase di revisione. Riceverai una notifica una volta risolto.",
        "step4": "Se bloccato per più di 2 ore, contatta il supporto con l'ID Transazione.",
        "callout": "<strong>Non</strong> inviare nuovamente lo stesso trasferimento mentre l'originale è ancora in fase di elaborazione. Ciò potrebbe comportare un doppio addebito."
      },
      "issue6": {
        "title": "Ricarica o prelievo non riusciti",
        "summary": "Impossibile aggiungere fondi o prelevare dal wallet.",
        "causes": "Possibili Cause",
        "cause1": "Conto bancario o carta non verificati",
        "cause2": "Limiti giornalieri o mensili superati",
        "cause3": "Banca che rifiuta la transazione",
        "cause4": "Verifica dell'account incompleta",
        "solution": "Soluzione",
        "step1": "Verifica il tuo conto bancario/carta collegati in <strong>Impostazioni → Metodi di Pagamento</strong>.",
        "step2": "Controlla i tuoi limiti attuali in <strong>Impostazioni → Limiti</strong>.",
        "step3": "Completa la verifica KYC per sbloccare limiti più elevati.",
        "step4": "Contatta la tua banca per assicurarti che non vi siano blocchi sulle transazioni online."
      }
    },
    "error_codes": {
      "title": "Riferimento Codici di Errore",
      "desc": "Se riscontri un codice di errore nell'app, usa questa tabella di riferimento per capire cosa significa e come risolverlo.",
      "filters": {
        "all": "Tutti",
        "low": "Basso",
        "medium": "Medio",
        "high": "Alto",
        "critical": "Critico"
      },
      "table": {
        "code": "Codice",
        "description": "Descrizione",
        "severity": "Gravità",
        "resolution": "Risoluzione"
      },
      "e1001": {
        "desc": "Timeout connessione di rete",
        "res": "Controlla la connessione Internet e riprova. Passa tra Wi-Fi e dati mobili."
      },
      "e1002": {
        "desc": "Autenticazione non riuscita",
        "res": "Reinserisci le tue credenziali. Se persiste, reimposta la password tramite recupero email."
      },
      "e1003": {
        "desc": "Sessione scaduta",
        "res": "Accedi di nuovo. È normale dopo 30 minuti di inattività."
      },
      "e2001": {
        "desc": "Saldo insufficiente",
        "res": "Ricarica il tuo wallet prima di riprovare la transazione."
      },
      "e2002": {
        "desc": "Limite di transazione superato",
        "res": "Hai raggiunto il tuo limite giornaliero/mensile. Completa il KYC per limiti più elevati o attendi il ripristino."
      },
      "e2003": {
        "desc": "Pagamento rifiutato dall'esercente",
        "res": "Il terminale dell'esercente ha rifiutato il pagamento. Verifica l'importo e riprova, o usa un metodo di pagamento diverso."
      },
      "e2004": {
        "desc": "Transazione duplicata rilevata",
        "res": "Il sistema ha rilevato un possibile duplicato. Controlla la cronologia delle transazioni prima di riprovare."
      },
      "e3001": {
        "desc": "Codice QR non valido o scaduto",
        "res": "Chiedi all'esercente di generare un nuovo codice QR. I codici QR scadono dopo 5 minuti."
      },
      "e3002": {
        "desc": "NFC non supportato",
        "res": "Il tuo dispositivo non supporta l'NFC. Usa invece la scansione del codice QR per i pagamenti."
      },
      "e4001": {
        "desc": "Account sospeso",
        "res": "Il tuo account è stato temporaneamente sospeso. Contatta immediatamente il supporto per la risoluzione."
      },
      "e4002": {
        "desc": "Verifica KYC richiesta",
        "res": "Completa la verifica dell'identità in Impostazioni → Account → Verifica Identità."
      },
      "e5001": {
        "desc": "Ricarica non riuscita",
        "res": "Verifica i dettagli della tua banca/carta collegati. Contatta la tua banca se il problema persiste."
      },
      "e5002": {
        "desc": "Ritardo elaborazione prelievo",
        "res": "I prelievi possono richiedere 1-3 giorni lavorativi. Nessuna azione necessaria a meno che non superi i 5 giorni."
      },
      "e9999": {
        "desc": "Errore interno del server",
        "res": "Si è verificato un errore imprevisto. Riavvia l'app e riprova. Se persiste, contatta il supporto."
      },
      "callout": "Puoi trovare il tuo codice di errore toccando il messaggio di errore nell'app. Il codice appare in fondo alla finestra di dialogo dell'errore. Includi questo codice quando contatti il supporto per una risoluzione più rapida."
    },
    "contact_support": {
      "title": "Contatta il Supporto",
      "desc": "Se non riesci a risolvere il tuo problema utilizzando le guide sopra, il nostro team di supporto è qui per aiutarti.",
      "ticket": {
        "title": "Ticket di Supporto",
        "desc": "Invia una richiesta di supporto dettagliata e ricevi una risposta entro 24 ore.",
        "link": "Invia Ticket"
      },
      "email": {
        "title": "Inviaci un'Email",
        "desc": "Invia un'email al nostro team di supporto per problemi complessi o richieste relative all'account.",
