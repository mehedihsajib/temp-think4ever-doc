  "requirements": {
    "heading": "Requisiti di Sistema",
    "intro": "Prima di scaricare, assicurati che il tuo dispositivo soddisfi i requisiti minimi:",
    "ios": {
      "name": "iOS",
      "desc": "iOS 15.0 o successivo. Compatibile con iPhone 8 e versioni successive. Richiesti circa 85 MB di spazio di archiviazione."
    },
    "android": {
      "name": "Android",
      "desc": "Android 10.0 (API livello 29) o successivo. Richiesti circa 60 MB di spazio di archiviazione."
    },
    "nfc_callout_title": "Requisito NFC",
    "nfc_callout_body": "Per la funzionalità tap-to-pay, il tuo dispositivo deve disporre dell'hardware NFC. La maggior parte degli smartphone moderni (iPhone 7+ e Android con NFC) supporta questa funzione."
  },
  "download": {
    "heading": "Scarica e Installa",
    "intro": "mPay Consumer Wallet è disponibile gratuitamente sui principali store. Scegli la tua piattaforma qui sotto:",
    "ios_btn": "App Store",
    "ios_btn_pre": "Scarica su",
    "android_btn": "Google Play",
    "android_btn_pre": "Disponibile su",
    "install_steps_heading": "Passaggi per l'Installazione",
    "steps": {
      "1": {
        "title": "Apri lo store",
        "content": "Apri l'<strong>App Store</strong> (iOS) o il <strong>Google Play Store</strong> (Android) sul tuo dispositivo."
      },
      "2": {
        "title": "Cerca mPay Wallet",
        "content": "Digita <code>mPay Consumer Wallet</code> nella barra di ricerca. Cerca l'app ufficiale con il logo mPay e lo sviluppatore \"mPay Network\"."
      },
      "3": {
        "title": "Scarica e installa",
        "content": "Tocca <strong>Ottieni</strong> (iOS) o <strong>Installa</strong> (Android). L'app verrà scaricata e installata automaticamente. Potrebbe essere chiesta l'autenticazione con Face ID o impronta digitale."
      },
      "4": {
        "title": "Apri l'app",
        "content": "Una volta installata, tocca <strong>Apri</strong> o cerca l'icona mPay sulla home screen. L'app si avvierà con la schermata di benvenuto."
      }
    },
    "verify_callout_title": "Verifica lo Sviluppatore",
    "verify_callout_body": "Verifica sempre che lo sviluppatore sia \"mPay Network\" prima del download. Non installare app da fonti non ufficiali."
  },
  "signup": {
    "heading": "Registrazione",
    "intro": "Creare il tuo account mPay è semplice e veloce. Ti serviranno un numero di telefono e un indirizzo email validi.",
    "steps": {
      "1": {
        "title": "Sei già un cliente mPay?",
        "content": "Nella schermata di benvenuto, ti verrà chiesto se <strong>\"Sei un cliente esistente?\"</strong>. Per i nuovi clienti, tocca il pulsante <strong>NO</strong>. Se hai già un account, seleziona <strong>SÌ</strong>."
      },
      "2": {
        "title": "Modulo Nuova Iscrizione",
        "content": "L'utente viene indirizzato al modulo di <strong>Iscrizione Nuovo Privato</strong>."
      },
      "3": {
        "title": "Informazioni Richieste",
        "content": "L'<strong>ID Utente</strong>, l'<strong>Indirizzo Email</strong> e il <strong>Numero di Mobile</strong> devono essere univoci per ogni cliente.",
        "info_callout": "Durante l'invio dell'iscrizione, il sistema verifica se i dati sono già in uso da altri clienti mPay."
      },
      "4": {
        "title": "Compila tutti i campi",
        "intro": "Inserisci le tue informazioni di base:",
        "field_name": "<strong>Nome e Cognome</strong> — Come appaiono sul tuo documento d'identità",
        "field_email": "<strong>Indirizzo Email</strong> — Un'email valida per notifiche e recupero",
        "field_mobile": "<strong>Numero di Mobile</strong> — Deve essere un numero valido per ricevere l'SMS di verifica",
        "field_referral": "<strong>Codice Referral</strong> — Campo opzionale per il codice di chi ti ha invitato."
      },
      "5": {
        "title": "Accetta i termini",
        "intro": "È necessario spuntare due caselle obbligatorie prima di procedere:",
        "check_terms": "Accetta <strong>Termini e Condizioni</strong>",
        "check_security": "Politica di sicurezza (un utente per dispositivo): <em>\"Accetto che la registrazione di un nuovo cliente rimuoverà l'account esistente collegato a questo dispositivo.\"</em>"
      },
      "6": {
        "title": "Opzione Identificazione App Esercente",
        "intro": "Scegli se email e cellulare possono essere usati per identificarti anche nell'App Esercente.",
        "check_terms": "Accetta <strong>Termini e Condizioni</strong>",
        "check_security": "Politica di sicurezza."
      }
    },
    "success_callout_title": "Account Creato!",
    "success_callout_body": "Una volta visualizzata la conferma, il tuo account è pronto. Puoi procedere alla configurazione del profilo e del wallet."
  },
  "first_login": {
    "heading": "Primo Accesso e Setup",
    "intro": "Dopo la creazione dell'account, sarai guidato attraverso una procedura guidata:",
    "profile_heading": "Configurazione Profilo",
    "profile_steps": {
      "1": {
        "title": "Aggiungi i tuoi dettagli personali",
        "content": "Inserisci il tuo nome completo. Opzionalmente, aggiungi una foto profilo per facilitare i trasferimenti P2P."
      },
      "2": {
        "title": "Imposta la sicurezza",
        "content": "Configura il tuo metodo di autenticazione preferito:",
        "pin": "<strong>Codice PIN</strong> — Imposta un PIN a 6 cifre per l'accesso rapido",
        "biometric": "<strong>Biometria</strong> — Abilita Face ID o impronta digitale",
        "recommend": "Consigliamo di abilitarli entrambi per la massima sicurezza"
      },
      "3": {
        "title": "Abilita le notifiche",
        "content_pre": "Consenti le notifiche push per ricevere conferme di pagamento istantanee e avvisi di sicurezza. Puoi personalizzarle in seguito nelle ",
        "settings_link": "Impostazioni",
        "content_post": "."
      }
    },
    "wallet_heading": "Configurazione Wallet",
    "wallet_steps": {
      "1": {
        "title": "Personalizza il profilo",
        "content": "Imposta un'immagine per il tuo account wallet."
      },
      "2": {
        "title": "Gestione Notifiche",
        "content": "Puoi attivare/disattivare le opzioni di notifica in base alle tue preferenze."
      },
      "3": {
        "title": "Completa il setup",
        "content": "Tocca <strong>Fine Setup</strong> per accedere alla tua dashboard. Sei pronto a pagare!"
      }
    },
    "tip_callout_title": "Suggerimento: Verifica subito il profilo",
    "tip_callout_body": "La verifica può richiedere 24-48 ore. Ti consigliamo di completarla subito per sbloccare tutte le funzioni di mPay Wallet."
  },
  "screenshots": {
    "heading": "Guida Visuale",
    "intro": "Ecco una panoramica delle schermate chiave che incontrerai durante il setup:",
    "step1_label": "Benvenuto",
