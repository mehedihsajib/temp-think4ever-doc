    <!-- ============ HERO SECTION ============ -->
    <section class="lp-hero" id="lp_hero_section">
      <!-- NFC Waves Decoration -->
      <div class="lp-nfc-waves" aria-hidden="true">
        <div class="lp-nfc-wave"></div>
        <div class="lp-nfc-wave"></div>
        <div class="lp-nfc-wave"></div>
      </div>

      <div class="lp-hero-inner">
        <div class="lp-hero-badge">
