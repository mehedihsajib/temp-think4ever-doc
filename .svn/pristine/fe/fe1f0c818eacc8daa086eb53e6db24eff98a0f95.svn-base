/* Merchant QR Payments - Page Specific CSS */

.merchant-qr-payments {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}

.docs-layout {
  display: flex;
  flex: 1;
  max-width: 1440px;
  margin: 0 auto;
  width: 100%;
}

/* Sidebar */
.docs-sidebar {
  width: 280px;
  min-width: 280px;
  border-right: 1px solid var(--color-border, #bfdbfe);
  background: var(--color-surface, #eff6ff);
  padding: 24px 0;
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
  z-index: 10;
}

.docs-sidebar::-webkit-scrollbar {
  width: 4px;
}

.docs-sidebar::-webkit-scrollbar-thumb {
  background: var(--color-border, #bfdbfe);
  border-radius: 4px;
}

.sidebar-section {
  margin-bottom: 8px;
}

.sidebar-section-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  padding: 8px 24px;
  margin-bottom: 4px;
}

.sidebar-nav-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.sidebar-nav-item a,
.sidebar-nav-item button {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 8px 24px;
  font-size: 0.875rem;
  color: #334155;
  text-decoration: none;
  border: none;
  background: none;
  cursor: pointer;
  transition: all 150ms ease;
  border-radius: 0;
  text-align: left;
  line-height: 1.5;
}

.sidebar-nav-item a:hover,
.sidebar-nav-item button:hover {
  background: rgba(37, 99, 235, 0.06);
  color: #2563eb;
}

.sidebar-nav-item.active > a,
.sidebar-nav-item.active > button {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
  font-weight: 600;
  border-right: 3px solid #2563eb;
}

.sidebar-nav-item .sidebar-icon {
  width: 18px;
  text-align: center;
  font-size: 0.8rem;
  color: #64748b;
  flex-shrink: 0;
}

.sidebar-nav-item.active .sidebar-icon {
  color: #2563eb;
}

/* Mobile sidebar toggle */
.sidebar-toggle {
  display: none;
  position: fixed;
  bottom: 24px;
  left: 24px;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #2563eb;
  color: white;
  border: none;
  font-size: 1.25rem;
  cursor: pointer;
  z-index: 100;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.35);
  transition: all 200ms ease;
}

.sidebar-toggle:hover {
  background: #1d4ed8;
  transform: scale(1.05);
}

.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 40;
}

/* Main Content */
.docs-main {
  flex: 1;
  min-width: 0;
  display: flex;
}

.docs-content {
  flex: 1;
  max-width: 860px;
  padding: 32px 48px 64px;
  min-width: 0;
}

/* Table of Contents */
.docs-toc {
  width: 220px;
  min-width: 220px;
  padding: 32px 24px 32px 0;
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
}

.toc-title {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin-bottom: 12px;
}

.toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
  border-left: 2px solid var(--color-border, #bfdbfe);
}

.toc-list li a {
  display: block;
  padding: 6px 0 6px 16px;
  font-size: 0.8125rem;
  color: #64748b;
  text-decoration: none;
  border-left: 2px solid transparent;
  margin-left: -2px;
  transition: all 150ms ease;
  line-height: 1.4;
}

.toc-list li a:hover {
  color: #2563eb;
}

.toc-list li a.active {
  color: #2563eb;
  border-left-color: #2563eb;
  font-weight: 500;
}

/* Breadcrumb */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: #64748b;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.breadcrumb a {
  color: #64748b;
  text-decoration: none;
  transition: color 150ms ease;
}

.breadcrumb a:hover {
  color: #2563eb;
}

.breadcrumb .separator {
  color: #94a3b8;
  font-size: 0.75rem;
}

.breadcrumb .current {
  color: #2563eb;
  font-weight: 500;
}

/* Page Title */
.page-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: #1e3a8a;
  letter-spacing: -0.025em;
  line-height: 1.25;
  margin-bottom: 8px;
  padding-bottom: 20px;
  border-bottom: 2px solid var(--color-border, #bfdbfe);
}

.page-subtitle {
  font-size: 1.125rem;
  color: #64748b;
  line-height: 1.6;
  margin-bottom: 0;
  margin-top: 16px;
}

/* Doc Content Sections */
.doc-section {
  margin-top: 48px;
}

.doc-section h2 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.875rem;
  font-weight: 700;
  color: #1e3a8a;
  letter-spacing: -0.02em;
  line-height: 1.25;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  scroll-margin-top: 80px;
}

.doc-section h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.25rem;
  font-weight: 600;
  color: #1e3a8a;
  letter-spacing: -0.015em;
  margin-top: 32px;
  margin-bottom: 12px;
  scroll-margin-top: 80px;
}

.doc-section p {
  font-size: 1rem;
  color: #334155;
  line-height: 1.625;
  margin-bottom: 16px;
}

.doc-section ul,
.doc-section ol {
  padding-left: 24px;
  margin-bottom: 16px;
}

.doc-section li {
  font-size: 1rem;
  color: #334155;
  line-height: 1.625;
  margin-bottom: 8px;
}

/* Inline code */
.doc-section code:not(.code-block code) {
  background: #eff6ff;
  color: #1d4ed8;
  padding: 2px 8px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.875em;
}

/* Code Block */
.code-block-wrapper {
  margin: 20px 0;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #334155;
}

.code-block-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #0f172a;
  padding: 10px 16px;
  border-bottom: 1px solid #334155;
}

.code-block-lang {
  font-size: 0.75rem;
  font-weight: 600;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.code-copy-btn {
  background: none;
  border: 1px solid #475569;
  color: #94a3b8;
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 0.75rem;
  cursor: pointer;
  transition: all 150ms ease;
  display: flex;
  align-items: center;
  gap: 4px;
}

.code-copy-btn:hover {
  background: #1e293b;
  color: #e2e8f0;
  border-color: #64748b;
}

.code-block {
  background: #1e293b;
  padding: 16px 20px;
  overflow-x: auto;
}

.code-block code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.875rem;
  color: #e2e8f0;
  line-height: 1.6;
  white-space: pre;
}

.code-block .comment {
  color: #64748b;
}

.code-block .string {
  color: #86efac;
}

.code-block .keyword {
  color: #93c5fd;
}

.code-block .number {
  color: #fbbf24;
}

/* Callout Boxes */
.callout {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-radius: 8px;
  margin: 20px 0;
  border-left: 4px solid;
}

.callout-icon {
  font-size: 1.1rem;
  margin-top: 2px;
  flex-shrink: 0;
}

.callout-content {
  flex: 1;
  min-width: 0;
}

.callout-content strong {
  display: block;
  margin-bottom: 4px;
  font-size: 0.9rem;
}

.callout-content p {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.5;
}

.callout-info {
  background: #eff6ff;
  border-color: #2563eb;
}

.callout-info .callout-icon { color: #2563eb; }

.callout-warning {
  background: #fffbeb;
  border-color: #f59e0b;
}

.callout-warning .callout-icon { color: #f59e0b; }

.callout-success {
  background: #f0fdf4;
  border-color: #22c55e;
}

.callout-success .callout-icon { color: #22c55e; }

.callout-danger {
  background: #fef2f2;
  border-color: #ef4444;
}

.callout-danger .callout-icon { color: #ef4444; }

/* Steps Component */
.steps {
  position: relative;
  padding-left: 36px;
  margin: 24px 0;
}

.steps::before {
  content: '';
  position: absolute;
  left: 14px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--color-border, #bfdbfe);
}

.step {
  position: relative;
  margin-bottom: 32px;
}

.step:last-child {
  margin-bottom: 0;
}

.step-number {
  position: absolute;
  left: -36px;
  top: 0;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #2563eb;
  color: white;
  font-size: 0.8rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.step h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 600;
  color: #1e3a8a;
  margin-bottom: 8px;
}

.step p {
  font-size: 0.95rem;
  color: #334155;
  line-height: 1.625;
  margin-bottom: 8px;
}

/* QR Demo Section */
.qr-demo-container {
  display: flex;
  gap: 32px;
  align-items: center;
  margin: 24px 0;
  padding: 32px;
  background: var(--color-surface, #eff6ff);
  border-radius: 12px;
  border: 1px solid var(--color-border, #bfdbfe);
}

.qr-visual {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.qr-code-frame {
  position: relative;
  width: 180px;
  height: 180px;
  background: white;
  border-radius: 12px;
  border: 2px solid var(--color-border, #bfdbfe);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.qr-code-frame canvas {
  display: block;
}

.qr-corner {
  position: absolute;
  width: 24px;
  height: 24px;
  border: 3px solid #2563eb;
}

.qr-corner.tl { top: 8px; left: 8px; border-right: none; border-bottom: none; border-radius: 4px 0 0 0; }
.qr-corner.tr { top: 8px; right: 8px; border-left: none; border-bottom: none; border-radius: 0 4px 0 0; }
.qr-corner.bl { bottom: 8px; left: 8px; border-right: none; border-top: none; border-radius: 0 0 0 4px; }
.qr-corner.br { bottom: 8px; right: 8px; border-left: none; border-top: none; border-radius: 0 0 4px 0; }

/* QR Scanner Animation */
.qr-scanner-line {
  position: absolute;
  left: 12px;
  right: 12px;
  height: 2px;
  background: linear-gradient(90deg, transparent, #2563eb, transparent);
  animation: qrScan 2.5s ease-in-out infinite;
  box-shadow: 0 0 8px rgba(37, 99, 235, 0.4);
}

@keyframes qrScan {
  0% { top: 12px; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { top: calc(100% - 14px); opacity: 0; }
}

.qr-label {
  font-size: 0.8rem;
  font-weight: 600;
  color: #64748b;
  text-align: center;
}

.qr-demo-info {
  flex: 1;
  min-width: 0;
}

.qr-demo-info h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 600;
  color: #1e3a8a;
  margin-bottom: 8px;
}

.qr-demo-info p {
  font-size: 0.95rem;
  color: #334155;
  line-height: 1.625;
  margin-bottom: 12px;
}

/* QR Type Cards */
.qr-type-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin: 24px 0;
}

.qr-type-card {
  padding: 24px;
  background: white;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  transition: all 250ms ease;
}

.qr-type-card:hover {
  border-color: #93bbfd;
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.08);
  transform: translateY(-2px);
}

.qr-type-card .card-icon {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  background: #eff6ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  color: #2563eb;
  margin-bottom: 16px;
}

.qr-type-card h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: #1e3a8a;
  margin-bottom: 8px;
}

.qr-type-card p {
  font-size: 0.9rem;
  color: #64748b;
  line-height: 1.5;
  margin: 0;
}

/* Payment Flow Visual */
.payment-flow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin: 32px 0;
  padding: 32px 24px;
  background: var(--color-surface, #eff6ff);
  border-radius: 12px;
  border: 1px solid var(--color-border, #bfdbfe);
  overflow-x: auto;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  min-width: 100px;
}

.flow-step-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: white;
  border: 2px solid #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  color: #2563eb;
  margin-bottom: 12px;
  position: relative;
}

.flow-step.completed .flow-step-icon {
  background: #2563eb;
  color: white;
}

.flow-step-label {
  font-size: 0.8rem;
  font-weight: 600;
  color: #1e3a8a;
  max-width: 100px;
}

.flow-step-desc {
  font-size: 0.75rem;
  color: #64748b;
  margin-top: 4px;
  max-width: 100px;
}

.flow-arrow {
  font-size: 1.25rem;
  color: #93bbfd;
  margin: 0 16px;
  margin-bottom: 30px;
}

/* Screenshots Gallery */
.screenshots-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin: 24px 0;
}

.screenshot-card {
  background: white;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  overflow: hidden;
  transition: all 250ms ease;
}

.screenshot-card:hover {
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.1);
  transform: translateY(-2px);
}

.screenshot-placeholder {
  width: 100%;
  height: 200px;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 50%, #eff6ff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  color: #93bbfd;
}

.screenshot-placeholder i {
  font-size: 2.5rem;
}

.screenshot-placeholder span {
  font-size: 0.75rem;
  font-weight: 500;
  color: #64748b;
}

.screenshot-caption {
  padding: 12px 16px;
  font-size: 0.8rem;
  color: #64748b;
  text-align: center;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

/* Best Practices Grid */
.best-practices-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin: 24px 0;
}

.best-practice-item {
  display: flex;
  gap: 12px;
  padding: 16px;
  background: white;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 8px;
}

.bp-icon {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
}

.bp-icon.do {
  background: #f0fdf4;
  color: #22c55e;
}

.bp-icon.dont {
  background: #fef2f2;
  color: #ef4444;
}

.bp-content h5 {
  font-size: 0.875rem;
  font-weight: 600;
  color: #1e3a8a;
  margin-bottom: 4px;
}

.bp-content p {
  font-size: 0.8rem;
  color: #64748b;
  line-height: 1.5;
  margin: 0;
}

/* FAQ Accordion */
.faq-list {
  margin: 24px 0;
}

.faq-item {
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 8px;
  margin-bottom: 8px;
  overflow: hidden;
  transition: border-color 150ms ease;
}

.faq-item:hover {
  border-color: #93bbfd;
}

.faq-item.active {
  border-color: #2563eb;
}

.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  width: 100%;
  padding: 16px 20px;
  background: white;
  border: none;
  cursor: pointer;
  text-align: left;
  font-size: 0.95rem;
  font-weight: 600;
  color: #1e3a8a;
  transition: background 150ms ease;
}

.faq-question:hover {
  background: #f8fafc;
}

.faq-item.active .faq-question {
  background: var(--color-surface, #eff6ff);
}

.faq-chevron {
  font-size: 0.75rem;
  color: #64748b;
  transition: transform 250ms ease;
  flex-shrink: 0;
}

.faq-item.active .faq-chevron {
  transform: rotate(180deg);
  color: #2563eb;
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 300ms ease;
}

.faq-answer-inner {
  padding: 0 20px 16px;
  font-size: 0.9rem;
  color: #334155;
  line-height: 1.625;
}

.faq-answer-inner p {
  margin-bottom: 8px;
}

.faq-answer-inner p:last-child {
  margin-bottom: 0;
}

/* Prev/Next Navigation */
.prev-next-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 64px;
  padding-top: 32px;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

.prev-next-card {
  display: flex;
  flex-direction: column;
  padding: 20px 24px;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  background: white;
  cursor: pointer;
  text-decoration: none;
  transition: all 250ms ease;
}

.prev-next-card:hover {
  border-color: #2563eb;
  background: var(--color-surface, #eff6ff);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.08);
}

.prev-next-card.next {
  align-items: flex-end;
  text-align: right;
}

.prev-next-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin-bottom: 4px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.prev-next-title {
  font-size: 1rem;
  font-weight: 600;
  color: #2563eb;
}

/* Dynamic Amount Input Demo */
.amount-demo {
  display: flex;
  gap: 16px;
  align-items: flex-end;
  margin: 20px 0;
  padding: 24px;
  background: var(--color-surface, #eff6ff);
  border-radius: 12px;
  border: 1px solid var(--color-border, #bfdbfe);
  flex-wrap: wrap;
}

.amount-input-group {
  flex: 1;
  min-width: 200px;
}

.amount-input-group label {
  display: block;
  font-size: 0.8rem;
  font-weight: 600;
  color: #1e3a8a;
  margin-bottom: 6px;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  background: white;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 8px;
  overflow: hidden;
  transition: border-color 150ms ease;
}

.amount-input-wrapper:focus-within {
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
}

.amount-prefix {
  padding: 10px 12px;
  background: #f8fafc;
  border-right: 1px solid var(--color-border, #bfdbfe);
  font-size: 0.875rem;
  font-weight: 600;
  color: #64748b;
}

.amount-input-wrapper input {
  border: none;
  padding: 10px 12px;
  font-size: 1rem;
  width: 100%;
  outline: none;
  font-family: 'JetBrains Mono', monospace;
  color: #1e3a8a;
}

.generate-qr-btn {
  padding: 10px 24px;
  background: #2563eb;
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 150ms ease;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 8px;
}

.generate-qr-btn:hover {
  background: #1d4ed8;
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25);
  transform: translateY(-1px);
}

.generate-qr-btn:active {
  transform: translateY(0);
}

.generate-qr-btn:focus-visible {
  outline: 2px solid #2563eb;
  outline-offset: 2px;
}

/* Comparison Table */
.comparison-table-wrapper {
  margin: 24px 0;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--color-border, #bfdbfe);
}

.comparison-table {
  width: 100%;
  border-collapse: collapse;
}

.comparison-table thead th {
  background: var(--color-surface, #eff6ff);
  padding: 12px 16px;
  font-size: 0.8rem;
  font-weight: 600;
  color: #1e3a8a;
  text-align: left;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
}

.comparison-table tbody td {
  padding: 12px 16px;
  font-size: 0.9rem;
  color: #334155;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
}

.comparison-table tbody tr:last-child td {
  border-bottom: none;
}

.comparison-table tbody tr:hover {
  background: #f8fafc;
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
}

.badge-blue {
  background: #eff6ff;
  color: #2563eb;
}

.badge-green {
  background: #f0fdf4;
  color: #22c55e;
}

.badge-amber {
  background: #fffbeb;
  color: #d97706;
}

/* Responsive */
@media (max-width: 1200px) {
  .docs-toc {
    display: none;
  }
}

@media (max-width: 1024px) {
  .docs-sidebar {
    width: 240px;
    min-width: 240px;
  }
  
  .docs-content {
    padding: 24px 32px 48px;
  }

  .screenshots-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .docs-sidebar {
    position: fixed;
    left: -300px;
    top: 0;
    height: 100vh;
    z-index: 50;
    transition: left 300ms ease;
    padding-top: 16px;
  }

  .docs-sidebar.open {
    left: 0;
  }

  .sidebar-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sidebar-overlay.active {
    display: block;
  }

  .docs-content {
    padding: 20px 16px 40px;
  }

  .page-title {
    font-size: 1.75rem;
  }

  .doc-section h2 {
    font-size: 1.5rem;
  }

  .qr-demo-container {
    flex-direction: column;
    text-align: center;
    padding: 24px;
  }

  .qr-type-grid {
    grid-template-columns: 1fr;
  }

  .best-practices-grid {
    grid-template-columns: 1fr;
  }

  .screenshots-grid {
    grid-template-columns: 1fr;
  }

  .payment-flow {
    flex-direction: column;
    gap: 4px;
    padding: 24px 16px;
  }

  .flow-arrow {
    transform: rotate(90deg);
    margin: 4px 0;
  }

  .prev-next-nav {
    grid-template-columns: 1fr;
  }

  .prev-next-card.next {
    align-items: flex-start;
    text-align: left;
  }

  .amount-demo {
    flex-direction: column;
    align-items: stretch;
  }
}

@media (prefers-reduced-motion: reduce) {
  .qr-scanner-line {
    animation: none;
  }
  
  * {
    transition-duration: 0ms !important;
    animation-duration: 0ms !important;
  }
}
