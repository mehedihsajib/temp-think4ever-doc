/* Consumer Troubleshooting Page CSS */

.consumer-troubleshooting-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}

.ctr-layout {
  display: flex;
  flex: 1;
  max-width: 1440px;
  margin: 0 auto;
  width: 100%;
}

/* Sidebar */
.ctr-sidebar {
  width: 280px;
  min-width: 280px;
  border-right: 1px solid var(--color-border, #bfdbfe);
  background: var(--color-surface, #eff6ff);
  padding: 24px 0;
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
  z-index: 10;
}

.ctr-sidebar-header {
  padding: 0 20px 16px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  margin-bottom: 16px;
}

.ctr-sidebar-header h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  margin: 0;
  cursor: pointer;
}

.ctr-sidebar-header h3:hover {
  color: var(--color-primary, #2563eb);
}

.ctr-sidebar-section {
  padding: 0 12px;
  margin-bottom: 8px;
}

.ctr-sidebar-section-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  padding: 8px 12px 4px;
  margin: 0;
}

.ctr-sidebar-link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 0.875rem;
  color: #334155;
  text-decoration: none;
  cursor: pointer;
  transition: all 150ms ease;
  line-height: 1.5;
}

.ctr-sidebar-link:hover {
  background: rgba(37, 99, 235, 0.08);
  color: var(--color-primary, #2563eb);
}

.ctr-sidebar-link.active {
  background: rgba(37, 99, 235, 0.12);
  color: var(--color-primary, #2563eb);
  font-weight: 600;
}

.ctr-sidebar-link i {
  width: 18px;
  text-align: center;
  font-size: 0.8rem;
  opacity: 0.7;
}

.ctr-sidebar-link.active i {
  opacity: 1;
}

/* Mobile sidebar toggle */
.ctr-sidebar-toggle {
  display: none;
  position: fixed;
  bottom: 24px;
  left: 24px;
  z-index: 100;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--color-primary, #2563eb);
  color: #fff;
  border: none;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
  cursor: pointer;
  font-size: 1.1rem;
  transition: all 200ms ease;
}

.ctr-sidebar-toggle:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 16px rgba(37, 99, 235, 0.5);
}

.ctr-sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99;
}

/* Main Content */
.ctr-main {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: center;
}

.ctr-content {
  max-width: 860px;
  width: 100%;
  padding: 32px 48px 80px;
}

/* TOC */
.ctr-toc {
  width: 220px;
  min-width: 220px;
  padding: 32px 16px 32px 0;
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
}

.ctr-toc-title {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin: 0 0 12px;
  padding: 0 12px;
}

.ctr-toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.ctr-toc-list li {
  margin: 0;
}

.ctr-toc-link {
  display: block;
  padding: 4px 12px;
  font-size: 0.813rem;
  color: #64748b;
  text-decoration: none;
  border-left: 2px solid transparent;
  transition: all 150ms ease;
  line-height: 1.6;
}

.ctr-toc-link:hover {
  color: var(--color-primary, #2563eb);
  border-left-color: var(--color-border, #bfdbfe);
}

.ctr-toc-link.active {
  color: var(--color-primary, #2563eb);
  border-left-color: var(--color-primary, #2563eb);
  font-weight: 500;
}

/* Breadcrumb */
.ctr-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: #64748b;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.ctr-breadcrumb a {
  color: #64748b;
  text-decoration: none;
  transition: color 150ms ease;
}

.ctr-breadcrumb a:hover {
  color: var(--color-primary, #2563eb);
}

.ctr-breadcrumb .separator {
  font-size: 0.75rem;
  color: #94a3b8;
}

.ctr-breadcrumb .current {
  color: var(--color-primary, #2563eb);
  font-weight: 500;
}

/* Page Title */
.ctr-page-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.025em;
  line-height: 1.25;
  margin: 0 0 8px;
  padding-bottom: 16px;
  border-bottom: 2px solid var(--color-border, #bfdbfe);
}

.ctr-page-subtitle {
  font-size: 1.125rem;
  color: #64748b;
  margin: 16px 0 40px;
  line-height: 1.625;
}

/* Search Bar */
.ctr-search-bar {
  position: relative;
  margin-bottom: 40px;
}

.ctr-search-bar input {
  width: 100%;
  padding: 12px 16px 12px 44px;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 10px;
  font-size: 0.9375rem;
  font-family: 'Inter', sans-serif;
  color: #334155;
  background: #fff;
  transition: all 200ms ease;
  outline: none;
}

.ctr-search-bar input::placeholder {
  color: #94a3b8;
}

.ctr-search-bar input:focus {
  border-color: var(--color-primary, #2563eb);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
}

.ctr-search-bar .search-icon {
  position: absolute;
  left: 14px;
  top: 50%;
  transform: translateY(-50%);
  color: #94a3b8;
  font-size: 0.95rem;
}

/* Section Styles */
.ctr-section {
  margin-bottom: 48px;
}

.ctr-section-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.875rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.02em;
  margin: 0 0 8px;
  padding-top: 24px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  line-height: 1.25;
}

.ctr-section-desc {
  font-size: 1rem;
  color: #64748b;
  margin: 12px 0 24px;
  line-height: 1.625;
}

/* Common Issues Cards */
.ctr-issue-card {
  background: #fff;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 24px;
  margin-bottom: 16px;
  transition: all 250ms ease;
}

.ctr-issue-card:hover {
  border-color: #93bbfd;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.08);
}

.ctr-issue-header {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  cursor: pointer;
}

.ctr-issue-icon {
  width: 44px;
  height: 44px;
  min-width: 44px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
}

.ctr-issue-icon.orange {
  background: #fff7ed;
  color: #f59e0b;
}

.ctr-issue-icon.red {
  background: #fef2f2;
  color: #ef4444;
}

.ctr-issue-icon.blue {
  background: #eff6ff;
  color: #2563eb;
}

.ctr-issue-icon.green {
  background: #f0fdf4;
  color: #22c55e;
}

.ctr-issue-icon.purple {
  background: #faf5ff;
  color: #8b5cf6;
}

.ctr-issue-info {
  flex: 1;
  min-width: 0;
}

.ctr-issue-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 4px;
  line-height: 1.4;
}

.ctr-issue-summary {
  font-size: 0.875rem;
  color: #64748b;
  margin: 0;
  line-height: 1.5;
}

.ctr-issue-toggle {
  width: 32px;
  height: 32px;
  min-width: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  color: #94a3b8;
  transition: all 200ms ease;
}

.ctr-issue-card:hover .ctr-issue-toggle {
  background: var(--color-surface, #eff6ff);
  color: var(--color-primary, #2563eb);
}

.ctr-issue-toggle i {
  transition: transform 250ms ease;
}

.ctr-issue-card.expanded .ctr-issue-toggle i {
  transform: rotate(180deg);
}

.ctr-issue-body {
  display: none;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid #f1f5f9;
}

.ctr-issue-card.expanded .ctr-issue-body {
  display: block;
}

.ctr-issue-body h4 {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 8px;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

.ctr-issue-body p,
.ctr-issue-body li {
  font-size: 0.9375rem;
  color: #334155;
  line-height: 1.625;
}

.ctr-issue-body ul,
.ctr-issue-body ol {
  padding-left: 20px;
  margin: 8px 0 16px;
}

.ctr-issue-body li {
  margin-bottom: 6px;
}

/* Callout boxes */
.ctr-callout {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-radius: 8px;
  margin: 16px 0;
  font-size: 0.9375rem;
  line-height: 1.625;
}

.ctr-callout-icon {
  font-size: 1rem;
  margin-top: 2px;
}

.ctr-callout.info {
  background: #eff6ff;
  border-left: 3px solid #2563eb;
  color: #1e40af;
}

.ctr-callout.info .ctr-callout-icon {
  color: #2563eb;
}

.ctr-callout.warning {
  background: #fffbeb;
  border-left: 3px solid #f59e0b;
  color: #92400e;
}

.ctr-callout.warning .ctr-callout-icon {
  color: #f59e0b;
}

.ctr-callout.success {
  background: #f0fdf4;
  border-left: 3px solid #22c55e;
  color: #166534;
}

.ctr-callout.success .ctr-callout-icon {
  color: #22c55e;
}

.ctr-callout.danger {
  background: #fef2f2;
  border-left: 3px solid #ef4444;
  color: #991b1b;
}

.ctr-callout.danger .ctr-callout-icon {
  color: #ef4444;
}

/* Inline code */
.ctr-code {
  background: #eff6ff;
  color: #1d4ed8;
  padding: 2px 6px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85em;
}

/* Error Codes Table */
.ctr-table-container {
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  overflow: hidden;
  margin: 16px 0;
}

.ctr-table {
  width: 100%;
  border-collapse: collapse;
}

.ctr-table thead {
  background: var(--color-surface, #eff6ff);
}

.ctr-table th {
  font-size: 0.8125rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #64748b;
  padding: 12px 16px;
  text-align: left;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
}

.ctr-table td {
  padding: 12px 16px;
  font-size: 0.9375rem;
  color: #334155;
  border-bottom: 1px solid #f1f5f9;
  line-height: 1.5;
}

.ctr-table tbody tr:last-child td {
  border-bottom: none;
}

.ctr-table tbody tr:hover {
  background: rgba(239, 246, 255, 0.5);
}

.ctr-error-code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8125rem;
  font-weight: 600;
  background: #fef2f2;
  color: #dc2626;
  padding: 3px 8px;
  border-radius: 4px;
  white-space: nowrap;
}

.ctr-severity {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8125rem;
  font-weight: 500;
  padding: 3px 10px;
  border-radius: 20px;
}

.ctr-severity.low {
  background: #f0fdf4;
  color: #16a34a;
}

.ctr-severity.medium {
  background: #fffbeb;
  color: #d97706;
}

.ctr-severity.high {
  background: #fef2f2;
  color: #dc2626;
}

.ctr-severity.critical {
  background: #fef2f2;
  color: #991b1b;
}

/* Filter tabs */
.ctr-filter-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.ctr-filter-tab {
  padding: 6px 16px;
  font-size: 0.8125rem;
  font-weight: 500;
  border-radius: 20px;
  border: 1px solid var(--color-border, #bfdbfe);
  background: #fff;
  color: #64748b;
  cursor: pointer;
  transition: all 150ms ease;
}

.ctr-filter-tab:hover {
  border-color: #93bbfd;
  color: var(--color-primary, #2563eb);
  background: #eff6ff;
}

.ctr-filter-tab.active {
  background: var(--color-primary, #2563eb);
  color: #fff;
  border-color: var(--color-primary, #2563eb);
}

/* Contact Support */
.ctr-support-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin: 24px 0;
}

.ctr-support-card {
  background: #fff;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 24px;
  text-align: center;
  transition: all 250ms ease;
  cursor: pointer;
}

.ctr-support-card:hover {
  border-color: var(--color-primary, #2563eb);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.12);
}

.ctr-support-card-icon {
  width: 56px;
  height: 56px;
  border-radius: 14px;
  background: var(--color-surface, #eff6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
  font-size: 1.35rem;
  color: var(--color-primary, #2563eb);
  transition: all 200ms ease;
}

.ctr-support-card:hover .ctr-support-card-icon {
  background: var(--color-primary, #2563eb);
  color: #fff;
}

.ctr-support-card h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 8px;
}

.ctr-support-card p {
  font-size: 0.875rem;
  color: #64748b;
  margin: 0 0 12px;
  line-height: 1.5;
}

.ctr-support-card-link {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-primary, #2563eb);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.ctr-support-card-link:hover {
  gap: 8px;
}

/* FAQ Accordion */
.ctr-faq-item {
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 10px;
  margin-bottom: 10px;
  overflow: hidden;
  transition: all 200ms ease;
}

.ctr-faq-item:hover {
  border-color: #93bbfd;
}

.ctr-faq-item.expanded {
  border-color: var(--color-primary, #2563eb);
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
}

.ctr-faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 16px 20px;
  cursor: pointer;
  background: #fff;
  transition: background 150ms ease;
}

.ctr-faq-question:hover {
  background: rgba(239, 246, 255, 0.5);
}

.ctr-faq-question span {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  line-height: 1.5;
}

.ctr-faq-question i {
  font-size: 0.8rem;
  color: #94a3b8;
  transition: transform 250ms ease;
  min-width: 20px;
  text-align: center;
}

.ctr-faq-item.expanded .ctr-faq-question i {
  transform: rotate(180deg);
  color: var(--color-primary, #2563eb);
}

.ctr-faq-answer {
  display: none;
  padding: 0 20px 20px;
  font-size: 0.9375rem;
  color: #334155;
  line-height: 1.625;
}

.ctr-faq-item.expanded .ctr-faq-answer {
  display: block;
}

.ctr-faq-answer p {
  margin: 0 0 12px;
}

.ctr-faq-answer p:last-child {
  margin-bottom: 0;
}

/* Steps */
.ctr-steps {
  margin: 16px 0;
}

.ctr-step {
  display: flex;
  gap: 16px;
  margin-bottom: 12px;
}

.ctr-step-num {
  width: 28px;
  height: 28px;
  min-width: 28px;
  border-radius: 50%;
  background: var(--color-primary, #2563eb);
  color: #fff;
  font-size: 0.8125rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2px;
}

.ctr-step-content {
  font-size: 0.9375rem;
  color: #334155;
  line-height: 1.625;
}

/* Prev / Next Navigation */
.ctr-prev-next {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 64px;
  padding-top: 32px;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

.ctr-nav-card {
  display: flex;
  flex-direction: column;
  padding: 20px 24px;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  cursor: pointer;
  transition: all 250ms ease;
  text-decoration: none;
  background: #fff;
}

.ctr-nav-card:hover {
  border-color: var(--color-primary, #2563eb);
  background: var(--color-surface, #eff6ff);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.08);
  transform: translateY(-2px);
}

.ctr-nav-card.next {
  text-align: right;
  align-items: flex-end;
}

.ctr-nav-label {
  font-size: 0.8125rem;
  font-weight: 500;
  color: #64748b;
  margin-bottom: 4px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.ctr-nav-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-primary, #2563eb);
}

/* Diagnostic tool */
.ctr-diagnostic {
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 24px;
  margin: 24px 0;
}

.ctr-diagnostic h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.ctr-diagnostic p {
  font-size: 0.9375rem;
  color: #334155;
  margin: 0 0 16px;
  line-height: 1.625;
}

.ctr-diagnostic-checks {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.ctr-diagnostic-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: #fff;
  border-radius: 8px;
  font-size: 0.9375rem;
  color: #334155;
  border: 1px solid #e2e8f0;
  transition: all 200ms ease;
}

.ctr-diagnostic-item .check-icon {
  width: 24px;
  height: 24px;
  min-width: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  background: #f1f5f9;
  color: #94a3b8;
}

.ctr-diagnostic-item.passed .check-icon {
  background: #dcfce7;
  color: #16a34a;
}

.ctr-diagnostic-item.failed .check-icon {
  background: #fef2f2;
  color: #dc2626;
}

.ctr-diagnostic-item.running {
  background: #fefce8;
  border-color: #fde68a;
}

.ctr-diagnostic-item.running .check-icon {
  background: #fef3c7;
  color: #d97706;
}

.ctr-diagnostic-btn {
  margin-top: 16px;
  padding: 10px 24px;
  background: var(--color-primary, #2563eb);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 200ms ease;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.ctr-diagnostic-btn:hover {
  background: var(--color-primary-dark, #1d4ed8);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
}

.ctr-diagnostic-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

/* Responsive */
@media (max-width: 1200px) {
  .ctr-toc {
    display: none;
  }
}

@media (max-width: 1024px) {
  .ctr-sidebar {
    width: 240px;
    min-width: 240px;
  }
  .ctr-content {
    padding: 24px 32px 64px;
  }
}

@media (max-width: 768px) {
  .ctr-sidebar {
    position: fixed;
    left: -300px;
    top: 0;
    height: 100vh;
    z-index: 101;
    transition: left 300ms ease;
    box-shadow: none;
  }
  .ctr-sidebar.open {
    left: 0;
    box-shadow: 8px 0 24px rgba(0,0,0,0.15);
  }
  .ctr-sidebar-toggle {
    display: flex;
  }
  .ctr-sidebar-overlay.visible {
    display: block;
  }
  .ctr-content {
    padding: 20px 16px 64px;
  }
  .ctr-page-title {
    font-size: 1.75rem;
  }
  .ctr-section-title {
    font-size: 1.5rem;
  }
  .ctr-support-grid {
    grid-template-columns: 1fr;
  }
  .ctr-prev-next {
    grid-template-columns: 1fr;
  }
  .ctr-nav-card.next {
    text-align: left;
    align-items: flex-start;
  }
  .ctr-table-container {
    overflow-x: auto;
  }
  .ctr-table {
    min-width: 600px;
  }
}

@media (max-width: 480px) {
  .ctr-page-title {
    font-size: 1.5rem;
  }
  .ctr-section-title {
    font-size: 1.25rem;
  }
  .ctr-issue-header {
    gap: 12px;
  }
  .ctr-issue-icon {
    width: 36px;
    height: 36px;
    min-width: 36px;
    font-size: 0.95rem;
  }
  .ctr-issue-title {
    font-size: 1rem;
  }
}

@media (prefers-reduced-motion: reduce) {
  .ctr-issue-card,
  .ctr-support-card,
  .ctr-nav-card,
  .ctr-faq-item,
  .ctr-sidebar-link,
  .ctr-filter-tab,
  .ctr-diagnostic-btn {
    transition: none !important;
  }
  .ctr-issue-toggle i,
  .ctr-faq-question i {
    transition: none !important;
  }
}