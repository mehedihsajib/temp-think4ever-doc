  "page": {
    "title": "Getting Started with Consumer Wallet",
    "subtitle": "Everything you need to download, install, and set up your mPay Consumer Wallet. Follow this step-by-step guide to start making fast, secure payments in minutes.",
    "time_badge": "Estimated setup time: 5 minutes"
  },

  "toc": {
    "on_this_page": "On This Page",
    "requirements": "System Requirements",
    "download": "Download & Install",
    "install_steps": "Installation Steps",
    "signup": "Sign Up",
    "first_login": "First Login & Setup",
