  "requirements": {
    "heading": "System Requirements",
    "intro": "Before downloading, make sure your device meets the minimum requirements:",
    "ios": {
      "name": "iOS",
      "desc": "iOS 15.0 or later. Compatible with iPhone 8 and newer. Approximately 85 MB of storage required."
    },
    "android": {
      "name": "Android",
      "desc": "Android 10.0 (API level 29) or later. Approximately 60 MB of storage required."
    },
    "nfc_callout_title": "NFC Requirement",
    "nfc_callout_body": "For tap-to-pay functionality, your device must have NFC hardware. Most modern smartphones (iPhone 7+ and Android with NFC) support this feature."
  },

  "download": {
    "heading": "Download & Install",
    "intro": "mPay Consumer Wallet is available for free on both major app stores. Choose your platform below:",
    "ios_btn": "App Store",
    "ios_btn_pre": "Download on the",
    "android_btn": "Google Play",
    "android_btn_pre": "Get it on",
    "install_steps_heading": "Installation Steps",
    "steps": {
      "1": {
        "title": "Open your app store",
        "content": "Open the <strong>App Store</strong> (iOS) or <strong>Google Play Store</strong> (Android) on your device."
      },
      "2": {
        "title": "Search for mPay Wallet",
        "content": "Type <code>mPay Consumer Wallet</code> in the search bar. Look for the official app with the mPay logo and \"mPay Network\" as the developer."
      },
      "3": {
        "title": "Download and install",
        "content": "Tap <strong>Get</strong> (iOS) or <strong>Install</strong> (Android). The app will download and install automatically. You may be asked to authenticate with your device password, Face ID, or fingerprint."
      },
      "4": {
        "title": "Open the app",
        "content": "Once installed, tap <strong>Open</strong> or find the mPay icon on your home screen. The app will launch with the welcome screen."
      }
    },
    "verify_callout_title": "Verify the Developer",
    "verify_callout_body": "Always verify that the developer is listed as \"mPay Network\" before downloading. Do not install apps from unofficial sources."
  },

  "signup": {
    "heading": "Sign Up",
    "intro": "Creating your mPay account is quick and straightforward. You'll need a valid phone number and email address.",
    "steps": {
      "1": {
        "title": "Are you an existing mPay Customer?",
        "content": "On the welcome screen, you will be prompted to select whether you <strong>\"Are an existing customer?\"</strong>. For new customers, tap the <strong>NO</strong> button. If you already have an account, select <strong>YES</strong> button instead."
      },
      "2": {
        "title": "Enroll New Consumer Form",
        "content": "User is taken to <strong>Enroll New Consumer</strong> form."
      },
      "3": {
        "title": "Required Customer Information",
        "content": "The <strong>User ID</strong>, <strong>E-mail Address</strong>, and <strong>Mobile Number</strong> should be unique for each customer.",
        "info_callout": "During enrollment submission, the system verifies whether the <strong>User ID</strong>, <strong>E-mail Address</strong> and <strong>Mobile Number</strong> is already in use by existing mPay customers."
      },
      "4": {
        "title": "Fill in all required fields",
        "intro": "Enter your basic information:",
        "field_name": "<strong>First and Last Name</strong> — As it appears on your ID",
        "field_email": "<strong>Email Address</strong> — A valid email for notifications and recovery",
        "field_mobile": "<strong>Mobile Number</strong> — Should be a valid mobile number that will receive SMS for verification",
        "field_referral": "<strong>Referral Code</strong> — Optional field for the referral code of the referring mPay customer."
      },
      "5": {
        "title": "Agree to terms",
        "intro": "There are two required checkboxes to accept prior to proceeding with enrollment:",
        "check_terms": "Accept <strong>Terms and Conditions</strong>",
        "check_security": "Security Policy that only one user is allowed per device which states: <em>\"I agree that enrolling a new customer will remove the existing account linked on this device.\"</em>"
      },
      "6": {
        "title": "Option to Use Email and Mobile in Merchant App",
        "intro": "Choose whether your email and mobile number can also be used to identify you in the Merchant App.",
        "check_terms": "Accept <strong>Terms and Conditions</strong>",
        "check_security": "Security Policy that only one user is allowed per device which states: <em>\"I agree that enrolling a new customer will remove the existing account linked on this device.\"</em>"
      }
    },
    "success_callout_title": "Account Created!",
    "success_callout_body": "Once you see the confirmation screen, your account is ready. You can now proceed to set up your profile and configure your wallet."
  },

  "first_login": {
    "heading": "First Login & Setup",
    "intro": "After creating your account, you'll be guided through the initial setup wizard. Here's what to expect:",
    "profile_heading": "Profile Setup",
    "profile_steps": {
      "1": {
        "title": "Add your personal details",
        "content": "Enter your full name as it appears on your government-issued ID. Optionally, add a profile photo for easy identification during P2P transfers."
      },
      "2": {
        "title": "Set up security",
        "content": "Configure your preferred authentication method:",
        "pin": "<strong>PIN Code</strong> — Set a 6-digit PIN for quick access",
        "biometric": "<strong>Biometric</strong> — Enable Face ID or fingerprint authentication",
        "recommend": "We recommend enabling both for maximum security"
      },
      "3": {
        "title": "Enable notifications",
        "content_pre": "Allow push notifications to receive instant payment confirmations, security alerts, and promotional offers. You can customize notification preferences later in ",
        "settings_link": "Settings",
        "content_post": "."
      }
    },
    "wallet_heading": "Wallet Configuration",
    "wallet_steps": {
      "1": {
        "title": "Personalize your profile",
        "content": "Set a profile picture for your wallet account."
      },
      "2": {
        "title": "Managing Notification Preferences",
        "content": "You can turn on/off a notification option, based on your own preferences."
      },
      "3": {
        "title": "Complete the setup",
        "content": "Tap <strong>Finish Setup</strong> to land on your wallet dashboard. You're ready to start making payments!"
      }
    },
    "tip_callout_title": "Tip: Complete Verification Early",
    "tip_callout_body": "Verification process may take 24 to 48 hours, it is advisable to complete the profile as soon as possible in order to gain full access to mPay Wallet features."
  },

