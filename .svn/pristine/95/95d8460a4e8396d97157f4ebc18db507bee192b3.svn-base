  "making_payments": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumer",
      "current": "Making Payments"
    },
    "title": "Making Payments",
    "subtitle": "Learn how to make fast, secure payments using the MPay Consumer Wallet. Whether scanning a QR code, showing yours, or tapping with NFC — paying has never been easier.",
    "method_cards": {
      "qr": {
        "title": "QR Code Payments",
        "body": "Scan or show a QR code to complete payments instantly at any MPay merchant."
      },
      "nfc": {
        "title": "NFC Tap-to-Pay",
        "body": "Simply hold your phone near the terminal for a contactless payment experience."
      }
    },
    "scan_qr": {
      "heading": "Scanning QR Codes",
      "intro": "The most common way to pay is by scanning a merchant's QR code. This process takes only a few seconds and securely processes your payment through the MPay network.",
      "how_to_title": "How to do a Scan to Pay",
      "how_to_intro": "<strong>Scan to Pay</strong> allows users to scan a QR code to quickly send money or make payments using their wallet.",
      "steps": {
        "1": {
          "title": "Tap \"Scan to Pay\"",
          "body": "From the home screen, tap the <strong>Scan to Pay icon</strong> in the <b>Send Money</b> section."
        },
        "2": {
          "title": "Scan the Recipient's QR Code",
          "body": "Point your camera at the recipient&apos;s QR code. Once scanned, the recipient&apos;s details will automatically populated in Scan to Pay form.&nbsp;"
        },
        "3": {
          "title": "Enter Amount and Confirm",
          "body": "Enter the transfer amount, review the details, and confirm with your PIN or biometric authentication."
        },
        "4": {
          "title": "Transfer Complete",
          "body": "You&apos;ll see a confirmation screen with a transaction <b>reference number.</b>&nbsp; <p>The recipient is notified instantly.</p>"
        }
      },
      "visual_label": "Align QR code within frame",
      "tip_title": "Tip: Quick Pay Shortcut",
      "tip_body": "You can also launch the QR scanner directly by double-tapping the MPay icon on your home screen, or by using the \"Scan\" shortcut from the notification shade widget."
    },
    "show_qr": {
      "heading": "Showing Your QR Code",
      "intro": "Some merchants prefer to scan your QR code using their terminal or device. In this case, you simply present your personal payment QR code for them to scan.",
      "how_to_title": "How to Show Your QR",
      "steps": {
        "1": {
          "title": "Open Your Payment Code",
          "body": "Tap <strong>\"Pay\"</strong> on the home screen, then select <strong>\"Show My QR Code\"</strong>. Your personal payment QR code will be displayed."
        },
        "2": {
          "title": "Present to Merchant",
          "body": "Hold your phone steady with the QR code visible. The merchant will scan it using their MPay Merchant terminal or device camera."
        },
        "3": {
          "title": "Confirm on Your Device",
          "body": "After the merchant scans and enters the amount, you'll receive a push notification. Confirm the payment amount and authenticate to complete."
        }
      },
      "visual_label": "Show this to merchant",
      "security_title": "Security Note",
      "security_body": "Your payment QR code refreshes every 60 seconds for security. Never share a screenshot of your QR code. Only show it at the point of sale when making a payment."
    },
    "nfc_tap": {
      "heading": "NFC Tap-to-Pay",
      "intro": "If your device supports NFC and the merchant has an NFC-enabled terminal, you can pay by simply tapping your phone against their payment device — no scanning needed.",
      "how_to_title": "How to Use NFC Payments",
      "steps": {
        "1": {
          "title": "Enable NFC",
          "body": "Ensure NFC is enabled in your phone settings and in the MPay app under <strong>Settings → Payment Methods → NFC Payments</strong>."
        },
        "2": {
          "title": "Hold Near Terminal",
          "body": "When the merchant's terminal shows the amount, hold the back of your phone (near the NFC antenna) within 4cm of the payment terminal."
        },
        "3": {
          "title": "Authenticate",
          "body": "A vibration or tone confirms the connection. Authenticate using biometrics or your PIN. The payment processes in under 2 seconds."
        },
        "4": {
          "title": "Payment Complete",
          "body": "You'll see a success checkmark and receive both an in-app notification and optional SMS receipt."
        }
      },
      "visual_phone": "Your Phone",
      "visual_terminal": "Payment Terminal",
      "antenna_title": "NFC Antenna Location",
      "antenna_body": "The NFC antenna is usually located at the top-center of the back of your phone. Remove thick phone cases if you're having trouble connecting."
    },
    "confirmation": {
      "heading": "Payment Confirmation",
      "intro": "After every successful payment, you'll receive an instant confirmation with transaction details. This serves as your digital receipt.",
      "receipt_title": "What's Included in Your Receipt",
      "receipt_intro": "Every payment confirmation includes the following details:",
      "receipt": {
        "success": "Payment Successful",
        "merchant": "Coffee House Downtown",
        "transaction_id": "Transaction ID",
        "datetime": "Date & Time",
        "method": "Payment Method",
        "status": "Status",
        "completed": "Completed",
        "balance": "Wallet Balance"
      },
      "share_title": "Share & Export Receipts",
      "share_body": "Tap the <strong>\"Share\"</strong> button on any receipt to send it via email, messaging apps, or save as a PDF.",
      "failed_title": "Failed or Pending Payments",
      "failed_intro": "If a payment fails or remains pending, you'll see a different status screen:",
      "failed_list": {
        "pending": "<strong>Pending:</strong> The payment is being processed. This usually resolves within 30 seconds.",
        "failed": "<strong>Failed:</strong> The payment could not be completed. Check your balance and connection.",
        "refunded": "<strong>Refunded:</strong> The merchant initiated a refund. Funds return within 1-3 business days."
      }
    },
    "history": {
      "heading": "Transaction History",
      "intro": "Track all your past payments in one place. Your transaction history keeps a complete record of every payment through the mPay Wallet.",
      "access_title": "Accessing Your History",
      "access_body": "Navigate to <strong>Home → Transactions</strong> or swipe up on the home screen.",
      "sample_title": "Sample Transaction History",
      "table": {
        "date": "Date",
        "merchant": "Merchant",
        "method": "Method",
        "amount": "Amount",
        "status": "Status",
        "completed": "Completed",
        "pending": "Pending"
      },
      "export_title": "Export Your Data",
      "export_body": "You can export your transaction history as CSV or PDF by tapping the <strong>\"Export\"</strong> button."
    },
    "overview": {
      "heading": "Payment Flow Overview",
      "intro": "Here's a visual walkthrough of the complete payment process from start to finish.",
      "steps": {
        "1": "Tap \"Pay\" on home screen",
        "2": "Choose QR scan or NFC tap",
        "3": "Scan merchant QR code",
        "4": "Review payment amount",
        "5": "Authenticate with biometrics",
        "6": "Payment confirmed!"
      }
    },
    "faq": {
      "heading": "Frequently Asked Questions",
      "q1": "What's the maximum amount I can pay per transaction?",
      "a1": "The default transaction limit is $5,000 per payment. Verified accounts (KYC Level 2) can request higher limits. You can manage your limits in <strong>Settings → Payment Limits</strong>.",
      "q2": "Can I pay without an internet connection?",
      "a2": "NFC payments can work in offline mode for small transactions (under $50) if configured. QR code payments always require an internet connection.",
      "q3": "What should I do if the QR scanner doesn't recognize the code?",
      "a3": "Ensure adequate lighting and clean your lens. If it fails, ask for a fresh code or enter the merchant ID manually.",
      "q4": "Is NFC payment supported on all devices?",
      "a4": "NFC payments require a device with an NFC chip. Most phones after 2018 and iPhones from 7 onwards support NFC.",
      "q5": "Are there any fees for making payments?",
      "a5": "MPay Consumer Wallet does not charge any fees for making payments to merchants. The processor handles fees.",
      "q6": "Can I cancel a payment after it's been sent?",
      "a6": "Completed payments cannot be cancelled directly. Contact the merchant for a refund or report a dispute in <b>Transactions</b>."
    },
    "pagination": {
      "previous": "Previous",
      "next": "Next",
      "prev_title": "Account Setup",
      "next_title": "Wallet Management"
    },
    "toc": {
      "title": "On this page",
      "scan_qr": "Scanning QR Codes",
      "show_qr": "Showing Your QR Code",
      "nfc_tap": "NFC Tap-to-Pay",
      "confirmation": "Payment Confirmation",
      "history": "Payment History",
      "flow": "Payment Flow Overview",
      "faq": "FAQs"
    }
  },
  "wallet_management": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumer",
      "current": "Wallet Management"
    },
    "title": "Wallet Management",
    "subtitle": "Learn how to check your balance, add funds, withdraw money, and understand your transaction limits.",
    "overview": {
      "title": "Your MPay Wallet",
      "body": "Your mPay wallet is a secure digital wallet that stores your funds and allows you to make payments, transfer money, and manage your finances — all from your smartphone."
    },
    "balance": {
      "heading": "Checking Your Balance",
      "intro": "Your wallet balance is always visible on the home screen of the mPay app. Here's everything you need to know about viewing and understanding your balance.",
      "demo": {
        "label": "Available Balance",
        "currency": "Antillean Guilders (XCG)",
        "topup": "Top Up",
        "withdraw": "Withdraw",
        "history": "History"
      },
      "how_to_title": "How to View Your Balance",
      "steps": {
        "1": {
          "title": "Open the MPay App",
          "desc": "Launch the mPay Consumer app on your device. Your balance appears prominently on the home screen."
        },
        "2": {
          "title": "View Available Balance",
          "desc": "Your available balance is displayed at the top of the screen. This is the amount you can spend or transfer immediately."
        },
        "3": {
          "title": "Toggle Balance Visibility",
          "desc": "Tap the <strong>eye icon</strong> to hide or show your balance for privacy when in public."
        }
      },
      "callout": "<strong>Pending transactions</strong> may temporarily reduce your available balance. Pending amounts are shown separately below your main balance."
    },
    "topup": {
      "heading": "Top-Up Methods",
      "intro": "Add funds to your MPay wallet using any of the following methods. Each method has different processing times and fees.",
      "methods": {
        "bank": {
          "title": "Bank Transfer",
          "desc": "Transfer funds from any local banks to your mPay wallet account via Instant Payment processing. Safe and fast.",
          "time": "Instant"
        },
        "wallet": {
          "title": "Wallet to Wallet",
          "desc": "Instantly load your wallet account by asking another mPay customer to send you money and pay them cash.",
          "time": "Instant"
        },
        "agent": {
          "title": "Cash Agent",
          "desc": "Visit an authorized mPay merchant near you to deposit cash into your wallet. Present your mPay QR code to the merchant.",
          "time": "Instant"
        }
      }
    },
    "withdraw": {
      "heading": "Withdrawals",
      "intro": "Withdraw funds from your wallet to your linked bank account. MPay supports instant withdrawals to major local banks.",
      "callout": "<strong>Important:</strong> mPay adheres to Curaçao Central Bank policies. Ensure bank account details are accurate and correct prior the transaction to avoid any delay."
    },
    "limits": {
      "heading": "Transaction Limits",
      "intro1": "mPay enforces transaction limits to protect your account. Your limits depend on many factors like customer type(Consumer or Merchant) and is calculated on a daily, monthly and annual accumulation.",
      "intro2": "Here's a sample table limit (these are controlled by mPay Network)",
      "table": {
        "type": "Transaction Type",
        "consumer": "Consumer",
        "merchant": "Merchant",
        "cashier": "Cashier",
        "scan_pay": "Scan to Pay",
        "pay_bills": "Pay Bills",
        "pay_email": "Pay to E-mail",
        "pay_mobile": "Pay to Mobile",
        "transfer_bank": "Transfer to Bank",
        "managed_by": "Managed by<br>Merchant Owner"
      },
      "how_to_increase": "How to Increase Your Limits",
      "callout_view": "<strong>View your current limits:</strong> Go to <strong>Profile Settings → Wallet Limits</strong> to see your current limit, usage, and remaining limits for the day/month.",
      "callout_increase": "<strong>Increasing your limit?</strong> Contact mPay Support for this request and is subject for review and approval."
    },
    "faq": {
      "heading": "Frequently Asked Questions",
      "q1": "How long does it take for my top-up to appear?",
      "a1": "Card top-ups appear instantly. Bank transfers typically take 1–2 business days, depending on your bank. Cash agent top-ups are also instant once confirmed by the agent. You'll receive a push notification as soon as the funds are credited.",
      "q2": "Can I withdraw money to someone else's bank account?",
      "a2": "No. For security reasons, withdrawals can only be made to bank accounts registered in the same name as your MPay account. This is a regulatory requirement to prevent fraud and money laundering. If you need to send money to someone else, use the <strong>P2P Transfer</strong> feature instead.",
      "q3": "What happens if I exceed my transaction limit?",
      "a3": "The transaction will be declined, and you'll see an error message explaining that you've reached your limit. You can either wait for the limit to reset (daily limits reset at midnight UTC, monthly limits on the 1st of each month) or upgrade your verification tier to get higher limits.",
      "q4": "Is there a fee for maintaining a wallet balance?",
      "a4": "No. There are no monthly fees, maintenance charges, or inactivity fees for your MPay wallet. Your balance stays yours. The only fees that may apply are for certain top-up methods (credit card top-ups) and express/instant withdrawals.",
      "q5": "Can I set up recurring/automatic top-ups?",
      "a5": "Yes! Go to <strong>Settings → Auto Top-Up</strong> to configure automatic balance replenishment. You can set a minimum balance threshold and a top-up amount. When your balance drops below the threshold, MPay will automatically top up from your preferred funding source.",
      "q6": "What happens to my balance if I lose my phone?",
      "a6": "Your balance is safe — it's stored securely on MPay servers, not on your device. If you lose your phone, immediately contact MPay support to freeze your account. Then, when you get a new device, log in with your credentials and your full balance will be restored. Enable remote wipe on your phone as an extra precaution."
    },
    "pagination": {
      "prev": "Previous",
      "prev_title": "Making Payments",
      "next": "Next",
      "next_title": "P2P Transfers"
    },
    "toc": {
      "title": "On This Page",
      "balance": "Checking Your Balance",
      "topup": "Top-Up Methods",
      "withdraw": "Withdrawals",
      "limits": "Transaction Limits",
      "faq": "FAQ"
    }
  },
  "p2p_transfers": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumer",
      "current": "P2P Transfers"
    },
    "title": "Sending and Receiving Money",
    "subtitle": "Send, receive, and request money instantly from anyone in the <b>mPay</b> Network. Sending and receiving money is fast, secure, and fee-free for standard transactions.",
    "illustration": {
      "sender": "Sender",
      "receiver": "Receiver"
    },
    "methods_grid": {
      "send": {
        "title": "Send Money",
        "desc": "Transfer funds to any mPay user instantly, fast and secured."
      },
      "receive": {
        "title": "Receive Money",
        "desc": "Accept transfers via QR code or email or mobile number."
      },
      "request": {
        "title": "Request Payment",
        "desc": "Send payment requests to other users by generating QR"
      }
    },
    "send": {
      "heading": "Sending Money",
      "intro_title": "Quick & Secure Transfers",
      "intro_body": "Send money to anyone on the <b>mPay Network</b> in seconds. You can send via username, phone number, or QR code — whichever is most convenient."
    },
    "send_email_mobile": {
      "title": "Send by E-mail or Mobile Number",
      "intro": "The newest way to send money is by searching for the recipient using their mPay <b>email</b> or <b>mobile number</b>.",
      "steps": {
        "1": {
          "title": "Launch the \"Pay to E-mail or Pay to Mobile\"",
          "body": "From the home screen, tap the <strong>either the \"Pay to Email\" </strong> <span>or \"<b>Pay to Mobile\"</b></span> icon."
        },
        "2": {
          "title": "Find the Recipient",
          "body": "Enter the recipient's mPay <b>e-mail</b> or <b>mobile number</b> in the search field. The app will show matching users in real-time. You can also select from your <strong>Recent Contacts</strong> or <strong>Favorites</strong> list."
        },
        "3": {
          "title": "Enter the Amount",
          "body": "Type the amount you want to send. The app will display your wallet's current balance. You can optionally add a note or memo in <b>Description</b> field (e.g., <code>Dinner split</code>)."
        },
        "4": {
          "title": "Review and Confirm",
          "body": "Review the transfer details including recipient, amount, and any fees. Tap <strong>Confirm & Send</strong> and authenticate with your <b>PIN</b> or <b>biometric</b>."
        },
        "5": {
          "title": "Transfer Complete",
          "body": "You'll see a confirmation screen with a transaction reference number. The recipient is notified instantly."
        }
      }
    },
    "send_gallery": {
      "title": "Send by Scan from Gallery",
      "intro": "One convenient way of sending money using <b>saved</b> <span>QR code on your phone gallery</span>",
      "steps": {
        "1": {
          "title": "Launch the \"Scan from Gallery\"",
          "body": "From the home screen, tap the <b>Scan from Gallery</b> icon."
        },
        "2": {
          "title": "Upload the QR code on your gallery",
          "body": "The sender can upload the recipient’s QR code from the mobile phone’s gallery to initiate the transaction."
        },
        "3": {
          "title": "Enter the Amount",
          "body": "Type the amount you want to send. The app will display your wallet's current balance. You can optionally add a note or memo in <b>Description</b> field (e.g., <code>Payment for clothes</code>)."
        },
        "4": {
          "title": "Review and Confirm",
          "body": "Review the transfer details including recipient, amount, and any fees. Tap <strong>Confirm & Send</strong> and authenticate with your <b>PIN</b> or <b>biometric</b>."
        },
        "5": {
          "title": "Transfer Complete",
          "body": "You'll see a confirmation screen with a transaction reference number. The recipient is notified instantly."
        }
      }
    },
    "send_scan_pay": {
      "title": "Send via Scan to Pay",
      "intro": "<b>Scan to Pay</b> allows users to scan a QR code to quickly send money or make payments using their wallet.",
      "steps": {
        "1": {
          "title": "Tap \"Scan to Pay\"",
          "body": "From the home screen, tap the <strong>Scan to Pay icon</strong> in the <b>Send Money</b> section."
        },
        "2": {
          "title": "Scan the Recipient's QR Code",
          "body": "Point your camera at the recipient's QR code. Once scanned, the recipient's details will automatically populated in Scan to Pay form."
        },
        "3": {
          "title": "Enter Amount and Confirm",
          "body": "Enter the transfer amount, review the details, and confirm with your PIN or biometric authentication."
        },
        "4": {
          "title": "Transfer Complete",
          "body": "You'll see a confirmation screen with a transaction <b>reference number.</b> <p>The recipient is notified instantly.</p>"
        }
      }
    },
    "send_pay_qr": {
      "title": "Send via Pay by QR",
      "intro": "<b>Pay by QR</b> allows users to generate a QR code that the recipient can scan to receive money.",
      "steps": {
        "1": {
          "title": "Tap \"Pay by QR\"",
          "body": "From the home screen, tap the <strong>Pay by QR </strong> <span>icon</span> in the <b>Send Money </b> <span>section.</span>"
        },
        "2": {
          "title": "Enter QR details",
          "body": "Users can define the amount, usage type (one-time or multiple), and expiry when generating a Pay by QR code."
        },
        "3": {
          "title": "Review and Confirm",
          "body": "Review the details, and confirm with your <b>PIN</b> or <b>biometric</b> authentication."
        },
        "4": {
          "title": "Transfer Complete",
          "body": "You'll see a confirmation screen with a transaction <b>reference number.</b> <p>The recipient is notified instantly.</p>"
        }
      }
    },
    "limits": {
      "title": "Transaction Limits",
      "desc": "Transaction limits depend on what has been setup in <b>Admin Console</b> which could be a <b>global limit</b> or <b>user-level</b> limit.",
      "callout": {
        "title": "Important",
        "body": "User transaction limits are defined and controlled by the mPay Network and cannot be modified within the application. However, customer can view their <b>accumulated</b> limits in <b>Profile Settings → Payment Limits</b>"
      }
    },
    "receive": {
      "heading": "Receiving Money",
      "intro_title": "Instant Incoming Transfers",
      "intro_body": "When someone sends you money, it arrives in your wallet instantly. You'll receive a push notification and the amount is immediately available to spend.",
      "notifications": {
        "title": "Transfer Notifications",
        "intro": "When a transfer or payment is is sent to your wallet account, you'll receive:",
        "list": {
          "push": "<strong>Push notification</strong> — Shows sender name, amount, and memo",
          "in_app": "<strong>In-app notification</strong> — Available in the Notifications center",
          "email": "<strong>Email notification</strong> — If enabled in your notification settings",
          "sms": "<strong>SMS alert</strong> — Transaction alert to your registered mobile number"
        }
      },
      "share_qr": {
        "title": "Share Your Profile QR Code",
        "intro": "Make it easy for others to send you money by sharing your <b>profile QR</b> code:",
        "steps": {
          "1": {
            "title": "Open Your QR Code",
            "body": "From the home screen, tap the <strong>Profile QR Code</strong> in the upper right corner of the page."
          },
          "2": {
            "title": "Share or Display",
            "body": "Show the QR code on your screen for the sender to scan, or tap <strong>Share</strong> to send it via message, email, or social media."
          }
        },
        "placeholder": "Personal QR Code screen with amount field"
      },
      "fees_callout": {
        "title": "No Fees for Receiving",
        "body": "Receiving P2P transfers on MPay Network is always free. There are no fees for incoming standard transfers."
      }
    },
    "request": {
      "heading": "Requesting Money",
      "intro_title": "Payment Requests Made Easy",
      "intro_body": "Need to collect money from a friend or split a bill? Send a payment request directly from the app. The recipient gets a notification and can pay with a single tap.",
      "req_qr": {
        "title": "Request Money by QR",
        "steps": {
          "1": {
            "title": "Open Request Screen",
            "body": "From the home screen, tap <strong>Request by QR</strong> <span> in the <b>Receive Money</b> section.</span>"
          },
          "2": {
            "title": "Set the Amount and Details",
            "body": "Enter the total amount and add a description (e.g., <code>Dinner at La Piazza - March 15</code>)."
          },
          "3": {
            "title": "Tap Submit to generate QR",
            "body": "Click on <b>Submit</b> <span> button to generate a customized QR code.</span>"
          },
          "4": {
            "title": "Share the QR to the Sender",
            "body": "Share the <b>QR code generated</b> <span> to the <b>Sender</b>.</span> <p>The sender will then send money using this QR via <b>Scan to Pay</b>.</p>"
          }
        }
      },
      "respond_qr": {
        "title": "Responding to a Request by QR",
        "intro": "When someone sends you a <b>Request by QR code</b>, you being the <b>Sender</b> can send the money or pay using <b>Scan to Pay</b> or <b>Scan from Gallery.</b>",
        "steps": {
          "1": {
            "title": "Review the Request",
            "body": "Is the person requesting money from you someone you trust?"
          },
          "2": {
            "title": "Send Money",
            "body": "Sender can use to pay the <b>Request by QR</b> code using either <b>Scan to Pay</b> or <b>Scan from Gallery</b>."
          },
          "3": {
            "title": "Verify and Authenticate",
            "body": "Confirm the transaction with your <b>PIN</b> or <b>biometric</b> authentication. The money is transferred immediately."
          }
        }
      },
      "tip_callout": {
        "title": "Sending Money Pro Tip",
        "body": "Always verify the requestor before sending payment to avoid potential fraud."
      },
      "fraud_callout": {
        "title": "Fraud Warning",
        "body": "Never pay a request from someone you don't know. If you receive an unexpected payment request, verify the sender before paying. Report suspicious requests to <strong>fraud@mpaynetwork.com</strong>."
      }
    },
    "faq": {
      "heading": "Frequently Asked Questions",
      "q1": "Are Send Money transactions free?",
      "a1": "Yes, standard P2P transfers between MPay wallet users are completely free. There are no fees for sending or receiving money. However, instant transfers to external bank accounts may incur a small fee (typically 1-2%).",
      "q2": "How long does a P2P transfer take?",
      "a2": "P2P transfers between MPay users are instant — the money appears in the recipient's wallet within seconds. In rare cases during high traffic, transfers may take up to 30 seconds to process.",
      "q3": "Can I cancel a P2P transfer after sending?",
      "a3": "Once a P2P transfer is confirmed and sent, it cannot be reversed. If you sent money to the wrong person, you can contact the recipient through the app to request they send it back. You can also open a dispute through <strong>Help → Report a Problem</strong> within 24 hours.",
      "q4": "Can I send money to someone who doesn't have MPay?",
      "a4": "You can invite non-MPay users to receive transfers. When you send money to a phone number not registered on MPay, the recipient receives an SMS with a link to download the app and claim the funds. Unclaimed transfers expire after 14 days and are automatically refunded.",
      "q5": "How do I increase my transfer limits?",
      "a5": "Transfer limits are tied to your account verification level. To increase your limits: <p>1. Go to <strong>Settings → Account → Verification</strong>.<br>2. Complete the required verification steps for the next level.<br>3. Limits are updated automatically once verification is approved (typically within 24 hours).</p>",
      "q6": "What happens if I send money to the wrong person?",
      "a6": "If you accidentally send money to the wrong recipient, you should: <p>1. Contact the recipient through the app's in-built messaging feature to request a return.<br>2. If the recipient is unresponsive, file a dispute within 24 hours through <strong>Help → Report a Problem → Wrong Recipient</strong>.<br>3. Our support team will mediate the situation. Please note that we cannot guarantee recovery of funds sent to the wrong person.</p> Always double-check the recipient's name and profile picture before confirming a transfer.",
      "q7": "Can I schedule recurring P2P transfers?",
      "a7": "Yes! You can set up recurring transfers for rent payments, allowances, or regular payments. After entering the transfer details, toggle on <strong>Make Recurring</strong> and choose your frequency (weekly, bi-weekly, or monthly). You can manage or cancel recurring transfers in <strong>Transfers → Scheduled</strong>."
    },
    "pagination": {
      "prev": "Previous",
      "prev_title": "Wallet Management",
      "next": "Next",
      "next_title": "Settings & Security"
    },
