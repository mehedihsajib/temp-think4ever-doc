  "troubleshooting": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumer",
      "current": "Troubleshooting"
    },
    "title": "Troubleshooting",
    "subtitle": "Find solutions to common issues, understand error codes, and learn how to resolve problems with your MPay Consumer Wallet.",
    "search_placeholder": "Search issues, error codes, and FAQs...",
    "diagnostic": {
      "title": "Quick Diagnostic Tool",
      "intro": "Run a quick check to identify potential issues with your wallet setup. This diagnostic verifies common configuration points.",
      "check_internet": "Internet connectivity",
      "check_version": "App version up to date",
      "check_permissions": "Required permissions granted",
      "check_nfc": "NFC hardware available",
      "check_storage": "Sufficient storage space",
      "btn": "Run Diagnostics",
      "running": "Running..."
    },
    "common_issues": {
      "title": "Common Issues",
      "desc": "Below are the most frequently encountered problems and their step-by-step solutions.",
      "issue1": {
        "title": "Unable to Connect to Server",
        "summary": "App shows \"Connection Error\" or takes too long to load.",
        "causes": "Possible Causes",
        "cause1": "Unstable internet connection (Wi-Fi or mobile data)",
        "cause2": "MPay Network servers may be undergoing maintenance",
        "cause3": "VPN or proxy interference",
        "cause4": "Outdated app version",
        "solution": "Solution",
        "step1": "Check your internet connection by opening a web page in your browser.",
        "step2": "Toggle airplane mode on and off, then retry.",
        "step3": "Disable any VPN or proxy services temporarily.",
        "step4": "Update the MPay Consumer Wallet app from your app store.",
        "step5": "If the issue persists, check <a href=\"#\" style=\"color:#2563eb;\">MPay Status Page</a> for ongoing incidents.",
        "callout": "Server maintenance typically lasts 15-30 minutes and is scheduled during off-peak hours (2:00 AM — 4:00 AM local time)."
      },
      "issue2": {
        "title": "QR Code Not Scanning",
        "summary": "Camera unable to detect or read merchant QR codes.",
        "causes": "Possible Causes",
        "cause1": "Camera permission not granted to the app",
        "cause2": "Poor lighting conditions",
        "cause3": "Damaged or blurry QR code",
        "cause4": "Camera lens is dirty or obstructed",
        "solution": "Solution",
        "step1": "Go to <strong>Settings → App Permissions</strong> and ensure camera access is enabled for MPay.",
        "step2": "Clean your camera lens with a soft cloth.",
        "step3": "Ensure adequate lighting — use the flashlight toggle in the scanner view.",
        "step4": "Hold your phone steady, about 6-12 inches from the QR code.",
        "step5": "If the QR code is on a screen, reduce screen glare by adjusting the angle.",
        "callout": "If the QR code appears damaged or corrupted, ask the merchant to regenerate a new one."
      },
      "issue3": {
        "title": "NFC Payment Failing",
        "summary": "Tap-to-pay not detected or transaction not completing.",
        "causes": "Possible Causes",
        "cause1": "NFC is disabled on your device",
        "cause2": "Phone case is blocking the NFC antenna",
        "cause3": "Device not positioned correctly on the terminal",
        "cause4": "Insufficient wallet balance",
        "solution": "Solution",
        "step1": "Enable NFC in your phone's Settings: <span class=\"ctr-code\">Settings → Connected Devices → NFC</span>",
        "step2": "Remove any thick phone case or metal accessories that may block NFC.",
        "step3": "Hold the back of your phone flat against the terminal for 2-3 seconds.",
        "step4": "Ensure your wallet has sufficient balance for the transaction.",
        "callout": "NFC antenna location varies by phone model. Most Android phones have it in the upper-middle back area. iPhones use the top edge."
      },
      "issue4": {
        "title": "Biometric Login Not Working",
        "summary": "Fingerprint or face recognition fails to authenticate.",
        "causes": "Possible Causes",
        "cause1": "Biometric data changed on the device (new fingerprint added)",
        "cause2": "Biometric hardware sensor dirty or damaged",
        "cause3": "Biometric permission revoked for the app",
        "solution": "Solution",
        "step1": "Log in using your PIN code as a fallback.",
        "step2": "Go to <strong>MPay Settings → Security → Biometric Login</strong> and re-enable it.",
        "step3": "If prompted, re-register your biometric data.",
        "step4": "Clean the fingerprint sensor or ensure face recognition has clear line of sight."
      },
      "issue5": {
        "title": "P2P Transfer Stuck or Pending",
        "summary": "Money sent but recipient hasn't received it.",
        "causes": "Possible Causes",
        "cause1": "Network congestion causing delays",
        "cause2": "Recipient's account may have restrictions",
        "cause3": "Transaction amount exceeds daily limits",
        "cause4": "Compliance review for large amounts",
        "solution": "Solution",
        "step1": "Check the transaction status in <strong>Activity → Transaction History</strong>.",
        "step2": "If status is \"Processing\", wait up to 30 minutes for completion.",
        "step3": "If status is \"Pending Review\", your transaction is being reviewed. You'll receive a notification once resolved.",
        "step4": "If stuck for more than 2 hours, contact support with the Transaction ID.",
        "callout": "<strong>Do not</strong> send the same transfer again while the original is still processing. This may result in a double charge."
      },
      "issue6": {
        "title": "Top-Up or Withdrawal Failed",
        "summary": "Unable to add funds or withdraw from wallet.",
        "causes": "Possible Causes",
        "cause1": "Bank account or card not verified",
        "cause2": "Daily or monthly limits exceeded",
        "cause3": "Bank rejecting the transaction",
        "cause4": "Account verification incomplete",
        "solution": "Solution",
        "step1": "Verify your linked bank account/card in <strong>Settings → Payment Methods</strong>.",
        "step2": "Check your current limits in <strong>Settings → Limits</strong>.",
        "step3": "Complete KYC verification to unlock higher limits.",
        "step4": "Contact your bank to ensure no holds or blocks on online transactions."
      }
    },
    "error_codes": {
      "title": "Error Codes Reference",
      "desc": "If you encounter an error code in the app, use this reference table to understand what it means and how to resolve it.",
      "filters": {
        "all": "All",
        "low": "Low",
        "medium": "Medium",
        "high": "High",
        "critical": "Critical"
      },
      "table": {
        "code": "Code",
        "description": "Description",
        "severity": "Severity",
        "resolution": "Resolution"
      },
      "e1001": {
        "desc": "Network Connection Timeout",
        "res": "Check internet connection and retry. Switch between Wi-Fi and mobile data."
      },
      "e1002": {
        "desc": "Authentication Failed",
        "res": "Re-enter your credentials. If persists, reset password via email recovery."
      },
      "e1003": {
        "desc": "Session Expired",
        "res": "Log in again. This is normal after 30 minutes of inactivity."
      },
      "e2001": {
        "desc": "Insufficient Balance",
        "res": "Top up your wallet before retrying the transaction."
      },
      "e2002": {
        "desc": "Transaction Limit Exceeded",
        "res": "You've reached your daily/monthly limit. Complete KYC for higher limits or wait for reset."
      },
      "e2003": {
        "desc": "Payment Declined by Merchant",
        "res": "The merchant's terminal rejected the payment. Verify amount and retry, or use a different payment method."
      },
      "e2004": {
        "desc": "Duplicate Transaction Detected",
        "res": "The system detected a possible duplicate. Check your transaction history before retrying."
      },
      "e3001": {
        "desc": "QR Code Invalid or Expired",
        "res": "Ask the merchant to generate a new QR code. QR codes expire after 5 minutes."
      },
      "e3002": {
        "desc": "NFC Not Supported",
        "res": "Your device doesn't support NFC. Use QR code scanning for payments instead."
      },
      "e4001": {
        "desc": "Account Suspended",
        "res": "Your account has been temporarily suspended. Contact support immediately for resolution."
      },
      "e4002": {
        "desc": "KYC Verification Required",
        "res": "Complete identity verification in Settings → Account → Verify Identity."
      },
      "e5001": {
        "desc": "Top-Up Failed",
        "res": "Verify your linked bank/card details. Contact your bank if the issue continues."
      },
      "e5002": {
        "desc": "Withdrawal Processing Delay",
        "res": "Withdrawals may take 1-3 business days. No action needed unless it exceeds 5 days."
      },
      "e9999": {
        "desc": "Internal Server Error",
        "res": "An unexpected error occurred. Restart the app and retry. If persists, contact support."
      },
      "callout": "You can find your error code by tapping the error message in the app. The code appears at the bottom of the error dialog. Include this code when contacting support for faster resolution."
    },
    "contact_support": {
      "title": "Contact Support",
      "desc": "If you can't resolve your issue using the guides above, our support team is here to help.",
      "ticket": {
        "title": "Support Ticket",
        "desc": "Submit a detailed support request and get a response within 24 hours.",
        "link": "Submit Ticket"
      },
      "email": {
        "title": "Email Us",
        "desc": "Send an email to our support team for complex issues or account inquiries.",
        "link": "support@mpaynetwork.com"
      },
      "chat": {
        "title": "In-App Chat",
        "desc": "Use the built-in chat feature for real-time assistance during business hours.",
        "link": "Open in App"
      },
      "checklist_title": "Before contacting support, please have the following ready:",
      "check1": "Your registered email address or phone number",
      "check2": "Error code (if applicable)",
      "check3": "Transaction ID (for payment issues)",
      "check4": "Device model and OS version",
      "check5": "App version (found in Settings → About)"
    },
    "faq": {
      "title": "Frequently Asked Questions",
      "desc": "Quick answers to the most common questions about the Consumer Wallet.",
      "q1": "How do I reset my wallet PIN?",
      "a1": "<p>Go to <strong>Settings → Security → Change PIN</strong>. You'll need to verify your identity using your registered email or phone number first. Enter your current PIN (or use the \"Forgot PIN\" option), then set a new 6-digit PIN.</p><p>If you've forgotten your PIN entirely, tap \"Forgot PIN\" on the login screen and follow the recovery steps. You'll receive a verification code via SMS or email.</p>",
      "q2": "Can I use MPay Wallet on multiple devices?",
      "a2": "<p>For security purposes, your MPay Consumer Wallet can only be active on one device at a time. If you log in on a new device, your previous session will be automatically ended.</p><p>To switch devices, simply install the app on your new device, log in with your credentials, and verify your identity. All your data will sync automatically.</p>",
      "q3": "What are the daily transaction limits?",
      "a3": "<p>Transaction limits depend on your verification level:</p><ul style=\"padding-left:20px;margin:8px 0;\"><li><strong>Basic (unverified):</strong> $100/day, $500/month</li><li><strong>Verified (KYC complete):</strong> $5,000/day, $25,000/month</li><li><strong>Premium:</strong> $25,000/day, $100,000/month</li></ul><p>You can check your current limits and verification level in <strong>Settings → Account → Limits</strong>.</p>",
      "q4": "How long do refunds take to process?",
      "a4": "<p>Refunds initiated by merchants typically appear in your wallet within 1-3 business days. You'll receive a push notification when the refund is credited. For refunds to your linked bank account, allow an additional 3-5 business days.</p><p>You can track refund status in <strong>Activity → Transaction History</strong> — refunded transactions are marked with a green \"Refunded\" badge.</p>",
      "q5": "Why is my account showing \"Under Review\"?",
      "a5": "<p>Account reviews are triggered automatically by our security system when unusual activity is detected. This may happen if:</p><ul style=\"padding-left:20px;margin:8px 0;\"><li>Multiple failed login attempts</li><li>Large or unusual transaction patterns</li><li>Login from a new location or device</li><li>Incomplete KYC verification</li></ul><p>Reviews typically complete within 24-48 hours. During review, you can still view your balance and history, but transactions may be temporarily restricted. Contact support if the review takes longer than expected.</p>",
      "q6": "How do I delete my account permanently?",
      "a6": "<p>To delete your account, go to <strong>Settings → Account → Delete Account</strong>. Before deletion, you must:</p><ul style=\"padding-left:20px;margin:8px 0;\"><li>Withdraw all remaining balance to your bank account</li><li>Ensure no pending transactions exist</li><li>Confirm your identity via email/phone verification</li></ul><p>Account deletion is permanent and cannot be undone. Your transaction history will be retained for 7 years as required by financial regulations, but your personal profile will be anonymized.</p>"
    },
