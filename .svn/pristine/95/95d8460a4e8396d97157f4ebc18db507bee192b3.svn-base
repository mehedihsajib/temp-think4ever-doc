  "settings": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumer",
      "settings_security": "Settings & Security"
    },
    "title": "Settings & Security",
    "subtitle": "Learn how to configure your MPay Consumer Wallet settings, manage security preferences, enable biometric authentication, and protect your account with advanced security features.",
    "visual": {
      "title": "Your Security Matters",
      "body": "MPay uses bank-grade encryption and multiple security layers to keep your wallet and transactions safe. Configure these settings to maximize your protection."
    },
    "pin": {
      "heading": "PIN Management",
      "intro": "Your transaction PIN is a 6-digit code used to authorize payments and sensitive account operations. It is separate from your device lock screen and provides an additional layer of security.",
      "setting_heading": "Setting Your PIN",
      "setting_intro": "When you first set up your mPay wallet, you'll be prompted to create a transaction PIN. Follow these steps:",
      "steps": {
        "1": {
          "title": "Navigate to Security Settings",
          "desc": "Open the app menu and tap <strong>Profile Settings</strong> → <strong>Security</strong> → <strong>Change PIN</strong>."
        },
        "2": {
          "title": "Enter a 6-Digit PIN",
          "desc": "Choose a PIN that you can remember but that isn't easily guessable. Avoid sequential numbers like <code>123456</code> or repeated digits like <code>111111</code>."
        },
        "3": {
          "title": "Confirm Your PIN",
          "desc": "Re-enter your PIN to confirm. The system will verify both entries match before saving."
        },
        "4": {
          "title": "PIN Saved Successfully",
          "desc": "Your PIN is now active. You'll use it to approve transactions, transfers, and account changes."
        }
      },
      "changing_heading": "Changing Your PIN",
      "changing_intro": "To change your existing PIN, you'll need to verify your current PIN first:",
      "changing_steps": {
        "1": {
          "title": "Go to Settings → Security → Change PIN",
          "desc": "Navigate to the PIN management section in your security settings."
        },
        "2": {
          "title": "Enter Current PIN",
          "desc": "Verify your identity by entering your current 6-digit PIN."
        },
        "3": {
          "title": "Enter & Confirm New PIN",
          "desc": "Type your new PIN and confirm it. Your new PIN takes effect immediately."
        }
      },
      "tips_title": "PIN Security Tips",
      "tips_body": "Never share your PIN with anyone, including MPay support staff. MPay will never ask you for your PIN via phone, email, or SMS. After 5 failed PIN attempts, your account will be temporarily locked for 30 minutes.",
      "forgot_title": "Forgot Your PIN?",
      "forgot_body": "If you forget your transaction PIN, tap <strong>\"Forgot PIN\"</strong> on the PIN entry screen. You'll need to verify your identity through your registered email or phone number to reset it."
    },
    "biometric": {
      "heading": "Biometric Authentication",
      "intro": "Enable fingerprint or Face ID authentication for quick and secure access to your wallet. Biometric login adds convenience while maintaining strong security.",
      "methods": {
        "fingerprint": {
          "title": "Fingerprint",
          "desc": "Use your registered fingerprint for fast wallet access and transaction approval.",
          "badge": "Most Common"
        },
        "faceid": {
          "title": "Face ID",
          "desc": "Authenticate with facial recognition for a seamless hands-free experience.",
          "badge": "Recommended"
        }
      },
      "enabling_heading": "Enabling Biometric Login",
      "steps": {
        "1": {
          "title": "Open Security Settings",
          "desc": "Go to <strong>Settings</strong> → <strong>Security</strong> → <strong>Biometric Authentication</strong>."
        },
        "2": {
          "title": "Toggle Biometric Login",
          "desc": "Turn on the biometric authentication toggle. Your device must have at least one fingerprint or Face ID enrolled."
        },
        "3": {
          "title": "Verify with PIN",
          "desc": "Enter your transaction PIN to confirm the change. This ensures only you can enable biometrics."
        },
        "4": {
          "title": "Test Your Biometric",
          "desc": "You'll be prompted to scan your fingerprint or face to verify it works correctly."
        }
      },
      "toggles": {
        "access": "Biometric Login for Wallet Access",
        "transactions": "Biometric Approval for Transactions"
      },
      "requirements_title": "Device Requirements",
      "requirements_body": "Biometric authentication requires a compatible device with enrolled biometrics. If your device doesn't support biometrics, this option will be unavailable. You can always fall back to PIN authentication."
    },
    "notifications": {
      "heading": "Notification Settings",
      "intro": "Configure how and when MPay sends you alerts about transactions, security events, and account activity. Keeping notifications enabled helps you monitor your account in real time.",
      "channels_heading": "Available Notification Channels",
      "channels": {
        "push": {
          "title": "Push Notifications",
          "desc": "Real-time alerts delivered directly to your device. Recommended for transaction alerts and security notifications."
        },
        "email": {
          "title": "Email Notifications",
          "desc": "Detailed notifications sent to your registered email address. Includes transaction receipts and monthly summaries."
        },
        "sms": {
          "title": "SMS Alerts",
          "desc": "Critical alerts via text message. Used for high-value transactions and security events when push is unavailable."
        }
      },
      "types_heading": "Configurable Alert Types",
      "types": {
        "transaction": "<strong>Transaction Alerts</strong> — Every payment sent or received",
        "promotional": "<strong>Promotional</strong> — News, offers, and feature announcements",
        "summary": "<strong>Weekly Summary</strong> — Weekly spending and activity digest"
      },
      "pro_tip_title": "Pro Tip",
      "pro_tip_body": "We recommend keeping <strong>Transaction Alerts</strong> and <strong>Security Alerts</strong> enabled at all times. These help you quickly detect unauthorized activity on your account.",
      "managing_heading": "Managing Notifications",
      "managing_body": "To adjust your notification preferences, navigate to <strong>Settings</strong> → <strong>Notifications</strong>. Use the toggles to enable or disable each notification type per channel. Changes take effect immediately.",
      "toggles": {
        "transaction": "Transaction Alerts (Push)",
        "security": "Security Alerts (Push + Email)",
        "promotional": "Promotional Notifications"
      }
    },
    "privacy": {
      "heading": "Privacy Settings",
      "intro": "MPay gives you full control over your personal data and privacy preferences. Manage how your information is used, shared, and stored.",
      "controls_heading": "Privacy Controls",
      "controls": {
        "visibility": {
          "title": "Profile Visibility",
          "desc": "Control who can see your display name and profile picture when sending or receiving payments."
        },
        "analytics": {
          "title": "Analytics & Usage Data",
          "desc": "Choose whether to share anonymized usage data to help improve the MPay experience."
        },
        "location": {
          "title": "Location Data",
          "desc": "Manage location access. Used for fraud detection and nearby merchant features."
        },
        "contacts": {
          "title": "Contacts Access",
          "desc": "Allow MPay to access your contacts for easy P2P transfers. Fully optional."
        }
      },
      "data_heading": "Data Management",
      "data_intro": "You have the right to access, export, and delete your personal data at any time:",
      "data_options": {
        "export": {
          "title": "Export Data",
          "desc": "Download a copy of all your personal data and transaction history"
        },
        "activity": {
          "title": "Activity Log",
          "desc": "Review a complete log of account activity and access events"
        },
        "delete": {
          "title": "Delete Account",
          "desc": "Permanently delete your account and all associated data"
        }
      },
      "deletion_title": "Account Deletion",
      "deletion_body": "Account deletion is permanent and cannot be undone. Before deleting, ensure your wallet balance is zero and all pending transactions are completed. Regulatory requirements may require us to retain certain transaction records for up to 7 years.",
      "policy_heading": "Privacy Policy",
      "policy_body": "For complete details on how MPay collects, uses, and protects your data, please review our <a onclick=\"load_page('privacy_policy')\" tabindex=\"0\" style=\"color: var(--color-primary, #2563eb); cursor: pointer; text-decoration: underline;\">Privacy Policy</a>."
    },
    "faq": {
      "heading": "Frequently Asked Questions",
      "questions": {
        "1": {
          "q": "What happens if I forget my transaction PIN?",
          "a": "Tap \"Forgot PIN\" on the PIN entry screen. You'll need to verify your identity through your registered email or phone number. A PIN reset link will be sent to you. After verification, you can set a new 6-digit PIN. Your account may be temporarily restricted during the reset process for security."
        },
        "2": {
          "q": "Can I use both fingerprint and Face ID?",
          "a": "You can only use the biometric method supported by your device. Most devices support either fingerprint or Face ID, not both simultaneously. If your device supports both, you can choose which one to use as your primary biometric method in the security settings."
        },
        "3": {
          "q": "How do I recover my account if I lose my 2FA device?",
          "a": "Use one of your backup codes to log in and disable 2FA. If you don't have backup codes, contact MPay support with your registered email and a government-issued ID for identity verification. The recovery process typically takes 24-48 hours for security reasons."
        },
        "4": {
          "q": "Why am I not receiving push notifications?",
          "a": "First, check that notifications are enabled in both the MPay app settings and your device's system settings. On Android, ensure the app isn't being restricted by battery optimization. On iOS, check the Notification Center settings. If notifications still aren't working, try logging out and back in, or reinstalling the app."
        },
        "5": {
          "q": "Can I download my transaction history?",
          "a": "Yes! Go to <strong>Settings → Privacy → Export Data</strong> to download a complete copy of your transaction history. You can export in CSV or PDF format. The export will be sent to your registered email address and typically arrives within a few minutes."
        },
        "6": {
          "q": "Is my PIN stored on MPay servers?",
          "a": "No. Your PIN is never stored in plain text. MPay uses strong one-way hashing (bcrypt) to store a hashed version of your PIN. This means even MPay employees cannot see your actual PIN. All PIN verification happens securely server-side by comparing hashes."
        }
      }
    },
    "pagination": {
      "prev": "Previous",
      "prev_title": "P2P Transfers",
      "next": "Next",
      "next_title": "Troubleshooting"
