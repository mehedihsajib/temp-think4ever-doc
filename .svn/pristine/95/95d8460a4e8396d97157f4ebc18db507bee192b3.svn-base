  "account_setup": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumer",
      "account_setup": "Account Setup"
    },
    "title": "Account Setup & Verification",
    "subtitle": "Learn how to register your mPay Consumer Wallet account, complete identity verification and configure your profile preferences.",
    "registration": {
      "heading": "Registration",
      "intro": "Creating your mPay Consumer Wallet account is quick and straightforward. All you need is a valid phone number to get started.",
      "wallet_registration": "Wallet Registration",
      "intro_2": "Your mobile number and e-mail address serve as one of the unique identifier in the mPay Network. Follow these steps to register or sign up:",
      "steps": {
        "1": {
          "title": "Are you an existing mPay Customer?",
          "content": "On the welcome screen, you will be prompted to select whether you <strong>\"Are an existing customer?\"</strong>. For new customers, tap the <strong>NO</strong> button. If you already have an account, select <strong>YES</strong> button instead."
        },
        "2": {
          "title": "Enroll New Customer Form",
          "content": "User is taken to <strong> Enroll New Consumer </strong> form."
        },
        "3": {
          "title": "Required Customer Information",
          "content": "The <strong> User ID </strong>, <strong> E-mail Address </strong>, and <strong>Mobile Number</strong> should be unique for each customers."
        },
        "4": {
          "title": "Create Your PIN",
          "content": "Set a 6-digit PIN that you'll use to authorize transactions and access your wallet. Choose something secure but memorable."
        },
        "5": {
          "title": "Accept Terms of Service",
          "content_pre": "Review and accept the mPay Network ",
          "tos": "Terms of Service",
          "privacy": "Privacy Policy",
          "content_mid": " and ",
          "content_post": "."
        },
        "6": {
          "title": "Security Questions setup",
          "content": "Setup security question, which will be used for account recovery and password reset. Click on <strong>Submit</strong> button"
        },
        "7": {
          "title": "OTP Verification",
          "content": "An SMS will be sent to your registered mobile number with <strong>OTP(One-Time PIN). </strong>",
          "ensure": "Ensure to verify the correct OTP.",
          "success": "Success message will be displayed that Registration is successful, tap <strong>OK</strong> button."
        },
        "8": {
          "title": "PIN Configuration",
          "content": "Customer is <strong>required</strong> to setup a PIN for the wallet application.",
          "pin_def": "<strong>PIN</strong> acts as your application's secure passcode.",
          "pin_req": "Users are required to enter their PIN each time they log in to verify their identity and access the application."
        },
        "9": {
          "title": "Biometrics Setup for Login",
          "content": "Customer can also use biometrics data to sign in to the wallet application as an added layer of security.",
          "default": "If biometrics is setup, we use <strong>Face ID</strong> or <strong>Touch ID</strong> to sign in to the wallet application <strong>by default.</strong>"
        }
      },
      "security_tip_title": "Security Tip",
      "security_tip_body": "It is recommended to keep both security measures enabled to ensure stronger protection for your wallet application.",
      "supported_regions_heading": "Supported Regions",
      "supported_regions_intro": "mPay Consumer Wallet is currently available in the following regions:",
      "regions": {
        "curacao": "Curaçao"
      },
      "voip_warning_title": "VoIP numbers not supported",
      "voip_warning_body": "Virtual phone numbers (Google Voice, Skype, etc.) are not accepted for registration. You must use a mobile carrier number."
    },
    "verification": {
      "heading": "Identity Verification",
      "intro": "mPay needs to verify its customer's identity to prevent fraud. Please refer below to learn more about customer's profile status:",
      "tiers_heading": "Wallet Account Status",
      "tiers": {
        "incomplete": {
          "badge": "Incomplete Profile",
          "title": "Newly Enrolled User",
          "f1": "Account created",
          "f2": "Need to complete profile",
          "f3": "To Upload ID documents",
          "f4": "Limited Access"
        },
        "pending": {
          "badge": "Not Verified",
          "title": "Waiting for Verification",
          "f1": "Has Completed Profile",
          "f2": "Uploaded ID Documents",
          "f3": "Profile is<strong>Pending</strong>",
          "f4": "Limited Access",
          "f5": "Verification process up to 48 hours"
        },
        "verified": {
          "badge": "Verified",
          "title": "Profile Fully Verified",
          "f1": "Identity was verified",
          "f2": "Full access",
          "f3": "Manage Wallet Account",
          "f4": "Send/Receive Funds",
          "f5": "Advanced analytics"
        }
      },
      "how_to_heading": "How to Verify Your Identity",
      "how_to_intro": "After a successful registration, login to your mPay Wallet application to <strong>Complete the Profile </strong> by uploading pertinent identification documents.",
      "how_to_steps": {
        "1": {
          "title": "Enter address details and other required information",
          "content": "Make sure the address matched with the government-issued ID to be submitted in the verification process."
        },
        "2": {
          "title": "Upload Government-Issued ID",
          "content": "Take a clear photo of your valid government-issued identification. Supported documents include passports, national ID cards, and driver's licenses."
        },
        "3": {
          "title": "Take a photo for your profile picture",
          "content": "Take a live selfie for facial comparison. Our system matches your face against your ID photo. Ensure good lighting and remove accessories like sunglasses."
        },
        "4": {
          "title": "Wait for Review",
          "content": "mPay Network will carefully review all customer's details and may take 24 to 48 hours for verification process to complete. Whatever the result of the verification process, customer will be verified via SMS and email."
        }
      },
      "required_docs_heading": "Required Documents",
      "table": {
        "doc": "Document",
        "consumer": "Consumer",
        "merchant": "Merchant",
        "notes": "Notes",
        "required": "Required",
        "optional": "Optional",
        "row1_name": "Government ID (Passport / National ID / Driver's License)",
        "row1_notes": "Must be valid and unexpired",
        "row2_name": "Selfie Photo",
        "row2_notes": "Live capture, no uploads",
        "row3_name": "Proof of Address",
        "row3_notes": "Utility bill, bank statement (last 3 months)",
        "row4_name": "Tax Identification Number",
        "row4_notes": "SSN, TIN, or equivalent"
      },
      "data_secure_title": "Your data is secure",
      "data_secure_body": "All documents are encrypted end-to-end and processed by our certified KYC partner. We never store raw images after verification is complete. See our <a onclick=\"load_page('privacy_policy')\" style=\"color: #166534; cursor: pointer; text-decoration: underline;\">Privacy Policy</a> for details.",
      "status_heading": "Checking Verification Status",
      "status_intro": "You can check your current verification status at any time:",
      "status_list": {
        "1": "Open the mPay app and login.",
        "2": "Depending on the customer's status, user will receive message after login:"
      },
      "status_indicators": "Status indicators:",
      "verified_status": "<strong>Verified</strong> — You can access the app functionalities. During the first time login after account has been verified, you will get a message <strong>\"Congratulations! Your account has been fully verified!\"</strong>",
      "pending_status": "<strong>Pending</strong> — Under review and will display a message that <strong>\"Your account is still under review.\" </strong>",
      "rejected_status": "<strong>Rejected</strong> — customer will see a message <strong>There's a problem with your account, please contact support@mpaynetwork.com for more details.</strong>"
    },
    "profile": {
      "heading": "Profile Configuration",
      "intro": "Customize your mPay profile so that friends and merchants can easily identify you during transactions.",
      "preview": {
        "name": "Alex Johnson",
        "phone": "+1 (555) 012-3456",
        "status": "Account Verified"
      },
      "fields_heading": "Profile Fields",
      "fields": {
        "name": {
          "title": "Full Name",
          "content": "The name shown to others during transactions. Can be your real name or a nickname."
        },
        "photo": {
          "title": "Profile Photo",
          "content": "Upload a photo or take a new one. Optional but recommended for P2P transfers."
        },
        "email": {
          "title": "Email Address",
          "content": "Used for transaction receipts and account recovery. Strongly recommended."
        },
        "language": {
          "title": "Preferred Language",
          "content": "Set your display language. Currently supports English, Spanish, French, German, and Portuguese."
        },
        "qr": {
          "title": "QR Profile",
          "content": "Your profile QR to use in receiving money to your wallet account."
        },
        "notifications": {
          "title": "Notification Preferences",
          "content": "Configure push notifications, email alerts, and SMS for payment and security events."
        }
      },
      "edit_heading": "Editing Your Profile",
      "edit_intro": "To <b>edit</b> your profile information:",
      "edit_steps": {
        "1": "1. Open the mPay app",
        "2": "2. Tap the <strong>profile icon</strong> in the top-right corner (or navigate to <strong>Settings &rarr; Profile</strong>)",
        "3": "3. Tap the <strong>\"Edit\"</strong> button next to the field you want to change",
        "4": "4. Make your changes and tap <strong>\"Save\"</strong>"
      },
      "phone_change_title": "Changing your phone number is subject for mPay Network's approval and verification",
      "phone_change_body": "Call the mPay hotline or send an e-mail to support@mpaynetwork.com.",
      "security_heading": "Initial Security Setup",
      "security_intro": "During account setup, we strongly recommend configuring these security features:",
      "security_list": {
        "biometric": "<strong>Biometric Authentication:</strong> Enable fingerprint or Face ID for quick, secure access",
        "pin": "<strong>Transaction PIN:</strong> Your 6-digit PIN is required for all transactions — never share it with anyone"
      },
      "never_share_title": "Never share your PIN or OTP codes",
      "never_share_body": "mPay will never ask for your PIN or OTP via phone, email, or chat. Anyone requesting these is attempting fraud. Report suspicious activity immediately through the app."
    },
    "faq": {
      "heading": "Frequently Asked Questions",
      "q1": "Can I register with a phone number from a different country?",
      "a1": "Yes, you can register with any supported country code. However, some features may be limited based on your registration region. Transaction limits and available features may vary by country due to local regulations.",
      "q2": "How long does identity verification take?",
      "a2": "Tier 2 (Standard) verification is automated and typically completes within 5 minutes. Tier 3 (Premium) verification may require manual review and can take up to 48 business hours. You'll receive a push notification when the review is complete.",
      "q3": "What happens if my verification is rejected?",
      "a3": "If your verification is rejected, you'll receive a notification with the specific reason (e.g., blurry photo, expired document, name mismatch). You can re-submit your documents from <strong>Settings → Account → Verification</strong>. There is no limit to re-submission attempts, but repeated failures may trigger a temporary cooldown period.",
      "q4": "Can I change my display name after registration?",
      "a4": "Yes, you can change your display name at any time from <strong>Settings → Profile → Edit Profile</strong>. Note that if you've completed Tier 2 or Tier 3 verification, your legal name on file cannot be changed without re-verification. Your display name (shown to other users) is separate from your legal name.",
      "q5": "I didn't receive the OTP code. What should I do?",
      "a5": "Wait at least 60 seconds, then tap \"Resend Code\". If you still don't receive it: (1) ensure your phone has signal, (2) check that your number is correct, (3) check your spam/blocked messages folder, (4) try restarting your phone. If the issue persists, visit our <a onclick=\"load_page('consumer_troubleshooting')\" style=\"color: var(--color-primary); cursor: pointer; text-decoration: underline;\">Troubleshooting page</a>.",
      "q6": "Is my personal data safe during verification?",
      "a6": "Absolutely. All documents are transmitted using end-to-end encryption (AES-256). Our KYC verification is handled by a certified, SOC 2 Type II compliant partner. Raw document images are deleted after verification is complete. Only the verification result and a hash are stored. Read more in our <a onclick=\"load_page('privacy_policy')\" style=\"color: var(--color-primary); cursor: pointer; text-decoration: underline;\">Privacy Policy</a>."
    },
    "pagination": {
      "previous": "Previous",
      "next": "Next",
      "prev_title": "Getting Started",
      "next_title": "Making Payments"
    },
