<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Changelog & Release Notes</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="assets/css/global.css">
    <link rel="stylesheet" href="assets/css/changelog_page.css">
    <style>
        /* Basic reset for preview consistency */
        body { margin: 0; padding: 0; font-family: sans-serif; }
    </style>
</head>
<body>
    <div class="changelog-page">
  <!-- Skip to content -->
  <a href="#changelog-content" class="skip-to-content">Skip to content</a>

  <!-- Header -->
  <header class="changelog-header" role="banner">
    <div class="header-inner">
      <a class="header-logo" onclick="load_page('index')" tabindex="0" aria-label="MPay Network Home">
        <img src="https://dev.think4ever.com/uifiles/20260311/ed3d2c21991e3bef5e069713af9fa6ca/only_m_with_white_bg_logo.png" alt="MPay Network Logo" />
        <span class="header-logo-text">MPay Network</span>
      </a>
      <nav class="header-nav" role="navigation" aria-label="Main navigation">
        <button class="header-nav-link" onclick="load_page('merchant_docs_home')">Merchant Docs</button>
        <button class="header-nav-link" onclick="load_page('consumer_docs_home')">Consumer Docs</button>
        <button class="header-nav-link" onclick="load_page('blog_listing')">Blog</button>
        <button class="header-nav-link active" aria-current="page">Changelog</button>
        <button class="header-nav-link mobile-show" onclick="load_page('feedback_form')">Feedback</button>
      </nav>
    </div>
  </header>

  <!-- Main Content -->
  <main class="changelog-main" id="changelog-content" role="main">

    <!-- Hero Section -->
    <section class="changelog-hero">
      <div class="changelog-hero-icon" aria-hidden="true">
        <i class="fa fa-history"></i>
      </div>
      <h1 class="changelog-title" id="cl_title">Changelog & Release Notes</h1>
      <p class="changelog-description" id="cl_description">Track all updates and improvements to MPay Network Wallet</p>
    </section>

    <!-- Filters -->
    <section class="changelog-filters" aria-label="Filter changelog entries">
      <div class="filters-row">
        <span class="filter-label">Wallet</span>
        <div class="wallet-filter-dropdown">
          <select id="cl_filter_wallet" class="wallet-filter-select" aria-label="Filter by wallet type">
            <option value="all">All Wallets</option>
            <option value="merchant">Merchant Wallet</option>
            <option value="consumer">Consumer Wallet</option>
          </select>
        </div>
      </div>
      <div class="filters-row">
        <span class="filter-label">Tags</span>
        <div class="tag-filters" id="cl_filter_tag" role="group" aria-label="Filter by change type">
          <button class="tag-filter-btn" data-tag="new-feature" aria-pressed="false">
            <i class="fa fa-star" aria-hidden="true"></i> New Feature
          </button>
          <button class="tag-filter-btn" data-tag="bug-fix" aria-pressed="false">
            <i class="fa fa-bug" aria-hidden="true"></i> Bug Fix
          </button>
          <button class="tag-filter-btn" data-tag="improvement" aria-pressed="false">
            <i class="fa fa-arrow-up" aria-hidden="true"></i> Improvement
          </button>
          <button class="tag-filter-btn" data-tag="breaking-change" aria-pressed="false">
            <i class="fa fa-exclamation-triangle" aria-hidden="true"></i> Breaking Change
          </button>
          <button class="tag-filter-btn" data-tag="security" aria-pressed="false">
            <i class="fa fa-shield" aria-hidden="true"></i> Security
          </button>
        </div>
      </div>
      <div class="active-filters hidden" id="cl_active_filters">
        <span class="active-filter-label">Filters active</span>
        <button class="clear-filters-btn" id="cl_clear_filters" aria-label="Clear all filters">
          <i class="fa fa-times" aria-hidden="true"></i> Clear all
        </button>
      </div>
    </section>

    <!-- Results Count -->
    <div class="results-count" id="cl_results_count" aria-live="polite">
      Showing <strong>8 releases</strong>
    </div>

    <!-- Timeline -->
    <section class="changelog-timeline" aria-label="Release timeline">
      <div class="timeline-line" aria-hidden="true"></div>
      <div id="cl_entry_list" role="list">
        <!-- Entries rendered by JS -->
      </div>

      <!-- Empty State -->
      <div class="changelog-empty hidden" id="cl_empty_state">
        <div class="empty-icon" aria-hidden="true">
          <i class="fa fa-search"></i>
        </div>
        <h3 class="empty-title">No releases found</h3>
        <p class="empty-text">Try adjusting your filters to see more results.</p>
        <button class="empty-reset-btn" id="cl_empty_reset">Reset Filters</button>
      </div>
    </section>

    <!-- Back to Home -->
    <div class="changelog-actions">
      <button class="back-home-btn" id="cl_back_home" onclick="load_page('index')" aria-label="Return to landing page">
        <i class="fa fa-arrow-left" aria-hidden="true"></i> Back to Home
      </button>
    </div>
  </main>



  <!-- Scroll to Top -->
  <button class="scroll-to-top" id="scroll_to_top" aria-label="Scroll to top">
    <i class="fa fa-chevron-up" aria-hidden="true"></i>
  </button>
</div>

  <!-- Footer -->
  <div id="docFooter"></div>
    
    <script src="assets/js/i18n.js"></script>
    <script src="assets/js/navigation.js"></script>
    <script src="assets/js/changelog_page.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
</body>
</html>