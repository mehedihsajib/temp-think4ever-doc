<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Admin Dashboard</title>
        <link href="css/theme.css" rel="stylesheet" type="text/css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="assets/css/global.css">
        <link rel="stylesheet" href="assets/css/admin_dashboard.css">
        <style>/* Basic reset for preview consistency */body { margin: 0; padding: 0; font-family: sans-serif; }</style>
    </head>
    <body>
        <div class="admin-dashboard">
            <!-- Skip to content -->
            <a href="#admin-main-content" class="sr-only" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:9999;padding:8px 16px;background:#2563eb;color:#fff;text-decoration:none;font-weight:600;border-radius:0 0 8px 0;" onfocus="this.style.position='fixed';this.style.left='0';this.style.top='0';this.style.width='auto';this.style.height='auto';this.style.overflow='visible';" onblur="this.style.position='absolute';this.style.left='-9999px';this.style.width='1px';this.style.height='1px';this.style.overflow='hidden';">Skip to main content</a>
            <!-- Mobile Header -->
            <div class="admin-mobile-header" role="banner">
                <button class="admin-mobile-toggle" id="admin-sidebar-toggle" aria-label="Toggle sidebar navigation" aria-expanded="false" aria-controls="admin-sidebar">
                    <i class="fa fa-bars"></i>
                </button>
                <span class="mobile-brand">MPay Admin</span>
            </div>
            <!-- Sidebar Overlay -->
            <div class="admin-sidebar-overlay" id="admin-sidebar-overlay"></div>
            <!-- Admin Sidebar -->
            <aside class="admin-sidebar" id="admin-sidebar" role="navigation" aria-label="Admin navigation">
                <div class="admin-sidebar-header">
                    <img src="https://dev.think4ever.com/uifiles/20260311/ed3d2c21991e3bef5e069713af9fa6ca/only_m_with_white_bg_logo.png" alt="MPay Network Logo">
                    <div>
                        <div class="admin-brand-text">MPay Network</div>
                        <div class="admin-brand-sub">Admin Panel</div>
                    </div>
                </div>
                <nav class="admin-sidebar-nav">
                    <div class="nav-section-label">Overview</div>
                    <button class="admin-nav-item active" onclick="load_page('admin_dashboard')" aria-current="page">
                        <i class="fa fa-tachometer-alt"></i>
                        Dashboard
                    </button>
                    <div class="nav-section-label">Content</div>
                    <button class="admin-nav-item" id="ad_nav_comments" onclick="load_page('admin_comment_moderation')">
                        <i class="fa fa-comments"></i>
                        Comments
                        <span class="admin-nav-badge" id="sidebar-pending-badge">7</span>
                    </button>
                    <button class="admin-nav-item" id="ad_nav_feedback" onclick="load_page('admin_feedback_viewer')">
                        <i class="fa fa-envelope-open-text"></i>
                        Feedback
                    </button>
                    <button class="admin-nav-item" id="ad_nav_changelog" onclick="load_page('admin_changelog_editor')">
                        <i class="fa fa-clipboard-list"></i>
                        Changelog
                    </button>
                    <div class="nav-section-label">Site</div>
                    <button class="admin-nav-item" onclick="load_page('landing_page')">
                        <i class="fa fa-external-link-alt"></i>
                        View Site
                    </button>
                    <button class="admin-nav-item" onclick="load_page('blog_listing')">
                        <i class="fa fa-newspaper"></i>
                        Blog
                    </button>
                </nav>
                <div class="admin-sidebar-footer">
                    <button class="admin-nav-item" id="ad_logout" onclick="load_page('admin_login')">
                        <i class="fa fa-sign-out-alt"></i>
                        Logout
                    </button>
                </div>
            </aside>
            <!-- Main Content -->
            <main class="admin-main" id="admin-main-content">
                <div class="admin-content">
                    <!-- Dashboard Header -->
                    <div class="dashboard-header">
                        <div class="dashboard-header-row">
                            <div>
                                <h1 id="ad_title">Admin Dashboard</h1>
                                <p class="dashboard-header-meta" id="last-updated">Last updated: --:--</p>
                            </div>
                            <div class="dashboard-header-actions">
                                <button class="btn-admin-secondary" id="admin-refresh-btn" aria-label="Refresh dashboard data">
                                    <i class="fa fa-sync-alt"></i>
                                    Refresh
                                </button>
                                <button class="btn-admin-primary" onclick="load_page('admin_comment_moderation')">
                                    <i class="fa fa-comments"></i>
                                    Moderate Comments
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- Stats Grid -->
                    <div class="stats-grid" role="region" aria-label="Dashboard statistics">
                        <!-- Pending Comments Stat -->
                        <div class="stat-card stat-card--warning" id="ad_pending_comments_stat" role="status">
                            <div class="stat-card-header">
                                <div class="stat-card-icon" aria-hidden="true">
                                    <i class="fa fa-clock"></i>
                                </div>
                                <div class="stat-card-trend stat-card-trend--up">
                                    <i class="fa fa-arrow-up"></i> +3 today
                                </div>
                            </div>
                            <div class="stat-card-value" id="ad_pending_comments_value" aria-label="Pending comments count">0</div>
                            <div class="stat-card-label">Pending Comments</div>
                        </div>
                        <!-- Total Comments Stat -->
                        <div class="stat-card stat-card--primary" id="ad_total_comments_stat" role="status">
                            <div class="stat-card-header">
                                <div class="stat-card-icon" aria-hidden="true">
                                    <i class="fa fa-comments"></i>
                                </div>
                                <div class="stat-card-trend stat-card-trend--up">
                                    <i class="fa fa-arrow-up"></i> +12 this week
                                </div>
                            </div>
                            <div class="stat-card-value" id="ad_total_comments_value" aria-label="Total approved comments count">0</div>
                            <div class="stat-card-label">Total Comments</div>
                        </div>
                        <!-- Feedback Submissions Stat -->
                        <div class="stat-card stat-card--success" id="ad_feedback_count_stat" role="status">
                            <div class="stat-card-header">
                                <div class="stat-card-icon" aria-hidden="true">
                                    <i class="fa fa-envelope"></i>
                                </div>
                                <div class="stat-card-trend stat-card-trend--neutral">
                                    <i class="fa fa-minus"></i> Steady
                                </div>
                            </div>
                            <div class="stat-card-value" id="ad_feedback_count_value" aria-label="Total feedback submissions count">0</div>
                            <div class="stat-card-label">Feedback Submissions</div>
                        </div>
                    </div>
                    <!-- Main Dashboard Grid -->
                    <div class="dashboard-grid">
                        <!-- Left Column: Recent Pending Comments -->
                        <div class="dashboard-card">
                            <div class="dashboard-card-header">
                                <h2>
              Recent Pending Comments <span class="header-badge">7</span> </h2>
                                <button class="view-all-link" onclick="load_page('admin_comment_moderation')" aria-label="View all pending comments">
                                    View all <i class="fa fa-arrow-right"></i>
                                </button>
                            </div>
                            <ul class="pending-comments-list" id="ad_recent_comments" role="list" aria-label="Recent pending comments">
                                <!-- Populated by JavaScript -->
                            </ul>
                        </div>
                        <!-- Right Column -->
                        <div style="display:flex;flex-direction:column;gap:24px;">
                            <!-- Quick Links -->
                            <div class="dashboard-card">
                                <div class="dashboard-card-header">
                                    <h2><i class="fa fa-bolt" aria-hidden="true" style="color:#f59e0b;"></i> Quick Actions</h2>
                                </div>
                                <div class="quick-links-list">
                                    <button class="quick-link-item" onclick="load_page('admin_comment_moderation')" aria-label="Go to comment moderation">
                                        <div class="quick-link-icon quick-link-icon--blue" aria-hidden="true">
                                            <i class="fa fa-comments"></i>
                                        </div>
                                        <div class="quick-link-text">
                                            <span class="ql-label">Moderate Comments</span>
                                            <span class="ql-desc">Review & approve pending comments</span>
                                        </div>
                                        <i class="fa fa-chevron-right quick-link-arrow" aria-hidden="true"></i>
                                    </button>
                                    <button class="quick-link-item" onclick="load_page('admin_feedback_viewer')" aria-label="Go to feedback viewer">
                                        <div class="quick-link-icon quick-link-icon--green" aria-hidden="true">
                                            <i class="fa fa-envelope-open-text"></i>
                                        </div>
                                        <div class="quick-link-text">
                                            <span class="ql-label">View Feedback</span>
                                            <span class="ql-desc">Read user feedback & reports</span>
                                        </div>
                                        <i class="fa fa-chevron-right quick-link-arrow" aria-hidden="true"></i>
                                    </button>
                                    <button class="quick-link-item" onclick="load_page('admin_changelog_editor')" aria-label="Go to changelog editor">
                                        <div class="quick-link-icon quick-link-icon--purple" aria-hidden="true">
                                            <i class="fa fa-clipboard-list"></i>
                                        </div>
                                        <div class="quick-link-text">
                                            <span class="ql-label">Manage Changelog</span>
                                            <span class="ql-desc">Add release notes & updates</span>
                                        </div>
                                        <i class="fa fa-chevron-right quick-link-arrow" aria-hidden="true"></i>
                                    </button>
                                    <button class="quick-link-item" onclick="load_page('blog_listing')" aria-label="Go to blog listing">
                                        <div class="quick-link-icon quick-link-icon--amber" aria-hidden="true">
                                            <i class="fa fa-newspaper"></i>
                                        </div>
                                        <div class="quick-link-text">
                                            <span class="ql-label">Blog Posts</span>
                                            <span class="ql-desc">View published blog posts</span>
                                        </div>
                                        <i class="fa fa-chevron-right quick-link-arrow" aria-hidden="true"></i>
                                    </button>
                                </div>
                            </div>
                            <!-- Recent Feedback -->
                            <div class="dashboard-card">
                                <div class="dashboard-card-header">
                                    <h2><i class="fa fa-inbox" aria-hidden="true" style="color:#2563eb;"></i> Recent Feedback</h2>
                                    <button class="view-all-link" onclick="load_page('admin_feedback_viewer')" aria-label="View all feedback">
                                        View all <i class="fa fa-arrow-right"></i>
                                    </button>
                                </div>
                                <ul class="activity-list" id="ad_recent_feedback" role="list" aria-label="Recent feedback submissions">
                                    <!-- Populated by JavaScript -->
                                </ul>
                            </div>
                            <!-- System Status -->
                            <div class="dashboard-card">
                                <div class="dashboard-card-header">
                                    <h2><i class="fa fa-server" aria-hidden="true" style="color:#16a34a;"></i> System Status</h2>
                                </div>
                                <div class="system-status">
                                    <div class="status-row">
                                        <span class="status-label">Documentation Site</span>
                                        <span class="status-indicator status-indicator--ok"> <span class="status-dot status-dot--green" aria-hidden="true"></span>
                  Operational </span>
                                    </div>
                                    <div class="status-row">
                                        <span class="status-label">Blog System</span>
                                        <span class="status-indicator status-indicator--ok"> <span class="status-dot status-dot--green" aria-hidden="true"></span>
                  Operational </span>
                                    </div>
                                    <div class="status-row">
                                        <span class="status-label">Feedback System</span>
                                        <span class="status-indicator status-indicator--ok"> <span class="status-dot status-dot--green" aria-hidden="true"></span>
                  Operational </span>
                                    </div>
                                    <div class="status-row">
                                        <span class="status-label">Search Index</span>
                                        <span class="status-indicator status-indicator--warning"> <span class="status-dot status-dot--amber" aria-hidden="true"></span>
                  Rebuilding </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
        <script src="assets/js/navigation.js"></script>
        <script src="assets/js/admin_dashboard.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    </body>
</html>