/* Consumer Making Payments Page CSS */

.cmp-page {
  display: flex;
  min-height: 100vh;
  background: var(--color-background, #ffffff);
}

/* Sidebar */
.cmp-sidebar {
  width: 280px;
  min-height: 100vh;
  background: var(--color-surface, #eff6ff);
  border-right: 1px solid var(--color-border, #bfdbfe);
  position: fixed;
  top: 64px;
  left: 0;
  bottom: 0;
  overflow-y: auto;
  z-index: 40;
  padding: 24px 0;
  transition: transform 0.3s ease;
}

.cmp-sidebar-header {
  padding: 0 20px 16px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  margin-bottom: 16px;
}

.cmp-sidebar-header h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  margin: 0;
  display: flex;
  align-items: center;
  gap: 8px;
}

.cmp-sidebar-header h3 i {
  color: var(--color-primary, #2563eb);
}

.cmp-sidebar-section {
  margin-bottom: 8px;
}

.cmp-sidebar-section-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  padding: 8px 20px 4px;
}

.cmp-sidebar-nav {
  list-style: none;
  margin: 0;
  padding: 0;
}

.cmp-sidebar-nav li a {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 20px;
  margin: 2px 8px;
  border-radius: 8px;
  font-size: 0.875rem;
  color: #334155;
  text-decoration: none;
  transition: all 0.15s ease;
  cursor: pointer;
}

.cmp-sidebar-nav li a:hover {
  background: rgba(37, 99, 235, 0.06);
  color: var(--color-primary, #2563eb);
}

.cmp-sidebar-nav li a.active {
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-primary, #2563eb);
  font-weight: 600;
}

.cmp-sidebar-nav li a i {
  width: 16px;
  font-size: 0.8rem;
  opacity: 0.7;
}

.cmp-sidebar-nav li a.active i {
  opacity: 1;
}

/* Mobile sidebar toggle */
.cmp-sidebar-toggle {
  display: none;
  position: fixed;
  bottom: 24px;
  left: 24px;
  z-index: 50;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--color-primary, #2563eb);
  color: #fff;
  border: none;
  cursor: pointer;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  font-size: 1.2rem;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.cmp-sidebar-toggle:hover {
  background: var(--color-primary-dark, #1d4ed8);
  transform: translateY(-2px);
}

.cmp-sidebar-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 39;
}

/* Main Content Area */
.cmp-main {
  margin-left: 280px;
  flex: 1;
  min-width: 0;
  padding-top: 64px;
}

.cmp-content-wrapper {
  display: flex;
  max-width: 1200px;
  margin: 0 auto;
}

.cmp-content {
  flex: 1;
  min-width: 0;
  max-width: 860px;
  padding: 32px 48px 64px;
}

/* Table of Contents (right side) */
.cmp-toc {
  width: 220px;
  flex-shrink: 0;
  padding: 32px 16px 32px 0;
  position: sticky;
  top: 96px;
  max-height: calc(100vh - 96px);
  overflow-y: auto;
  align-self: flex-start;
}

.cmp-toc-title {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin-bottom: 12px;
}

.cmp-toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
  border-left: 2px solid var(--color-border, #bfdbfe);
}

.cmp-toc-list li a {
  display: block;
  padding: 4px 0 4px 12px;
  font-size: 0.8125rem;
  color: #64748b;
  text-decoration: none;
  border-left: 2px solid transparent;
  margin-left: -2px;
  transition: all 0.15s ease;
  line-height: 1.5;
}

.cmp-toc-list li a:hover {
  color: var(--color-primary, #2563eb);
}

.cmp-toc-list li a.active {
  color: var(--color-primary, #2563eb);
  border-left-color: var(--color-primary, #2563eb);
  font-weight: 500;
}

/* Breadcrumb */
.cmp-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: #64748b;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.cmp-breadcrumb a {
  color: #64748b;
  text-decoration: none;
  transition: color 0.15s ease;
}

.cmp-breadcrumb a:hover {
  color: var(--color-primary, #2563eb);
}

.cmp-breadcrumb .separator {
  font-size: 0.75rem;
  opacity: 0.5;
}

.cmp-breadcrumb .current {
  color: var(--color-primary, #2563eb);
  font-weight: 500;
}

/* Page Title */
.cmp-page-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.025em;
  line-height: 1.25;
  margin: 0 0 8px;
  padding-bottom: 16px;
  border-bottom: 2px solid var(--color-border, #bfdbfe);
}

.cmp-page-subtitle {
  font-size: 1.125rem;
  color: #64748b;
  line-height: 1.6;
  margin: 16px 0 32px;
}

/* Content Sections */
.cmp-section {
  margin-top: 48px;
}

.cmp-section:first-of-type {
  margin-top: 32px;
}

.cmp-section-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.875rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.02em;
  margin: 0 0 8px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  scroll-margin-top: 96px;
}

.cmp-section h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 24px 0 12px;
}

.cmp-section p {
  font-size: 1rem;
  color: #334155;
  line-height: 1.625;
  margin: 0 0 16px;
}

/* Steps Component */
.cmp-steps {
  list-style: none;
  padding: 0;
  margin: 20px 0 24px;
  position: relative;
}

.cmp-steps::before {
  content: '';
  position: absolute;
  left: 15px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--color-border, #bfdbfe);
}

.cmp-step {
  position: relative;
  padding-left: 44px;
  padding-bottom: 24px;
}

.cmp-step:last-child {
  padding-bottom: 0;
}

.cmp-step-number {
  position: absolute;
  left: 0;
  top: 0;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--color-primary, #2563eb);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8125rem;
  font-weight: 700;
  z-index: 1;
}

.cmp-step-content h5 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 4px 0 6px;
}

.cmp-step-content p {
  font-size: 0.9375rem;
  color: #334155;
  line-height: 1.6;
  margin: 0;
}

/* Callout Boxes */
.cmp-callout {
  border-radius: 8px;
  padding: 16px 20px;
  margin: 20px 0;
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.cmp-callout-icon {
  font-size: 1.1rem;
  margin-top: 2px;
  flex-shrink: 0;
}

.cmp-callout-body {
  flex: 1;
  min-width: 0;
}

.cmp-callout-body strong {
  display: block;
  margin-bottom: 4px;
}

.cmp-callout-body p {
  margin: 0;
  font-size: 0.9375rem;
  line-height: 1.5;
}

.cmp-callout.info {
  background: #eff6ff;
  border-left: 4px solid var(--color-primary, #2563eb);
}

.cmp-callout.info .cmp-callout-icon {
  color: var(--color-primary, #2563eb);
}

.cmp-callout.success {
  background: #f0fdf4;
  border-left: 4px solid var(--color-success, #22c55e);
}

.cmp-callout.success .cmp-callout-icon {
  color: var(--color-success, #22c55e);
}

.cmp-callout.warning {
  background: #fffbeb;
  border-left: 4px solid var(--color-warning, #f59e0b);
}

.cmp-callout.warning .cmp-callout-icon {
  color: var(--color-warning, #f59e0b);
}

.cmp-callout.danger {
  background: #fef2f2;
  border-left: 4px solid var(--color-error, #ef4444);
}

.cmp-callout.danger .cmp-callout-icon {
  color: var(--color-error, #ef4444);
}

/* QR Code Scanner Visual */
.cmp-qr-visual {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48px;
  margin: 32px 0;
  flex-wrap: wrap;
}

.cmp-phone-mockup {
  width: 200px;
  height: 360px;
  background: #0f172a;
  border-radius: 24px;
  padding: 12px;
  box-shadow: 0 20px 40px rgba(15, 23, 42, 0.2);
  position: relative;
}

.cmp-phone-screen {
  width: 100%;
  height: 100%;
  background: #1e293b;
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cmp-phone-notch {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80px;
  height: 20px;
  background: #0f172a;
  border-radius: 0 0 12px 12px;
}

/* QR Scanner Viewport */
.cmp-qr-scanner {
  width: 120px;
  height: 120px;
  position: relative;
  margin-top: 20px;
}

.cmp-qr-corner {
  position: absolute;
  width: 20px;
  height: 20px;
  border-color: var(--color-accent, #60a5fa);
  border-style: solid;
  border-width: 0;
}

.cmp-qr-corner.top-left {
  top: 0; left: 0;
  border-top-width: 3px;
  border-left-width: 3px;
  border-top-left-radius: 4px;
}

.cmp-qr-corner.top-right {
  top: 0; right: 0;
  border-top-width: 3px;
  border-right-width: 3px;
  border-top-right-radius: 4px;
}

.cmp-qr-corner.bottom-left {
  bottom: 0; left: 0;
  border-bottom-width: 3px;
  border-left-width: 3px;
  border-bottom-left-radius: 4px;
}

.cmp-qr-corner.bottom-right {
  bottom: 0; right: 0;
  border-bottom-width: 3px;
  border-right-width: 3px;
  border-bottom-right-radius: 4px;
}

.cmp-qr-scan-line {
  position: absolute;
  left: 4px;
  right: 4px;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--color-accent, #60a5fa), transparent);
  animation: cmp-scan 2s ease-in-out infinite;
  box-shadow: 0 0 8px rgba(96, 165, 250, 0.5);
}

@keyframes cmp-scan {
  0%, 100% { top: 4px; }
  50% { top: calc(100% - 6px); }
}

.cmp-qr-label {
  color: #94a3b8;
  font-size: 0.6875rem;
  margin-top: 16px;
  text-align: center;
}

/* QR Code Display */
.cmp-qr-code-display {
  width: 120px;
  height: 120px;
  background: #fff;
  border-radius: 8px;
  padding: 8px;
  display: grid;
  grid-template-columns: repeat(11, 1fr);
  grid-template-rows: repeat(11, 1fr);
  gap: 1px;
  margin-top: 20px;
}

.cmp-qr-cell {
  border-radius: 1px;
}

.cmp-qr-cell.dark {
  background: #1e293b;
}

.cmp-qr-cell.light {
  background: #fff;
}

/* NFC Wave Animation */
.cmp-nfc-visual {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 32px 0;
  gap: 60px;
  flex-wrap: wrap;
}

.cmp-nfc-device {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cmp-nfc-icon-container {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--color-surface, #eff6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cmp-nfc-icon-container i {
  font-size: 2rem;
  color: var(--color-primary, #2563eb);
  z-index: 2;
}

.cmp-nfc-wave {
  position: absolute;
  border-radius: 50%;
  border: 2px solid var(--color-accent, #60a5fa);
  animation: cmp-nfc-wave 2s ease-out infinite;
}

.cmp-nfc-wave:nth-child(2) {
  width: 100px;
  height: 100px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation-delay: 0s;
}

.cmp-nfc-wave:nth-child(3) {
  width: 130px;
  height: 130px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation-delay: 0.4s;
}

.cmp-nfc-wave:nth-child(4) {
  width: 160px;
  height: 160px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation-delay: 0.8s;
}

@keyframes cmp-nfc-wave {
  0% {
    opacity: 0.6;
    transform: translate(-50%, -50%) scale(0.8);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.2);
  }
}

.cmp-nfc-label {
  margin-top: 20px;
  font-size: 0.875rem;
  color: #64748b;
  font-weight: 500;
  text-align: center;
}

.cmp-nfc-arrow {
  font-size: 1.5rem;
  color: var(--color-accent, #60a5fa);
  animation: cmp-pulse-arrow 1.5s ease-in-out infinite;
}

@keyframes cmp-pulse-arrow {
  0%, 100% { opacity: 0.4; transform: translateX(0); }
  50% { opacity: 1; transform: translateX(4px); }
}

/* Payment Flow Screenshots */
.cmp-screenshots-section {
  margin: 48px 0;
}

.cmp-screenshots-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 20px;
}

.cmp-screenshot-card {
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.25s ease;
}

.cmp-screenshot-card:hover {
  border-color: rgba(37, 99, 235, 0.3);
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.1);
  transform: translateY(-2px);
}

.cmp-screenshot-image {
  width: 100%;
  height: 200px;
  background: linear-gradient(135deg, #dbeafe, #eff6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cmp-screenshot-image i {
  font-size: 3rem;
  color: var(--color-primary, #2563eb);
  opacity: 0.3;
}

.cmp-screenshot-step-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--color-primary, #2563eb);
  color: #fff;
  font-size: 0.6875rem;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 12px;
}

.cmp-screenshot-caption {
  padding: 14px 16px;
  font-size: 0.875rem;
  color: #334155;
  font-weight: 500;
  text-align: center;
}

/* Payment Confirmation UI Mock */
.cmp-receipt-mock {
  max-width: 360px;
  margin: 24px auto;
  background: #fff;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 16px;
  padding: 32px 24px;
  text-align: center;
  box-shadow: 0 4px 16px rgba(0,0,0,0.06);
}

.cmp-receipt-icon {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: #f0fdf4;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16px;
}

.cmp-receipt-icon i {
  font-size: 1.75rem;
  color: var(--color-success, #22c55e);
}

.cmp-receipt-amount {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2rem;
  font-weight: 800;
  color: var(--color-text, #1e3a8a);
  margin: 8px 0 4px;
}

.cmp-receipt-label {
  color: #64748b;
  font-size: 0.875rem;
}

.cmp-receipt-details {
  margin-top: 20px;
  border-top: 1px dashed var(--color-border, #bfdbfe);
  padding-top: 16px;
}

.cmp-receipt-row {
  display: flex;
  justify-content: space-between;
  padding: 6px 0;
  font-size: 0.875rem;
}

.cmp-receipt-row .label {
  color: #64748b;
}

.cmp-receipt-row .value {
  color: #334155;
  font-weight: 500;
}

/* Payment History Table */
.cmp-history-table-wrapper {
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  overflow: hidden;
  margin: 20px 0;
}

.cmp-history-table {
  width: 100%;
  border-collapse: collapse;
}

.cmp-history-table thead {
  background: var(--color-surface, #eff6ff);
}

.cmp-history-table th {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  padding: 12px 16px;
  text-align: left;
}

.cmp-history-table td {
  padding: 12px 16px;
  font-size: 0.875rem;
  color: #334155;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

.cmp-history-table tbody tr:hover {
  background: rgba(239, 246, 255, 0.5);
}

.cmp-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 10px;
  border-radius: 12px;
  font-size: 0.75rem;
  font-weight: 600;
}

.cmp-status-badge.completed {
  background: #f0fdf4;
  color: #16a34a;
}

.cmp-status-badge.pending {
  background: #fffbeb;
  color: #d97706;
}

.cmp-status-badge.failed {
  background: #fef2f2;
  color: #dc2626;
}

.cmp-method-icon {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.cmp-method-icon i {
  color: var(--color-primary, #2563eb);
}

/* FAQ Accordion */
.cmp-faq-section {
  margin-top: 48px;
}

.cmp-faq-item {
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 10px;
  margin-bottom: 10px;
  overflow: hidden;
  transition: border-color 0.2s ease;
}

.cmp-faq-item:hover {
  border-color: rgba(37, 99, 235, 0.3);
}

.cmp-faq-item.open {
  border-color: var(--color-primary, #2563eb);
}

.cmp-faq-question {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  text-align: left;
  gap: 12px;
  transition: background 0.15s ease;
}

.cmp-faq-question:hover {
  background: rgba(239, 246, 255, 0.5);
}

.cmp-faq-question i {
  transition: transform 0.25s ease;
  color: #64748b;
  font-size: 0.875rem;
  flex-shrink: 0;
}

.cmp-faq-item.open .cmp-faq-question i {
  transform: rotate(180deg);
  color: var(--color-primary, #2563eb);
}

.cmp-faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
}

.cmp-faq-item.open .cmp-faq-answer {
  max-height: 500px;
}

.cmp-faq-answer-inner {
  padding: 0 20px 16px;
  font-size: 0.9375rem;
  color: #334155;
  line-height: 1.6;
}

/* Prev/Next Navigation */
.cmp-prev-next {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 64px;
  padding-top: 32px;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

.cmp-prev-next-link {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 16px 20px;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  text-decoration: none;
  transition: all 0.2s ease;
  cursor: pointer;
}

.cmp-prev-next-link:hover {
  border-color: var(--color-primary, #2563eb);
  background: var(--color-surface, #eff6ff);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.08);
}

.cmp-prev-next-link.next {
  text-align: right;
  align-items: flex-end;
}

.cmp-prev-next-label {
  font-size: 0.75rem;
  color: #64748b;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 4px;
}

.cmp-prev-next-title {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-primary, #2563eb);
}

/* Inline Code */
.cmp-content code:not(pre code) {
  background: #eff6ff;
  color: var(--color-primary-dark, #1d4ed8);
  padding: 2px 6px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85em;
}

/* Payment method cards */
.cmp-method-cards {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin: 24px 0;
}

.cmp-method-card {
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 24px;
  text-align: center;
  transition: all 0.25s ease;
}

.cmp-method-card:hover {
  border-color: rgba(37, 99, 235, 0.3);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.08);
}

.cmp-method-card-icon {
  width: 56px;
  height: 56px;
  border-radius: 12px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.cmp-method-card-icon i {
  font-size: 1.5rem;
  color: var(--color-primary, #2563eb);
}

.cmp-method-card h5 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 6px;
}

.cmp-method-card p {
  font-size: 0.8125rem;
  color: #64748b;
  line-height: 1.5;
  margin: 0;
}

/* Scrollbar for sidebar */
.cmp-sidebar::-webkit-scrollbar {
  width: 4px;
}

.cmp-sidebar::-webkit-scrollbar-track {
  background: transparent;
}

.cmp-sidebar::-webkit-scrollbar-thumb {
  background: var(--color-border, #bfdbfe);
  border-radius: 4px;
}

/* Responsive */
@media (max-width: 1200px) {
  .cmp-toc {
    display: none;
  }
}

@media (max-width: 1024px) {
  .cmp-sidebar {
    width: 240px;
  }
  .cmp-main {
    margin-left: 240px;
  }
  .cmp-content {
    padding: 24px 32px 64px;
  }
  .cmp-screenshots-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .cmp-sidebar {
    transform: translateX(-100%);
    width: 280px;
    top: 0;
    z-index: 50;
  }
  .cmp-sidebar.open {
    transform: translateX(0);
  }
  .cmp-sidebar-overlay.active {
    display: block;
  }
  .cmp-sidebar-toggle {
    display: flex;
  }
  .cmp-main {
    margin-left: 0;
  }
  .cmp-content {
    padding: 20px 16px 48px;
  }
  .cmp-page-title {
    font-size: 1.75rem;
  }
  .cmp-section-title {
    font-size: 1.5rem;
  }
  .cmp-qr-visual,
  .cmp-nfc-visual {
    gap: 24px;
    flex-direction: column;
  }
  .cmp-screenshots-grid {
    grid-template-columns: 1fr;
  }
  .cmp-method-cards {
    grid-template-columns: 1fr;
  }
  .cmp-prev-next {
    grid-template-columns: 1fr;
  }
  .cmp-history-table-wrapper {
    overflow-x: auto;
  }
  .cmp-history-table {
    min-width: 500px;
  }
  .cmp-nfc-arrow {
    transform: rotate(90deg);
  }
}

@media (prefers-reduced-motion: reduce) {
  .cmp-qr-scan-line,
  .cmp-nfc-wave,
  .cmp-nfc-arrow {
    animation: none;
  }
  .cmp-qr-scan-line {
    top: 50%;
  }
  .cmp-nfc-wave:nth-child(2) { opacity: 0.4; }
  .cmp-nfc-wave:nth-child(3) { opacity: 0.25; }
  .cmp-nfc-wave:nth-child(4) { opacity: 0.1; }
}

/* Focus visible */
.cmp-faq-question:focus-visible,
.cmp-prev-next-link:focus-visible,
.cmp-sidebar-nav li a:focus-visible {
  outline: 2px solid var(--color-primary, #2563eb);
  outline-offset: 2px;
}

/* Skip to content */
.cmp-skip-link {
  position: absolute;
  top: -100px;
  left: 16px;
  background: var(--color-primary, #2563eb);
  color: #fff;
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  z-index: 100;
  text-decoration: none;
  transition: top 0.2s;
}

.cmp-skip-link:focus {
  top: 16px;
}