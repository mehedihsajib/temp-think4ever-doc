/* Consumer Account Setup Page CSS */

.consumer-account-setup {
  display: flex;
  min-height: 100vh;
  background: var(--color-background, #ffffff);
}

/* Sidebar Styles */
.cas-sidebar {
  width: 280px;
  min-height: 100vh;
  background: var(--color-surface, #eff6ff);
  border-right: 1px solid var(--color-border, #bfdbfe);
  position: fixed;
  top: 64px;
  left: 0;
  bottom: 0;
  overflow-y: auto;
  z-index: 40;
  padding: 24px 0;
  transition: transform 0.3s ease;
}

.cas-sidebar-header {
  padding: 0 20px 16px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  margin-bottom: 16px;
}

.cas-sidebar-header h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  margin: 0;
  display: flex;
  align-items: center;
  gap: 8px;
}

.cas-sidebar-header h3 i {
  color: var(--color-primary, #2563eb);
}

.sidebar-section {
  margin-bottom: 8px;
}

.sidebar-section-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  padding: 8px 20px 4px;
  display: block;
}

.sidebar-nav-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.sidebar-nav-list li {
  margin: 2px 8px;
}

.sidebar-nav-list a {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  font-size: 0.875rem;
  color: #334155;
  text-decoration: none;
  border-radius: 8px;
  transition: all 0.15s ease;
  cursor: pointer;
  line-height: 1.5;
}

.sidebar-nav-list a:hover {
  background: rgba(37, 99, 235, 0.06);
  color: var(--color-primary, #2563eb);
}

.sidebar-nav-list a.active {
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-primary, #2563eb);
  font-weight: 600;
}

.sidebar-nav-list a i {
  width: 18px;
  font-size: 0.8rem;
  text-align: center;
  flex-shrink: 0;
}

/* Mobile sidebar overlay */
.sidebar-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 39;
}

.sidebar-overlay.active {
  display: block;
}

.mobile-menu-toggle {
  display: none;
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--color-primary, #2563eb);
  color: white;
  border: none;
  font-size: 1.2rem;
  cursor: pointer;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s ease;
}

.mobile-menu-toggle:hover {
  background: var(--color-primary-dark, #1d4ed8);
}

/* Main Content Area */
.cas-main {
  flex: 1;
  /* margin-left: 280px; */
  min-width: 0;
  /* display: flex; */
  justify-content: center;
}

.cas-content-wrapper {
  max-width: 860px;
  width: 100%;
  padding: 32px 40px 80px;
}

/* TOC - Table of Contents */
.cas-toc {
  width: 220px;
  position: fixed;
  top: 96px;
  right: 24px;
  max-height: calc(100vh - 120px);
  overflow-y: auto;
  display: none;
}

@media (min-width: 1400px) {
  .cas-toc {
    display: block;
  }
}

.cas-toc-title {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin-bottom: 12px;
}

.cas-toc-list {
  list-style: none;
  margin: 0;
  padding: 0;
  border-left: 2px solid var(--color-border, #bfdbfe);
}

.cas-toc-list li {
  margin: 0;
}

.cas-toc-list a {
  display: block;
  padding: 4px 12px;
  font-size: 0.8125rem;
  color: #64748b;
  text-decoration: none;
  border-left: 2px solid transparent;
  margin-left: -2px;
  transition: all 0.15s ease;
  line-height: 1.5;
}

.cas-toc-list a:hover,
.cas-toc-list a.active {
  color: var(--color-primary, #2563eb);
  border-left-color: var(--color-primary, #2563eb);
}

/* Breadcrumb */
.cas-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: #64748b;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.cas-breadcrumb a {
  color: #64748b;
  text-decoration: none;
  transition: color 0.15s ease;
  cursor: pointer;
}

.cas-breadcrumb a:hover {
  color: var(--color-primary, #2563eb);
}

.cas-breadcrumb .separator {
  color: #94a3b8;
  font-size: 0.75rem;
}

.cas-breadcrumb .current {
  color: var(--color-primary, #2563eb);
  font-weight: 500;
}

/* Page Title */
.cas-page-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.025em;
  line-height: 1.25;
  margin: 0 0 8px;
  padding-bottom: 16px;
  border-bottom: 2px solid var(--color-border, #bfdbfe);
}

.cas-page-subtitle {
  font-size: 1.125rem;
  color: #64748b;
  line-height: 1.6;
  margin: 16px 0 40px;
}

/* Content Sections */
.doc-section {
  margin-bottom: 48px;
}

.doc-section h2 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.875rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.02em;
  line-height: 1.25;
  margin: 0 0 8px;
  padding-top: 48px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
}

.doc-section h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.015em;
  line-height: 1.25;
  margin: 32px 0 12px;
}

.doc-section h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 24px 0 8px;
}

.doc-section p {
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  line-height: 1.625;
  color: #334155;
  margin: 0 0 16px;
}

.doc-section ul, .doc-section ol {
  margin: 0 0 16px;
  padding-left: 24px;
}

.doc-section li {
  font-size: 1rem;
  line-height: 1.625;
  color: #334155;
  margin-bottom: 6px;
}

/* Steps Component */
.steps-container {
  position: relative;
  padding-left: 32px;
  margin: 24px 0;
}

.steps-container::before {
  content: '';
  position: absolute;
  left: 15px;
  top: 4px;
  bottom: 4px;
  width: 2px;
  background: var(--color-border, #bfdbfe);
  border-radius: 1px;
}

.step-item {
  position: relative;
  padding: 0 0 28px 20px;
}

.step-item:last-child {
  padding-bottom: 0;
}

.step-number {
  position: absolute;
  left: -25px;
  top: 2px;
  width: 24px;
  height: 24px;
  background: var(--color-primary, #2563eb);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  z-index: 1;
}

.step-item h4 {
  margin: 0 0 8px;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
}

.step-item p {
  margin: 0 0 8px;
  font-size: 0.9375rem;
  line-height: 1.625;
  color: #334155;
}

/* Callout Boxes */
.callout {
  border-radius: 8px;
  padding: 16px 20px;
  margin: 20px 0;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  font-size: 0.9375rem;
  line-height: 1.6;
}

.callout i {
  margin-top: 2px;
  flex-shrink: 0;
  font-size: 1rem;
}

.callout-info {
  background: #eff6ff;
  border-left: 4px solid var(--color-primary, #2563eb);
  color: #1e40af;
}

.callout-info i {
  color: var(--color-primary, #2563eb);
}

.callout-warning {
  background: #fffbeb;
  border-left: 4px solid #f59e0b;
  color: #92400e;
}

.callout-warning i {
  color: #f59e0b;
}

.callout-success {
  background: #f0fdf4;
  border-left: 4px solid #22c55e;
  color: #166534;
}

.callout-success i {
  color: #22c55e;
}

.callout-danger {
  background: #fef2f2;
  border-left: 4px solid #ef4444;
  color: #991b1b;
}

.callout-danger i {
  color: #ef4444;
}

.callout-content strong {
  display: block;
  margin-bottom: 4px;
}

/* Code Blocks */
.code-block {
  border-radius: 12px;
  overflow: hidden;
  margin: 20px 0;
  border: 1px solid #334155;
  background: #1e293b;
}

.code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 16px;
  background: #0f172a;
  font-size: 0.8125rem;
  color: #94a3b8;
}

.code-copy-btn {
  background: none;
  border: 1px solid #475569;
  color: #94a3b8;
  padding: 4px 10px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.75rem;
  transition: all 0.15s ease;
}

.code-copy-btn:hover {
  background: #334155;
  color: #e2e8f0;
}

.code-block pre {
  margin: 0;
  padding: 16px;
  overflow-x: auto;
}

.code-block code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.875rem;
  line-height: 1.6;
  color: #e2e8f0;
}

/* Inline code */
.doc-section code:not(.code-block code) {
  background: #eff6ff;
  color: #1e3a8a;
  padding: 2px 6px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.875em;
}

/* Verification Tiers Table */
.tier-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin: 24px 0;
}

.tier-card {
  background: white;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 24px;
  transition: all 0.25s ease;
}

.tier-card:hover {
  border-color: var(--color-primary, #2563eb);
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.1);
  transform: translateY(-2px);
}

.tier-card.recommended {
  border-color: var(--color-primary, #2563eb);
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.12);
  position: relative;
}

.tier-badge {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 12px;
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 12px;
}

.tier-badge.basic {
  background: #eff6ff;
  color: var(--color-primary, #2563eb);
}

.tier-badge.standard {
  background: #f0fdf4;
  color: #16a34a;
}

.tier-badge.premium {
  background: #fef3c7;
  color: #d97706;
}

.tier-card h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 4px;
}

.tier-limit {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--color-primary, #2563eb);
  margin: 8px 0;
}

.tier-limit span {
  font-size: 0.875rem;
  font-weight: 400;
  color: #64748b;
}

.tier-features {
  list-style: none;
  padding: 0;
  margin: 12px 0 0;
}

.tier-features li {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: #334155;
  padding: 4px 0;
}

.tier-features li i {
  color: #22c55e;
  font-size: 0.75rem;
}

/* Document Requirements Table */
.doc-table-wrapper {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--color-border, #bfdbfe);
  margin: 20px 0;
}

.doc-table {
  width: 100%;
  border-collapse: collapse;
}

.doc-table thead {
  background: var(--color-surface, #eff6ff);
}

.doc-table th {
  padding: 12px 16px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  text-align: left;
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

.doc-table td {
  padding: 12px 16px;
  font-size: 0.9375rem;
  color: #334155;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

.doc-table tbody tr:hover {
  background: rgba(239, 246, 255, 0.5);
}

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 8px;
  border-radius: 6px;
  font-size: 0.75rem;
  font-weight: 600;
}

.status-badge.required {
  background: #fef2f2;
  color: #dc2626;
}

.status-badge.optional {
  background: #f0fdf4;
  color: #16a34a;
}

/* Profile Setup Visual */
.profile-preview {
  display: flex;
  align-items: center;
  gap: 20px;
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 24px;
  margin: 20px 0;
}

.profile-avatar-placeholder {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: var(--color-primary, #2563eb);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.75rem;
  flex-shrink: 0;
}

.profile-details {
  flex: 1;
}

.profile-details .profile-name {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 4px;
}

.profile-details .profile-phone {
  font-size: 0.875rem;
  color: #64748b;
  margin: 0 0 8px;
}

.profile-details .profile-status {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: #16a34a;
}

.profile-details .profile-status i {
  font-size: 0.75rem;
}

/* FAQ Accordion */
.faq-section {
  margin-top: 48px;
}

.faq-section h2 {
  padding-top: 48px;
}

.faq-item {
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 8px;
  margin-bottom: 8px;
  overflow: hidden;
  transition: border-color 0.15s ease;
}

.faq-item:hover {
  border-color: #93bbfd;
}

.faq-item.active {
  border-color: var(--color-primary, #2563eb);
}

.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 16px 20px;
  background: none;
  border: none;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  text-align: left;
  gap: 12px;
  line-height: 1.5;
  transition: background 0.15s ease;
}

.faq-question:hover {
  background: rgba(239, 246, 255, 0.5);
}

.faq-question i {
  flex-shrink: 0;
  font-size: 0.75rem;
  color: #64748b;
  transition: transform 0.25s ease;
}

.faq-item.active .faq-question i {
  transform: rotate(180deg);
  color: var(--color-primary, #2563eb);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
}

.faq-answer-inner {
  padding: 0 20px 16px;
  font-size: 0.9375rem;
  line-height: 1.625;
  color: #334155;
}

.faq-item.active .faq-answer {
  max-height: 400px;
}

/* Prev / Next Navigation */
.prev-next-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 64px;
  padding-top: 32px;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

.prev-next-card {
  display: flex;
  flex-direction: column;
  padding: 20px;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.25s ease;
  background: white;
}

.prev-next-card:hover {
  border-color: var(--color-primary, #2563eb);
  background: var(--color-surface, #eff6ff);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.08);
  transform: translateY(-2px);
}

.prev-next-card.next {
  text-align: right;
  align-items: flex-end;
}

.prev-next-label {
  font-size: 0.8125rem;
  color: #64748b;
  font-weight: 500;
  margin-bottom: 4px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.prev-next-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-primary, #2563eb);
}

/* Screenshot placeholder */
.screenshot-placeholder {
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 40px;
  margin: 20px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: #64748b;
  font-size: 0.875rem;
}

.screenshot-placeholder i {
  font-size: 2.5rem;
  color: var(--color-primary, #2563eb);
  opacity: 0.4;
}

/* Config option list */
.config-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin: 20px 0;
}

.config-item {
  display: flex;
  gap: 12px;
  padding: 16px;
  background: white;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 10px;
  transition: all 0.2s ease;
}

.config-item:hover {
  border-color: #93bbfd;
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.06);
}

.config-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  background: var(--color-surface, #eff6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--color-primary, #2563eb);
  font-size: 1rem;
}

.config-text h5 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 4px;
}

.config-text p {
  font-size: 0.8125rem;
  line-height: 1.5;
  color: #64748b;
  margin: 0;
}

/* Responsive */
@media (max-width: 1024px) {
  .cas-sidebar {
    width: 240px;
  }
  .cas-main {
    /* margin-left: 240px; */
  }
  .cas-content-wrapper {
    padding: 24px 28px 80px;
  }
  .tier-cards {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .cas-sidebar {
    transform: translateX(-100%);
    z-index: 50;
    width: 280px;
    top: 0;
    background: white;
  }
  .cas-sidebar.open {
    transform: translateX(0);
    box-shadow: 4px 0 24px rgba(0,0,0,0.15);
  }
  .mobile-menu-toggle {
    display: flex;
  }
  .cas-main {
    margin-left: 0;
  }
  .cas-content-wrapper {
    padding: 20px 16px 80px;
  }
  .cas-page-title {
    font-size: 1.75rem;
  }
  .doc-section h2 {
    font-size: 1.5rem;
    padding-top: 32px;
  }
  .doc-section h3 {
    font-size: 1.25rem;
  }
  .prev-next-nav {
    grid-template-columns: 1fr;
  }
  .prev-next-card.next {
    text-align: left;
    align-items: flex-start;
  }
  .tier-cards {
    grid-template-columns: 1fr;
  }
  .config-grid {
    grid-template-columns: 1fr;
  }
  .profile-preview {
    flex-direction: column;
    text-align: center;
  }
}

@media (max-width: 480px) {
  .cas-page-title {
    font-size: 1.5rem;
  }
  .cas-content-wrapper {
    padding: 16px 12px 80px;
  }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  * {
    transition: none !important;
    animation: none !important;
  }
}