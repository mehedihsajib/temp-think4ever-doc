<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Admin - Feedback Viewer</title>
        <link href="css/theme.css" rel="stylesheet" type="text/css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="assets/css/global.css">
        <link rel="stylesheet" href="assets/css/admin_feedback_viewer.css">
        <style>/* Basic reset for preview consistency */body { margin: 0; padding: 0; font-family: sans-serif; }</style>
    </head>
    <body>
        <div class="admin-feedback-viewer">
            <!-- Skip to content -->
            <a href="#main-content" class="sr-only" style="position:absolute;top:-40px;left:0;background:#2563eb;color:#fff;padding:8px 16px;z-index:1000;border-radius:0 0 8px 0;" onfocus="this.style.top='0'" onblur="this.style.top='-40px'">Skip to main content</a>
            <!-- Sidebar Overlay (Mobile) -->
            <div id="admin-sidebar-overlay" class="admin-sidebar-overlay" aria-hidden="true"></div>
            <!-- Admin Sidebar -->
            <aside class="admin-sidebar" role="navigation" aria-label="Admin navigation">
                <div class="admin-sidebar-header">
                    <img src="https://dev.think4ever.com/uifiles/20260311/ed3d2c21991e3bef5e069713af9fa6ca/only_m_with_white_bg_logo.png" alt="MPay Logo"/>
                    <div>
                        <div class="admin-brand">MPay Network</div>
                        <div class="admin-brand-sub">Admin Panel</div>
                    </div>
                </div>
                <nav class="admin-nav">
                    <div class="admin-nav-section">
                        <div class="admin-nav-section-label">Overview</div>
                        <button class="admin-nav-link" onclick="load_page('admin_dashboard')">
                            <i class="fa-solid fa-gauge-high"></i> Dashboard
                        </button>
                    </div>
                    <div class="admin-nav-section">
                        <div class="admin-nav-section-label">Moderation</div>
                        <button class="admin-nav-link" onclick="load_page('admin_comment_moderation')">
                            <i class="fa-solid fa-comments"></i> Comments
                        </button>
                        <button class="admin-nav-link active">
                            <i class="fa-solid fa-message"></i> Feedback
                        </button>
                    </div>
                    <div class="admin-nav-section">
                        <div class="admin-nav-section-label">Content</div>
                        <button class="admin-nav-link" onclick="load_page('admin_changelog_editor')">
                            <i class="fa-solid fa-clock-rotate-left"></i> Changelog
                        </button>
                        <button class="admin-nav-link" onclick="load_page('blog_listing')">
                            <i class="fa-solid fa-newspaper"></i> Blog Posts
                        </button>
                    </div>
                    <div class="admin-nav-section">
                        <div class="admin-nav-section-label">Navigation</div>
                        <button class="admin-nav-link" onclick="load_page('landing_page')">
                            <i class="fa-solid fa-globe"></i> View Site
                        </button>
                    </div>
                </nav>
                <div class="admin-sidebar-footer">
                    <div class="admin-user-info">
                        <div class="admin-avatar">A</div>
                        <div>
                            <div class="admin-user-name">Admin User</div>
                            <div class="admin-user-role">Super Admin</div>
                        </div>
                    </div>
                </div>
            </aside>
            <!-- Main Content -->
            <div class="admin-main">
                <!-- Top Bar -->
                <header class="admin-topbar">
                    <div class="admin-topbar-left">
                        <button class="admin-hamburger" id="admin-hamburger-btn" aria-label="Toggle sidebar">
                            <i class="fa-solid fa-bars"></i>
                        </button>
                        <nav class="admin-breadcrumb" aria-label="Breadcrumb">
                            <a onclick="load_page('admin_dashboard')">Admin</a>
                            <span class="separator">/</span>
                            <span class="current">Feedback Submissions</span>
                        </nav>
                    </div>
                    <div class="admin-topbar-right">
                        <button class="btn btn-secondary btn-sm" id="afv_back_dashboard" onclick="load_page('admin_dashboard')">
                            <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
                        </button>
                    </div>
                </header>
                <!-- Page Content -->
                <main class="admin-content" id="main-content">
                    <!-- Page Header -->
                    <div class="feedback-page-header">
                        <h1 id="afv_title"><i class="fa-solid fa-message" style="color:#2563eb;margin-right:8px"></i>Feedback Submissions</h1>
                        <div class="feedback-header-actions">
                            <button class="btn btn-outline" id="afv_export_btn">
                                <i class="fa-solid fa-file-csv"></i> Export to CSV
                            </button>
                        </div>
                    </div>
                    <!-- Stats Cards -->
                    <div class="feedback-stats">
                        <div class="feedback-stat-card">
                            <div class="feedback-stat-icon new">
                                <i class="fa-solid fa-circle-exclamation"></i>
                            </div>
                            <div>
                                <div class="feedback-stat-value" id="stat-new">0</div>
                                <div class="feedback-stat-label">New</div>
                            </div>
                        </div>
                        <div class="feedback-stat-card">
                            <div class="feedback-stat-icon read">
                                <i class="fa-solid fa-eye"></i>
                            </div>
                            <div>
                                <div class="feedback-stat-value" id="stat-read">0</div>
                                <div class="feedback-stat-label">Read</div>
                            </div>
                        </div>
                        <div class="feedback-stat-card">
                            <div class="feedback-stat-icon responded">
                                <i class="fa-solid fa-reply"></i>
                            </div>
                            <div>
                                <div class="feedback-stat-value" id="stat-responded">0</div>
                                <div class="feedback-stat-label">Responded</div>
                            </div>
                        </div>
                        <div class="feedback-stat-card">
                            <div class="feedback-stat-icon archived">
                                <i class="fa-solid fa-box-archive"></i>
                            </div>
                            <div>
                                <div class="feedback-stat-value" id="stat-archived">0</div>
                                <div class="feedback-stat-label">Archived</div>
                            </div>
                        </div>
                    </div>
                    <!-- Filters -->
                    <div class="feedback-filters">
                        <div class="filters-row">
                            <div class="filter-group">
                                <label for="afv_filter_category">Category</label>
                                <select id="afv_filter_category" aria-label="Filter by category">
                                    <option value="">All Categories</option>
                                    <option value="Merchant Wallet">Merchant Wallet</option>
                                    <option value="Consumer Wallet">Consumer Wallet</option>
                                    <option value="General">General</option>
                                    <option value="Bug Report">Bug Report</option>
                                    <option value="Feature Request">Feature Request</option>
                                </select>
                            </div>
                            <div class="filter-group">
                                <label for="afv_filter_status">Status</label>
                                <select id="afv_filter_status" aria-label="Filter by status">
                                    <option value="">All Statuses</option>
                                    <option value="New">New</option>
                                    <option value="Read">Read</option>
                                    <option value="Responded">Responded</option>
                                    <option value="Archived">Archived</option>
                                </select>
                            </div>
                            <div class="filter-group">
                                <label for="afv_filter_rating">Rating</label>
                                <select id="afv_filter_rating" aria-label="Filter by rating">
                                    <option value="">All Ratings</option>
                                    <option value="5">★★★★★ (5)</option>
                                    <option value="4">★★★★☆ (4)</option>
                                    <option value="3">★★★☆☆ (3)</option>
                                    <option value="2">★★☆☆☆ (2)</option>
                                    <option value="1">★☆☆☆☆ (1)</option>
                                </select>
                            </div>
                            <div class="filter-group" style="flex:1.5">
                                <label for="afv_search">Search</label>
                                <div class="search-input-wrapper">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                    <input type="text" id="afv_search" placeholder="Search by name, email, subject..." aria-label="Search feedback"/>
                                </div>
                            </div>
                            <div class="filter-actions">
                                <button class="btn btn-ghost btn-sm" id="clear-filters-btn" title="Clear all filters">
                                    <i class="fa-solid fa-filter-circle-xmark"></i> Clear
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- Feedback Table -->
                    <div class="feedback-table-container">
                        <div class="table-header-bar">
                            <div class="table-info" id="table-info">Loading...</div>
                            <div class="table-bulk-actions" id="bulk-actions-bar" style="display:none">
                                <span style="font-size:0.8125rem;color:#2563eb;font-weight:600" id="selected-count">0 selected</span>
                                <button class="btn btn-secondary btn-sm" id="bulk-read-btn">
                                    <i class="fa-solid fa-eye"></i> Mark Read
                                </button>
                                <button class="btn btn-secondary btn-sm" id="bulk-archive-btn">
                                    <i class="fa-solid fa-box-archive"></i> Archive
                                </button>
                            </div>
                        </div>
                        <div style="overflow-x:auto">
                            <table class="admin-table" id="afv_feedback_table" aria-label="Feedback submissions table">
                                <thead>
                                    <tr>
                                        <th class="td-checkbox">
                                            <input type="checkbox" id="select-all-checkbox" aria-label="Select all feedback"/>
                                        </th>
                                        <th>Submitter <i class="fa-solid fa-sort sort-icon"></i></th>
                                        <th>Category <i class="fa-solid fa-sort sort-icon"></i></th>
                                        <th>Subject <i class="fa-solid fa-sort sort-icon"></i></th>
                                        <th>Rating <i class="fa-solid fa-sort sort-icon"></i></th>
                                        <th>Status <i class="fa-solid fa-sort sort-icon"></i></th>
                                        <th>Date <i class="fa-solid fa-sort sort-icon"></i></th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="feedback-tbody">
                                    <!-- Populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <!-- Pagination -->
                    <div class="feedback-pagination">
                        <div class="pagination-info" id="pagination-info"></div>
                        <div class="pagination-controls" id="afv_pagination" role="navigation" aria-label="Feedback pagination">
                            <!-- Populated by JavaScript -->
                        </div>
                    </div>
                </main>
            </div>
            <!-- Detail Modal -->
            <div class="modal-overlay" id="afv_detail_modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
                <div class="modal-container">
                    <div class="modal-header">
                        <h2 id="modal-title">Feedback Detail</h2>
                        <button class="modal-close" id="modal-close-btn" aria-label="Close modal">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="modal-detail-grid">
                            <div class="modal-detail-item">
                                <span class="modal-detail-label">From</span>
                                <span class="modal-detail-value" id="modal-detail-name"></span>
                            </div>
                            <div class="modal-detail-item">
                                <span class="modal-detail-label">Email</span>
                                <a class="modal-detail-value" id="modal-detail-email" href="#" style="color:#2563eb;text-decoration:none;"></a>
                            </div>
                            <div class="modal-detail-item">
                                <span class="modal-detail-label">Category</span>
                                <span class="modal-detail-value" id="modal-detail-category"></span>
                            </div>
                            <div class="modal-detail-item">
                                <span class="modal-detail-label">Date</span>
                                <span class="modal-detail-value" id="modal-detail-date"></span>
                            </div>
                            <div class="modal-detail-item">
                                <span class="modal-detail-label">Rating</span>
                                <span class="modal-detail-value" id="modal-detail-rating"></span>
                            </div>
                            <div class="modal-detail-item">
                                <span class="modal-detail-label">Status</span>
                                <span class="modal-detail-value" id="modal-detail-status"></span>
                            </div>
                        </div>
                        <div class="modal-detail-item full-width" style="margin-bottom:16px">
                            <span class="modal-detail-label">Subject</span>
                            <span class="modal-detail-value" id="modal-detail-subject" style="font-size:1.0625rem;font-weight:700;color:#1e3a8a"></span>
                        </div>
                        <div class="modal-detail-item full-width">
                            <span class="modal-detail-label" style="margin-bottom:8px;display:block">Message</span>
                            <div class="modal-feedback-content" id="modal-detail-message"></div>
                        </div>
                        <!-- Attachment -->
                        <div class="modal-attachment" id="modal-attachment-section" style="display:none">
                            <div class="modal-attachment-label">Attachment</div>
                            <div class="modal-attachment-preview">
                                <i class="fa-solid fa-paperclip"></i>
                                <div class="attachment-info">
                                    <div class="attachment-name" id="modal-attachment-name"></div>
                                    <div class="attachment-size" id="modal-attachment-size"></div>
                                </div>
                                <button class="btn btn-ghost btn-sm" title="Download attachment">
                                    <i class="fa-solid fa-download"></i>
                                </button>
                            </div>
                        </div>
                        <!-- Previous Response -->
                        <div id="modal-prev-response" style="display:none;margin-top:20px">
                            <div class="modal-detail-label" style="margin-bottom:8px">Previous Response</div>
                            <div class="modal-feedback-content" id="modal-prev-response-text" style="background:#dcfce7;border-color:#bbf7d0"></div>
                        </div>
                        <!-- Response Section -->
                        <div class="modal-response-section">
                            <label for="modal-response-textarea">
                                <i class="fa-solid fa-reply" style="margin-right:6px;color:#2563eb"></i>Send Response
                            </label>
                            <textarea id="modal-response-textarea" placeholder="Type your response to this feedback..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <div class="modal-footer-left">
                            <button class="btn btn-secondary btn-sm" id="afv_mark_read">
                                <i class="fa-solid fa-eye"></i> Mark as Read
                            </button>
                            <button class="btn btn-outline btn-sm" id="afv_archive_btn">
                                <i class="fa-solid fa-box-archive"></i> Archive
                            </button>
                        </div>
                        <div class="modal-footer-right">
                            <button class="btn btn-ghost btn-sm" id="modal-cancel-btn">Cancel</button>
                            <button class="btn btn-primary btn-sm" id="modal-send-response-btn">
                                <i class="fa-solid fa-paper-plane"></i> Send Response
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script src="assets/js/navigation.js"></script>
        <script src="assets/js/admin_feedback_viewer.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    </body>
</html>