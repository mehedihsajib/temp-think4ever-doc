/* Landing Page Specific CSS */

/* ============ NAVBAR ============ */
.lp-page {
  min-height: 100vh;
  background: #ffffff;
}

.lp-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 64px;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid transparent;
  z-index: 1000;
  transition: border-color 0.25s ease, box-shadow 0.25s ease;
}

.lp-navbar.scrolled {
  border-bottom-color: #bfdbfe;
  box-shadow: 0 1px 8px rgba(37, 99, 235, 0.06);
}

.lp-navbar-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 8px;
}

.lp-navbar-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  cursor: pointer;
  text-decoration: none;
  flex-shrink: 0;
}

.lp-navbar-logo img {
  height: 36px;
  width: auto;
}

.lp-navbar-logo span {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 700;
  color: #1e3a8a;
  letter-spacing: -0.01em;
}

.lp-navbar-links {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-left: 32px;
}

.lp-navbar-links a {
  font-size: 0.875rem;
  font-weight: 500;
  color: #334155;
  text-decoration: none;
  padding: 6px 12px;
  border-radius: 8px;
  transition: background 0.15s ease, color 0.15s ease;
  white-space: nowrap;
}

.lp-navbar-links a:hover {
  background: #eff6ff;
  color: #2563eb;
}

.lp-navbar-right {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-left: auto;
}

.lp-search-trigger {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 14px;
  background: #f8fafc;
  border: 1px solid #bfdbfe;
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.875rem;
  color: #94a3b8;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
  min-width: 200px;
}

.lp-search-trigger:hover {
  border-color: #93bbfd;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.08);
}

.lp-search-trigger:focus-visible {
  outline: none;
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
}

.lp-search-trigger i {
  font-size: 14px;
  color: #94a3b8;
}

.lp-search-kbd {
  font-size: 11px;
  background: #e2e8f0;
  color: #64748b;
  padding: 2px 6px;
  border-radius: 4px;
  font-family: 'Inter', sans-serif;
  margin-left: auto;
}

/* Dropdown styles */
.lp-dropdown {
  position: relative;
}

.lp-dropdown-trigger {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  background: transparent;
  border: 1px solid #bfdbfe;
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.8125rem;
  font-weight: 500;
  color: #334155;
  transition: all 0.15s ease;
  white-space: nowrap;
}

.lp-dropdown-trigger:hover {
  background: #eff6ff;
  border-color: #93bbfd;
}

.lp-dropdown-trigger:focus-visible {
  outline: none;
  border-color: #2563eb;
  box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2);
}

.lp-dropdown-trigger i.fa-chevron-down {
  font-size: 10px;
  transition: transform 0.2s ease;
}

.lp-dropdown.open .lp-dropdown-trigger i.fa-chevron-down {
  transform: rotate(180deg);
}

.lp-dropdown-menu {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  min-width: 140px;
  background: #fff;
  border: 1px solid #bfdbfe;
  border-radius: 10px;
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.1);
  padding: 6px;
  display: none;
  z-index: 1001;
}

.lp-dropdown.open .lp-dropdown-menu {
  display: block;
  animation: lp-dropdown-in 0.15s ease;
}

@keyframes lp-dropdown-in {
  from { opacity: 0; transform: translateY(-4px); }
  to { opacity: 1; transform: translateY(0); }
}

.lp-dropdown-item {
  display: block;
  width: 100%;
  padding: 8px 12px;
  font-size: 0.8125rem;
  color: #334155;
  background: transparent;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  text-align: left;
  transition: background 0.15s ease;
}

.lp-dropdown-item:hover {
  background: #eff6ff;
  color: #2563eb;
}

.lp-dropdown-item.active {
  background: #eff6ff;
  color: #2563eb;
  font-weight: 600;
}

/* Dark mode toggle */
.lp-dark-toggle {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1px solid #bfdbfe;
  border-radius: 8px;
  cursor: pointer;
  color: #334155;
  font-size: 16px;
  transition: all 0.15s ease;
}

.lp-dark-toggle:hover {
  background: #eff6ff;
  color: #2563eb;
}

.lp-dark-toggle:focus-visible {
  outline: none;
  border-color: #2563eb;
  box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.2);
}

/* Hamburger */
.lp-hamburger {
  display: none;
  width: 36px;
  height: 36px;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1px solid #bfdbfe;
  border-radius: 8px;
  cursor: pointer;
  color: #334155;
  font-size: 18px;
}

/* Mobile nav overlay */
.lp-mobile-nav {
  display: none;
  position: fixed;
  top: 64px;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(12px);
  z-index: 999;
  padding: 24px;
  overflow-y: auto;
}

.lp-mobile-nav.open {
  display: block;
  animation: lp-fade-in 0.2s ease;
}

@keyframes lp-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.lp-mobile-nav a {
  display: block;
  font-size: 1rem;
  font-weight: 500;
  color: #334155;
  text-decoration: none;
  padding: 14px 16px;
  border-radius: 10px;
  transition: background 0.15s ease;
}

.lp-mobile-nav a:hover {
  background: #eff6ff;
  color: #2563eb;
}

.lp-mobile-nav-divider {
  height: 1px;
  background: #bfdbfe;
  margin: 12px 0;
}

.lp-mobile-controls {
  display: flex;
  gap: 8px;
  margin-top: 12px;
  flex-wrap: wrap;
}

/* ============ SEARCH MODAL ============ */
.lp-search-modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.5);
  z-index: 2000;
  align-items: flex-start;
  justify-content: center;
  padding-top: 15vh;
}

.lp-search-modal.open {
  display: flex;
  animation: lp-fade-in 0.15s ease;
}

.lp-search-modal-content {
  width: 100%;
  max-width: 600px;
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  overflow: hidden;
  margin: 0 16px;
}

.lp-search-input-wrap {
  display: flex;
  align-items: center;
  padding: 16px 20px;
  border-bottom: 1px solid #bfdbfe;
  gap: 12px;
}

.lp-search-input-wrap i {
  color: #94a3b8;
  font-size: 18px;
}

.lp-search-input-wrap input {
  flex: 1;
  border: none;
  outline: none;
  font-size: 1rem;
  font-family: 'Inter', sans-serif;
  color: #1e3a8a;
  background: transparent;
}

.lp-search-input-wrap input::placeholder {
  color: #94a3b8;
}

.lp-search-esc {
  font-size: 11px;
  background: #e2e8f0;
  color: #64748b;
  padding: 3px 8px;
  border-radius: 4px;
  cursor: pointer;
}

.lp-search-results {
  padding: 12px 16px;
  max-height: 300px;
  overflow-y: auto;
}

.lp-search-empty {
  text-align: center;
  padding: 24px;
  color: #94a3b8;
  font-size: 0.875rem;
}

.lp-search-result-item {
  display: block;
  padding: 10px 12px;
  border-radius: 8px;
  text-decoration: none;
  color: #334155;
  cursor: pointer;
  transition: background 0.15s ease;
}

.lp-search-result-item:hover {
  background: #eff6ff;
}

.lp-search-result-item .result-title {
  font-weight: 600;
  font-size: 0.875rem;
  color: #1e3a8a;
}

.lp-search-result-item .result-desc {
  font-size: 0.8125rem;
  color: #64748b;
  margin-top: 2px;
}

/* ============ HERO ============ */
.lp-hero {
  padding-top: 128px;
  padding-bottom: 80px;
  background: linear-gradient(160deg, #ffffff 0%, #eff6ff 35%, #dbeafe 55%, #eff6ff 75%, #ffffff 100%);
  position: relative;
  overflow: hidden;
}

.lp-hero::before {
  content: '';
  position: absolute;
  top: -60%;
  right: -20%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(37, 99, 235, 0.06) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.lp-hero::after {
  content: '';
  position: absolute;
  bottom: -40%;
  left: -15%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(96, 165, 250, 0.05) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.lp-hero-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
  z-index: 1;
}

.lp-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 16px;
  background: rgba(37, 99, 235, 0.08);
  border: 1px solid rgba(37, 99, 235, 0.15);
  border-radius: 100px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: #2563eb;
  margin-bottom: 24px;
}

.lp-hero-badge i {
  font-size: 12px;
}

.lp-hero-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 3rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: 1.15;
  margin-bottom: 16px;
  background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 50%, #3b82f6 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  max-width: 700px;
}

.lp-hero-subtitle {
  font-size: 1.25rem;
  font-weight: 400;
  color: #334155;
  line-height: 1.6;
  max-width: 560px;
  margin-bottom: 12px;
}

.lp-hero-tagline {
  font-size: 1rem;
  color: #64748b;
  margin-bottom: 36px;
}

.lp-hero-ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 48px;
}

.lp-btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  background: #2563eb;
  color: #fff;
  font-size: 0.9375rem;
  font-weight: 600;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  text-decoration: none;
  transition: all 0.15s ease;
}

.lp-btn-primary:hover {
  background: #1d4ed8;
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.25);
  transform: translateY(-1px);
}

.lp-btn-primary:active {
  background: #1e3a8a;
  transform: translateY(0);
  box-shadow: none;
}

.lp-btn-primary:focus-visible {
  outline: 2px solid #2563eb;
  outline-offset: 2px;
}

.lp-btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  background: transparent;
  color: #2563eb;
  font-size: 0.9375rem;
  font-weight: 600;
  border: 2px solid #bfdbfe;
  border-radius: 8px;
  cursor: pointer;
  text-decoration: none;
  transition: all 0.15s ease;
}

.lp-btn-outline:hover {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
  transform: translateY(-1px);
}

.lp-btn-outline:active {
  background: #1e3a8a;
  border-color: #1e3a8a;
  color: #fff;
  transform: translateY(0);
}

.lp-btn-outline:focus-visible {
  outline: 2px solid #2563eb;
  outline-offset: 2px;
}

/* Hero image / QR Animation */
.lp-hero-image-wrap {
  max-width: 480px;
  width: 100%;
  border-radius: 16px;
  overflow: visible;
  animation: lp-float 6s ease-in-out infinite;
}

@keyframes lp-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.lp-hero-image-wrap img {
  display: block;
  width: 100%;
  height: auto;
}

/* ---- QR Payment Animated Scene ---- */
.lp-qr-payment-scene {
  position: relative;
  width: 280px;
  height: 380px;
  margin: 0 auto;
}

/* Phone Mockup */
.lp-phone-mockup {
  position: relative;
  width: 240px;
  height: 360px;
  background: #ffffff;
  border-radius: 28px;
  box-shadow: 0 20px 60px rgba(37, 99, 235, 0.18), 0 0 0 1px rgba(37, 99, 235, 0.1), inset 0 0 0 2px rgba(37, 99, 235, 0.06);
  margin: 0 auto;
  overflow: hidden;
  z-index: 2;
}

.lp-phone-screen {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 16px 20px;
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 40%);
}

.lp-phone-header {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.lp-phone-status {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: #1e3a8a;
}

.lp-phone-dots {
  display: flex;
  gap: 3px;
}

.lp-phone-dots span {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: #93bbfd;
}

/* QR Code Area */
.lp-phone-qr-area {
  width: 160px;
  height: 160px;
  background: #fff;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  border: 2px solid #dbeafe;
  position: relative;
  overflow: hidden;
}

.lp-animated-qr {
  width: 130px;
  height: 130px;
  position: relative;
  animation: lp-qr-appear 1.5s ease-out forwards;
}

@keyframes lp-qr-appear {
  0% { opacity: 0; transform: scale(0.8); }
  60% { opacity: 1; transform: scale(1.03); }
  100% { opacity: 1; transform: scale(1); }
}

/* QR Grid blocks */
.lp-qr-grid {
  position: absolute;
  top: 28px;
  left: 28px;
  right: 28px;
  bottom: 28px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: repeat(4, 1fr);
  gap: 3px;
}

.lp-qr-block {
  border-radius: 2px;
  animation: lp-qr-block-in 0.4s ease-out forwards;
  opacity: 0;
}

.lp-qr-block.b1 { background: #1e3a8a; animation-delay: 0.3s; }
.lp-qr-block.b2 { background: transparent; animation-delay: 0.35s; }
.lp-qr-block.b3 { background: #2563eb; animation-delay: 0.4s; }
.lp-qr-block.b4 { background: #1e3a8a; animation-delay: 0.45s; }
.lp-qr-block.b5 { background: transparent; animation-delay: 0.5s; }
.lp-qr-block.b6 { background: #1e3a8a; animation-delay: 0.55s; }
.lp-qr-block.b7 { background: transparent; animation-delay: 0.6s; }
.lp-qr-block.b8 { background: #2563eb; animation-delay: 0.65s; }
.lp-qr-block.b9 { background: #2563eb; animation-delay: 0.7s; }
.lp-qr-block.b10 { background: transparent; animation-delay: 0.75s; }
.lp-qr-block.b11 { background: #1e3a8a; animation-delay: 0.8s; }
.lp-qr-block.b12 { background: transparent; animation-delay: 0.85s; }
.lp-qr-block.b13 { background: #1e3a8a; animation-delay: 0.9s; }
.lp-qr-block.b14 { background: #2563eb; animation-delay: 0.95s; }
.lp-qr-block.b15 { background: transparent; animation-delay: 1.0s; }
.lp-qr-block.b16 { background: #1e3a8a; animation-delay: 1.05s; }

@keyframes lp-qr-block-in {
  0% { opacity: 0; transform: scale(0); }
  80% { opacity: 1; transform: scale(1.2); }
  100% { opacity: 1; transform: scale(1); }
}

/* QR Finder Patterns (corners) */
.lp-qr-finder {
  position: absolute;
  width: 26px;
  height: 26px;
  border: 3px solid #1e3a8a;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: lp-qr-finder-in 0.5s ease-out forwards;
  opacity: 0;
}

.lp-qr-finder-inner {
  width: 10px;
  height: 10px;
  background: #1e3a8a;
  border-radius: 2px;
}

.lp-qr-finder.tl { top: 0; left: 0; animation-delay: 0.1s; }
.lp-qr-finder.tr { top: 0; right: 0; animation-delay: 0.15s; }
.lp-qr-finder.bl { bottom: 0; left: 0; animation-delay: 0.2s; }

@keyframes lp-qr-finder-in {
  0% { opacity: 0; transform: scale(0) rotate(-10deg); }
  100% { opacity: 1; transform: scale(1) rotate(0deg); }
}

/* Scan Beam */
.lp-qr-scan-beam {
  position: absolute;
  left: 4px;
  right: 4px;
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, #2563eb 20%, #60a5fa 50%, #2563eb 80%, transparent 100%);
  border-radius: 2px;
  box-shadow: 0 0 8px rgba(37, 99, 235, 0.5), 0 0 20px rgba(37, 99, 235, 0.2);
  animation: lp-scan-beam 2.5s ease-in-out infinite 1.2s;
  opacity: 0;
}

@keyframes lp-scan-beam {
  0% { top: 4px; opacity: 0; }
  5% { opacity: 1; }
  45% { top: calc(100% - 6px); opacity: 1; }
  50% { top: calc(100% - 6px); opacity: 0; }
  55% { top: calc(100% - 6px); opacity: 1; }
  95% { top: 4px; opacity: 1; }
  100% { top: 4px; opacity: 0; }
}

/* Amount display */
.lp-phone-amount {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 12px;
}

.lp-amount-label {
  font-size: 11px;
  color: #64748b;
  font-weight: 500;
  margin-bottom: 2px;
}

.lp-amount-value {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 24px;
  font-weight: 800;
  color: #1e3a8a;
  animation: lp-amount-pulse 3s ease-in-out infinite;
}

@keyframes lp-amount-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.lp-phone-btn-pay {
  width: 100%;
  padding: 10px 0;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  text-align: center;
  border-radius: 10px;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  animation: lp-btn-glow 2s ease-in-out infinite;
}

@keyframes lp-btn-glow {
  0%, 100% { box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); }
  50% { box-shadow: 0 4px 20px rgba(37, 99, 235, 0.5), 0 0 30px rgba(37, 99, 235, 0.15); }
}

/* Payment Particles */
.lp-payment-particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
}

.lp-particle {
  position: absolute;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  opacity: 0;
}

.lp-particle.p1 {
  background: #2563eb;
  top: 20%;
  left: 5%;
  animation: lp-particle-float 4s ease-in-out infinite 0s;
}
.lp-particle.p2 {
  background: #60a5fa;
  top: 60%;
  right: 5%;
  width: 8px;
  height: 8px;
  animation: lp-particle-float 5s ease-in-out infinite 0.5s;
}
.lp-particle.p3 {
  background: #3b82f6;
  top: 80%;
  left: 10%;
  width: 5px;
  height: 5px;
  animation: lp-particle-float 3.5s ease-in-out infinite 1s;
}
.lp-particle.p4 {
  background: #93bbfd;
  top: 10%;
  right: 10%;
  width: 7px;
  height: 7px;
  animation: lp-particle-float 4.5s ease-in-out infinite 1.5s;
}
.lp-particle.p5 {
  background: #2563eb;
  top: 45%;
  left: 0;
  width: 4px;
  height: 4px;
  animation: lp-particle-float 3s ease-in-out infinite 0.8s;
}
.lp-particle.p6 {
  background: #dbeafe;
  top: 70%;
  right: 0;
  width: 10px;
  height: 10px;
  animation: lp-particle-float 5.5s ease-in-out infinite 2s;
}

@keyframes lp-particle-float {
  0%, 100% { opacity: 0; transform: translateY(0) scale(0.5); }
  20% { opacity: 0.7; transform: translateY(-10px) scale(1); }
  50% { opacity: 0.5; transform: translateY(-25px) scale(0.8); }
  80% { opacity: 0.3; transform: translateY(-40px) scale(0.6); }
}

/* Floating Icons */
.lp-floating-icon {
  position: absolute;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.15), 0 0 0 1px rgba(37, 99, 235, 0.08);
  color: #2563eb;
  z-index: 3;
}

.lp-fi-1 {
  top: 15%;
  left: -10px;
  animation: lp-icon-bounce 3s ease-in-out infinite 0s;
}

.lp-fi-2 {
  top: 40%;
  right: -10px;
  animation: lp-icon-bounce 3.5s ease-in-out infinite 0.5s;
  color: #22c55e;
}

.lp-fi-3 {
  bottom: 15%;
  left: -5px;
  animation: lp-icon-bounce 4s ease-in-out infinite 1s;
}

@keyframes lp-icon-bounce {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25% { transform: translateY(-8px) rotate(-3deg); }
  75% { transform: translateY(4px) rotate(2deg); }
}

/* NFC waves animation in hero */
.lp-nfc-waves {
  position: absolute;
  top: 50%;
  right: 5%;
  width: 120px;
  height: 120px;
  opacity: 0.15;
  pointer-events: none;
}

.lp-nfc-wave {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 2px solid #2563eb;
  border-radius: 50%;
  animation: lp-nfc-pulse 3s ease-out infinite;
}

.lp-nfc-wave:nth-child(1) { width: 40px; height: 40px; animation-delay: 0s; }
.lp-nfc-wave:nth-child(2) { width: 70px; height: 70px; animation-delay: 0.5s; }
.lp-nfc-wave:nth-child(3) { width: 100px; height: 100px; animation-delay: 1s; }

@keyframes lp-nfc-pulse {
  0% { opacity: 0.6; transform: translate(-50%, -50%) scale(0.8); }
  100% { opacity: 0; transform: translate(-50%, -50%) scale(1.4); }
}

/* ============ FEATURES SECTION ============ */
.lp-features {
  padding: 80px 24px;
  max-width: 1280px;
  margin: 0 auto;
}

.lp-section-label {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.8125rem;
  font-weight: 700;
  color: #2563eb;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 12px;
}

.lp-section-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: #1e3a8a;
  letter-spacing: -0.025em;
  line-height: 1.25;
  margin-bottom: 12px;
}

.lp-section-desc {
  font-size: 1.0625rem;
  color: #64748b;
  line-height: 1.6;
  max-width: 600px;
  margin-bottom: 48px;
}

.lp-features-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.lp-feature-card {
  background: #fff;
  border: 1px solid #bfdbfe;
  border-radius: 12px;
  padding: 28px 24px;
  transition: all 0.25s ease;
  cursor: default;
  position: relative;
}

.lp-feature-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(37, 99, 235, 0.1);
  border-color: #93bbfd;
}

.lp-feature-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eff6ff;
  border-radius: 10px;
  margin-bottom: 16px;
  font-size: 20px;
  color: #2563eb;
  transition: background 0.2s ease;
}

.lp-feature-card:hover .lp-feature-icon {
  background: #dbeafe;
}

.lp-feature-card h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 700;
  color: #1e3a8a;
  margin-bottom: 8px;
}

.lp-feature-card p {
  font-size: 0.875rem;
  color: #64748b;
  line-height: 1.625;
}

/* QR Scanner animation for QR card */
.lp-qr-visual {
  position: relative;
  width: 44px;
  height: 44px;
}

.lp-qr-frame {
  position: absolute;
  width: 100%;
  height: 100%;
}

.lp-qr-corner {
  position: absolute;
  width: 10px;
  height: 10px;
  border-color: #2563eb;
  border-style: solid;
}

.lp-qr-corner.tl { top: 0; left: 0; border-width: 2px 0 0 2px; }
.lp-qr-corner.tr { top: 0; right: 0; border-width: 2px 2px 0 0; }
.lp-qr-corner.bl { bottom: 0; left: 0; border-width: 0 0 2px 2px; }
.lp-qr-corner.br { bottom: 0; right: 0; border-width: 0 2px 2px 0; }

.lp-qr-scanline {
  position: absolute;
  left: 4px;
  right: 4px;
  height: 2px;
  background: linear-gradient(90deg, transparent, #2563eb, transparent);
  animation: lp-qr-scan 2s ease-in-out infinite;
  border-radius: 2px;
}

@keyframes lp-qr-scan {
  0%, 100% { top: 4px; opacity: 0.4; }
  50% { top: calc(100% - 6px); opacity: 1; }
}

/* ============ QUICK NAV SECTION ============ */
.lp-quicknav {
  padding: 0 24px 80px;
  max-width: 1280px;
  margin: 0 auto;
}

.lp-quicknav-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.lp-quicknav-grid.three-col {
  grid-template-columns: repeat(3, 1fr);
}

.lp-nav-card {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  background: #fff;
  border: 1px solid #bfdbfe;
  border-radius: 12px;
  padding: 24px;
  cursor: pointer;
  text-decoration: none;
  transition: all 0.25s ease;
  position: relative;
  overflow: hidden;
}

.lp-nav-card::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: #2563eb;
  transform: scaleX(0);
  transition: transform 0.3s ease;
}

.lp-nav-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(37, 99, 235, 0.1);
  border-color: #93bbfd;
}

.lp-nav-card:hover::after {
  transform: scaleX(1);
}

.lp-nav-card:focus-visible {
  outline: 2px solid #2563eb;
  outline-offset: 2px;
}

.lp-nav-card-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eff6ff;
  border-radius: 10px;
  font-size: 20px;
  color: #2563eb;
  flex-shrink: 0;
}

.lp-nav-card-content h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.0625rem;
  font-weight: 700;
  color: #1e3a8a;
  margin-bottom: 6px;
}

.lp-nav-card-content p {
  font-size: 0.875rem;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 10px;
}

.lp-nav-card-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: #2563eb;
  transition: gap 0.15s ease;
}

.lp-nav-card:hover .lp-nav-card-link {
  gap: 10px;
}

/* ============ FOOTER ============ */
.lp-footer {
  background: #0f172a;
  padding: 64px 24px 32px;
}

.lp-footer-inner {
  max-width: 1280px;
  margin: 0 auto;
}

.lp-footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  margin-bottom: 48px;
}

.lp-footer-brand {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.lp-footer-logo {
  display: flex;
  align-items: center;
  gap: 10px;
}

.lp-footer-logo img {
  height: 32px;
  filter: brightness(0) invert(1);
}

.lp-footer-logo span {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
}

.lp-footer-brand p {
  font-size: 0.875rem;
  color: #94a3b8;
  line-height: 1.625;
  max-width: 280px;
}

.lp-footer-social {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

.lp-footer-social a {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
  border: 1px solid #334155;
  border-radius: 8px;
  font-size: 14px;
  text-decoration: none;
  transition: all 0.15s ease;
}

.lp-footer-social a:hover {
  color: #fff;
  border-color: #2563eb;
  background: rgba(37, 99, 235, 0.15);
}

.lp-footer-col h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.8125rem;
  font-weight: 700;
  color: #e2e8f0;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 16px;
}

.lp-footer-col a {
  display: block;
  font-size: 0.875rem;
  color: #94a3b8;
  text-decoration: none;
  padding: 5px 0;
  transition: color 0.15s ease;
}

.lp-footer-col a:hover {
  color: #60a5fa;
}

.lp-footer-bottom {
  border-top: 1px solid #1e293b;
  padding-top: 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12px;
}

.lp-footer-bottom p {
  font-size: 0.8125rem;
  color: #64748b;
}

.lp-footer-bottom-links {
  display: flex;
  gap: 20px;
}

.lp-footer-bottom-links a {
  font-size: 0.8125rem;
  color: #64748b;
  text-decoration: none;
  transition: color 0.15s ease;
}

.lp-footer-bottom-links a:hover {
  color: #60a5fa;
}

/* ============ SKIP LINK ============ */
.lp-skip-link {
  position: absolute;
  top: -100%;
  left: 16px;
  background: #2563eb;
  color: #fff;
  padding: 8px 16px;
  border-radius: 0 0 8px 8px;
  z-index: 9999;
  font-size: 0.875rem;
  font-weight: 600;
  text-decoration: none;
  transition: top 0.2s ease;
}

.lp-skip-link:focus {
  top: 0;
}

/* ============ SCROLL TO TOP ============ */
.lp-scroll-top {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2563eb;
  color: #fff;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  font-size: 16px;
  box-shadow: 0 4px 16px rgba(37, 99, 235, 0.3);
  opacity: 0;
  visibility: hidden;
  transform: translateY(12px);
  transition: all 0.25s ease;
  z-index: 900;
}

.lp-scroll-top.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.lp-scroll-top:hover {
  background: #1d4ed8;
  transform: translateY(-2px);
}

/* ============ RESPONSIVE ============ */
@media (max-width: 1024px) {
  .lp-features-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .lp-quicknav-grid.three-col {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .lp-footer-grid {
    grid-template-columns: 2fr 1fr 1fr;
    gap: 32px;
  }
}

@media (max-width: 768px) {
  .lp-navbar-links {
    display: none;
  }
  
  .lp-search-trigger {
    min-width: auto;
    padding: 7px 10px;
  }
  
  .lp-search-trigger span,
  .lp-search-kbd {
    display: none;
  }
  
  .lp-hamburger {
    display: flex;
  }
  
  .lp-dropdown.lp-desktop-only {
    display: none;
  }
  
  .lp-hero {
    padding-top: 104px;
    padding-bottom: 56px;
  }
  
  .lp-hero-title {
    font-size: 2.25rem;
  }
  
  .lp-hero-subtitle {
    font-size: 1.0625rem;
  }
  
  .lp-hero-image-wrap {
    max-width: 340px;
  }

  .lp-qr-payment-scene {
    width: 240px;
    height: 340px;
  }

  .lp-phone-mockup {
    width: 210px;
    height: 320px;
  }

  .lp-phone-qr-area {
    width: 135px;
    height: 135px;
  }

  .lp-animated-qr {
    width: 110px;
    height: 110px;
  }

  .lp-floating-icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
  }

  .lp-floating-icon svg {
    width: 16px;
    height: 16px;
  }
  
  .lp-features {
    padding: 56px 16px;
  }
  
  .lp-section-title {
    font-size: 1.75rem;
  }
  
  .lp-features-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  .lp-quicknav {
    padding: 0 16px 56px;
  }
  
  .lp-quicknav-grid,
  .lp-quicknav-grid.three-col {
    grid-template-columns: 1fr;
    gap: 16px;
  }
  
  .lp-footer-grid {
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  
  .lp-nfc-waves {
    display: none;
  }
}

@media (max-width: 480px) {
  .lp-hero-title {
    font-size: 1.875rem;
  }
  
  .lp-hero-ctas {
    flex-direction: column;
    width: 100%;
    max-width: 300px;
  }
  
  .lp-btn-primary,
  .lp-btn-outline {
    justify-content: center;
    width: 100%;
  }
  
  .lp-footer-grid {
    grid-template-columns: 1fr;
    gap: 28px;
  }
  
  .lp-footer-bottom {
    flex-direction: column;
    text-align: center;
  }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .lp-hero-image-wrap {
    animation: none;
  }
  .lp-qr-scanline {
    animation: none;
  }
  .lp-nfc-wave {
    animation: none;
  }
  .lp-feature-card,
  .lp-nav-card,
  .lp-btn-primary,
  .lp-btn-outline {
    transition: none;
  }
}