            </header>
            <div class="docs-layout">
                <!-- Sidebar Overlay for mobile -->
                <div class="sidebar-overlay" id="msetSidebarOverlay" aria-hidden="true"></div>
                <!-- Sidebar -->
                <aside class="docs-sidebar" id="msetSidebar" role="navigation" aria-label="Documentation navigation">
                    <div class="sidebar-section">
                        <div class="sidebar-section-label">Getting Started</div>
                        <a class="sidebar-link" onclick="load_page('merchant_getting_started')" tabindex="0"> <i class="fa fa-rocket"></i> Getting Started </a>
                        <a class="sidebar-link" onclick="load_page('merchant_account_setup')" tabindex="0"> <i class="fa fa-user-check"></i> Account Setup </a>
                    </div>
                    <div class="sidebar-section">
                        <div class="sidebar-section-label">Payments</div>
                        <a class="sidebar-link" onclick="load_page('merchant_qr_payments')" tabindex="0"> <i class="fa fa-qrcode"></i> QR Code Payments </a>
                        <a class="sidebar-link" onclick="load_page('merchant_nfc_payments')" tabindex="0"> <i class="fa fa-wifi"></i> NFC Payments </a>
                    </div>
                    <div class="sidebar-section">
                        <div class="sidebar-section-label">Management</div>
                        <a class="sidebar-link" onclick="load_page('merchant_transactions')" tabindex="0"> <i class="fa fa-receipt"></i> Transactions </a>
                        <a class="sidebar-link active" onclick="load_page('merchant_operations')" tabindex="0"> <i class="fa fa-cog"></i> Merchant Operations </a>
                    </div>
                    <div class="sidebar-section">
                        <div class="sidebar-section-label">Support</div>
                        <a class="sidebar-link" onclick="load_page('merchant_troubleshooting')" tabindex="0"> <i class="fa fa-life-ring"></i> Troubleshooting </a>
                    </div>
