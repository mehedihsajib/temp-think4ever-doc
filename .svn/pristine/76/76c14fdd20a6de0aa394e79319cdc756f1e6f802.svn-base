                <!-- Main Content -->
                <div class="docs-content-wrapper">
                    <main class="docs-content" id="mset-main-content">
                        <!-- Breadcrumb -->
                        <nav class="breadcrumb" aria-label="Breadcrumb">
                            <a onclick="load_page('landing_page')">Docs</a>
                            <span class="separator"><i class="fa fa-chevron-right"></i></span>
                            <a onclick="load_page('merchant_docs_home')">Merchant</a>
                            <span class="separator"><i class="fa fa-chevron-right"></i></span>
                            <span class="current">Operations</span>
                        </nav>
                        <!-- Page Title -->
                        <h1 class="page-title" id="mset_title">Merchant Operations</h1>
                        <p class="page-subtitle">Merchant Operations allows the owner to manage and control branch activities, including opening or closing specific branch(es) as needed. This ensures proper operational control and enables the business to manage store availability efficiently across all locations.</p>
                        <!-- Profile operations Section -->
                        <section class="doc-section" id="section-profile">
                            <h2><i class="fa fa-user-circle" style="color:#2563eb;margin-right:8px;font-size:1.5rem;"></i>Manage Branches</h2>
                            <p>Keep your business profile up-to-date to ensure smooth transactions and maintain customer trust. Your profile information is displayed on receipts and during payment interactions.</p>
                            <div class="operations-grid">
                                <div class="setting-card">
                                    <div class="setting-card-header">
                                        <div class="setting-card-icon">
                                            <i class="fa fa-store"></i>
                                        </div>
                                        <div class="setting-card-title">Business Name</div>
                                    </div>
                                    <div class="setting-card-desc">Update your displayed business name as it appears to customers during payments and on receipts.</div>
                                </div>
                                <div class="setting-card">
                                    <div class="setting-card-header">
                                        <div class="setting-card-icon">
                                            <i class="fa fa-map-marker-alt"></i>
                                        </div>
                                        <div class="setting-card-title">Business Address</div>
                                    </div>
                                    <div class="setting-card-desc">Set your business location, used for receipt printing and location-based services.</div>
                                </div>
                                <div class="setting-card">
                                    <div class="setting-card-header">
                                        <div class="setting-card-icon">
                                            <i class="fa fa-phone"></i>
                                        </div>
                                        <div class="setting-card-title">Contact Information</div>
                                    </div>
                                    <div class="setting-card-desc">Manage phone numbers and email addresses for business communications.</div>
                                </div>
                                <div class="setting-card">
                                    <div class="setting-card-header">
                                        <div class="setting-card-icon">
                                            <i class="fa fa-image"></i>
                                        </div>
                                        <div class="setting-card-title">Logo & Branding</div>
                                    </div>
                                    <div class="setting-card-desc">Upload your business logo to appear on payment screens and digital receipts.</div>
                                </div>
                            </div>
                            <h3>Updating Your Business Profile</h3>
                            <ol class="steps">
                                <li class="step">
                                    <div class="step-number">1</div>
                                    <div class="step-title">Open operations</div>
                                    <div class="step-desc">Navigate to the <strong>operations</strong> tab in the bottom navigation bar, then tap <strong>Profile operations</strong>.
                                    </div>
                                </li>
                                <li class="step">
                                    <div class="step-number">2</div>
                                    <div class="step-title">Edit Fields</div>
                                    <div class="step-desc">Tap any field to edit. You can update your business name, address, phone number, email, and business category.</div>
                                </li>
                                <li class="step">
                                    <div class="step-number">3</div>
                                    <div class="step-title">Upload Logo</div>
                                    <div class="step-desc">Tap the logo area to upload a new image. Recommended size is <code>512×512px</code> in PNG or JPG format.
                                    </div>
                                </li>
                                <li class="step">
                                    <div class="step-number">4</div>
                                    <div class="step-title">Save Changes</div>
                                    <div class="step-desc">Tap <strong>Save Profile</strong> to apply your changes. Some changes may require re-verification.
                                    </div>
                                </li>
                            </ol>
                            <div class="callout callout-info">
                                <div class="callout-icon">
                                    <i class="fa fa-info-circle"></i>
                                </div>
                                <div class="callout-content">
                                    <strong>Note</strong>
                                    <p>Changes to your registered business name or legal entity may require additional KYC verification and can take 1–3 business days to process.</p>
                                </div>
                            </div>
                        </section>
                        <!-- Notification Preferences Section -->
                        <section class="doc-section" id="section-notifications">
                            <h2><i class="fa fa-bell" style="color:#2563eb;margin-right:8px;font-size:1.5rem;"></i>Notification Preferences</h2>
                            <p>Stay informed about transactions, security events, and important updates. Customize which notifications you receive and how they are delivered.</p>
                            <h3>Notification Channels</h3>
                            <div class="doc-table-wrapper">
                                <table class="doc-table">
                                    <thead>
                                        <tr>
                                            <th>Channel</th>
                                            <th>Description</th>
                                            <th>Default</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><i class="fa fa-mobile-alt" style="color:#2563eb;margin-right:6px;"></i> Push Notifications</td>
                                            <td>Real-time alerts on your mobile device for payments and security events</td>
                                            <td><span class="badge badge-recommended">Enabled</span></td>
                                        </tr>
                                        <tr>
                                            <td><i class="fa fa-envelope" style="color:#2563eb;margin-right:6px;"></i> Email</td>
                                            <td>Transaction summaries, daily/weekly reports, and account alerts</td>
                                            <td><span class="badge badge-recommended">Enabled</span></td>
                                        </tr>
                                        <tr>
                                            <td><i class="fa fa-sms" style="color:#2563eb;margin-right:6px;"></i> SMS</td>
                                            <td>Critical security alerts and high-value transaction notifications</td>
                                            <td><span class="badge badge-recommended">Enabled</span></td>
                                        </tr>
                                        <tr>
                                            <td><i class="fa fa-volume-up" style="color:#2563eb;margin-right:6px;"></i> In-App Sounds</td>
                                            <td>Audio feedback for completed payments and alerts</td>
                                            <td><span class="badge badge-optional">Optional</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="toggle-list">
</div>
                            <div class="callout callout-warning">
                                <div class="callout-icon">
                                    <i class="fa fa-exclamation-triangle"></i>
                                </div>
                                <div class="callout-content">
                                    <strong>Important</strong>
                                    <p>Security Alerts cannot be fully disabled. Critical security notifications (e.g., unauthorized access attempts) will always be sent regardless of your preferences.</p>
                                </div>
                            </div>
                        </section>
                        <!-- Security operations Section -->
                        <section class="doc-section" id="section-security">
                            <h2><i class="fa fa-shield-alt" style="color:#2563eb;margin-right:8px;font-size:1.5rem;"></i>Security operations</h2>
                            <p>Protect your business and customer data with MPay's robust security features. We recommend enabling all available security options for maximum protection.</p>
                            <div class="security-features">
                                <div class="security-feature">
                                    <div class="security-feature-icon">
                                        <i class="fa fa-lock"></i>
                                    </div>
                                    <div class="security-feature-title">PIN Protection</div>
                                    <div class="security-feature-desc">6 digit PIN required for app access and transaction approval</div>
                                </div>
                                <div class="security-feature">
                                    <div class="security-feature-icon">
                                        <i class="fa fa-fingerprint"></i>
                                    </div>
                                    <div class="security-feature-title">Biometric Auth</div>
                                    <div class="security-feature-desc">Use fingerprint or face recognition for quick, secure access</div>
                                </div>
                                <div class="security-feature">
                                    <div class="security-feature-icon">
                                        <i class="fa fa-key"></i>
                                    </div>
                                    <div class="security-feature-title">OTP Verification</div>
                                    <div class="security-feature-desc">OTP is required in mPay Wallet sign in process to protect your account.</div>
                                </div>
                            </div>
                            <h3>Setting Up Your PIN</h3>
                            <ol class="steps">
                                <li class="step">
                                    <div class="step-number">1</div>
                                    <div class="step-title">Navigate to Security</div>
                                    <div class="step-desc">Go to <strong>operations</strong> → <strong>Security</strong> → <strong>PIN operations</strong>.
                                    </div>
                                </li>
                                <li class="step">
                                    <div class="step-number">2</div>
                                    <div class="step-title">Create Your PIN</div>
                                    <div class="step-desc">Enter a 6 digit PIN. Avoid simple patterns like <code>123456</code> or <code>000000</code>.
                                    </div>
                                </li>
                                <li class="step">
                                    <div class="step-number">3</div>
                                    <div class="step-title">Confirm PIN</div>
                                    <div class="step-desc">Re-enter your PIN to confirm. Your PIN is now active.</div>
                                </li>
                            </ol>
                            <ol class="steps">
</ol>
                            <div class="callout callout-danger">
                                <div class="callout-icon">
                                    <i class="fa fa-exclamation-circle"></i>
                                </div>
                                <div class="callout-content">
                                    <strong>Critical: Ensure PIN is backed with biometrics</strong>
                                    <p>If <b>biometric</b> authentication is available, it will be used as the default sign-in method. If the biometric attempt is unsuccessful, the user will be prompted to enter their PIN.</p>
                                </div>
                            </div>
                            <div class="doc-table-wrapper">
                                <table class="doc-table">
                                    <thead>
</thead>
                                    <tbody>
                                        <tr>
</tr>
                                        <tr>
</tr>
                                        <tr>
</tr>
                                        <tr>
</tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                        <!-- Payment Preferences Section -->
                        <section class="doc-section" id="section-payment">
                            <h2><i class="fa fa-credit-card" style="color:#2563eb;margin-right:8px;font-size:1.5rem;"></i>Payment Preferences</h2>
                            <p>Set up and configure your business structure by managing branches, staff, and terminals.</p>
                            <h3>Manage Branches and Cashiers</h3>
                            <div class="operations-grid">
                                <div class="setting-card">
                                    <div class="setting-card-header">
                                        <div class="setting-card-icon">
                                            <i class="fa fa-dollar-sign"></i>
                                        </div>
                                        <div class="setting-card-title">Manage Branches</div>
                                    </div>
                                    <div class="setting-card-desc">Manage branch information by adding, updating, or removing branch locations and configuring their operational details.</div>
                                </div>
                                <div class="setting-card">
                                    <div class="setting-card-header">
                                        <div class="setting-card-icon">
                                            <i class="fa fa-percent"></i>
                                        </div>
                                        <div class="setting-card-title">Manage Cashiers</div>
                                    </div>
                                    <div class="setting-card-desc">Manage cashier profiles by creating, updating, or removing cashier accounts and assigning the necessary access permissions for performing transactions.</div>
                                </div>
                            </div>
                            <h3>Setting up the Store</h3>
                            <p>Adding a <b>Branch</b><span>&nbsp;is required before <b>creating a cashier&nbsp;</b><span>&nbsp;user.</span></span></p>
                            <div class="code-block">
</div>
                            <h2>Manage Merchant Operations</h2>
                            <h3>Opening a Branch Operations</h3>
                            <div class="step">
                                <div class="step-number">1</div>
                                <div class="step-title">Login to Merchant App as Admin/Owner</div>
                                <div class="step-desc">Go to <strong>Menu</strong> &rarr; <strong>Merchant Operations</strong>&nbsp;
                                </div>
                            </div>
                            <div class="step">
                                <div class="step-number">2</div>
                                <div class="step-title">Select a branch.</div>
                                <div class="step-desc">Select the branch you want to open from the dropdown list.</div>
                            </div>
                            <div class="step">
                                <div class="step-number">3</div>
                                <div class="step-title">Open the Store</div>
                                <div class="step-desc">Tap on <b>Open Store</b>
                                    <span>&nbsp;button.</span>
                                </div>
                            </div>
                            <h3>Closing the Branch Operations</h3>
                            <div class="step">
                                <div class="step-number">1</div>
                                <div class="step-title">Login to Merchant App as Admin/Owner</div>
                                <div class="step-desc">Go to <strong>Menu</strong> &rarr; <strong>Merchant Operations</strong>&nbsp;
                                </div>
                            </div>
                            <div class="step">
                                <div class="step-number">2</div>
                                <div class="step-title">Select a branch that is currently &quot;opened&quot;</div>
                                <div class="step-desc">Select the branch you want to close the operations for that business day.</div>
                            </div>
                            <div class="step">
                                <div class="step-number">3</div>
                                <div class="step-title">Open the Store</div>
                                <div class="step-desc">Tap on <b>Open Store</b>
                                    <span>&nbsp;button.</span>
                                </div>
                            </div>
                            <div class="toggle-list">
</div>
                            <div class="callout callout-success">
                                <div class="callout-icon">
                                    <i class="fa fa-lightbulb"></i>
                                </div>
                                <div class="callout-content">
                                    <strong>Tip</strong>
                                    <p>Once a store has been closed, the merchant cannot open the store for that day anymore.&nbsp;</p>
                                    <p>A store cannot be closed if there is an active cashier(s) under that branch.</p>
                                </div>
                            </div>
                            <h3>Payment Acceptance operations</h3>
                            <div class="doc-table-wrapper">
                                <table class="doc-table">
                                    <thead>
                                        <tr>
                                            <th>Setting</th>
                                            <th>Description</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>QR Code Payments</td>
                                            <td>Accept payments via dynamic and static QR codes</td>
                                            <td><span class="badge badge-required"><i class="fa fa-check-circle"></i> Required</span></td>
                                        </tr>
                                        <tr>
                                            <td>NFC Tap-to-Pay</td>
                                            <td>Accept contactless NFC payments from supported devices</td>
                                            <td><span class="badge badge-recommended"><i class="fa fa-star"></i> Recommended</span></td>
                                        </tr>
                                        <tr>
                                            <td>Wallet Transfers</td>
                                            <td>Accept direct wallet-to-wallet transfers from consumers</td>
                                            <td><span class="badge badge-recommended"><i class="fa fa-star"></i> Recommended</span></td>
                                        </tr>
                                        <tr>
                                            <td>Recurring Payments</td>
                                            <td>Set up subscription or recurring payment schedules</td>
                                            <td><span class="badge badge-optional">Optional</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                        <!-- FAQ Section -->
                        <section class="doc-section faq-section" id="section-faq">
                            <h2><i class="fa fa-question-circle" style="color:#2563eb;margin-right:8px;font-size:1.5rem;"></i>Frequently Asked Questions</h2>
                            <div class="faq-item">
                                <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-1">
                                    <span class="faq-question-text">How do I change my registered business name?</span>
                                    <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                </button>
                                <div class="faq-answer" id="faq-answer-1">
                                    <div class="faq-answer-content">
                                        <p>To change your registered business name, go to <strong>operations → Profile → Business Name</strong>. Note that changing your legal business name will require re-submission of KYC documents and may take 1–3 business days to verify. Your existing business name will remain active until the new name is approved.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="faq-item">
                                <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-2">
                                    <span class="faq-question-text">Can I use both biometric and PIN authentication simultaneously?</span>
                                    <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                </button>
                                <div class="faq-answer" id="faq-answer-2">
                                    <div class="faq-answer-content">
                                        <p>Yes! We recommend using both. Biometric authentication serves as the primary quick-access method, while your PIN acts as a fallback. For high-value transactions (above your configured threshold), both may be required for added security.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="faq-item">
                                <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-3">
                                    <span class="faq-question-text">How do I reset my PIN if I forget it?</span>
                                    <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                </button>
                                <div class="faq-answer" id="faq-answer-3">
                                    <div class="faq-answer-content">
                                        <p>If you forget your PIN, tap <strong>"Forgot PIN"</strong> on the PIN entry screen. You'll need to verify your identity using your registered email or phone number. A verification code will be sent, and once verified, you can set a new PIN. For security, a 24-hour cooldown may apply after multiple failed attempts.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="faq-item">
                                <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-4">
                                    <span class="faq-question-text">Can I customize the tipping percentages shown to customers?</span>
                                    <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                </button>
                                <div class="faq-answer" id="faq-answer-4">
                                    <div class="faq-answer-content">
                                        <p>Yes, you can fully customize the tipping screen. Go to <strong>operations → Payment Preferences → Tipping</strong> to change suggested percentages, set fixed amount options, choose a default suggestion, or disable tipping entirely. You can also set whether the tipping screen appears before or after the payment confirmation.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="faq-item">
                                <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-5">
                                    <span class="faq-question-text">How do I stop receiving promotional notifications?</span>
                                    <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                </button>
                                <div class="faq-answer" id="faq-answer-5">
                                    <div class="faq-answer-content">
                                        <p>Navigate to <strong>operations → Notifications → Promotional Updates</strong> and toggle it off. You can also manage email preferences by clicking the "Unsubscribe" link in any promotional email. Note that important service and security notifications cannot be disabled.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="faq-item">
                                <button class="faq-question" aria-expanded="false" aria-controls="faq-answer-6">
                                    <span class="faq-question-text">What happens to my operations if I switch devices?</span>
                                    <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                </button>
                                <div class="faq-answer" id="faq-answer-6">
                                    <div class="faq-answer-content">
                                        <p>Most operations are synced to your account and will transfer when you log in on a new device. However, device-specific operations like biometric authentication and in-app sound preferences will need to be reconfigured on the new device. Your PIN, 2FA, and notification preferences are preserved.</p>
                                    </div>
                                </div>
                            </div>
