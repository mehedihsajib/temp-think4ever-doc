                </div>
                <nav style="display:flex;align-items:center;gap:20px;" aria-label="Main navigation">
                    <a style="font-size:0.875rem;color:#334155;text-decoration:none;cursor:pointer;" onclick="load_page('merchant_docs_home')">Merchant</a>
                    <a style="font-size:0.875rem;color:#334155;text-decoration:none;cursor:pointer;" onclick="load_page('consumer_docs_home')">Consumer</a>
                    <a style="font-size:0.875rem;color:#334155;text-decoration:none;cursor:pointer;" onclick="load_page('blog_listing')">Blog</a>
                    <a style="font-size:0.875rem;color:#334155;text-decoration:none;cursor:pointer;" onclick="load_page('changelog_page')">Changelog</a>
                    <button style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:6px 14px;font-size:0.8125rem;color:#64748b;cursor:pointer;display:flex;align-items:center;gap:6px;" onclick="load_page('search_results')" aria-label="Search documentation">
                        <i class="fa fa-search"></i>
                        <span>Search...</span>
                        <kbd style="font-size:0.6875rem;background:#e2e8f0;border-radius:4px;padding:1px 5px;color:#94a3b8;">Ctrl+K</kbd>
                    </button>
