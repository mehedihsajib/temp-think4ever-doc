<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title data-i18n="search.title">Search Results</title>
        <link href="css/theme.css" rel="stylesheet" type="text/css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="assets/css/global.css">
        <link rel="stylesheet" href="assets/css/search_results.css">
        <style>/* Basic reset for preview consistency */body { margin: 0; padding: 0; font-family: sans-serif; }</style>
    </head>
    <body>
        <div class="search-results-page">
            <!-- Skip to content -->
            <a href="#sr-main-content" class="sr-only" style="position:absolute;top:-40px;left:0;background:#2563eb;color:#fff;padding:8px 16px;z-index:1000;" data-i18n="skip_to_main">Skip to main content</a>
            <!-- Header -->
            <header class="sr-header" role="banner">
                <div class="sr-header-inner">
                    <a class="sr-header-logo" onclick="load_page('index')" role="link" tabindex="0" aria-label="MPay Network Home" data-i18n-attr="aria-label:header.brand"> <img src="https://dev.think4ever.com/uifiles/20260311/ed3d2c21991e3bef5e069713af9fa6ca/only_m_with_white_bg_logo.png" alt="MPay Network Logo"/> <span data-i18n="header.brand">MPay Network</span> </a>
                    <nav class="sr-header-nav" role="navigation" aria-label="Main navigation">
                        <a onclick="load_page('merchant_docs_home')" tabindex="0" data-i18n="nav.merchant">Merchant Docs</a>
                        <a onclick="load_page('consumer_docs_home')" tabindex="0" data-i18n="nav.consumer">Consumer Docs</a>
                        <a onclick="load_page('blog_listing')" tabindex="0" data-i18n="nav.blog">Blog</a>
                        <a onclick="load_page('changelog_page')" tabindex="0" data-i18n="nav.changelog">Changelog</a>
                    </nav>

                    <div class="sr-header-actions" style="margin-left: auto; display: flex; align-items: center; gap: 1rem;">
                        <!-- Modern Language Dropdown -->
                        <div class="modern-lang-wrapper" id="langWrapper">
                            <button class="modern-lang-btn" id="modernLangBtn" aria-expanded="false" aria-haspopup="true">
                                <i class="fa fa-globe" style="font-size: 14px"></i>
                                <span id="current-lang-code" style="text-transform: uppercase" data-i18n="meta.lang_code">EN</span>
                                <i class="fa fa-chevron-down" style="font-size: 10px; margin-left: 2px"></i>
                            </button>
                            <div class="modern-lang-menu" id="modernLangMenu" role="menu">
                                <button onclick="changeLanguage('en')" data-lang-btn="en" class="lang-opt-en" role="menuitem">
                                    <span>English</span><span class="lang-code">EN</span>
                                </button>
                                <button onclick="changeLanguage('es')" data-lang-btn="es" class="lang-opt-es" role="menuitem">
                                    <span>Español</span><span class="lang-code">ES</span>
                                </button>
                                <button onclick="changeLanguage('fr')" data-lang-btn="fr" class="lang-opt-fr" role="menuitem">
                                    <span>Français</span><span class="lang-code">FR</span>
                                </button>
                                <button onclick="changeLanguage('it')" data-lang-btn="it" class="lang-opt-it" role="menuitem">
                                    <span>Italiano</span><span class="lang-code">IT</span>
                                </button>
                                <button onclick="changeLanguage('nl')" data-lang-btn="nl" class="lang-opt-nl" role="menuitem">
                                    <span>Nederlands</span><span class="lang-code">NL</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </header>
            <!-- Main Content -->
            <main class="sr-main" id="sr-main-content" role="main">
                <!-- Search Hero -->
                <section class="sr-search-hero">
                    <h1 data-i18n="search.hero_title">Search Documentation</h1>
                    <div class="sr-search-wrapper">
                        <i class="fa-solid fa-magnifying-glass sr-search-icon" aria-hidden="true"></i>
                        <input type="search" id="sr_search_input" placeholder="Search docs, blog posts, changelog..." autocomplete="off" aria-label="Search documentation" spellcheck="false" data-i18n-attr="placeholder:search.input_placeholder, aria-label:search.hero_title"/>
                        <button class="sr-clear-btn" aria-label="Clear search" type="button" data-i18n-attr="aria-label:clear_filters">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                        <button class="sr-search-btn" type="button" aria-label="Search" data-i18n-attr="aria-label:search.btn_search">
                            <i class="fa-solid fa-magnifying-glass"></i> <span data-i18n="search.btn_search">Search</span>
                        </button>
                    </div>
                </section>
                <!-- Recent Searches (shown when no query) -->
                <div id="sr_recent_searches" class="sr-recent-searches" aria-label="Recent searches" data-i18n-attr="aria-label:search.recent_label"></div>
                <!-- Meta Bar: Result Count + Filters -->
                <div class="sr-meta-bar" style="display: none;">
                    <div id="sr_result_count" class="sr-result-count" aria-live="polite" role="status">
                        <strong>0</strong> results found
                    </div>
                    <div id="sr_filter_type" class="sr-filter-group" role="group" aria-label="Filter results by content type">
                        <button class="sr-filter-btn active" data-filter="all" type="button">
                            <span data-i18n="search.filters.all">All</span> <span class="sr-filter-count">12</span>
                        </button>
                        <button class="sr-filter-btn" data-filter="merchant-docs" type="button">
                            <span data-i18n="search.filters.merchant">Merchant Docs</span> <span class="sr-filter-count">5</span>
                        </button>
                        <button class="sr-filter-btn" data-filter="consumer-docs" type="button">
                            <span data-i18n="search.filters.consumer">Consumer Docs</span> <span class="sr-filter-count">4</span>
                        </button>
                        <button class="sr-filter-btn" data-filter="blog" type="button">
                            <span data-i18n="search.filters.blog">Blog</span> <span class="sr-filter-count">2</span>
                        </button>
                        <button class="sr-filter-btn" data-filter="changelog" type="button">
                            <span data-i18n="search.filters.changelog">Changelog</span> <span class="sr-filter-count">1</span>
                        </button>
                    </div>
                </div>
                <!-- Results List -->
                <div id="sr_results_list" class="sr-results-list" role="feed" aria-label="Search results"></div>
                <!-- No Results State -->
                <div id="sr_no_results" class="sr-no-results" style="display: none;" role="status">
                    <div class="sr-no-results-icon">
                        <i class="fa-regular fa-face-frown"></i>
                    </div>
                    <h2 data-i18n="search.no_results.title">No results found</h2>
                    <p data-i18n="search.no_results.text">We couldn't find any matches for your search. Try adjusting your keywords or browse our documentation directly.</p>
                    <div class="sr-no-results-suggestions">
                        <h3 data-i18n="search.no_results.tips_title">Search tips:</h3>
                        <ul>
                            <li data-i18n="search.no_results.tip_broader">Try using broader or alternative keywords</li>
                            <li data-i18n="search.no_results.tip_spelling">Check your spelling and try again</li>
                            <li data-i18n="search.no_results.tip_fewer">Use fewer words to broaden the search</li>
                            <li data-i18n="search.no_results.tip_related">Try searching for a related topic</li>
                        </ul>
                    </div>
                    <button id="sr_back_home" class="sr-back-home-btn" onclick="load_page('index')" type="button">
                        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i> <span data-i18n="search.back_home">Back to Home</span>
                    </button>
                    <div class="sr-quick-links">
                        <a class="sr-quick-link" onclick="load_page('merchant_docs_home')" tabindex="0"><i class="fa-solid fa-store" aria-hidden="true"></i> <span data-i18n="search.filters.merchant">Merchant Docs</span></a>
                        <a class="sr-quick-link" onclick="load_page('consumer_docs_home')" tabindex="0"><i class="fa-solid fa-wallet" aria-hidden="true"></i> <span data-i18n="search.filters.consumer">Consumer Docs</span></a>
                        <a class="sr-quick-link" onclick="load_page('blog_listing')" tabindex="0"><i class="fa-solid fa-newspaper" aria-hidden="true"></i> <span data-i18n="search.filters.blog">Blog</span></a>
                        <a class="sr-quick-link" onclick="load_page('feedback_form')" tabindex="0"><i class="fa-solid fa-message" aria-hidden="true"></i> <span data-i18n="search.quick_links.feedback">Send Feedback</span></a>
                    </div>
                </div>
                <!-- Pagination -->
                <nav id="sr_pagination" class="sr-pagination" style="display: none;" role="navigation" aria-label="Search results pagination"></nav>
            </main>
            <!-- Footer -->
        </div>
        <div id="docFooter"></div>
        <script src="assets/js/i18n.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                if (window.I18n) {
                    window.I18n.init();
                }
            });
        </script>
        <script src="assets/js/navigation.js"></script>
        <script src="assets/js/search_results.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    </body>
</html>