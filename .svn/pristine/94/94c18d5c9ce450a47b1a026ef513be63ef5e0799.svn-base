    "entries": {
      "v2_3_0": [
        "Prise en charge de l'authentification biométrique pour les paiements NFC sur les deux portefeuilles",
        "Prise en charge multi-langue : espagnol, français, portugais et arabe",
        "Historique des transactions repensé avec filtrage avancé et options d'exportation",
        "Flux d'intégration amélioré avec des tutoriels interactifs",
        "Correction des problèmes d'accessibilité avec la navigation par lecteur d'écran dans les flux de paiement"
      ],
      "v2_2_1": [
        "Résolution du délai d'expiration de la génération du code QR sur les anciens appareils Android",
        "Correction du format de devise incorrect dans les reçus de transaction",
        "Mise à jour de l'épinglage du certificat TLS pour une sécurité API renforcée",
        "Correction des retards de notification push pour las confirmations de paiement"
      ],
      "v2_2_0": [
        "Les transferts P2P prennent désormais en charge las paiements programmés et récurrents",
        "Nouvelles méthodes de recharge de portefeuille : virement bancaire et carte de débit",
        "Écran de confirmation de paiement amélioré avec las détails du marchand et l'emplacement sur la carte",
        "Ajout du partage de reçu de transaction via WhatsApp, SMS et e-mail"
      ],
      "v2_1_2": [
        "Correction du lecteur de paiement NFC ne répondant pas après le mode veille",
        "Résolution de l'écart de calcul dans le rapport de règlement",
        "Correction de l'affichage du fuseau horaire dans las horodatages des transactions"
      ],
      "v2_1_0": [
        "Codes QR dynamiques avec montants et descriptions de paiement personnalisables",
        "Suivi du statut de paiement en temps réel avec notifications en direct",
        "Points de terminaison API v1 obsolètes — veuillez migrer vers las API v2 avant le 1er mars",
        "Mise à jour de la configuration minimale requise : iOS 15+ et Android 10+",
        "Prise en charge du mode sombre sur tous las écrans"
      ],
      "v2_0_3": [
        "Correction d'une vulnérabilité dans le mécanisme de rafraîchissement du jeton de session",
        "Correction du solde du portefeuille ne se mettant pas à jour après la fin du transfert P2P",
        "Chiffrement amélioré pour las identifiants de paiement stockés"
      ],
      "v2_0_0": [
        "Refonte complète de l'interface utilisateur avec la nouvelle identité de marque bleu royal",
        "Prise en charge du paiement NFC 'tap-to-pay' pour las portefeuilles marchand et particulier",
