      },
      "e5001": {
        "desc": "Échec du rechargement",
        "res": "Vérifiez les détails de votre banque/carte lié. Contactez votre banque si le problème persiste."
      },
      "e5002": {
        "desc": "Délai de traitement du retrait",
        "res": "Les retraits peuvent prendre 1 à 3 jours ouvrables. Aucune action n'est requise sauf si le délai dépasse 5 jours."
      },
      "e9999": {
        "desc": "Erreur interne du serveur",
        "res": "Une erreur inattendue s'est produite. Redémarrez l'application et réessayez. Si cela persiste, contactez le support."
      },
      "callout": "Vous pouvez trouver votre code d'erreur en appuyant sur le message d'erreur dans l'application. Le code apparaît en bas de la boîte de dialogue de l'erreur. Incluez ce code lorsque vous contactez le support pour une résolution plus rapide."
    },
    "contact_support": {
      "title": "Contacter le Support",
      "desc": "Si vous ne parvenez pas à résoudre votre problème à l'aide des guides ci-dessus, notre équipe de support est là pour vous aider.",
      "ticket": {
        "title": "Ticket de Support",
        "desc": "Envoyez une demande de support détaillée et recevez une réponse sous 24 heures.",
