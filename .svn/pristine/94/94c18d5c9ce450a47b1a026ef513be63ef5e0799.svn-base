  "page": {
    "title": "Premiers pas avec le Portefeuille Particulier",
    "subtitle": "Tout ce dont vous avez besoin pour télécharger, installer et configurer votre portefeuille mPay. Suivez ce guide étape par étape pour commencer à effectuer des paiements rapides et sécurisés en quelques minutes.",
    "time_badge": "Temps de configuration estimé : 5 minutes"
  },
  "toc": {
    "on_this_page": "Sur cette page",
    "requirements": "Configuration requise",
    "download": "Téléchargement et installation",
    "install_steps": "Étapes d'installation",
    "signup": "S'inscrire",
    "first_login": "Première connexion et configuration",
