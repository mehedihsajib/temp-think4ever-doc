    "title": "Dépannage",
    "subtitle": "Trouvez des solutions aux problèmes courants, comprenez les codes d'erreur et apprenez à résoudre les problèmes avec votre portefeuille mPay.",
    "search_placeholder": "Rechercher des problèmes, des codes d'erreur et des FAQ...",
    "diagnostic": {
      "title": "Outil de Diagnostic Rapide",
      "intro": "Lancez une vérification rapide pour identifier les problèmes potentiels avec la configuration de votre portefeuille. Ce diagnostic vérifie les points de configuration courants.",
      "check_internet": "Connectivité Internet",
      "check_version": "Version de l'application à jour",
      "check_permissions": "Autorisations requises accordées",
      "check_nfc": "Matériel NFC disponible",
      "check_storage": "Espace de stockage suffisant",
