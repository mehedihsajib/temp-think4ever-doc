  "requirements": {
    "heading": "Configuration requise",
    "intro": "Avant de télécharger, assurez-vous que votre appareil répond aux exigences minimales :",
    "ios": {
      "name": "iOS",
      "desc": "iOS 15.0 ou version ultérieure. Compatible avec l'iPhone 8 et les modèles plus récents. Environ 85 Mo de stockage requis."
    },
    "android": {
      "name": "Android",
      "desc": "Android 10.0 (API niveau 29) ou version ultérieure. Environ 60 Mo de stockage requis."
    },
    "nfc_callout_title": "Exigence NFC",
    "nfc_callout_body": "Pour la fonctionnalité de paiement sans contact (tap-to-pay), votre appareil doit disposer du matériel NFC. La plupart des smartphones modernes (iPhone 7+ et Android avec NFC) prennent en charge cette fonctionnalité."
  },
  "download": {
    "heading": "Téléchargement et installation",
    "intro": "Le portefeuille mPay est disponible gratuitement sur les deux principaux magasins d'applications. Choisissez votre plateforme ci-dessous :",
    "ios_btn": "App Store",
    "ios_btn_pre": "Télécharger dans l'",
    "android_btn": "Google Play",
    "android_btn_pre": "Disponible sur",
    "install_steps_heading": "Étapes d'installation",
    "steps": {
      "1": {
        "title": "Ouvrez votre magasin d'applications",
        "content": "Ouvrez l'<strong>App Store</strong> (iOS) ou le <strong>Google Play Store</strong> (Android) sur votre appareil."
      },
      "2": {
        "title": "Recherchez mPay Wallet",
        "content": "Tapez <code>mPay Consumer Wallet</code> dans la barre de recherche. Recherchez l'application officielle avec le logo mPay et \"mPay Network\" comme développeur."
      },
      "3": {
        "title": "Téléchargez et installez",
        "content": "Appuyez sur <strong>Obtenir</strong> (iOS) ou <strong>Installer</strong> (Android). L'application se téléchargera et s'installera automatiquement. Vous devrez peut-être vous authentifier avec votre mot de passe, Face ID ou empreinte digitale."
      },
      "4": {
        "title": "Ouvrez l'application",
        "content": "Une fois installée, appuyez sur <strong>Ouvrir</strong> ou trouvez l'icône mPay sur votre écran d'accueil. L'application se lancera sur l'écran de bienvenue."
      }
    },
    "verify_callout_title": "Vérifiez le développeur",
    "verify_callout_body": "Vérifiez toujours que le développeur est répertorié comme \"mPay Network\" avant de télécharger. N'installez pas d'applications provenant de sources non officielles."
  },
  "signup": {
    "heading": "S'inscrire",
    "intro": "La création de votre compte mPay est rapide et simple. Vous aurez besoin d'un numéro de téléphone et d'une adresse e-mail valides.",
    "steps": {
      "1": {
        "title": "Êtes-vous déjà client mPay ?",
        "content": "Sur l'écran de bienvenue, il vous sera demandé si vous <strong>\"Êtes déjà client ?\"</strong>. Pour les nouveaux clients, appuyez sur le bouton <strong>NON</strong>. Si vous avez déjà un compte, sélectionnez le bouton <strong>OUI</strong>."
      },
      "2": {
        "title": "Formulaire d'inscription",
        "content": "L'utilisateur est redirigé vers le formulaire <strong>Inscription d'un nouveau particulier</strong>."
      },
      "3": {
        "title": "Informations requises",
        "content": "L'<strong>Identifiant utilisateur</strong>, l'<strong>Adresse e-mail</strong> et le <strong>Numéro de mobile</strong> doivent être uniques pour chaque client.",
        "info_callout": "Lors de la soumission de l'inscription, le système vérifie si ces informations sont déjà utilisées par des clients mPay existants."
      },
      "4": {
        "title": "Remplissez tous les champs",
        "intro": "Saisissez vos informations de base :",
        "field_name": "<strong>Prénom et Nom</strong> — Tels qu'ils apparaissent sur votre pièce d'identité",
        "field_email": "<strong>Adresse e-mail</strong> — Une adresse valide pour les notifications et la récupération",
        "field_mobile": "<strong>Numéro de mobile</strong> — Doit être un numéro valide pour recevoir le SMS de vérification",
        "field_referral": "<strong>Code de parrainage</strong> — Champ optionnel si vous avez été parrainé."
      },
      "5": {
        "title": "Acceptez les conditions",
        "intro": "Deux cases doivent être cochées avant de poursuivre :",
        "check_terms": "Accepter les <strong>Conditions Générales</strong>",
        "check_security": "Politique de sécurité stipulant qu'un seul utilisateur est autorisé par appareil : <em>\"J'accepte que l'inscription d'un nouveau client supprime le compte existant lié à cet appareil.\"</em>"
      },
      "6": {
        "title": "Option d'identification sur l'App Marchand",
        "intro": "Choisissez si votre e-mail et votre numéro de mobile peuvent être utilisés pour vous identifier sur l'application Marchand.",
        "check_terms": "Accepter les <strong>Conditions Générales</strong>",
        "check_security": "Politique de sécurité (un seul utilisateur par appareil)."
      }
    },
    "success_callout_title": "Compte créé !",
    "success_callout_body": "Dès que l'écran de confirmation apparaît, votre compte est prêt. Vous pouvez maintenant configurer votre profil et votre portefeuille."
  },
  "first_login": {
    "heading": "Première connexion et configuration",
    "intro": "Après avoir créé votre compte, vous serez guidé par un assistant de configuration initiale :",
    "profile_heading": "Configuration du profil",
    "profile_steps": {
      "1": {
        "title": "Ajoutez vos informations personnelles",
        "content": "Saisissez votre nom complet tel qu'il figure sur votre pièce d'identité officielle. Ajoutez éventuellement une photo de profil pour être identifié facilement lors des transferts P2P."
      },
      "2": {
        "title": "Configurez la sécurité",
        "content": "Choisissez votre méthode d'authentification préférée :",
        "pin": "<strong>Code PIN</strong> — Définissez un code à 6 chiffres pour un accès rapide",
        "biometric": "<strong>Biométrie</strong> — Activez Face ID ou l'authentification par empreinte digitale",
        "recommend": "Nous recommandons d'activer les deux pour une sécurité maximale"
      },
      "3": {
        "title": "Activez les notifications",
        "content_pre": "Autorisez les notifications push pour recevoir des confirmations de paiement instantanées, des alertes de sécurité et des offres. Vous pourrez les personnaliser plus tard dans les ",
        "settings_link": "Paramètres",
        "content_post": "."
      }
    },
    "wallet_heading": "Configuration du portefeuille",
    "wallet_steps": {
      "1": {
        "title": "Personnalisez votre profil",
        "content": "Définissez une photo de profil pour votre compte de portefeuille."
      },
      "2": {
        "title": "Gestion des préférences de notification",
        "content": "Vous pouvez activer ou désactiver les options de notification selon vos préférences."
      },
      "3": {
        "title": "Terminez la configuration",
        "content": "Appuyez sur <strong>Terminer la configuration</strong> pour accéder à votre tableau de bord. Vous êtes prêt à payer !"
      }
    },
    "tip_callout_title": "Conseil : Vérifiez votre identité tôt",
    "tip_callout_body": "Le processus de vérification peut prendre de 24 à 48 heures. Il est conseillé de compléter votre profil dès que possible pour accéder à toutes les fonctionnalités."
  },
  "screenshots": {
    "heading": "Aperçu de la configuration",
    "intro": "Voici un aperçu visuel des principaux écrans lors de la configuration :",
    "step1_label": "Écran de bienvenue",
    "step1_sublabel": "Créer un compte ou se connecter",
    "step1_caption": "Étape 1 : Écran de bienvenue",
    "step2_label": "Vérification du téléphone",
    "step2_sublabel": "Saisir le code OTP",
    "step2_caption": "Étape 2 : Vérifier le téléphone",
    "step3_label": "Sécurité",
    "step3_sublabel": "PIN et Biométrie",
    "step3_caption": "Étape 3 : Configurer la sécurité",
    "step4_label": "Infos du profil",
    "step4_sublabel": "Nom et Photo",
    "step4_caption": "Étape 4 : Votre profil",
    "step5_label": "Configuration du portefeuille",
    "step5_sublabel": "Devise et Financement",
    "step5_caption": "Étape 5 : Configurer le portefeuille",
    "step6_label": "C'est prêt !",
    "step6_sublabel": "Tableau de bord prêt",
    "step6_caption": "Étape 6 : Prêt à partir !"
  },
  "faq": {
    "heading": "Foire Aux Questions",
    "q1": "Puis-je utiliser mPay Wallet sur plusieurs appareils ?",
    "a1": "Oui, vous pouvez vous connecter sur plusieurs appareils. Cependant, pour des raisons de sécurité, <b>un seul appareil peut être actif à la fois</b>. Se connecter sur un nouvel appareil déconnectera automatiquement le précédent.",
    "q2": "Que faire si je ne reçois pas le code OTP ?",
    "a2": "Si vous ne recevez pas l'OTP dans les 60 secondes, appuyez sur \"Renvoyer le code\". Assurez-vous d'avoir du réseau. Si le problème persiste, essayez l'option \"Appelez-moi\" pour une vérification vocale.",
    "q3": "Y a-t-il un dépôt minimum pour commencer ?",
    "a3": "Non, aucun dépôt minimum n'est requis. Vous pouvez créer votre compte et explorer l'application sans fonds. Vous créditerez votre portefeuille au moment de payer.",
    "q4": "Puis-je changer mon numéro après l'inscription ?",
    "a4": "Oui, via la page Paramètres. Vous devrez vérifier votre identité et le nouveau numéro par OTP. Une période de carence de 24h peut s'appliquer pour certaines fonctions.",
    "q5": "Que faire si l'application plante pendant la configuration ?",
    "a5": "Réouvrez-la simplement. Votre progression est sauvegardée à chaque étape. Si cela persiste, videz le cache (Android) ou réinstallez l'application (iOS).",
    "q6": "Mes données sont-elles sécurisées lors de l'inscription ?",
    "a6": "Absolument. Toutes les données sont cryptées via le standard TLS 1.3. Vos informations sont stockées de manière sécurisée et jamais partagées sans votre consentement."
  },
