    "common_issues": {
      "title": "Problèmes Courants",
      "desc": "Vous trouverez ci-dessous les problèmes les plus fréquemment rencontrés et leurs solutions étape par étape.",
      "issue1": {
        "title": "Impossible de se connecter au serveur",
        "summary": "L'application affiche \"Erreur de connexion\" ou met trop de temps à se charger.",
        "causes": "Causes Possibles",
        "cause1": "Connexion Internet instabile (Wi-Fi ou données mobiles)",
        "cause2": "Les serveurs de MPay Network peuvent être en maintenance",
        "cause3": "Interférence d'un VPN ou d'un proxy",
        "cause4": "Version de l'application obsolète",
        "solution": "Solution",
        "step1": "Vérifiez votre connexion Internet en ouvrant une page Web dans votre navigateur.",
        "step2": "Activez et désactivez le mode avion, puis réessayez.",
        "step3": "Désactivez temporairement tout service VPN ou proxy.",
        "step4": "Mettez à jour l'application MPay de votre magasin d'applications.",
        "step5": "Si le problème persiste, consultez la <a href=\"#\" style=\"color:#2563eb;\">Page de Statut MPay</a> pour les incidents en cours.",
        "callout": "La maintenance du serveur dure généralement de 15 à 30 minutes et est planifiée pendant les heures creuses (2h00 — 4h00 heure locale)."
      },
      "issue2": {
        "title": "Le code QR ne s'affiche pas ou ne se scanne pas",
        "summary": "L'appareil photo ne parvient pas à détecter ou à lire les codes QR des marchands.",
        "causes": "Causes Possibles",
        "cause1": "Autorisation de l'appareil photo non accordée à l'application",
        "cause2": "Mauvaises conditions d'éclairage",
        "cause3": "Code QR endommagé ou flou",
        "cause4": "L'objectif de l'appareil photo est sale ou obstrué",
        "solution": "Solution",
        "step1": "Allez dans <strong>Paramètres → Autorisations d'application</strong> et assurez-vous que l'accès à l'appareil photo est activé pour MPay.",
        "step2": "Nettoyez l'objectif de votre appareil photo avec un chiffon doux.",
        "step3": "Assurez un éclairage adéquat — utilisez le bouton de lampe de poche dans la vue du scanner.",
        "step4": "Tenez votre téléphone fermement, à environ 15-30 cm du code QR.",
        "step5": "Si le code QR est sur un écran, réduisez les reflets en ajustant l'angle.",
        "callout": "Si le code QR semble endommagé ou corrompu, demandez au marchand d'en générer un nouveau."
      },
      "issue3": {
        "title": "Échec du paiement NFC",
        "summary": "Le paiement sans contact n'est pas détecté ou la transaction ne se termine pas.",
        "causes": "Causes Possibles",
        "cause1": "NFC désactivé sur votre appareil",
        "cause2": "La coque du téléphone bloque l'antenne NFC",
        "cause3": "L'appareil n'est pas positionné correctement sur le terminal",
        "cause4": "Solde du portefeuille insuffisant",
        "solution": "Solution",
        "step1": "Activez le NFC dans les paramètres de votre téléphone : <span class=\"ctr-code\">Paramètres → Appareils connectés → NFC</span>",
        "step2": "Retirez toute coque épaisse ou accessoire métallique qui pourrait bloquer le NFC.",
        "step3": "Maintenez le dos de votre téléphone contre le terminal pendant 2-3 secondes.",
        "step4": "Assurez-vous que votre portefeuille dispose d'un solde suffisant pour la transaction.",
        "callout": "L'emplacement de l'antenne NFC varie selon le modèle de téléphone. La plupart des téléphones Android l'ont dans la zone centrale supérieure à l'arrière. Les iPhones utilisent le bord supérieur."
      },
      "issue4": {
        "title": "L'authentification biométrique ne fonctionne pas",
        "summary": "La reconnaissance d'empreintes digitales ou faciale ne parvient pas à vous authentifier.",
        "causes": "Causes Possibles",
        "cause1": "Données biométriques modifiées sur l'appareil (nouvelle empreinte ajoutée)",
        "cause2": "Capteur biométrique sale ou endommagé",
        "cause3": "Autorisation biométrique révoquée pour l'application",
        "solution": "Solution",
        "step1": "Connectez-vous en utilisant votre code PIN comme solution de secours.",
        "step2": "Allez dans <strong>Paramètres MPay → Sécurité → Connexion Biométrique</strong> et réactivez-la.",
        "step3": "Si vous y êtes invité, réenregistrez vos données biométriques.",
        "step4": "Nettoyez le capteur d'empreintes digitales ou assurez-vous que la reconnaissance faciale a une vue dégagée."
      },
      "issue5": {
        "title": "Transfert P2P bloqué ou en attente",
        "summary": "L'argent a été envoyé mais le destinataire ne l'a pas reçu.",
        "causes": "Causes Possibles",
        "cause1": "Congestion du réseau provoquant des retards",
        "cause2": "Le compte du destinataire peut avoir des restrictions",
        "cause3": "Le montant de la transaction dépasse les limites quotidiennes",
        "cause4": "Examen de conformité pour les montants élevés",
        "solution": "Solution",
        "step1": "Vérifiez le statut de la transaction dans <strong>Activité → Historique des transactions</strong>.",
        "step2": "Si le statut est \"En cours\", attendez jusqu'à 30 minutes pour la fin de l'opération.",
        "step3": "Si le statut est \"En attente d'examen\", votre transaction est en cours de vérification. Vous recevrez une notification une fois résolu.",
        "step4": "Si le transfert est bloqué depuis plus de 2 heures, contactez le support avec l'ID de transaction.",
        "callout": "<strong>Ne renvoyez pas</strong> le même transfert alors que l'original est encore en cours. Cela pourrait entraîner un double débit."
      },
      "issue6": {
        "title": "Échec du rechargement ou du retrait",
        "summary": "Impossible d'ajouter des fonds ou de retirer de l'argent du portefeuille.",
        "causes": "Causes Possibles",
        "cause1": "Compte bancaire ou carte non vérifié",
        "cause2": "Limites quotidiennes ou mensuelles dépassées",
        "cause3": "La banque rejette la transaction",
        "cause4": "Vérification du compte incomplète",
        "solution": "Solution",
        "step1": "Vérifiez votre compte bancaire/carte lié dans <strong>Paramètres → Méthodes de paiement</strong>.",
        "step2": "Consultez vos limites actuelles dans <strong>Paramètres → Limites</strong>.",
        "step3": "Effectuez la vérification KYC pour débloquer des limites plus élevées.",
        "step4": "Contactez votre banque pour vous assurer qu'il n'y a pas de blocage sur les transactions en ligne."
      }
    },
