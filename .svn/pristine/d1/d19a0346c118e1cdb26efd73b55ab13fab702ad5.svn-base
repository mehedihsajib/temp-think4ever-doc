/* Merchant NFC Payments Page CSS */

.merchant-nfc-page {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}

.merchant-nfc-page .docs-layout {
  display: flex;
  flex: 1;
  max-width: 1440px;
  margin: 0 auto;
  width: 100%;
}

/* Sidebar */
.merchant-nfc-page .docs-sidebar {
  width: 280px;
  min-width: 280px;
  border-right: 1px solid var(--color-border, #bfdbfe);
  background: var(--color-surface, #eff6ff);
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
  padding: 24px 0;
  scrollbar-width: thin;
  scrollbar-color: #bfdbfe transparent;
  z-index: 10;
}

.merchant-nfc-page .docs-sidebar::-webkit-scrollbar {
  width: 4px;
}

.merchant-nfc-page .docs-sidebar::-webkit-scrollbar-thumb {
  background: #bfdbfe;
  border-radius: 4px;
}

.merchant-nfc-page .sidebar-section {
  margin-bottom: 8px;
}

.merchant-nfc-page .sidebar-section-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  padding: 8px 24px;
  margin-bottom: 2px;
}

.merchant-nfc-page .sidebar-link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 24px;
  font-size: 0.875rem;
  color: #334155;
  text-decoration: none;
  cursor: pointer;
  border-radius: 0;
  transition: all 150ms ease;
  position: relative;
  line-height: 1.5;
}

.merchant-nfc-page .sidebar-link:hover {
  background: rgba(37, 99, 235, 0.06);
  color: #2563eb;
}

.merchant-nfc-page .sidebar-link.active {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
  font-weight: 500;
  border-right: 3px solid #2563eb;
}

.merchant-nfc-page .sidebar-link i {
  width: 18px;
  text-align: center;
  font-size: 0.8rem;
  opacity: 0.7;
}

.merchant-nfc-page .sidebar-link.active i {
  opacity: 1;
}

/* Mobile sidebar toggle */
.merchant-nfc-page .sidebar-toggle {
  display: none;
  position: fixed;
  bottom: 20px;
  left: 20px;
  z-index: 100;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #2563eb;
  color: white;
  border: none;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  cursor: pointer;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  transition: background 150ms ease;
}

.merchant-nfc-page .sidebar-toggle:hover {
  background: #1d4ed8;
}

.merchant-nfc-page .sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 49;
}

/* Main Content */
.merchant-nfc-page .docs-main {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: center;
}

.merchant-nfc-page .docs-content {
  max-width: 860px;
  width: 100%;
  padding: 32px 48px 64px;
}

/* TOC Sidebar */
.merchant-nfc-page .docs-toc {
  width: 220px;
  min-width: 220px;
  position: sticky;
  top: 88px;
  height: calc(100vh - 88px);
  overflow-y: auto;
  padding: 32px 16px 32px 0;
  scrollbar-width: none;
}

.merchant-nfc-page .docs-toc::-webkit-scrollbar {
  display: none;
}

.merchant-nfc-page .toc-title {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin-bottom: 12px;
}

.merchant-nfc-page .toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.merchant-nfc-page .toc-list li {
  margin-bottom: 2px;
}

.merchant-nfc-page .toc-list a {
  display: block;
  padding: 4px 12px;
  font-size: 0.8125rem;
  color: #64748b;
  text-decoration: none;
  border-left: 2px solid transparent;
  transition: all 150ms ease;
  line-height: 1.5;
}

.merchant-nfc-page .toc-list a:hover {
  color: #2563eb;
  border-left-color: #bfdbfe;
}

.merchant-nfc-page .toc-list a.active {
  color: #2563eb;
  font-weight: 500;
  border-left-color: #2563eb;
}

.merchant-nfc-page .toc-list .toc-sub {
  padding-left: 24px;
}

/* Breadcrumb */
.merchant-nfc-page .breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: #64748b;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.merchant-nfc-page .breadcrumb a {
  color: #64748b;
  text-decoration: none;
  transition: color 150ms ease;
}

.merchant-nfc-page .breadcrumb a:hover {
  color: #2563eb;
}

.merchant-nfc-page .breadcrumb .separator {
  font-size: 0.75rem;
  color: #94a3b8;
}

.merchant-nfc-page .breadcrumb .current {
  color: #2563eb;
  font-weight: 500;
}

/* Page Title */
.merchant-nfc-page .page-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: #1e3a8a;
  letter-spacing: -0.025em;
  line-height: 1.25;
  margin-bottom: 8px;
  padding-bottom: 16px;
  border-bottom: 2px solid #bfdbfe;
}

.merchant-nfc-page .page-subtitle {
  font-size: 1.0625rem;
  color: #64748b;
  line-height: 1.6;
  margin-bottom: 40px;
}

/* NFC Visual Header */
.merchant-nfc-page .nfc-hero-visual {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40px;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 50%, #eff6ff 100%);
  border: 1px solid #bfdbfe;
  border-radius: 16px;
  padding: 40px;
  margin-bottom: 48px;
  position: relative;
  overflow: hidden;
}

.merchant-nfc-page .nfc-animation-container {
  position: relative;
  width: 120px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.merchant-nfc-page .nfc-icon-center {
  width: 56px;
  height: 56px;
  background: #2563eb;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 1.5rem;
  z-index: 2;
  position: relative;
}

.merchant-nfc-page .nfc-wave {
  position: absolute;
  border: 2px solid rgba(37, 99, 235, 0.3);
  border-radius: 50%;
  animation: nfc-pulse 2s ease-out infinite;
}

.merchant-nfc-page .nfc-wave:nth-child(2) {
  width: 80px;
  height: 80px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation-delay: 0s;
}

.merchant-nfc-page .nfc-wave:nth-child(3) {
  width: 100px;
  height: 100px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation-delay: 0.4s;
}

.merchant-nfc-page .nfc-wave:nth-child(4) {
  width: 120px;
  height: 120px;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation-delay: 0.8s;
}

@keyframes nfc-pulse {
  0% {
    opacity: 0.7;
    transform: translate(-50%, -50%) scale(0.85);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.3);
  }
}

.merchant-nfc-page .nfc-hero-text {
  flex: 1;
  max-width: 400px;
}

.merchant-nfc-page .nfc-hero-text h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.25rem;
  font-weight: 700;
  color: #1e3a8a;
  margin-bottom: 8px;
}

.merchant-nfc-page .nfc-hero-text p {
  font-size: 0.9375rem;
  color: #475569;
  line-height: 1.6;
}

/* Section Headings */
.merchant-nfc-page .doc-section {
  margin-bottom: 48px;
}

.merchant-nfc-page .doc-section h2 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.875rem;
  font-weight: 700;
  color: #1e3a8a;
  letter-spacing: -0.02em;
  line-height: 1.25;
  margin-top: 0;
  margin-bottom: 8px;
  padding-bottom: 12px;
  border-bottom: 1px solid #e2e8f0;
  scroll-margin-top: 80px;
}

.merchant-nfc-page .doc-section h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.25rem;
  font-weight: 600;
  color: #1e3a8a;
  margin-top: 32px;
  margin-bottom: 12px;
  scroll-margin-top: 80px;
}

.merchant-nfc-page .doc-section h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.125rem;
  font-weight: 600;
  color: #334155;
  margin-top: 24px;
  margin-bottom: 8px;
}

.merchant-nfc-page .doc-section p {
  font-size: 1rem;
  color: #334155;
  line-height: 1.625;
  margin-bottom: 16px;
}

/* Callout Boxes */
.merchant-nfc-page .callout {
  display: flex;
  gap: 16px;
  padding: 16px 20px;
  border-radius: 8px;
  margin-bottom: 20px;
  border-left: 4px solid;
}

.merchant-nfc-page .callout-icon {
  font-size: 1.125rem;
  margin-top: 2px;
  flex-shrink: 0;
}

.merchant-nfc-page .callout-content {
  flex: 1;
}

.merchant-nfc-page .callout-content strong {
  display: block;
  margin-bottom: 4px;
  font-size: 0.875rem;
}

.merchant-nfc-page .callout-content p {
  margin: 0;
  font-size: 0.875rem;
  line-height: 1.6;
}

.merchant-nfc-page .callout.info {
  background: #eff6ff;
  border-left-color: #2563eb;
}

.merchant-nfc-page .callout.info .callout-icon {
  color: #2563eb;
}

.merchant-nfc-page .callout.info .callout-content strong {
  color: #1d4ed8;
}

.merchant-nfc-page .callout.success {
  background: #f0fdf4;
  border-left-color: #22c55e;
}

.merchant-nfc-page .callout.success .callout-icon {
  color: #22c55e;
}

.merchant-nfc-page .callout.success .callout-content strong {
  color: #16a34a;
}

.merchant-nfc-page .callout.warning {
  background: #fffbeb;
  border-left-color: #f59e0b;
}

.merchant-nfc-page .callout.warning .callout-icon {
  color: #f59e0b;
}

.merchant-nfc-page .callout.warning .callout-content strong {
  color: #d97706;
}

.merchant-nfc-page .callout.danger {
  background: #fef2f2;
  border-left-color: #ef4444;
}

.merchant-nfc-page .callout.danger .callout-icon {
  color: #ef4444;
}

.merchant-nfc-page .callout.danger .callout-content strong {
  color: #dc2626;
}

/* Steps Component */
.merchant-nfc-page .steps {
  position: relative;
  padding-left: 40px;
  margin: 24px 0 32px;
}

.merchant-nfc-page .steps::before {
  content: '';
  position: absolute;
  left: 15px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: #bfdbfe;
}

.merchant-nfc-page .step {
  position: relative;
  padding-bottom: 28px;
}

.merchant-nfc-page .step:last-child {
  padding-bottom: 0;
}

.merchant-nfc-page .step::before {
  content: attr(data-step);
  position: absolute;
  left: -40px;
  top: 0;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: #2563eb;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8125rem;
  font-weight: 700;
  z-index: 1;
}

.merchant-nfc-page .step-title {
  font-weight: 600;
  color: #1e3a8a;
  font-size: 1rem;
  margin-bottom: 8px;
  line-height: 30px;
}

.merchant-nfc-page .step-desc {
  font-size: 0.9375rem;
  color: #475569;
  line-height: 1.6;
}

/* Code Blocks */
.merchant-nfc-page .code-block {
  background: #1e293b;
  border-radius: 12px;
  border: 1px solid #334155;
  margin: 16px 0 24px;
  overflow: hidden;
}

.merchant-nfc-page .code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #0f172a;
  padding: 8px 16px;
  border-bottom: 1px solid #334155;
}

.merchant-nfc-page .code-lang {
  font-size: 0.75rem;
  color: #94a3b8;
  font-weight: 500;
  text-transform: uppercase;
}

.merchant-nfc-page .code-copy-btn {
  background: transparent;
  border: 1px solid #475569;
  color: #94a3b8;
  font-size: 0.75rem;
  padding: 4px 10px;
  border-radius: 4px;
  cursor: pointer;
  transition: all 150ms ease;
  display: flex;
  align-items: center;
  gap: 6px;
}

.merchant-nfc-page .code-copy-btn:hover {
  background: #334155;
  color: #e2e8f0;
}

.merchant-nfc-page .code-body {
  padding: 16px;
  overflow-x: auto;
}

.merchant-nfc-page .code-body code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.875rem;
  color: #e2e8f0;
  line-height: 1.7;
}

/* Inline code */
.merchant-nfc-page code.inline {
  background: #eff6ff;
  color: #1d4ed8;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85em;
  padding: 2px 7px;
  border-radius: 4px;
}

/* Device compatibility table */
.merchant-nfc-page .device-table-wrapper {
  border: 1px solid #bfdbfe;
  border-radius: 12px;
  overflow: hidden;
  margin: 16px 0 24px;
}

.merchant-nfc-page .device-table {
  width: 100%;
  border-collapse: collapse;
}

.merchant-nfc-page .device-table thead th {
  background: #eff6ff;
  font-size: 0.8125rem;
  font-weight: 600;
  color: #1e3a8a;
  padding: 12px 16px;
  text-align: left;
  border-bottom: 1px solid #bfdbfe;
}

.merchant-nfc-page .device-table tbody td {
  padding: 12px 16px;
  font-size: 0.875rem;
  color: #334155;
  border-bottom: 1px solid #e2e8f0;
}

.merchant-nfc-page .device-table tbody tr:last-child td {
  border-bottom: none;
}

.merchant-nfc-page .device-table tbody tr:hover {
  background: #f8fafc;
}

.merchant-nfc-page .status-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.75rem;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 100px;
}

.merchant-nfc-page .status-badge.supported {
  background: #dcfce7;
  color: #16a34a;
}

.merchant-nfc-page .status-badge.partial {
  background: #fef3c7;
  color: #d97706;
}

.merchant-nfc-page .status-badge.unsupported {
  background: #fef2f2;
  color: #dc2626;
}

/* Requirements grid */
.merchant-nfc-page .requirements-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin: 16px 0 24px;
}

.merchant-nfc-page .requirement-card {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  background: white;
  border: 1px solid #bfdbfe;
  border-radius: 10px;
  padding: 16px 18px;
  transition: border-color 200ms ease, box-shadow 200ms ease;
}

.merchant-nfc-page .requirement-card:hover {
  border-color: #93bbfd;
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
}

.merchant-nfc-page .requirement-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: #eff6ff;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #2563eb;
  font-size: 1rem;
  flex-shrink: 0;
}

.merchant-nfc-page .requirement-info h4 {
  font-size: 0.9375rem;
  font-weight: 600;
  color: #1e3a8a;
  margin: 0 0 4px;
}

.merchant-nfc-page .requirement-info p {
  font-size: 0.8125rem;
  color: #64748b;
  line-height: 1.5;
  margin: 0;
}

/* Troubleshooting accordion */
.merchant-nfc-page .trouble-item {
  border: 1px solid #bfdbfe;
  border-radius: 8px;
  margin-bottom: 12px;
  overflow: hidden;
  transition: border-color 200ms ease;
}

.merchant-nfc-page .trouble-item.open {
  border-color: #93bbfd;
}

.merchant-nfc-page .trouble-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  cursor: pointer;
  background: white;
  border: none;
  width: 100%;
  text-align: left;
  font-size: 0.9375rem;
  font-weight: 600;
  color: #1e3a8a;
  transition: background 150ms ease;
}

.merchant-nfc-page .trouble-header:hover {
  background: #f8fafc;
}

.merchant-nfc-page .trouble-header .trouble-icon {
  width: 28px;
  height: 28px;
  border-radius: 6px;
  background: #fef2f2;
  color: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  flex-shrink: 0;
}

.merchant-nfc-page .trouble-header .trouble-chevron {
  margin-left: auto;
  color: #94a3b8;
  transition: transform 250ms ease;
}

.merchant-nfc-page .trouble-item.open .trouble-chevron {
  transform: rotate(180deg);
}

.merchant-nfc-page .trouble-body {
  display: none;
  padding: 0 18px 18px;
  font-size: 0.875rem;
  color: #475569;
  line-height: 1.6;
  border-top: 1px solid #e2e8f0;
  padding-top: 14px;
}

.merchant-nfc-page .trouble-item.open .trouble-body {
  display: block;
}

.merchant-nfc-page .trouble-body ul {
  margin: 8px 0;
  padding-left: 20px;
}

.merchant-nfc-page .trouble-body li {
  margin-bottom: 6px;
}

/* FAQ Accordion */
.merchant-nfc-page .faq-item {
  border: 1px solid #bfdbfe;
  border-radius: 8px;
  margin-bottom: 10px;
  overflow: hidden;
  transition: border-color 200ms ease;
}

.merchant-nfc-page .faq-item.open {
  border-color: #93bbfd;
}

.merchant-nfc-page .faq-question {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 18px;
  cursor: pointer;
  background: white;
  border: none;
  width: 100%;
  text-align: left;
  font-size: 0.9375rem;
  font-weight: 600;
  color: #1e3a8a;
  transition: background 150ms ease;
}

.merchant-nfc-page .faq-question:hover {
  background: #f8fafc;
}

.merchant-nfc-page .faq-question .faq-q-icon {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #eff6ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  flex-shrink: 0;
}

.merchant-nfc-page .faq-question .faq-chevron {
  margin-left: auto;
  color: #94a3b8;
  transition: transform 250ms ease;
}

.merchant-nfc-page .faq-item.open .faq-chevron {
  transform: rotate(180deg);
}

.merchant-nfc-page .faq-answer {
  display: none;
  padding: 0 18px 16px 58px;
  font-size: 0.875rem;
  color: #475569;
  line-height: 1.6;
}

.merchant-nfc-page .faq-item.open .faq-answer {
  display: block;
}

/* Prev / Next Navigation */
.merchant-nfc-page .prev-next-nav {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 56px;
  padding-top: 32px;
  border-top: 1px solid #e2e8f0;
}

.merchant-nfc-page .pn-card {
  display: flex;
  flex-direction: column;
  padding: 18px 22px;
  border: 1px solid #bfdbfe;
  border-radius: 10px;
  cursor: pointer;
  text-decoration: none;
  transition: all 200ms ease;
  background: white;
}

.merchant-nfc-page .pn-card:hover {
  border-color: #2563eb;
  background: #f8fafc;
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
  transform: translateY(-2px);
}

.merchant-nfc-page .pn-card.next {
  text-align: right;
  align-items: flex-end;
}

.merchant-nfc-page .pn-label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin-bottom: 6px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 6px;
}

.merchant-nfc-page .pn-title {
  font-size: 0.9375rem;
  font-weight: 600;
  color: #2563eb;
}

/* Ordered / Unordered lists */
.merchant-nfc-page .doc-section ul,
.merchant-nfc-page .doc-section ol {
  padding-left: 20px;
  margin: 12px 0 20px;
}

.merchant-nfc-page .doc-section li {
  font-size: 0.9375rem;
  color: #334155;
  line-height: 1.625;
  margin-bottom: 8px;
}

.merchant-nfc-page .doc-section li strong {
  color: #1e3a8a;
}

/* Scroll to top */
.merchant-nfc-page .scroll-top-btn {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: white;
  border: 1px solid #bfdbfe;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  color: #2563eb;
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 50;
  transition: all 200ms ease;
}

.merchant-nfc-page .scroll-top-btn.visible {
  display: flex;
}

.merchant-nfc-page .scroll-top-btn:hover {
  background: #2563eb;
  color: white;
  border-color: #2563eb;
}

/* NFC payment flow illustration */
.merchant-nfc-page .nfc-flow-illustration {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  margin: 24px 0;
  padding: 32px;
  background: #f8fafc;
  border-radius: 12px;
  border: 1px solid #e2e8f0;
}

.merchant-nfc-page .flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-width: 140px;
}

.merchant-nfc-page .flow-step-icon {
  width: 56px;
  height: 56px;
  border-radius: 14px;
  background: #eff6ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  color: #2563eb;
  margin-bottom: 10px;
  border: 2px solid #bfdbfe;
}

.merchant-nfc-page .flow-step-label {
  font-size: 0.8125rem;
  font-weight: 600;
  color: #1e3a8a;
}

.merchant-nfc-page .flow-arrow {
  color: #94a3b8;
  font-size: 1.25rem;
}

/* Section divider */
.merchant-nfc-page .section-divider {
  border: none;
  border-top: 1px solid #e2e8f0;
  margin: 40px 0;
}

/* Responsive */
@media (max-width: 1200px) {
  .merchant-nfc-page .docs-toc {
    display: none;
  }
}

@media (max-width: 1024px) {
  .merchant-nfc-page .docs-sidebar {
    width: 240px;
    min-width: 240px;
  }
  .merchant-nfc-page .docs-content {
    padding: 24px 32px 48px;
  }
}

@media (max-width: 768px) {
  .merchant-nfc-page .docs-sidebar {
    position: fixed;
    left: -300px;
    top: 0;
    height: 100vh;
    z-index: 50;
    transition: left 300ms ease;
    width: 280px;
  }

  .merchant-nfc-page .docs-sidebar.open {
    left: 0;
  }

  .merchant-nfc-page .sidebar-toggle {
    display: flex;
  }

  .merchant-nfc-page .sidebar-overlay.visible {
    display: block;
  }

  .merchant-nfc-page .docs-content {
    padding: 20px 16px 48px;
  }

  .merchant-nfc-page .page-title {
    font-size: 1.75rem;
  }

  .merchant-nfc-page .doc-section h2 {
    font-size: 1.5rem;
  }

  .merchant-nfc-page .nfc-hero-visual {
    flex-direction: column;
    padding: 28px 24px;
    gap: 20px;
  }

  .merchant-nfc-page .nfc-hero-text {
    text-align: center;
  }

  .merchant-nfc-page .requirements-grid {
    grid-template-columns: 1fr;
  }

  .merchant-nfc-page .prev-next-nav {
    grid-template-columns: 1fr;
  }

  .merchant-nfc-page .pn-card.next {
    text-align: left;
    align-items: flex-start;
  }

  .merchant-nfc-page .nfc-flow-illustration {
    flex-direction: column;
    gap: 12px;
    padding: 24px 16px;
  }

  .merchant-nfc-page .flow-arrow {
    transform: rotate(90deg);
  }

  .merchant-nfc-page .device-table-wrapper {
    overflow-x: auto;
  }

  .merchant-nfc-page .device-table {
    min-width: 560px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .merchant-nfc-page .nfc-wave {
    animation: none;
  }
  .merchant-nfc-page .pn-card:hover {
    transform: none;
  }
}