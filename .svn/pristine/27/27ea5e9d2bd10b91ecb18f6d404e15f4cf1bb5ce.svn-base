/* Merchant Transactions Documentation Page CSS */

.merchant-transactions-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--color-background, #ffffff);
}

/* Docs Layout */
.docs-layout {
  display: flex;
  flex: 1;
  max-width: 1440px;
  margin: 0 auto;
  width: 100%;
}

/* Sidebar */
.docs-sidebar {
  width: 280px;
  min-width: 280px;
  border-right: 1px solid var(--color-border, #bfdbfe);
  background: var(--color-surface, #eff6ff);
  height: calc(100vh - 64px);
  position: sticky;
  top: 64px;
  overflow-y: auto;
  padding: 24px 0;
  z-index: 10;
}

.sidebar-section {
  margin-bottom: 8px;
}

.sidebar-section-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  padding: 8px 24px;
  margin-bottom: 4px;
}

.sidebar-nav-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.sidebar-nav-item {
  margin: 0;
}

.sidebar-nav-link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 24px;
  font-size: 0.875rem;
  color: #334155;
  text-decoration: none;
  border-radius: 0;
  margin: 0 8px;
  border-radius: 8px;
  cursor: pointer;
  transition: all 150ms ease;
  line-height: 1.5;
}

.sidebar-nav-link:hover {
  background: rgba(37, 99, 235, 0.06);
  color: #2563eb;
}

.sidebar-nav-link.active {
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
  font-weight: 500;
}

.sidebar-nav-link i {
  width: 18px;
  font-size: 0.8rem;
  text-align: center;
  opacity: 0.7;
}

.sidebar-nav-link.active i {
  opacity: 1;
}

/* Mobile sidebar toggle */
.sidebar-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 99;
}

.sidebar-overlay.active {
  display: block;
}

.mobile-sidebar-toggle {
  display: none;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 8px;
  font-size: 0.875rem;
  color: #334155;
  cursor: pointer;
  margin-bottom: 16px;
}

.mobile-sidebar-toggle i {
  font-size: 1rem;
}

/* Main Content */
.docs-main {
  flex: 1;
  min-width: 0;
  display: flex;
  gap: 0;
}

.docs-content {
  flex: 1;
  max-width: 860px;
  padding: 32px 48px 64px;
  min-width: 0;
  margin-left: 0;
  margin-top: 0;
}

/* TOC Sidebar */
.docs-toc {
  width: 220px;
  min-width: 220px;
  padding: 32px 16px 32px 0;
  position: sticky;
  top: 64px;
  height: calc(100vh - 64px);
  overflow-y: auto;
}

.toc-title {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
  margin-bottom: 12px;
}

.toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
  border-left: 2px solid var(--color-border, #bfdbfe);
}

.toc-link {
  display: block;
  padding: 4px 0 4px 16px;
  font-size: 0.8125rem;
  color: #64748b;
  text-decoration: none;
  border-left: 2px solid transparent;
  margin-left: -2px;
  transition: all 150ms ease;
  line-height: 1.5;
}

.toc-link:hover {
  color: #2563eb;
}

.toc-link.active {
  color: #2563eb;
  border-left-color: #2563eb;
  font-weight: 500;
}

/* Breadcrumb */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: #64748b;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.breadcrumb a {
  color: #64748b;
  text-decoration: none;
  transition: color 150ms ease;
}

.breadcrumb a:hover {
  color: #2563eb;
}

.breadcrumb-separator {
  color: #94a3b8;
  font-size: 0.75rem;
}

.breadcrumb-current {
  color: #2563eb;
  font-weight: 500;
}

/* Page Title */
.doc-page-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: #1e3a8a;
  letter-spacing: -0.025em;
  line-height: 1.25;
  margin: 0 0 8px;
  padding-bottom: 16px;
  border-bottom: 2px solid var(--color-border, #bfdbfe);
}

.doc-page-subtitle {
  font-size: 1.125rem;
  color: #64748b;
  line-height: 1.625;
  margin: 16px 0 32px;
}

/* Content Sections */
.doc-section {
  margin-top: 48px;
}

.doc-section:first-of-type {
  margin-top: 32px;
}

.doc-section-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.875rem;
  font-weight: 700;
  color: #1e3a8a;
  letter-spacing: -0.02em;
  line-height: 1.25;
  margin: 0 0 8px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  scroll-margin-top: 80px;
}

.doc-section h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.5rem;
  font-weight: 600;
  color: #1e3a8a;
  letter-spacing: -0.015em;
  line-height: 1.25;
  margin: 32px 0 12px;
  scroll-margin-top: 80px;
}

.doc-section h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.25rem;
  font-weight: 600;
  color: #1e3a8a;
  margin: 24px 0 8px;
}

.doc-section p {
  font-size: 1rem;
  color: #334155;
  line-height: 1.625;
  margin: 0 0 16px;
}

.doc-section ul, .doc-section ol {
  color: #334155;
  line-height: 1.625;
  margin: 0 0 16px;
  padding-left: 24px;
}

.doc-section li {
  margin-bottom: 8px;
}

/* Inline code */
.doc-section code:not(.code-block code) {
  background: #eff6ff;
  color: #1e3a8a;
  padding: 2px 8px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.875em;
}

/* Code Block */
.code-block-container {
  margin: 16px 0 24px;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid #334155;
  background: #1e293b;
}

.code-block-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 16px;
  background: #0f172a;
  border-bottom: 1px solid #334155;
}

.code-block-lang {
  font-size: 0.75rem;
  color: #94a3b8;
  font-weight: 500;
  text-transform: uppercase;
}

.code-copy-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  background: transparent;
  border: none;
  color: #94a3b8;
  font-size: 0.75rem;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 4px;
  transition: all 150ms ease;
}

.code-copy-btn:hover {
  background: rgba(255,255,255,0.1);
  color: #e2e8f0;
}

.code-copy-btn.copied {
  color: #22c55e;
}

.code-block {
  padding: 16px;
  overflow-x: auto;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.875rem;
  line-height: 1.625;
  color: #e2e8f0;
  margin: 0;
  white-space: pre;
}

/* Callout boxes */
.callout {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-radius: 8px;
  margin: 16px 0 24px;
  border-left: 4px solid;
}

.callout-icon {
  flex-shrink: 0;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  margin-top: 2px;
}

.callout-content {
  flex: 1;
  font-size: 0.9375rem;
  line-height: 1.625;
  color: #334155;
}

.callout-content strong {
  display: block;
  margin-bottom: 4px;
  font-weight: 600;
}

.callout.callout-info {
  background: #eff6ff;
  border-color: #2563eb;
}

.callout.callout-info .callout-icon {
  color: #2563eb;
}

.callout.callout-warning {
  background: #fffbeb;
  border-color: #f59e0b;
}

.callout.callout-warning .callout-icon {
  color: #f59e0b;
}

.callout.callout-success {
  background: #f0fdf4;
  border-color: #22c55e;
}

.callout.callout-success .callout-icon {
  color: #22c55e;
}

.callout.callout-danger {
  background: #fef2f2;
  border-color: #ef4444;
}

.callout.callout-danger .callout-icon {
  color: #ef4444;
}

/* Steps component */
.steps {
  margin: 16px 0 24px;
  padding: 0;
  list-style: none;
  position: relative;
}

.steps::before {
  content: '';
  position: absolute;
  left: 15px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--color-border, #bfdbfe);
}

.step {
  position: relative;
  padding-left: 44px;
  padding-bottom: 24px;
}

.step:last-child {
  padding-bottom: 0;
}

.step-number {
  position: absolute;
  left: 4px;
  top: 0;
  width: 24px;
  height: 24px;
  background: #2563eb;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  z-index: 1;
}

.step-title {
  font-weight: 600;
  color: #1e3a8a;
  margin-bottom: 4px;
  font-size: 1rem;
}

.step-content {
  color: #334155;
  font-size: 0.9375rem;
  line-height: 1.625;
}

/* Table styles */
.doc-table-container {
  margin: 16px 0 24px;
  border-radius: 12px;
  border: 1px solid var(--color-border, #bfdbfe);
  overflow: hidden;
}

.doc-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9375rem;
}

.doc-table thead th {
  background: var(--color-surface, #eff6ff);
  padding: 12px 16px;
  text-align: left;
  font-weight: 600;
  font-size: 0.8125rem;
  color: #1e3a8a;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  white-space: nowrap;
}

.doc-table tbody td {
  padding: 12px 16px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  color: #334155;
  line-height: 1.5;
}

.doc-table tbody tr:last-child td {
  border-bottom: none;
}

.doc-table tbody tr:hover {
  background: rgba(239, 246, 255, 0.5);
}

/* Status badges */
.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 2px 10px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  line-height: 1.5;
}

.status-badge.status-completed {
  background: #dcfce7;
  color: #166534;
}

.status-badge.status-pending {
  background: #fef3c7;
  color: #92400e;
}

.status-badge.status-failed {
  background: #fee2e2;
  color: #991b1b;
}

.status-badge.status-refunded {
  background: #e0e7ff;
  color: #3730a3;
}

/* Transaction card mockup */
.txn-card-mockup {
  background: #fff;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 20px;
  margin: 16px 0 24px;
  max-width: 480px;
}

.txn-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.txn-card-id {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8125rem;
  color: #64748b;
}

.txn-card-amount {
  font-size: 1.5rem;
  font-weight: 700;
  color: #1e3a8a;
}

.txn-card-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
  border-top: 1px solid #f1f5f9;
  font-size: 0.875rem;
}

.txn-card-label {
  color: #64748b;
}

.txn-card-value {
  color: #334155;
  font-weight: 500;
}

/* FAQ Accordion */
.faq-section {
  margin-top: 48px;
}

.faq-item {
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 8px;
  margin-bottom: 8px;
  overflow: hidden;
  transition: border-color 150ms ease;
}

.faq-item:hover {
  border-color: #93bbfd;
}

.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 16px 20px;
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 0.9375rem;
  font-weight: 600;
  color: #1e3a8a;
  text-align: left;
  line-height: 1.5;
  gap: 12px;
  transition: background 150ms ease;
}

.faq-question:hover {
  background: rgba(239, 246, 255, 0.5);
}

.faq-question:focus-visible {
  outline: 2px solid #2563eb;
  outline-offset: -2px;
  border-radius: 8px;
}

.faq-chevron {
  flex-shrink: 0;
  transition: transform 250ms ease;
  color: #64748b;
  font-size: 0.75rem;
}

.faq-item.active .faq-chevron {
  transform: rotate(180deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 300ms ease;
}

.faq-answer-inner {
  padding: 0 20px 16px;
  color: #334155;
  font-size: 0.9375rem;
  line-height: 1.625;
}

.faq-item.active .faq-answer {
  max-height: 500px;
}

/* Prev/Next Navigation */
.doc-pagination {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 64px;
  padding-top: 32px;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

.doc-pagination-link {
  display: flex;
  flex-direction: column;
  padding: 16px 20px;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  text-decoration: none;
  cursor: pointer;
  transition: all 250ms ease;
}

.doc-pagination-link:hover {
  border-color: #2563eb;
  background: var(--color-surface, #eff6ff);
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
  transform: translateY(-2px);
}

.doc-pagination-link.prev {
  align-items: flex-start;
}

.doc-pagination-link.next {
  align-items: flex-end;
  text-align: right;
}

.doc-pagination-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: #64748b;
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 4px;
}

.doc-pagination-title {
  font-size: 0.9375rem;
  font-weight: 600;
  color: #2563eb;
}

/* Screenshot/Image container */
.doc-image-container {
  margin: 16px 0 24px;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  overflow: hidden;
  background: var(--color-surface, #eff6ff);
}

.doc-image-container img {
  display: block;
  width: 100%;
  height: auto;
}

.doc-image-caption {
  padding: 8px 16px;
  font-size: 0.8125rem;
  color: #64748b;
  text-align: center;
  border-top: 1px solid var(--color-border, #bfdbfe);
  background: #fff;
}

/* Filter bar mockup */
.filter-bar-mockup {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  padding: 16px 20px;
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  margin: 16px 0 24px;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  background: #fff;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 8px;
  font-size: 0.8125rem;
  color: #334155;
}

.filter-item i {
  color: #64748b;
  font-size: 0.75rem;
}

.filter-item-label {
  color: #64748b;
  font-weight: 500;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: #2563eb;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 0.8125rem;
  font-weight: 600;
  cursor: pointer;
}

/* Export format cards */
.export-formats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin: 16px 0 24px;
}

.export-format-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 16px;
  background: #fff;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  text-align: center;
  transition: all 250ms ease;
}

.export-format-card:hover {
  border-color: #93bbfd;
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.08);
}

.export-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface, #eff6ff);
  border-radius: 12px;
  margin-bottom: 12px;
  font-size: 1.25rem;
  color: #2563eb;
}

.export-format-name {
  font-weight: 600;
  color: #1e3a8a;
  font-size: 0.9375rem;
  margin-bottom: 4px;
}

.export-format-desc {
  font-size: 0.8125rem;
  color: #64748b;
  line-height: 1.5;
}

/* Settlement timeline */
.settlement-timeline {
  display: flex;
  align-items: center;
  gap: 0;
  margin: 24px 0;
  position: relative;
  overflow-x: auto;
  padding: 20px 0;
}

.settlement-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  flex: 1;
  min-width: 100px;
  position: relative;
}

.settlement-step:not(:last-child)::after {
  content: '';
  position: absolute;
  top: 20px;
  left: 50%;
  width: 100%;
  height: 2px;
  background: var(--color-border, #bfdbfe);
  z-index: 0;
}

.settlement-dot {
  width: 40px;
  height: 40px;
  background: #2563eb;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  z-index: 1;
  margin-bottom: 8px;
  position: relative;
}

.settlement-label {
  font-size: 0.8125rem;
  font-weight: 600;
  color: #1e3a8a;
  margin-bottom: 2px;
}

.settlement-desc {
  font-size: 0.75rem;
  color: #64748b;
}

/* Responsive */
@media (max-width: 1200px) {
  .docs-toc {
    display: none;
  }
}

@media (max-width: 1024px) {
  .docs-sidebar {
    width: 240px;
    min-width: 240px;
  }

  .docs-content {
    padding: 24px 32px 48px;
  }
}

@media (max-width: 768px) {
  .docs-sidebar {
    position: fixed;
    top: 0;
    left: -280px;
    width: 280px;
    min-width: 280px;
    height: 100vh;
    z-index: 100;
    transition: left 300ms ease;
    padding-top: 24px;
  }

  .docs-sidebar.open {
    left: 0;
  }

  .mobile-sidebar-toggle {
    display: flex;
  }

  .docs-content {
    padding: 20px 16px 48px;
  }

  .doc-page-title {
    font-size: 1.75rem;
  }

  .doc-section-title {
    font-size: 1.5rem;
  }

  .doc-pagination {
    grid-template-columns: 1fr;
  }

  .export-formats {
    grid-template-columns: 1fr;
  }

  .filter-bar-mockup {
    flex-direction: column;
    align-items: stretch;
  }

  .settlement-timeline {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .settlement-step {
    flex-direction: row;
    text-align: left;
    min-width: auto;
    gap: 12px;
  }

  .settlement-step:not(:last-child)::after {
    display: none;
  }
}

@media (max-width: 480px) {
  .doc-page-title {
    font-size: 1.5rem;
  }

  .doc-section-title {
    font-size: 1.25rem;
  }

  .txn-card-mockup {
    max-width: 100%;
  }

  .doc-table-container {
    overflow-x: auto;
  }

  .doc-table {
    min-width: 500px;
  }
}

/* Scroll to top */
.scroll-to-top {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 44px;
  height: 44px;
  background: #2563eb;
  color: #fff;
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  opacity: 0;
  visibility: hidden;
  transition: all 250ms ease;
  z-index: 50;
}

.scroll-to-top.visible {
  opacity: 1;
  visibility: visible;
}

.scroll-to-top:hover {
  background: #1d4ed8;
  transform: translateY(-2px);
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    transition-duration: 0.01ms !important;
    animation-duration: 0.01ms !important;
  }
}