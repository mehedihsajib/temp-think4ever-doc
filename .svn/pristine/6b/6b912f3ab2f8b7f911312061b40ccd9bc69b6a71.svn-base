                <!-- Main Content -->
                <main class="docs-main" id="main-content">
                    <div class="docs-content">
                        <!-- Breadcrumb -->
                        <nav class="breadcrumb" id="mqr_breadcrumb" aria-label="Breadcrumb">
                            <a onclick="load_page('index')" tabindex="0">Docs</a>
                            <span class="separator"><i class="fa fa-chevron-right"></i></span>
                            <a onclick="load_page('merchant_docs_home')" tabindex="0">Merchant</a>
                            <span class="separator"><i class="fa fa-chevron-right"></i></span>
                            <span class="current">QR Code Payments</span>
                        </nav>
                        <!-- Page Title -->
                        <h1 class="page-title" id="mqr_title">QR Code Payments</h1>
                        <p class="page-subtitle">
          Learn how to generate, display, and manage QR code payments in your MPay Merchant Wallet. Accept payments instantly by letting customers scan your QR code. </p>
                        <!-- Section: Generating QR Codes -->
                        <section class="doc-section" id="mqr_content_generate">
                            <h2 id="generating-qr-codes">Generating QR Codes</h2>
                            <p>mPay Merchant Wallet supports two types of QR codes for accepting payments. Each serves a different use case depending on your business needs.</p>
                            <div class="qr-type-grid">
                                <div class="qr-type-card">
                                    <div class="card-icon">
                                        <i class="fa fa-qrcode"></i>
                                    </div>
                                    <h4>Static QR Code</h4>
                                    <p>A fixed QR code linked to your merchant account. Customers scan and enter the payment amount themselves. Ideal for print displays.</p>
                                </div>
                                <div class="qr-type-card">
                                    <div class="card-icon">
                                        <i class="fa fa-sync-alt"></i>
                                    </div>
                                    <h4>Dynamic QR Code</h4>
                                    <p>A one-time QR code generated per transaction with a specific amount. Perfect for point-of-sale checkouts with fixed pricing.</p>
                                </div>
                            </div>
                            <h3 id="generating-static-qr">Generating a Static QR Code</h3>
                            <div class="steps">
                                <div class="step">
                                    <h4>Open Merchant Wallet</h4>
                                    <p>Launch the mPay Merchant Wallet app and log in with your credentials.</p>
                                </div>
                                <div class="step">
                                    <h4>Navigate to QR Payments</h4>
                                    <p>Tap the <code>Profile QR Code</code> tab in the upper left portion of the page, or go to menu <b>Profile Settings</b></p>
                                </div>
                                <div class="step">
                                    <h4>Share or Download the QR</h4>
                                    <p>Choose either the <code>Share or Download</code>&nbsp;option.&nbsp;</p>
                                </div>
                                <div class="step">
                                    <h4>Print a physical QR code or show QR from your device</h4>
                                    <p>Merchant can now start accepting payments from their customers. The Merchant customers can pay using <b>Scan to Pay</b> features.</p>
                                </div>
                            </div>
                            <!-- QR Demo -->
                            <div class="qr-demo-container">
                                <div class="qr-visual">
                                    <div class="qr-code-frame">
                                        <canvas id="qrDemoCanvas" width="150" height="150" aria-label="Sample merchant static QR code">
                                            <iframe></iframe>
                                        </canvas>
                                        <div class="qr-corner tl"></div>
                                        <div class="qr-corner tr"></div>
                                        <div class="qr-corner bl"></div>
                                        <div class="qr-corner br"></div>
                                    </div>
                                    <span class="qr-label">Sample Static QR Code</span>
                                </div>
                                <div class="qr-demo-info">
                                    <h4>Your Merchant QR Code</h4>
                                    <p>This is an example of a static merchant QR code. When a customer scans it, they'll be directed to your payment page where they can enter the amount and complete the transaction.</p>
                                    <div class="callout callout-info" style="margin:0;">
                                        <span class="callout-icon"><i class="fa fa-info-circle"></i></span>
                                        <div class="callout-content">
                                            <p>Static QR codes never expire and can be reused for unlimited transactions.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                        <!-- Section: Receiving Payments -->
                        <section class="doc-section" id="mqr_content_receive">
                            <h2 id="receiving-payments">Receiving Payments</h2>
                            <p>
            When a customer scans your QR code, the payment process is initiated automatically. Here's how the flow works from both sides: </p>
                            <!-- Payment Flow Visual -->
                            <div class="payment-flow">
                                <div class="flow-step completed">
                                    <div class="flow-step-icon">
                                        <i class="fa fa-store"></i>
                                    </div>
                                    <span class="flow-step-label">Merchant Displays QR</span>
                                    <span class="flow-step-desc">Show your QR code</span>
                                </div>
                                <div class="flow-arrow">
                                    <i class="fa fa-arrow-right"></i>
                                </div>
                                <div class="flow-step completed">
                                    <div class="flow-step-icon">
                                        <i class="fa fa-camera"></i>
                                    </div>
                                    <span class="flow-step-label">Customer Scans</span>
                                    <span class="flow-step-desc">Using MPay app</span>
                                </div>
                                <div class="flow-arrow">
                                    <i class="fa fa-arrow-right"></i>
                                </div>
                                <div class="flow-step completed">
                                    <div class="flow-step-icon">
                                        <i class="fa fa-dollar-sign"></i>
                                    </div>
                                    <span class="flow-step-label">Enters Amount</span>
                                    <span class="flow-step-desc">Or auto-filled</span>
                                </div>
                                <div class="flow-arrow">
                                    <i class="fa fa-arrow-right"></i>
                                </div>
                                <div class="flow-step completed">
                                    <div class="flow-step-icon">
                                        <i class="fa fa-shield-alt"></i>
                                    </div>
                                    <span class="flow-step-label">Confirms Payment</span>
                                    <span class="flow-step-desc">PIN or biometric</span>
                                </div>
                                <div class="flow-arrow">
                                    <i class="fa fa-arrow-right"></i>
                                </div>
                                <div class="flow-step">
                                    <div class="flow-step-icon" style="background:#22c55e;border-color:#22c55e;color:white;">
                                        <i class="fa fa-check"></i>
                                    </div>
                                    <span class="flow-step-label">Payment Complete</span>
                                    <span class="flow-step-desc">Instant notification</span>
                                </div>
                            </div>
                            <h3>Real-Time Notifications</h3>
                            <p>When a payment is received, you'll get:</p>
                            <ul>
                                <li>
                                    <strong>Push Notification</strong> — Instant alert on your device with payment amount and customer reference
                                </li>
                                <li>
                                    <strong>In-App Alert</strong> — Payment confirmation banner within the merchant wallet
                                </li>
                                <li>
                                    <strong>Sound Alert</strong> — Configurable payment received sound (can be customized in <a onclick="load_page('merchant_settings')" style="color:#2563eb;cursor:pointer;">Settings</a>)
                                </li>
                                <li>
                                    <strong>Transaction Log</strong> — Automatically recorded in your <a onclick="load_page('merchant_transactions')" style="color:#2563eb;cursor:pointer;">Transaction History</a>
                                </li>
                            </ul>
                            <div class="callout callout-success">
                                <span class="callout-icon"><i class="fa fa-check-circle"></i></span>
                                <div class="callout-content">
                                    <strong>Instant Settlement</strong>
                                    <p>QR code payments through MPay are settled instantly. The funds appear in your merchant wallet balance within seconds.</p>
                                </div>
                            </div>
                            <h3>Payment Confirmation Code</h3>
                            <p>
            Every successful payment generates a unique confirmation code. This code serves as a receipt reference for both you and the customer. </p>
                            <div class="code-block-wrapper">
                                <div class="code-block-header">
                                    <span class="code-block-lang">Payment Confirmation</span>
                                    <button class="code-copy-btn" aria-label="Copy code">
                                        <i class="fa fa-copy"></i> Copy
                                    </button>
                                </div>
                                <div class="code-block">
                                    <code>Transaction ID:  <span class="string">TXN-2025-0311-A7F2K9</span>
Merchant:        <span class="string">STORE001 - Coffee House</span>
Amount:          <span class="number">$12.50 USD</span>
Status:          <span class="keyword">COMPLETED</span>
Timestamp:       <span class="string">2025-03-11T14:32:18Z</span>
Confirmation:    <span class="string">MPY-XK9F-2D4A</span></code>
                                </div>
                            </div>
                        </section>
                        <!-- Section: Printing & Displaying -->
                        <section class="doc-section" id="mqr_content_print">
                            <h2 id="printing-displaying">Printing & Displaying QR Codes</h2>
                            <p>
            For brick-and-mortar businesses, printing and displaying your QR code prominently is essential for quick payments. Follow these best practices: </p>
                            <h3>Best Practices</h3>
                            <div class="best-practices-grid">
                                <div class="best-practice-item">
                                    <div class="bp-icon do">
                                        <i class="fa fa-check"></i>
                                    </div>
                                    <div class="bp-content">
                                        <h5>Use High Resolution</h5>
                                        <p>Download and print at 300 DPI or higher. The app provides print-ready files.</p>
                                    </div>
                                </div>
                                <div class="best-practice-item">
                                    <div class="bp-icon do">
                                        <i class="fa fa-check"></i>
                                    </div>
                                    <div class="bp-content">
                                        <h5>Maintain Quiet Zone</h5>
                                        <p>Keep at least 4mm of white space around the QR code for reliable scanning.</p>
                                    </div>
                                </div>
                                <div class="best-practice-item">
                                    <div class="bp-icon do">
                                        <i class="fa fa-check"></i>
                                    </div>
                                    <div class="bp-content">
                                        <h5>Place at Eye Level</h5>
                                        <p>Position QR codes at counter or eye level for easy scanning by customers.</p>
                                    </div>
                                </div>
                                <div class="best-practice-item">
                                    <div class="bp-icon do">
                                        <i class="fa fa-check"></i>
                                    </div>
                                    <div class="bp-content">
                                        <h5>Include Instructions</h5>
                                        <p>Add a brief "Scan to Pay with MPay" label near the QR code.</p>
                                    </div>
                                </div>
                                <div class="best-practice-item">
                                    <div class="bp-icon dont">
                                        <i class="fa fa-times"></i>
                                    </div>
                                    <div class="bp-content">
                                        <h5>Don't Use Low Contrast</h5>
                                        <p>Always use dark QR on light background. Avoid colored or patterned backgrounds.</p>
                                    </div>
                                </div>
                                <div class="best-practice-item">
                                    <div class="bp-icon dont">
                                        <i class="fa fa-times"></i>
                                    </div>
                                    <div class="bp-content">
                                        <h5>Don't Print Too Small</h5>
                                        <p>Minimum print size is 2cm × 2cm. Recommended: 4cm × 4cm or larger.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="callout callout-warning">
                                <span class="callout-icon"><i class="fa fa-exclamation-triangle"></i></span>
                                <div class="callout-content">
                                    <strong>Avoid Laminating with Glossy Finish</strong>
                                    <p>Glossy lamination can cause glare which interferes with QR scanning. Use matte lamination instead if you need to protect your printed QR code.</p>
                                </div>
                            </div>
                            <h3>Recommended Print Sizes</h3>
                            <div class="comparison-table-wrapper">
                                <table class="comparison-table">
                                    <thead>
                                        <tr>
                                            <th>Location</th>
                                            <th>Recommended Size</th>
                                            <th>Min Distance</th>
                                            <th>Material</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Counter Stand</td>
                                            <td><span class="badge badge-blue">8 × 8 cm</span></td>
                                            <td>15-30 cm</td>
                                            <td>Matte card stock</td>
                                        </tr>
                                        <tr>
                                            <td>Table Tent</td>
                                            <td><span class="badge badge-blue">6 × 6 cm</span></td>
                                            <td>10-25 cm</td>
                                            <td>Folded card stock</td>
                                        </tr>
                                        <tr>
                                            <td>Window/Wall Poster</td>
                                            <td><span class="badge badge-blue">15 × 15 cm</span></td>
                                            <td>50-100 cm</td>
                                            <td>Matte vinyl/paper</td>
                                        </tr>
                                        <tr>
                                            <td>Receipt / Invoice</td>
                                            <td><span class="badge badge-blue">3 × 3 cm</span></td>
                                            <td>5-15 cm</td>
                                            <td>Thermal paper</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </section>
                        <!-- Section: Dynamic Amount QR Codes -->
                        <section class="doc-section" id="mqr_content_dynamic">
                            <h2 id="dynamic-amount">Dynamic Amount QR Codes</h2>
                            <p>
            Dynamic QR codes include a pre-set payment amount, so customers don't need to enter it manually. This is ideal for point-of-sale transactions where you know the exact amount. </p>
                            <h3>How to Generate a Dynamic QR Code</h3>
                            <div class="steps">
                                <div class="step">
                                    <h4>Open QR Payments</h4>
                                    <p>Navigate to home page, click on <b>Request by QR.</b></p>
                                </div>
                                <div class="step">
                                    <h4>Enter the Amount</h4>
                                    <p>Type in the payment amount. You can optionally add an order reference or description.</p>
                                </div>
                                <div class="step">
                                    <h4>Generate &amp; Show to customer</h4>
                                    <p>Tap <strong>Submit</strong>&nbsp;button to create the QR code. Show it to the customer or display on a secondary screen.</p>
                                </div>
                            </div>
                            <!-- Interactive Demo -->
                            <h3>Try It Out</h3>
                            <p>Enter an amount below to see how a dynamic QR code is generated:</p>
                            <div class="amount-demo">
                                <div class="amount-input-group">
                                    <label for="qrAmountInput">Payment Amount</label>
                                    <div class="amount-input-wrapper">
                                        <span class="amount-prefix">USD $</span>
                                        <input type="number" id="qrAmountInput" placeholder="0.00" step="0.01" min="0.01" aria-label="Enter payment amount">
                                    </div>
                                </div>
                                <button class="generate-qr-btn" id="generateQrBtn" type="button">
                                    <i class="fa fa-qrcode"></i> Generate QR
                                </button>
                            </div>
                            <div class="qr-demo-container">
                                <div class="qr-visual">
                                    <div class="qr-code-frame">
                                        <canvas id="dynamicQrCanvas" width="150" height="150" aria-label="Dynamic QR code preview"></canvas>
                                        <div class="qr-corner tl"></div>
                                        <div class="qr-corner tr"></div>
                                        <div class="qr-corner bl"></div>
                                        <div class="qr-corner br"></div>
                                        <div class="qr-scanner-line"></div>
                                    </div>
                                    <span class="qr-label">Dynamic QR Preview</span>
                                </div>
                                <div class="qr-demo-info">
                                    <h4>Dynamic QR Code Details</h4>
                                    <p>This QR code embeds the payment amount directly, so the customer only needs to confirm the payment. The QR code expires after 15 minutes or upon successful payment.</p>
                                    <div class="code-block-wrapper" style="margin-top:12px;">
                                        <div class="code-block-header">
                                            <span class="code-block-lang">QR Data Format</span>
                                            <button class="code-copy-btn" aria-label="Copy code">
                                                <i class="fa fa-copy"></i> Copy
                                            </button>
                                        </div>
                                        <div class="code-block">
                                            <code><span class="comment">// Dynamic QR code payload structure</span>
{ <span class="keyword">"type"</span>: <span class="string">"dynamic"</span>, <span class="keyword">"merchant_id"</span>: <span class="string">"STORE001"</span>, <span class="keyword">"amount"</span>: <span class="number">12.50</span>, <span class="keyword">"currency"</span>: <span class="string">"USD"</span>, <span class="keyword">"reference"</span>: <span class="string">"ORD-20250311-001"</span>, <span class="keyword">"expires_at"</span>: <span class="string">"2025-03-11T15:00:00Z"</span>
}</code>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <h3>Static vs. Dynamic QR — Comparison</h3>
                            <div class="comparison-table-wrapper">
                                <table class="comparison-table">
                                    <thead>
                                        <tr>
                                            <th>Feature</th>
                                            <th>Static QR</th>
                                            <th>Dynamic QR</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Amount Pre-set</td>
                                            <td><span class="badge badge-amber">No — customer enters</span></td>
                                            <td><span class="badge badge-green">Yes — embedded</span></td>
                                        </tr>
                                        <tr>
                                            <td>Expiration</td>
                                            <td><span class="badge badge-green">Never expires</span></td>
                                            <td><span class="badge badge-amber">15 min default</span></td>
                                        </tr>
                                        <tr>
                                            <td>Reusable</td>
                                            <td><span class="badge badge-green">Unlimited</span></td>
                                            <td><span class="badge badge-amber">Single use</span></td>
                                        </tr>
                                        <tr>
                                            <td>Best For</td>
                                            <td>Print, display, general accept</td>
                                            <td>POS, checkout, invoicing</td>
                                        </tr>
                                        <tr>
                                            <td>Order Reference</td>
                                            <td><span class="badge badge-amber">Not supported</span></td>
                                            <td><span class="badge badge-green">Supported</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="callout callout-info">
                                <span class="callout-icon"><i class="fa fa-lightbulb"></i></span>
                                <div class="callout-content">
                                    <strong>Pro Tip: Use Both!</strong>
                                    <p>Many merchants use a printed static QR code at the counter for walk-in customers, and generate dynamic QR codes on their tablet for specific orders during busy hours.</p>
                                </div>
                            </div>
                        </section>
                        <!-- Screenshots Section -->
                        <section class="doc-section" id="mqr_screenshots">
                            <h2 id="screenshots">QR Payment Screenshots</h2>
                            <p>Visual walkthrough of the QR payment experience in the MPay Merchant Wallet.</p>
                            <div class="screenshots-grid">
                                <div class="screenshot-card">
                                    <div class="screenshot-placeholder">
                                        <i class="fa fa-qrcode"></i>
                                        <span>QR Code Generation</span>
                                    </div>
                                    <div class="screenshot-caption">Main QR code screen showing static QR with download and share options</div>
                                </div>
                                <div class="screenshot-card">
                                    <div class="screenshot-placeholder">
                                        <i class="fa fa-mobile-alt"></i>
                                        <span>Customer Scanning</span>
                                    </div>
                                    <div class="screenshot-caption">Customer view when scanning a merchant QR code in the consumer app</div>
                                </div>
                                <div class="screenshot-card">
                                    <div class="screenshot-placeholder">
                                        <i class="fa fa-check-circle"></i>
                                        <span>Payment Confirmation</span>
                                    </div>
                                    <div class="screenshot-caption">Payment success screen with transaction details and confirmation code</div>
                                </div>
                                <div class="screenshot-card">
                                    <div class="screenshot-placeholder">
                                        <i class="fa fa-dollar-sign"></i>
                                        <span>Dynamic Amount Entry</span>
                                    </div>
                                    <div class="screenshot-caption">Dynamic QR creation screen with amount input and order reference field</div>
                                </div>
                                <div class="screenshot-card">
                                    <div class="screenshot-placeholder">
                                        <i class="fa fa-bell"></i>
                                        <span>Payment Notification</span>
                                    </div>
                                    <div class="screenshot-caption">Real-time push notification received when payment is completed</div>
                                </div>
                                <div class="screenshot-card">
                                    <div class="screenshot-placeholder">
                                        <i class="fa fa-print"></i>
                                        <span>Print Preview</span>
                                    </div>
                                    <div class="screenshot-caption">Print-ready QR code layout with business name and instructions</div>
                                </div>
                            </div>
                        </section>
                        <!-- FAQ Accordion -->
                        <section class="doc-section" id="mqr_faq_accordion">
                            <h2 id="faq">Frequently Asked Questions</h2>
                            <div class="faq-list">
                                <div class="faq-item">
                                    <button class="faq-question" aria-expanded="false" aria-controls="faq-1">
                                        <span>What happens if a customer scans an expired dynamic QR code?</span>
                                        <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                    </button>
                                    <div class="faq-answer" id="faq-1" role="region">
                                        <div class="faq-answer-inner">
                                            <p>If a customer scans an expired dynamic QR code, the MPay app will display an "Expired QR Code" message and prompt them to ask the merchant for a new code. No payment will be processed.</p>
                                            <p>Dynamic QR codes expire after 15 minutes by default, but you can adjust this in <strong>Settings → QR Code Preferences</strong>.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="faq-item">
                                    <button class="faq-question" aria-expanded="false" aria-controls="faq-2">
                                        <span>Can I customize the appearance of my QR code?</span>
                                        <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                    </button>
                                    <div class="faq-answer" id="faq-2" role="region">
                                        <div class="faq-answer-inner">
                                            <p>Yes! You can customize your QR code with your business logo and brand colors. Go to <strong>Settings → QR Code Preferences → Customize</strong>. Note that customization should not exceed 30% of the QR code area to maintain scannability.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="faq-item">
                                    <button class="faq-question" aria-expanded="false" aria-controls="faq-3">
                                        <span>Is there a transaction limit for QR code payments?</span>
                                        <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                    </button>
                                    <div class="faq-answer" id="faq-3" role="region">
                                        <div class="faq-answer-inner">
                                            <p>QR code payment limits depend on your merchant verification level:</p>
                                            <p><strong>Basic Verified:</strong> Up to $500 per transaction, $2,000 daily limit.</p>
                                            <p><strong>Fully Verified (KYC):</strong> Up to $5,000 per transaction, $25,000 daily limit.</p>
                                            <p><strong>Enterprise:</strong> Custom limits based on your agreement. Contact support for details.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="faq-item">
                                    <button class="faq-question" aria-expanded="false" aria-controls="faq-4">
                                        <span>Can non-MPay users pay via my QR code?</span>
                                        <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                    </button>
                                    <div class="faq-answer" id="faq-4" role="region">
                                        <div class="faq-answer-inner">
                                            <p>Currently, QR code payments require the customer to have the MPay Consumer Wallet app installed. However, when a non-MPay user scans your code, they'll be redirected to the app download page with your merchant info pre-loaded for their first payment after installation.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="faq-item">
                                    <button class="faq-question" aria-expanded="false" aria-controls="faq-5">
                                        <span>How do I handle refunds for QR code payments?</span>
                                        <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                    </button>
                                    <div class="faq-answer" id="faq-5" role="region">
                                        <div class="faq-answer-inner">
                                            <p>To refund a QR code payment, go to <strong>Transactions</strong>, find the payment, and tap <strong>Refund</strong>. You can issue full or partial refunds. Refunds are processed within 24 hours. See <a onclick="load_page('merchant_transactions')" style="color:#2563eb;cursor:pointer;">Transaction Management</a> for detailed instructions.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="faq-item">
                                    <button class="faq-question" aria-expanded="false" aria-controls="faq-6">
                                        <span>Can I use QR codes on a secondary screen or tablet?</span>
                                        <span class="faq-chevron"><i class="fa fa-chevron-down"></i></span>
                                    </button>
                                    <div class="faq-answer" id="faq-6" role="region">
                                        <div class="faq-answer-inner">
                                            <p>Yes! The MPay Merchant Wallet supports a "Customer Display" mode that shows a large, clean QR code optimized for secondary screens. Go to <strong>Settings → Display Mode → Customer-Facing Display</strong> to enable it. This is perfect for tablet stands at checkout counters.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
