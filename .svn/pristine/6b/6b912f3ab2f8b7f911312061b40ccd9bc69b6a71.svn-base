            <!-- Site Header -->
            <header class="site-header" style="position:sticky;top:0;z-index:30;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border-bottom:1px solid #bfdbfe;height:64px;display:flex;align-items:center;padding:0 24px;">
