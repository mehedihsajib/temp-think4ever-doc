    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="assets/css/global.css">
    <link rel="stylesheet" href="assets/css/privacy_policy.css">
    <style>
        /* Basic reset for preview consistency */
        body { margin: 0; padding: 0; font-family: sans-serif; }
    </style>
</head>
<body>
    <div class="privacy-policy-page">
  <!-- Skip to content -->
  <a href="#pp-main-content" class="pp-skip-link sr-only" style="position:absolute;top:-40px;left:0;background:#2563eb;color:#fff;padding:8px 16px;z-index:10000;font-size:0.875rem;transition:top 200ms;" onfocus="this.style.top='0'" onblur="this.style.top='-40px'">Skip to content</a>

  <!-- Header -->
  <header class="pp-header" role="banner">
    <div class="pp-header-inner">
      <a class="pp-header-logo" onclick="load_page('index')" role="link" tabindex="0" aria-label="MPay Network Home">
        <img src="https://dev.think4ever.com/uifiles/20260311/ed3d2c21991e3bef5e069713af9fa6ca/only_m_with_white_bg_logo.png" alt="MPay Network Logo" />
        <span>MPay Network</span>
      </a>
      <nav class="pp-header-nav" aria-label="Main navigation">
        <a class="pp-header-nav-link" onclick="load_page('index')" tabindex="0">Home</a>
        <a class="pp-header-nav-link" onclick="load_page('merchant_docs_home')" tabindex="0">Merchant Docs</a>
        <a class="pp-header-nav-link" onclick="load_page('consumer_docs_home')" tabindex="0">Consumer Docs</a>
        <a class="pp-header-nav-link" onclick="load_page('blog_listing')" tabindex="0">Blog</a>
        <a class="pp-header-nav-link" onclick="load_page('changelog_page')" tabindex="0">Changelog</a>
      </nav>
    </div>
  </header>

  <!-- Main Content -->
  <main class="pp-main" id="pp-main-content" role="main">
    <div class="pp-container">
      <!-- Breadcrumb -->
      <nav class="pp-breadcrumb" aria-label="Breadcrumb">
        <a onclick="load_page('index')" tabindex="0">Home</a>
        <span class="pp-breadcrumb-sep" aria-hidden="true">/</span>
        <span class="pp-breadcrumb-current" aria-current="page">Privacy Policy</span>
      </nav>

      <!-- Last Updated -->
      <div class="pp-last-updated" id="pp_last_updated">
        <i class="fa fa-calendar-alt" aria-hidden="true"></i>
        Last Updated: January 15, 2025
      </div>

      <!-- Page Title -->
      <h1 class="pp-title" id="pp_title">Privacy Policy</h1>
      <p class="pp-subtitle">This Privacy Policy describes how MPay Network ("we", "our", or "us") collects, uses, protects, and shares your personal information when you use our mobile payment applications and documentation services.</p>

      <!-- Table of Contents -->
      <div class="pp-toc" role="navigation" aria-label="Table of contents">
        <div class="pp-toc-title">
          <i class="fa fa-list" aria-hidden="true"></i>
          Table of Contents
        </div>
        <button class="pp-toc-toggle" aria-expanded="false" aria-controls="pp-toc-nav">
          <span>Show sections</span>
          <i class="fa fa-chevron-down" aria-hidden="true"></i>
        </button>
        <ol class="pp-toc-list" id="pp-toc-nav">
          <li><a href="#section-info-collect">Information We Collect</a></li>
          <li><a href="#section-how-use">How We Use Your Information</a></li>
          <li><a href="#section-data-sharing">Data Sharing & Disclosure</a></li>
          <li><a href="#section-cookies">Cookies & Tracking Technologies</a></li>
          <li><a href="#section-data-security">Data Security</a></li>
          <li><a href="#section-data-retention">Data Retention</a></li>
          <li><a href="#section-feedback">Feedback & User Content</a></li>
          <li><a href="#section-your-rights">Your Rights & Choices</a></li>
          <li><a href="#section-children">Children's Privacy</a></li>
          <li><a href="#section-international">International Data Transfers</a></li>
          <li><a href="#section-changes">Changes to This Policy</a></li>
          <li><a href="#section-contact">Contact Us</a></li>
        </ol>
      </div>

      <!-- Privacy Policy Content -->
      <div class="pp-content" id="pp_content">

        <!-- Section 1: Information We Collect -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-info-collect">1. Information We Collect</h2>
          <p>We collect information to provide, improve, and secure our payment services. The types of information we collect include:</p>

          <h3 class="pp-subsection-title">1.1 Information You Provide Directly</h3>
          <ul>
            <li><strong>Account Registration Data:</strong> Name, email address, phone number, date of birth, and government-issued identification for KYC (Know Your Customer) verification.</li>
            <li><strong>Business Information (Merchants):</strong> Business name, registration number, business address, bank account details, and tax identification number.</li>
            <li><strong>Payment Information:</strong> Bank account details, wallet addresses, and transaction histories necessary to process payments.</li>
            <li><strong>Profile Information:</strong> Profile photos, display names, and other optional information you choose to provide.</li>
            <li><strong>Communications:</strong> Messages, support tickets, feedback submissions, and any correspondence you send to us.</li>
          </ul>

          <h3 class="pp-subsection-title">1.2 Information Collected Automatically</h3>
          <ul>
            <li><strong>Device Information:</strong> Device type, operating system, unique device identifiers, mobile network information, and browser type.</li>
            <li><strong>Usage Data:</strong> Pages visited on our documentation site, features used in the app, time spent on pages, and click patterns.</li>
            <li><strong>Location Data:</strong> Approximate location based on IP address. Precise location data is only collected with your explicit consent for NFC payment proximity features.</li>
            <li><strong>Log Data:</strong> IP addresses, access times, error logs, and referring URLs.</li>
          </ul>

          <h3 class="pp-subsection-title">1.3 Information from Third Parties</h3>
          <ul>
            <li><strong>Identity Verification Services:</strong> Results of KYC checks conducted through our verification partners.</li>
            <li><strong>Payment Processors:</strong> Transaction confirmations and payment status updates from banking partners.</li>
          </ul>
        </section>

        <!-- Section 2: How We Use Your Information -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-how-use">2. How We Use Your Information</h2>
          <p>We use the information we collect for the following purposes:</p>

          <div class="pp-data-table-wrapper">
            <table class="pp-data-table">
              <thead>
                <tr>
                  <th>Purpose</th>
                  <th>Legal Basis</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Processing QR code and NFC payments</td>
                  <td>Contract performance</td>
                </tr>
                <tr>
                  <td>Account creation and management</td>
                  <td>Contract performance</td>
                </tr>
                <tr>
                  <td>Identity verification (KYC/AML compliance)</td>
                  <td>Legal obligation</td>
                </tr>
                <tr>
                  <td>Fraud detection and prevention</td>
                  <td>Legitimate interest</td>
                </tr>
                <tr>
                  <td>Customer support and communication</td>
                  <td>Contract performance</td>
                </tr>
                <tr>
                  <td>Service improvement and analytics</td>
                  <td>Legitimate interest</td>
                </tr>
                <tr>
                  <td>Documentation site personalization</td>
                  <td>Consent</td>
                </tr>
                <tr>
                  <td>Marketing communications (opt-in only)</td>
                  <td>Consent</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- Section 3: Data Sharing -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-data-sharing">3. Data Sharing & Disclosure</h2>
          <p>We do not sell your personal information. We may share your information with the following categories of recipients:</p>
          <ul>
            <li><strong>Payment Processing Partners:</strong> Banks and payment networks that process your transactions. They receive only the data necessary to complete the transaction.</li>
            <li><strong>Identity Verification Providers:</strong> Third-party KYC services used to verify your identity during account setup.</li>
            <li><strong>Cloud Service Providers:</strong> Infrastructure providers that host our services (data is encrypted at rest and in transit).</li>
            <li><strong>Regulatory Authorities:</strong> When required by law, regulation, or legal process (e.g., anti-money laundering regulations).</li>
            <li><strong>Business Transfers:</strong> In connection with a merger, acquisition, or sale of assets, with appropriate safeguards.</li>
          </ul>

          <div class="pp-callout pp-callout-info">
            <i class="fa fa-info-circle" aria-hidden="true"></i>
            <div class="pp-callout-text">
              All third-party service providers are contractually required to protect your data and may only use it for the specified purposes. We conduct regular security audits of our partners.
            </div>
          </div>
        </section>

        <!-- Section 4: Cookies -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-cookies">4. Cookies & Tracking Technologies</h2>
          <p>Our documentation website uses cookies and similar technologies to enhance your browsing experience:</p>

          <div class="pp-data-table-wrapper">
            <table class="pp-data-table">
              <thead>
                <tr>
                  <th>Cookie Type</th>
                  <th>Purpose</th>
                  <th>Duration</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Essential</strong></td>
                  <td>Site functionality, session management, security</td>
                  <td>Session / 30 days</td>
                </tr>
                <tr>
                  <td><strong>Analytics</strong></td>
                  <td>Understanding usage patterns, page views, and navigation flows</td>
                  <td>Up to 12 months</td>
                </tr>
                <tr>
                  <td><strong>Preferences</strong></td>
                  <td>Remembering your settings (e.g., dark mode, language)</td>
                  <td>Up to 12 months</td>
                </tr>
                <tr>
                  <td><strong>Performance</strong></td>
                  <td>Monitoring site performance and error tracking</td>
                  <td>Up to 6 months</td>
                </tr>
              </tbody>
            </table>
          </div>

          <p>You can manage cookie preferences through your browser settings. Disabling essential cookies may affect site functionality.</p>

          <div class="pp-callout pp-callout-warning">
            <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
            <div class="pp-callout-text">
              Our mobile applications do not use browser cookies. However, they may use device-level storage for authentication tokens and user preferences.
            </div>
          </div>
        </section>

        <!-- Section 5: Data Security -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-data-security">5. Data Security</h2>
          <p>We implement industry-standard security measures to protect your personal information:</p>
          <ul>
            <li><strong>Encryption:</strong> All data is encrypted in transit (TLS 1.3) and at rest (AES-256).</li>
            <li><strong>Access Control:</strong> Strict role-based access controls limit who can view personal data within our organization.</li>
            <li><strong>Regular Audits:</strong> We conduct penetration testing and security audits at least annually.</li>
            <li><strong>Secure Payments:</strong> Payment data is handled in compliance with PCI DSS (Payment Card Industry Data Security Standard).</li>
            <li><strong>Incident Response:</strong> We maintain a comprehensive incident response plan and will notify affected users within 72 hours of discovering a data breach.</li>
            <li><strong>Two-Factor Authentication:</strong> Available and recommended for all user accounts.</li>
          </ul>
        </section>

        <!-- Section 6: Data Retention -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-data-retention">6. Data Retention</h2>
          <p>We retain your personal information for as long as necessary to provide our services and comply with legal obligations:</p>
          <ul>
            <li><strong>Active Accounts:</strong> Data is retained for the lifetime of your account plus 30 days after deletion request.</li>
            <li><strong>Transaction Records:</strong> Retained for a minimum of 7 years to comply with financial regulations and anti-money laundering laws.</li>
            <li><strong>KYC Documentation:</strong> Retained for 5 years after account closure, as required by regulatory obligations.</li>
            <li><strong>Analytics Data:</strong> Aggregated and anonymized data may be retained indefinitely for statistical purposes.</li>
            <li><strong>Support Tickets:</strong> Retained for 3 years after resolution for quality assurance purposes.</li>
          </ul>
          <p>When data is no longer needed, it is securely deleted or anonymized so that it can no longer be associated with you.</p>
        </section>

        <!-- Section 7: Feedback & User Content -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-feedback">7. Feedback & User Content</h2>
          <p>When you submit feedback, bug reports, feature requests, or blog comments through our documentation site:</p>
          <ul>
            <li><strong>Feedback Submissions:</strong> Your name (or alias), email address (if provided), and the content of your feedback are stored in our system for review and response.</li>
            <li><strong>Blog Comments:</strong> Comments undergo moderation before being published. Your display name and comment content will be publicly visible once approved.</li>
            <li><strong>Ratings:</strong> Star ratings submitted on blog posts are aggregated anonymously.</li>
            <li><strong>Screenshots & Attachments:</strong> Files uploaded with feedback are stored securely and accessible only to authorized support staff.</li>
          </ul>

          <div class="pp-callout pp-callout-info">
            <i class="fa fa-info-circle" aria-hidden="true"></i>
            <div class="pp-callout-text">
              You may request the deletion of your feedback submissions or comments at any time by contacting us at <strong>privacy@mpaynetwork.com</strong>.
            </div>
          </div>
        </section>

        <!-- Section 8: Your Rights -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-your-rights">8. Your Rights & Choices</h2>
          <p>Depending on your jurisdiction, you may have the following rights regarding your personal information:</p>
          <ul>
            <li><strong>Right to Access:</strong> Request a copy of the personal data we hold about you.</li>
            <li><strong>Right to Rectification:</strong> Request correction of inaccurate or incomplete data.</li>
            <li><strong>Right to Erasure:</strong> Request deletion of your personal data (subject to legal retention requirements).</li>
            <li><strong>Right to Restrict Processing:</strong> Request that we limit how we use your data in certain circumstances.</li>
            <li><strong>Right to Data Portability:</strong> Receive your data in a structured, machine-readable format.</li>
            <li><strong>Right to Object:</strong> Object to processing based on legitimate interests, including direct marketing.</li>
            <li><strong>Right to Withdraw Consent:</strong> Where processing is based on consent, you can withdraw it at any time.</li>
          </ul>
          <p>To exercise any of these rights, please contact us using the information in Section 12 below. We will respond to your request within 30 days.</p>
        </section>

        <!-- Section 9: Children's Privacy -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-children">9. Children's Privacy</h2>
          <p>MPay Network services are not intended for individuals under the age of 18. We do not knowingly collect personal information from children. If we become aware that we have collected data from a child under 18, we will take steps to delete that information promptly.</p>
          <p>If you believe a child has provided us with personal information, please contact us immediately at <strong>privacy@mpaynetwork.com</strong>.</p>
        </section>

        <!-- Section 10: International Data Transfers -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-international">10. International Data Transfers</h2>
          <p>Your information may be transferred to and processed in countries other than your country of residence. When we transfer data internationally, we ensure appropriate safeguards are in place, including:</p>
          <ul>
            <li>Standard Contractual Clauses (SCCs) approved by relevant authorities.</li>
            <li>Adequacy decisions where the destination country provides an adequate level of protection.</li>
            <li>Binding Corporate Rules for intra-group transfers.</li>
          </ul>
        </section>

        <!-- Section 11: Changes to This Policy -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-changes">11. Changes to This Policy</h2>
          <p>We may update this Privacy Policy from time to time to reflect changes in our practices, technologies, legal requirements, or other factors. When we make material changes:</p>
          <ul>
            <li>We will update the "Last Updated" date at the top of this page.</li>
            <li>We will notify you via email or in-app notification for significant changes.</li>
            <li>We will post the updated policy on our documentation site and in our <a onclick="load_page('changelog_page')" tabindex="0">Changelog</a>.</li>
          </ul>
          <p>We encourage you to review this Privacy Policy periodically. Your continued use of our services after changes take effect constitutes acceptance of the updated policy.</p>
        </section>

        <!-- Section 12: Contact Us -->
        <section class="pp-section">
          <h2 class="pp-section-title" id="section-contact">12. Contact Us</h2>
          <p>If you have questions, concerns, or requests regarding this Privacy Policy or our data practices, please contact us:</p>

          <div class="pp-contact-card">
            <div class="pp-contact-card-title">MPay Network Privacy Team</div>
            <div class="pp-contact-item">
              <i class="fa fa-envelope" aria-hidden="true"></i>
              <span>privacy@mpaynetwork.com</span>
            </div>
            <div class="pp-contact-item">
              <i class="fa fa-map-marker-alt" aria-hidden="true"></i>
              <span>MPay Network Inc., 100 Financial District, Suite 400, Singapore 018960</span>
            </div>
            <div class="pp-contact-item">
              <i class="fa fa-phone" aria-hidden="true"></i>
              <span>+65 6000 1234</span>
            </div>
            <div class="pp-contact-item">
              <i class="fa fa-globe" aria-hidden="true"></i>
              <span>Data Protection Officer: dpo@mpaynetwork.com</span>
            </div>
          </div>

          <p>If you are not satisfied with our response, you have the right to lodge a complaint with your local data protection authority.</p>
        </section>
      </div>

      <!-- Bottom Actions -->
      <div class="pp-bottom-actions">
        <div style="display:flex;gap:12px;flex-wrap:wrap;">
          <button class="pp-back-btn" id="pp_back_home" onclick="load_page('index')" aria-label="Back to Home">
            <i class="fa fa-arrow-left" aria-hidden="true"></i>
            Back to Home
          </button>
          <button class="pp-print-btn" aria-label="Print this page">
            <i class="fa fa-print" aria-hidden="true"></i>
            Print
          </button>
        </div>
        <a class="pp-terms-link" onclick="load_page('terms_of_service')" tabindex="0" aria-label="View Terms of Service">
          Terms of Service
          <i class="fa fa-arrow-right" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </main>

  <div id="docFooter"></div>

  <!-- Scroll to Top -->
  <button class="pp-scroll-top" aria-label="Scroll to top" title="Back to top">
    <i class="fa fa-arrow-up" aria-hidden="true"></i>
  </button>
</div>
    
