    <link rel="stylesheet" href="assets/css/consumer_wallet_management.css">
    <style>
        /* Basic reset for preview consistency */
        body { margin: 0; padding: 0; font-family: sans-serif; }
    </style>
</head>
<body>
    <div class="cwm-docs-layout">
  <!-- Skip to content -->
  <a href="#cwm-main-content" class="sr-only" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">Skip to main content</a>

  <!-- Mobile Sidebar Overlay -->
  <div class="cwm-sidebar-overlay" id="cwm-sidebar-overlay" aria-hidden="true"></div>

  <!-- Sidebar -->
  <aside class="cwm-sidebar" id="cwm-sidebar" role="navigation" aria-label="Consumer documentation navigation">
    <nav>
      <div class="cwm-sidebar-section">
        <p class="cwm-sidebar-label">Getting Started</p>
        <ul class="cwm-sidebar-links">
          <li><a onclick="load_page('consumer_docs_home')" href="javascript:void(0)"><i class="fa fa-home" aria-hidden="true"></i> Overview</a></li>
          <li><a onclick="load_page('consumer_getting_started')" href="javascript:void(0)"><i class="fa fa-rocket" aria-hidden="true"></i> Getting Started</a></li>
          <li><a onclick="load_page('consumer_account_setup')" href="javascript:void(0)"><i class="fa fa-user-circle" aria-hidden="true"></i> Account Setup</a></li>
        </ul>
      </div>
      <div class="cwm-sidebar-section">
        <p class="cwm-sidebar-label">Using Your Wallet</p>
        <ul class="cwm-sidebar-links">
          <li><a onclick="load_page('consumer_making_payments')" href="javascript:void(0)"><i class="fa fa-credit-card" aria-hidden="true"></i> Making Payments</a></li>
          <li><a class="active" onclick="load_page('consumer_wallet_management')" href="javascript:void(0)"><i class="fa fa-wallet" aria-hidden="true"></i> Wallet Management</a></li>
          <li><a onclick="load_page('consumer_p2p_transfers')" href="javascript:void(0)"><i class="fa fa-exchange-alt" aria-hidden="true"></i> QR Transactions</a></li>
        </ul>
      </div>
      <div class="cwm-sidebar-section">
        <p class="cwm-sidebar-label">Settings & Help</p>
        <ul class="cwm-sidebar-links">
          <li><a onclick="load_page('consumer_settings')" href="javascript:void(0)"><i class="fa fa-cog" aria-hidden="true"></i> Settings & Security</a></li>
          <li><a onclick="load_page('consumer_troubleshooting')" href="javascript:void(0)"><i class="fa fa-life-ring" aria-hidden="true"></i> Troubleshooting</a></li>
