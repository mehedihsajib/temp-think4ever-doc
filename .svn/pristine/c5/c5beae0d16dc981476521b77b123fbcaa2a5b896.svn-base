  <!-- Mobile Sidebar Toggle -->
  <button class="cwm-sidebar-toggle" id="cwm-sidebar-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
    <i class="fa fa-bars" aria-hidden="true"></i>
  </button>

  <!-- Main Content -->
  <div class="cwm-main">
    <div class="cwm-content-wrapper" id="cwm-main-content">
      
      <!-- Breadcrumb -->
      <nav class="cwm-breadcrumb" aria-label="Breadcrumb">
        <a onclick="load_page('landing_page')" href="javascript:void(0)">Docs</a>
        <span class="separator"><i class="fa fa-chevron-right" aria-hidden="true"></i></span>
        <a onclick="load_page('consumer_docs_home')" href="javascript:void(0)">Consumer</a>
        <span class="separator"><i class="fa fa-chevron-right" aria-hidden="true"></i></span>
        <span class="current">Wallet Management</span>
      </nav>

      <!-- Page Title -->
      <h1 class="cwm-page-title">Wallet Management</h1>
      <p class="cwm-page-subtitle">Learn how to check your balance, add funds, withdraw money, and understand your transaction limits.</p>
      <hr class="cwm-title-divider">

      <!-- Wallet Overview Card -->
      <div class="cwm-wallet-overview cwm-animate-in">
        <div class="cwm-wallet-overview-inner">
          <div class="cwm-wallet-icon-container">
            <i class="fa fa-wallet" aria-hidden="true"></i>
          </div>
          <div class="cwm-wallet-overview-text">
            <h3>Your MPay Wallet</h3>
            <p>Your MPay wallet is a secure digital wallet that stores your funds and allows you to make payments, transfer money, and manage your finances — all from your smartphone.</p>
          </div>
        </div>
      </div>

      <!-- Section: Checking Balance -->
      <section class="cwm-section" id="cwm_content_balance">
        <h2 class="cwm-section-heading" id="checking-balance">
          <i class="fa fa-eye heading-icon" aria-hidden="true"></i>Checking Your Balance
        </h2>
        <p class="cwm-section-intro">Your wallet balance is always visible on the home screen of the MPay app. Here's everything you need to know about viewing and understanding your balance.</p>

        <!-- Balance Demo -->
        <div class="cwm-balance-demo">
          <button class="cwm-balance-toggle" id="cwm-balance-toggle" aria-label="Hide balance">
            <i class="fa fa-eye" aria-hidden="true"></i>
          </button>
          <div class="cwm-balance-demo-header">Available Balance</div>
          <div class="cwm-balance-demo-amount" id="cwm-balance-amount">$2,458.50</div>
          <div class="cwm-balance-demo-currency">US Dollars (USD)</div>
          <div class="cwm-balance-demo-actions">
            <button class="cwm-balance-btn cwm-balance-btn-topup" aria-label="Top up wallet">
              <i class="fa fa-plus-circle" aria-hidden="true"></i>
              Top Up
            </button>
            <button class="cwm-balance-btn cwm-balance-btn-withdraw" aria-label="Withdraw funds">
              <i class="fa fa-arrow-circle-down" aria-hidden="true"></i>
              Withdraw
            </button>
            <button class="cwm-balance-btn cwm-balance-btn-history" aria-label="View transaction history">
              <i class="fa fa-history" aria-hidden="true"></i>
              History
            </button>
          </div>
        </div>

        <h3 class="cwm-subsection-heading">How to View Your Balance</h3>
        <div class="cwm-steps">
          <div class="cwm-step">
            <span class="cwm-step-dot">1</span>
            <p class="cwm-step-title">Open the MPay App</p>
            <p class="cwm-step-desc">Launch the MPay Consumer app on your device. Your balance appears prominently on the home screen.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">2</span>
            <p class="cwm-step-title">View Available Balance</p>
            <p class="cwm-step-desc">Your available balance is displayed at the top of the screen. This is the amount you can spend or transfer immediately.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">3</span>
            <p class="cwm-step-title">Toggle Balance Visibility</p>
            <p class="cwm-step-desc">Tap the <strong>eye icon</strong> (<i class="fa fa-eye" aria-hidden="true"></i>) to hide or show your balance for privacy when in public.</p>
          </div>
        </div>

        <div class="cwm-callout cwm-callout-info">
          <span class="cwm-callout-icon"><i class="fa fa-info-circle" aria-hidden="true"></i></span>
          <div><strong>Pending transactions</strong> may temporarily reduce your available balance. Pending amounts are shown separately below your main balance.</div>
        </div>
      </section>

      <!-- Section: Top-Up Methods -->
      <section class="cwm-section" id="cwm_content_topup">
        <h2 class="cwm-section-heading" id="topup-methods">
          <i class="fa fa-plus-circle heading-icon" aria-hidden="true"></i>Top-Up Methods
        </h2>
        <p class="cwm-section-intro">Add funds to your MPay wallet using any of the following methods. Each method has different processing times and fees.</p>

        <div class="cwm-method-cards">
          <div class="cwm-method-card">
            <div class="cwm-method-card-icon">
              <i class="fa fa-university" aria-hidden="true"></i>
            </div>
            <h4>Bank Transfer</h4>
            <p>Transfer funds directly from your linked bank account to your MPay wallet. No fees for standard transfers.</p>
            <div class="cwm-method-time"><i class="fa fa-clock" aria-hidden="true"></i> 1-2 business days</div>
          </div>
          <div class="cwm-method-card">
            <div class="cwm-method-card-icon">
              <i class="fa fa-credit-card" aria-hidden="true"></i>
            </div>
            <h4>Debit / Credit Card</h4>
            <p>Instantly load your wallet using a Visa, Mastercard, or supported debit card. Small processing fee may apply.</p>
            <div class="cwm-method-time"><i class="fa fa-bolt" aria-hidden="true"></i> Instant</div>
          </div>
          <div class="cwm-method-card">
            <div class="cwm-method-card-icon">
              <i class="fa fa-store" aria-hidden="true"></i>
            </div>
            <h4>Cash Agent</h4>
            <p>Visit an authorized MPay agent near you to deposit cash into your wallet. Present your MPay QR code to the agent.</p>
            <div class="cwm-method-time"><i class="fa fa-bolt" aria-hidden="true"></i> Instant</div>
          </div>
        </div>

        <h3 class="cwm-subsection-heading">How to Top Up via Bank Transfer</h3>
        <div class="cwm-steps">
          <div class="cwm-step">
            <span class="cwm-step-dot">1</span>
            <p class="cwm-step-title">Tap "Top Up" on Home Screen</p>
            <p class="cwm-step-desc">From your wallet home screen, tap the <strong>Top Up</strong> button.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">2</span>
            <p class="cwm-step-title">Select "Bank Transfer"</p>
            <p class="cwm-step-desc">Choose <strong>Bank Transfer</strong> from the list of top-up methods.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">3</span>
            <p class="cwm-step-title">Enter Amount</p>
            <p class="cwm-step-desc">Enter the amount you wish to add. The minimum top-up is <span class="cwm-code">$10.00</span> and the maximum per transaction is <span class="cwm-code">$5,000.00</span>.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">4</span>
            <p class="cwm-step-title">Select Linked Bank Account</p>
            <p class="cwm-step-desc">Choose from your linked bank accounts, or add a new one by tapping <strong>"+ Add Bank Account"</strong>.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">5</span>
            <p class="cwm-step-title">Confirm & Authenticate</p>
            <p class="cwm-step-desc">Review the details and confirm using your PIN, fingerprint, or Face ID.</p>
          </div>
        </div>

        <div class="cwm-callout cwm-callout-success">
          <span class="cwm-callout-icon"><i class="fa fa-check-circle" aria-hidden="true"></i></span>
          <div><strong>Tip:</strong> Set up automatic top-ups to maintain a minimum balance. Go to <strong>Settings → Auto Top-Up</strong> to configure.</div>
        </div>

        <h3 class="cwm-subsection-heading">How to Top Up via Card</h3>
        <div class="cwm-steps">
          <div class="cwm-step">
            <span class="cwm-step-dot">1</span>
            <p class="cwm-step-title">Tap "Top Up" → Select "Debit/Credit Card"</p>
            <p class="cwm-step-desc">Navigate to the top-up screen and select the card payment option.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">2</span>
            <p class="cwm-step-title">Enter Amount & Card Details</p>
            <p class="cwm-step-desc">Enter the top-up amount and select a saved card or enter new card details. A fee of <span class="cwm-code">1.5%</span> applies to credit card top-ups.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">3</span>
            <p class="cwm-step-title">Complete 3D Secure Verification</p>
            <p class="cwm-step-desc">You may be redirected to your bank's 3D Secure page for additional verification.</p>
          </div>
        </div>

        <div class="cwm-callout cwm-callout-warning">
          <span class="cwm-callout-icon"><i class="fa fa-exclamation-triangle" aria-hidden="true"></i></span>
          <div><strong>Note:</strong> Credit card top-ups incur a 1.5% processing fee. Debit card top-ups are free. We recommend using bank transfers or debit cards to avoid fees.</div>
        </div>
      </section>

      <!-- Section: Withdrawals -->
      <section class="cwm-section" id="cwm_content_withdraw">
        <h2 class="cwm-section-heading" id="withdrawals">
          <i class="fa fa-arrow-circle-down heading-icon" aria-hidden="true"></i>Withdrawals
        </h2>
        <p class="cwm-section-intro">Withdraw funds from your MPay wallet to your linked bank account at any time. Here's how the withdrawal process works.</p>

        <!-- Withdrawal Flow -->
        <div class="cwm-flow">
          <div class="cwm-flow-step">
            <div class="cwm-flow-step-icon">
              <i class="fa fa-hand-pointer" aria-hidden="true"></i>
            </div>
            <span class="cwm-flow-step-label">Initiate<br>Withdrawal</span>
          </div>
          <div class="cwm-flow-arrow"><i class="fa fa-arrow-right" aria-hidden="true"></i></div>
          <div class="cwm-flow-step">
            <div class="cwm-flow-step-icon">
              <i class="fa fa-dollar-sign" aria-hidden="true"></i>
            </div>
            <span class="cwm-flow-step-label">Enter<br>Amount</span>
          </div>
          <div class="cwm-flow-arrow"><i class="fa fa-arrow-right" aria-hidden="true"></i></div>
          <div class="cwm-flow-step">
            <div class="cwm-flow-step-icon">
              <i class="fa fa-university" aria-hidden="true"></i>
            </div>
            <span class="cwm-flow-step-label">Select<br>Bank</span>
          </div>
          <div class="cwm-flow-arrow"><i class="fa fa-arrow-right" aria-hidden="true"></i></div>
          <div class="cwm-flow-step">
            <div class="cwm-flow-step-icon">
              <i class="fa fa-fingerprint" aria-hidden="true"></i>
            </div>
            <span class="cwm-flow-step-label">Confirm &<br>Authenticate</span>
          </div>
          <div class="cwm-flow-arrow"><i class="fa fa-arrow-right" aria-hidden="true"></i></div>
          <div class="cwm-flow-step">
            <div class="cwm-flow-step-icon">
              <i class="fa fa-check" aria-hidden="true"></i>
            </div>
            <span class="cwm-flow-step-label">Funds<br>Transferred</span>
          </div>
        </div>

        <h3 class="cwm-subsection-heading">Step-by-Step Withdrawal Guide</h3>
        <div class="cwm-steps">
          <div class="cwm-step">
            <span class="cwm-step-dot">1</span>
            <p class="cwm-step-title">Navigate to Withdrawals</p>
            <p class="cwm-step-desc">From the home screen, tap <strong>Withdraw</strong> or go to <strong>Wallet → Withdraw Funds</strong>.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">2</span>
            <p class="cwm-step-title">Enter Withdrawal Amount</p>
            <p class="cwm-step-desc">Enter the amount you'd like to withdraw. The minimum withdrawal is <span class="cwm-code">$20.00</span>. Your available balance will be shown above the input.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">3</span>
            <p class="cwm-step-title">Select Destination Bank Account</p>
            <p class="cwm-step-desc">Choose from your linked bank accounts. You can link a new bank account from <strong>Settings → Bank Accounts</strong>.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">4</span>
            <p class="cwm-step-title">Review & Confirm</p>
            <p class="cwm-step-desc">Review the withdrawal details including any applicable fees, then authenticate with your PIN, fingerprint, or Face ID.</p>
          </div>
          <div class="cwm-step">
            <span class="cwm-step-dot">5</span>
            <p class="cwm-step-title">Track Your Withdrawal</p>
            <p class="cwm-step-desc">You'll receive a confirmation with a reference number. Track the status in <strong>Transaction History</strong>.</p>
          </div>
        </div>

        <h3 class="cwm-subsection-heading">Withdrawal Processing Times</h3>
        <div class="cwm-table-container">
          <table class="cwm-table" aria-label="Withdrawal processing times">
            <thead>
              <tr>
                <th scope="col">Method</th>
                <th scope="col">Processing Time</th>
                <th scope="col">Fee</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Standard Withdrawal</strong></td>
                <td>1–2 business days</td>
                <td>Free</td>
              </tr>
              <tr>
                <td><strong>Express Withdrawal</strong></td>
                <td>Within 2 hours</td>
                <td>$1.50 flat fee</td>
              </tr>
              <tr>
                <td><strong>Instant Withdrawal</strong></td>
                <td>Within minutes</td>
                <td>1.5% (min $2.00)</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="cwm-callout cwm-callout-danger">
          <span class="cwm-callout-icon"><i class="fa fa-exclamation-circle" aria-hidden="true"></i></span>
          <div><strong>Important:</strong> Withdrawals cannot be canceled once confirmed. Please double-check the bank account and amount before confirming.</div>
        </div>
      </section>

      <!-- Section: Transaction Limits -->
      <section class="cwm-section" id="cwm_content_limits">
        <h2 class="cwm-section-heading" id="transaction-limits">
          <i class="fa fa-tachometer-alt heading-icon" aria-hidden="true"></i>Transaction Limits
        </h2>
        <p class="cwm-section-intro">MPay enforces transaction limits to protect your account. Your limits depend on your verification level. Here's a breakdown of what you can do at each tier.</p>

        <div class="cwm-table-container">
          <table class="cwm-table" aria-label="Transaction limits by tier">
            <thead>
              <tr>
                <th scope="col">Limit Type</th>
                <th scope="col"><span class="cwm-badge cwm-badge-basic">Basic</span></th>
                <th scope="col"><span class="cwm-badge cwm-badge-verified">Verified</span></th>
                <th scope="col"><span class="cwm-badge cwm-badge-premium">Premium</span></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Single Transaction</strong></td>
                <td>$500</td>
                <td>$5,000</td>
                <td>$25,000</td>
              </tr>
              <tr>
                <td><strong>Daily Top-Up</strong></td>
                <td>$1,000</td>
                <td>$10,000</td>
                <td>$50,000</td>
              </tr>
              <tr>
                <td><strong>Daily Withdrawal</strong></td>
                <td>$500</td>
                <td>$5,000</td>
                <td>$25,000</td>
              </tr>
              <tr>
                <td><strong>Monthly Total</strong></td>
                <td>$5,000</td>
                <td>$50,000</td>
                <td>$250,000</td>
              </tr>
              <tr>
                <td><strong>Wallet Balance Max</strong></td>
                <td>$2,500</td>
                <td>$25,000</td>
                <td>$100,000</td>
              </tr>
              <tr>
                <td><strong>P2P Transfer (per tx)</strong></td>
                <td>$250</td>
                <td>$2,500</td>
                <td>$10,000</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="cwm-subsection-heading">How to Increase Your Limits</h3>
        <p>To move to a higher tier, you'll need to complete additional verification:</p>
        <ul>
          <li><strong>Basic → Verified:</strong> Complete identity verification (KYC) by submitting a government-issued ID and a selfie. Go to <strong>Settings → Verification → Upgrade to Verified</strong>.</li>
          <li><strong>Verified → Premium:</strong> Submit proof of address (utility bill or bank statement dated within 90 days) and complete enhanced due diligence. Go to <strong>Settings → Verification → Apply for Premium</strong>.</li>
        </ul>

        <div class="cwm-callout cwm-callout-info">
          <span class="cwm-callout-icon"><i class="fa fa-info-circle" aria-hidden="true"></i></span>
          <div><strong>View your current limits:</strong> Go to <strong>Settings → Account → Transaction Limits</strong> to see your current tier, usage, and remaining limits for the day/month.</div>
        </div>

        <div class="cwm-callout cwm-callout-warning">
          <span class="cwm-callout-icon"><i class="fa fa-exclamation-triangle" aria-hidden="true"></i></span>
          <div><strong>Approaching your limit?</strong> You'll receive a notification when you've used 80% of your daily or monthly limit. Transactions exceeding your limit will be declined.</div>
        </div>
      </section>

      <!-- Section: FAQ -->
      <section class="cwm-faq-section" id="cwm_faq_accordion">
        <h2 class="cwm-section-heading cwm-faq-heading" id="faq">
          <i class="fa fa-question-circle heading-icon" aria-hidden="true"></i>Frequently Asked Questions
        </h2>

        <div class="cwm-accordion" role="region" aria-label="Wallet management FAQ">
          <div class="cwm-accordion-item">
            <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-1">
              <span>How long does it take for a top-up to appear in my wallet?</span>
              <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
            </button>
            <div class="cwm-accordion-panel" id="faq-1" role="region">
              <div class="cwm-accordion-panel-inner">
                Card top-ups appear instantly. Bank transfers typically take 1–2 business days, depending on your bank. Cash agent top-ups are also instant once confirmed by the agent. You'll receive a push notification as soon as the funds are credited.
              </div>
            </div>
          </div>

          <div class="cwm-accordion-item">
            <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-2">
              <span>Can I withdraw to a bank account that isn't in my name?</span>
              <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
            </button>
            <div class="cwm-accordion-panel" id="faq-2" role="region">
              <div class="cwm-accordion-panel-inner">
                No. For security reasons, withdrawals can only be made to bank accounts registered in the same name as your MPay account. This is a regulatory requirement to prevent fraud and money laundering. If you need to send money to someone else, use the <strong>P2P Transfer</strong> feature instead.
              </div>
            </div>
          </div>

          <div class="cwm-accordion-item">
            <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-3">
              <span>What happens if I exceed my transaction limit?</span>
              <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
            </button>
            <div class="cwm-accordion-panel" id="faq-3" role="region">
              <div class="cwm-accordion-panel-inner">
                The transaction will be declined, and you'll see an error message explaining that you've reached your limit. You can either wait for the limit to reset (daily limits reset at midnight UTC, monthly limits on the 1st of each month) or upgrade your verification tier to get higher limits.
              </div>
            </div>
          </div>

          <div class="cwm-accordion-item">
            <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-4">
              <span>Is there a fee for maintaining a wallet balance?</span>
              <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
            </button>
            <div class="cwm-accordion-panel" id="faq-4" role="region">
              <div class="cwm-accordion-panel-inner">
                No. There are no monthly fees, maintenance charges, or inactivity fees for your MPay wallet. Your balance stays yours. The only fees that may apply are for certain top-up methods (credit card top-ups) and express/instant withdrawals.
              </div>
            </div>
          </div>

          <div class="cwm-accordion-item">
            <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-5">
              <span>Can I set up recurring/automatic top-ups?</span>
              <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
            </button>
            <div class="cwm-accordion-panel" id="faq-5" role="region">
              <div class="cwm-accordion-panel-inner">
                Yes! Go to <strong>Settings → Auto Top-Up</strong> to configure automatic balance replenishment. You can set a minimum balance threshold and a top-up amount. When your balance drops below the threshold, MPay will automatically top up from your preferred funding source.
              </div>
            </div>
          </div>

          <div class="cwm-accordion-item">
            <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-6">
              <span>What happens to my balance if I lose my phone?</span>
              <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
            </button>
            <div class="cwm-accordion-panel" id="faq-6" role="region">
              <div class="cwm-accordion-panel-inner">
                Your balance is safe — it's stored securely on MPay servers, not on your device. If you lose your phone, immediately contact MPay support to freeze your account. Then, when you get a new device, log in with your credentials and your full balance will be restored. Enable remote wipe on your phone as an extra precaution.
              </div>
            </div>
          </div>
        </div>
      </section>

