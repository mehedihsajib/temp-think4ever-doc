      },
      "r11": {
        "title": "Mejores prácticas de seguridad para pagos digitales",
        "excerpt": "Proteja sus datos de <mark>pago</mark> con estos consejos esenciales de seguridad. Habilite la autenticación de dos factores, use contraseñas seguras y monitoree las transacciones."
      },
      "r12": {
        "title": "Configuración de seguridad y privacidad de la aplicación del consumidor",
        "excerpt": "Configure sus preferencias de seguridad, incluyendo inicio de sesión biométrico, límites de <mark>pago</mark>, notificaciones de transacciones y controles de privacidad."
      }
