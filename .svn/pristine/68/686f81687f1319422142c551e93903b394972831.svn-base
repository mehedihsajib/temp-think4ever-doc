  "making_payments": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumidor",
      "current": "Realizar Pagos"
    },
    "title": "Realizar Pagos",
    "subtitle": "Aprenda a realizar pagos rápidos y seguros con el Monedero del Consumidor MPay. Ya sea escaneando un código QR, mostrando el suyo o tocando con NFC, pagar nunca ha sido tan fácil.",
    "method_cards": {
      "qr": {
        "title": "Pagos con Código QR",
        "body": "Escanee o muestre un código QR para completar pagos al instante en cualquier comercio de MPay."
      },
      "nfc": {
        "title": "NFC Toca-para-Pagar",
        "body": "Simplemente sostenga su teléfono cerca de la terminal para una experiencia de pago sin contacto."
      }
    },
    "scan_qr": {
      "heading": "Escaneo de Códigos QR",
      "intro": "La forma más común de pagar es escaneando el código QR de un comercio. Este proceso solo toma unos segundos y procesa su pago de forma segura a través de la red MPay.",
      "how_to_title": "Cómo Escanear para Pagar",
      "how_to_intro": "<strong>Escanear para Pagar</strong> permite a los usuarios escanear un código QR para enviar dinero o realizar pagos rápidamente usando su monedero.",
      "steps": {
        "1": {
          "title": "Toque \"Escanear para Pagar\"",
          "body": "Desde la pantalla de inicio, toque el <strong>icono de Escanear para Pagar</strong> en la sección de <b>Enviar Dinero</b>."
        },
        "2": {
          "title": "Escanee el Código QR del Destinatario",
          "body": "Apunte su cámara al código QR del destinatario. Una vez escaneado, los detalles del destinatario se completarán automáticamente en el formulario de Escanear para Pagar.&nbsp;"
        },
        "3": {
          "title": "Ingrese el Monto y Confirme",
          "body": "Ingrese el monto de la transferencia, revise los detalles y confirme con su PIN o autenticación biométrica."
        },
        "4": {
          "title": "Transferencia Completada",
          "body": "Verá una pantalla de confirmación con un <b>número de referencia</b> de la transacción.&nbsp; <p>El destinatario es notificado al instante.</p>"
        }
      },
      "visual_label": "Alinee el código QR dentro del marco",
      "tip_title": "Consejo: Acceso Directo de Pago Rápido",
      "tip_body": "También puede iniciar el escáner QR directamente tocando dos veces el icono de MPay en su pantalla de inicio, o usando el acceso directo \"Escanear\" desde el widget de la pantalla de notificaciones."
    },
    "show_qr": {
      "heading": "Mostrar su Código QR",
      "intro": "Algunos comercios prefieren escanear su código QR usando su terminal o dispositivo. En este caso, simplemente presente su código QR de pago personal para que lo escaneen.",
      "how_to_title": "Cómo Mostrar su QR",
      "steps": {
        "1": {
          "title": "Abra su Código de Pago",
          "body": "Toque <strong>\"Pagar\"</strong> en la pantalla de inicio, luego seleccione <strong>\"Mostrar mi Código QR\"</strong>. Se mostrará su código QR de pago personal."
        },
        "2": {
          "title": "Presentar al Comercio",
          "body": "Sostenga su teléfono firme con el código QR visible. El comercio lo escaneará usando su terminal MPay Merchant o la cámara del dispositivo."
        },
        "3": {
          "title": "Confirmar en su Dispositivo",
          "body": "Después de que el comercio escanee e ingrese el monto, recibirá una notificación push. Confirme el monto del pago y autentíquese para completar."
        }
      },
      "visual_label": "Muestre esto al comercio",
      "security_title": "Nota de Seguridad",
      "security_body": "Su código QR de pago se actualiza cada 60 segundos por seguridad. Nunca comparta una captura de pantalla de su código QR. Solo muéstrelo en el punto de venta al realizar un pago."
    },
    "nfc_tap": {
      "heading": "NFC Toca-para-Pagar",
      "intro": "Si su dispositivo soporta NFC y el comercio tiene una terminal habilitada para NFC, puede pagar simplemente tocando su teléfono contra su dispositivo de pago — sin necesidad de escanear.",
      "how_to_title": "Cómo usar Pagos NFC",
      "steps": {
        "1": {
          "title": "Habilitar NFC",
          "body": "Asegúrese de que el NFC esté habilitado en los ajustes de su teléfono y en la aplicación MPay en <strong>Ajustes → Métodos de Pago → Pagos NFC</strong>."
        },
        "2": {
          "title": "Sostener Cerca de la Terminal",
          "body": "Cuando la terminal del comercio muestre el monto, sostenga la parte posterior de su teléfono (cerca de la antena NFC) a menos de 4 cm de la terminal de pago."
        },
        "3": {
          "title": "Autenticar",
          "body": "Una vibración o tono confirma la conexión. Autentíquese usando biometría o su PIN. El pago se procesa en menos de 2 segundos."
        },
        "4": {
          "title": "Pago Completado",
          "body": "Verá una marca de verificación de éxito y recibirá una notificación en la aplicación y un recibo SMS opcional."
        }
      },
      "visual_phone": "Su Teléfono",
      "visual_terminal": "Terminal de Pago",
      "antenna_title": "Ubicación de la Antena NFC",
      "antenna_body": "La antena NFC suele estar ubicada en la parte superior central de la parte posterior de su teléfono. Quite las fundas gruesas si tiene problemas para conectar."
    },
    "confirmation": {
      "heading": "Confirmación de Pago",
      "intro": "Después de cada pago exitoso, recibirá una confirmación instantánea con los detalles de la transacción. Esto sirve como su recibo digital.",
      "receipt_title": "Qué se Incluye en su Recibo",
      "receipt_intro": "Cada confirmación de pago incluye los siguientes detalles:",
      "receipt": {
        "success": "Pago Exitoso",
        "merchant": "Coffee House Downtown",
        "transaction_id": "ID de Transacción",
        "datetime": "Fecha y Hora",
        "method": "Método de Pago",
        "status": "Estado",
        "completed": "Completado",
        "balance": "Saldo del Monedero"
      },
      "share_title": "Compartir y Exportar Recibos",
      "share_body": "Toque el botón <strong>\"Compartir\"</strong> en cualquier recibo para enviarlo por correo electrónico, aplicaciones de mensajería o guardarlo como PDF.",
      "failed_title": "Pagos Fallidos o Pendientes",
      "failed_intro": "Si un pago falla o permanece pendiente, verá una pantalla de estado diferente:",
      "failed_list": {
        "pending": "<strong>Pendiente:</strong> El pago se está procesando. Esto suele resolverse en 30 segundos.",
        "failed": "<strong>Fallido:</strong> El pago no pudo completarse. Compruebe su saldo y conexión.",
        "refunded": "<strong>Reembolsado:</strong> El comercio inició un reembolso. Los fondos regresan en 1-3 días hábiles."
      }
    },
    "history": {
      "heading": "Historial de Transacciones",
      "intro": "Rastree todos sus pagos pasados en un solo lugar. Su historial de transacciones mantiene un registro completo de cada pago realizado a través del Monedero mPay.",
      "access_title": "Acceder a su Historial",
      "access_body": "Navegue a <strong>Inicio → Transacciones</strong> o deslice hacia arriba en la pantalla de inicio.",
      "sample_title": "Ejemplo de Historial de Transacciones",
      "table": {
        "date": "Fecha",
        "merchant": "Comercio",
        "method": "Método",
        "amount": "Monto",
        "status": "Estado",
        "completed": "Completado",
        "pending": "Pendiente"
      },
      "export_title": "Exportar sus Datos",
      "export_body": "Puede exportar su historial de transacciones como CSV o PDF tocando el botón <strong>\"Exportar\"</strong>."
    },
    "overview": {
      "heading": "Resumen del Flujo de Pago",
      "intro": "Aquí tiene un recorrido visual del proceso de pago completo de principio a fin.",
      "steps": {
        "1": "Toque \"Pagar\" en la pantalla de inicio",
        "2": "Elija escaneo QR o toque NFC",
        "3": "Escanee el código QR del comercio",
        "4": "Revise el monto del pago",
        "5": "Autentíquese con biometría",
        "6": "¡Pago confirmado!"
      }
    },
    "faq": {
      "heading": "Preguntas Frecuentes",
      "q1": "¿Cuál es el monto máximo que puedo pagar por transacción?",
      "a1": "El límite de transacción predeterminado es de $5,000 por pago. Las cuentas verificadas (KYC Nivel 2) pueden solicitar límites superiores. Puede gestionar sus límites en <strong>Ajustes → Límites de Pago</strong>.",
      "q2": "¿Puedo pagar sin conexión a internet?",
      "a2": "Los pagos NFC pueden funcionar en modo offline para pequeñas transacciones (menos de $50) si se configuran. Los pagos con código QR siempre requieren conexión a internet.",
      "q3": "¿Qué debo hacer si el escáner QR no reconoce el código?",
      "a3": "Asegúrese de tener una iluminación adecuada y limpie su lente. Si falla, solicite un código nuevo o ingrese el ID del comercio manualmente.",
      "q4": "¿Es compatible el pago NFC en todos los dispositivos?",
      "a4": "Los pagos NFC requieren un dispositivo con chip NFC. La mayoría de los teléfonos posteriores a 2018 e iPhones desde el 7 en adelante soportan NFC.",
      "q5": "¿Hay alguna tarifa por realizar pagos? ",
      "a5": "El Monedero del Consumidor MPay no cobra ninguna tarifa por realizar pagos a comercios. El procesamiento de la tarifa se gestiona del lado del comercio.",
      "q6": "¿Puedo cancelar un pago después de enviarlo?",
      "a6": "Los pagos completados no pueden cancelarse directamente. Contacte al comercio para un reembolso o reporte una disputa en <b>Transacciones</b>."
    },
    "pagination": {
      "previous": "Anterior",
      "next": "Siguiente",
      "prev_title": "Configuración de la Cuenta",
      "next_title": "Gestión del Monedero"
    },
    "toc": {
