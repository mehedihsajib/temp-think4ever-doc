    "entries": {
      "v2_3_0": [
        "Soporte de autenticación biométrica para pagos NFC en ambas billeteras",
        "Soporte multi-idioma: español, francés, portugués y árabe",
        "Historial de transacciones rediseñado con filtrado avanzado y opciones de exportación",
        "Flujo de incorporación mejorado con tutoriales interactivos",
        "Se corrigieron problemas de accesibilidad con la navegación por lector de pantalla en los flujos de pago"
      ],
      "v2_2_1": [
        "Se resolvió el tiempo de espera de generación de código QR en dispositivos Android antiguos",
        "Se corrigió el formato de moneda incorrecto en los recibos de transacciones",
        "Se actualizó el anclaje de certificados TLS para una seguridad de API mejorada",
        "Se corrigieron los retrasos en las notificaciones push para las confirmaciones de pago"
      ],
      "v2_2_0": [
        "Las transferencias P2P ahora admiten pagos programados y recurrentes",
        "Nuevos métodos de recarga de billetera: transferencia bancaria y tarjeta de débito",
        "Pantalla de confirmación de pago mejorada con detalles del comerciante y ubicación en el mapa",
        "Se agregó el intercambio de recibos de transacciones a través de WhatsApp, SMS y correo electrónico"
      ],
      "v2_1_2": [
        "Se corrigió que el lector de pagos NFC no respondiera después del modo de suspensión",
        "Se resolvió la discrepancia en el cálculo del informe de liquidación",
        "Se corrigió la visualización de la zona horaria en las marcas de tiempo de las transacciones"
      ],
      "v2_1_0": [
        "Códigos QR dinámicos con montos y descripciones de pago personalizables",
        "Seguimiento del estado del pago en tiempo real con notificaciones en vivo",
        "Puntos finales de la API v1 obsoletos: migre a las API v2 antes del 1 de marzo",
        "Requisitos mínimos del sistema operativo actualizados: iOS 15+ y Android 10+",
        "Soporte de modo oscuro en todas las pantallas"
      ],
      "v2_0_3": [
        "Vulnerabilidad parcheada en el mecanismo de actualización del token de sesión",
        "Se corrigió que el saldo de la billetera no se actualizara después de completar la transferencia P2P",
        "Cifrado mejorado para las credenciales de pago almacenadas"
      ],
      "v2_0_0": [
        "Rediseño completo de la interfaz de usuario con la nueva identidad de marca azul real",
        "Soporte de pago NFC para las billeteras de comerciante y consumidor",
        "Nuevo tablero de comerciante con análisis de ventas y conocimientos",
        "Migración a una nueva infraestructura de procesamiento de pagos segura",
        "Se eliminaron las integraciones de métodos de pago heredados (procesamiento de tarjetas v1)",
        "Verificación KYC optimizada con escaneo de documentos"
      ],
      "v1_8_0": [
        "Exportación de transacciones por lotes en formatos CSV, PDF y Excel",
        "Velocidad de escaneo de códigos QR mejorada en un 40% con un nuevo motor de cámara",
        "Preferencias de notificación personalizables por tipo de transacción"
      ]
    }
