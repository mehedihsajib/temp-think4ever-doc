    "request": {
      "heading": "Solicitud de dinero",
      "intro_title": "Solicitudes de pago fáciles",
      "intro_body": "¿Necesita cobrar dinero a un amigo o dividir una cuenta? Envíe una solicitud de pago directamente desde la aplicación. El destinatario recibe una notificación y puede pagar con un solo toque.",
      "req_qr": {
        "title": "Solicitar dinero mediante QR",
        "steps": {
