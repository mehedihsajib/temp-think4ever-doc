    "common_issues": {
      "title": "Problemas Comunes",
      "desc": "A continuación se muestran los problemas encontrados con más frecuencia y sus soluciones paso a paso.",
      "issue1": {
        "title": "No se puede conectar al servidor",
        "summary": "La aplicación muestra \"Error de conexión\" o tarda demasiado en cargarse.",
        "causes": "Posibles Causas",
        "cause1": "Conexión a Internet inestable (Wi-Fi o datos móviles)",
        "cause2": "Los servidores de MPay Network pueden estar en mantenimiento",
        "cause3": "Interferencia de VPN o proxy",
        "cause4": "Versión de la aplicación desactualizada",
        "solution": "Solución",
        "step1": "Verifique su conexión a Internet abriendo una página web en su navegador.",
        "step2": "Active y desactive el modo avión, luego reintente.",
        "step3": "Desactive temporalmente cualquier servicio de VPN o proxy.",
        "step4": "Actualice la aplicación MPay Consumer Wallet desde su tienda de aplicaciones.",
        "step5": "Si el problema persiste, consulte la <a href=\"#\" style=\"color:#2563eb;\">Página de Estado de MPay</a> para incidentes en curso.",
        "callout": "El mantenimiento del servidor suele durar entre 15 y 30 minutos y se programa durante las horas de menor actividad (2:00 AM — 4:00 AM hora local)."
      },
      "issue2": {
        "title": "El código QR no se escanea",
        "summary": "La cámara no puede detectar o leer los códigos QR de los comerciantes.",
        "causes": "Posibles Causas",
        "cause1": "Permiso de cámara no concedido a la aplicación",
        "cause2": "Pobres condiciones de iluminación",
        "cause3": "Código QR dañado o borroso",
        "cause4": "La lente de la cámara está sucia u obstruida",
        "solution": "Solución",
        "step1": "Vaya a <strong>Ajustes → Permisos de la Aplicación</strong> y asegúrese de que el acceso a la cámara esté habilitado para MPay.",
        "step2": "Limpie la lente de su cámara con un paño suave.",
        "step3": "Asegure una iluminación adecuada; use el interruptor de linterna en la vista del escáner.",
        "step4": "Sujete su teléfono con firmeza, a unos 15-30 cm del código QR.",
        "step5": "Si el código QR está en una pantalla, reduzca el brillo de la pantalla ajustando el ángulo.",
        "callout": "Si el código QR parece dañado o corrupto, pida al comerciante que genere uno nuevo."
      },
      "issue3": {
        "title": "Fallo en el pago NFC",
        "summary": "No se detecta el toque para pagar o la transacción no se completa.",
        "causes": "Posibles Causas",
        "cause1": "NFC está desactivado en su dispositivo",
        "cause2": "La funda del teléfono está bloqueando la antena NFC",
        "cause3": "El dispositivo no está colocado correctamente en el terminal",
        "cause4": "Saldo insuficiente en la billetera",
        "solution": "Solución",
        "step1": "Habilite NFC en los Ajustes de su teléfono: <span class=\"ctr-code\">Ajustes → Dispositivos Conectados → NFC</span>",
        "step2": "Retire cualquier funda gruesa o accesorios metálicos que puedan bloquear el NFC.",
        "step3": "Sujete la parte posterior de su teléfono sobre el terminal durante 2-3 segundos.",
        "step4": "Asegúrese de que su billetera tenga saldo suficiente para la transacción.",
        "callout": "La ubicación de la antena NFC varía según el modelo de teléfono. La mayoría de los teléfonos Android la tienen en la zona media-superior trasera. Los iPhones usan el borde superior."
      },
      "issue4": {
        "title": "El inicio de sesión biométrico no funciona",
        "summary": "El reconocimiento de huella dactilar o facial no logra autenticarse.",
        "causes": "Posibles Causas",
        "cause1": "Los datos biométricos cambiaron en el dispositivo (se añadió una nueva huella)",
        "cause2": "Sensor de hardware biométrico sucio o dañado",
        "cause3": "Permiso biométrico revocado para la aplicación",
        "solution": "Solución",
        "step1": "Inicie sesión con su código PIN como alternativa.",
        "step2": "Vaya a <strong>Ajustes de MPay → Seguridad → Inicio de Sesión Biométrico</strong> y vuelva a habilitarlo.",
        "step3": "Si se le solicita, vuelva a registrar sus datos biométricos.",
        "step4": "Limpie el sensor de huellas dactilares o asegúrese de que el reconocimiento facial tenga una línea de visión clara."
      },
      "issue5": {
        "title": "Transferencia P2P atascada o pendiente",
        "summary": "Dinero enviado pero el destinatario no lo ha recibido.",
        "causes": "Posibles Causas",
        "cause1": "Congestión en la red causando retrasos",
        "cause2": "La cuenta del destinatario puede tener restricciones",
        "cause3": "El monto de la transacción supera los límites diarios",
        "cause4": "Revisión de cumplimiento para montos grandes",
        "solution": "Solución",
        "step1": "Verifique el estado de la transacción en <strong>Actividad → Historial de Transacciones</strong>.",
        "step2": "Si el estado es \"Procesando\", espere hasta 30 minutos para que se complete.",
        "step3": "Si el estado es \"Pendiente de Revisión\", su transacción está siendo revisada. Recibirá una notificación una vez resuelto.",
        "step4": "Si está atascada por más de 2 horas, contacte al soporte con el ID de Transacción.",
        "callout": "<strong>No</strong> envíe la misma transferencia de nuevo mientras la original aún se esté procesando. Esto podría resultar en un cargo doble."
      },
      "issue6": {
        "title": "Fallo en la recarga o retiro",
        "summary": "No se pueden añadir fondos o retirar de la billetera.",
        "causes": "Posibles Causas",
        "cause1": "Cuenta bancaria o tarjeta no verificada",
        "cause2": "Límites diarios o mensuales excedidos",
        "cause3": "El banco rechaza la transacción",
        "cause4": "Verificación de cuenta incompleta",
        "solution": "Solución",
        "step1": "Verifique su cuenta bancaria/tarjeta vinculada en <strong>Ajustes → Métodos de Pago</strong>.",
        "step2": "Verifique sus límites actuales en <strong>Ajustes → Límites</strong>.",
        "step3": "Complete la verificación KYC para desbloquear límites más altos.",
        "step4": "Contacte a su banco para asegurarse de que no haya retenciones o bloqueos en las transacciones en línea."
      }
