  "requirements": {
    "heading": "Requisitos del Sistema",
    "intro": "Antes de descargar, asegúrate de que tu dispositivo cumple los requisitos mínimos:",
    "ios": {
      "name": "iOS",
      "desc": "iOS 15.0 o posterior. Compatible con iPhone 8 y modelos más nuevos. Se requieren aproximadamente 85 MB de almacenamiento."
    },
    "android": {
      "name": "Android",
      "desc": "Android 10.0 (nivel de API 29) o posterior. Se requieren aproximadamente 60 MB de almacenamiento."
    },
    "nfc_callout_title": "Requisito NFC",
    "nfc_callout_body": "Para la funcionalidad de pago por contacto, tu dispositivo debe tener hardware NFC. La mayoría de los smartphones modernos (iPhone 7+ y Android con NFC) soportan esta función."
  },

  "download": {
    "heading": "Descargar e Instalar",
    "intro": "La Billetera de Consumidor mPay está disponible de forma gratuita en las dos tiendas de aplicaciones principales. Elige tu plataforma a continuación:",
    "ios_btn": "App Store",
    "ios_btn_pre": "Descargar en el",
    "android_btn": "Google Play",
    "android_btn_pre": "Disponible en",
    "install_steps_heading": "Pasos de Instalación",
    "steps": {
      "1": {
        "title": "Abre tu tienda de aplicaciones",
        "content": "Abre la <strong>App Store</strong> (iOS) o <strong>Google Play Store</strong> (Android) en tu dispositivo."
      },
      "2": {
        "title": "Busca mPay Wallet",
        "content": "Escribe <code>mPay Consumer Wallet</code> en la barra de búsqueda. Busca la aplicación oficial con el logo de mPay y \"mPay Network\" como desarrollador."
      },
      "3": {
        "title": "Descargar e instalar",
        "content": "Toca <strong>Obtener</strong> (iOS) o <strong>Instalar</strong> (Android). La aplicación se descargará e instalará automáticamente. Es posible que se te pida autenticarte con la contraseña de tu dispositivo, Face ID o huella dactilar."
      },
      "4": {
        "title": "Abre la aplicación",
        "content": "Una vez instalada, toca <strong>Abrir</strong> o busca el ícono de mPay en tu pantalla de inicio. La aplicación se iniciará con la pantalla de bienvenida."
      }
    },
    "verify_callout_title": "Verifica el Desarrollador",
    "verify_callout_body": "Siempre verifica que el desarrollador aparezca como \"mPay Network\" antes de descargar. No instales aplicaciones de fuentes no oficiales."
  },

  "signup": {
    "heading": "Registrarse",
    "intro": "Crear tu cuenta mPay es rápido y sencillo. Necesitarás un número de teléfono y una dirección de correo electrónico válidos.",
    "steps": {
      "1": {
        "title": "¿Eres cliente existente de mPay?",
        "content": "En la pantalla de bienvenida, se te pedirá seleccionar si <strong>\"¿Eres cliente existente?\"</strong>. Para nuevos clientes, toca el botón <strong>NO</strong>. Si ya tienes una cuenta, selecciona el botón <strong>SÍ</strong>."
      },
      "2": {
        "title": "Formulario de Inscripción de Nuevo Consumidor",
        "content": "El usuario es llevado al formulario de <strong>Inscripción de Nuevo Consumidor</strong>."
      },
      "3": {
        "title": "Información Requerida del Cliente",
        "content": "El <strong>ID de Usuario</strong>, <strong>Dirección de E-mail</strong> y <strong>Número de Móvil</strong> deben ser únicos para cada cliente.",
        "info_callout": "Durante el envío de la inscripción, el sistema verifica si el <strong>ID de Usuario</strong>, <strong>Dirección de E-mail</strong> y <strong>Número de Móvil</strong> ya están siendo utilizados por clientes existentes de mPay."
      },
      "4": {
        "title": "Completa todos los campos requeridos",
        "intro": "Ingresa tu información básica:",
        "field_name": "<strong>Nombre y Apellido</strong> — Tal como aparece en tu identificación",
        "field_email": "<strong>Correo Electrónico</strong> — Un email válido para notificaciones y recuperación",
        "field_mobile": "<strong>Número Móvil</strong> — Debe ser un número de móvil válido que recibirá SMS de verificación",
        "field_referral": "<strong>Código de Referido</strong> — Campo opcional para el código de referido del cliente mPay que te refirió."
      },
      "5": {
        "title": "Acepta los términos",
        "intro": "Hay dos casillas de verificación requeridas que debes aceptar antes de proceder con la inscripción:",
        "check_terms": "Acepta los <strong>Términos y Condiciones</strong>",
        "check_security": "Política de Seguridad que indica que solo un usuario está permitido por dispositivo: <em>\"Acepto que inscribir un nuevo cliente eliminará la cuenta existente vinculada a este dispositivo.\"</em>"
      },
      "6": {
        "title": "Opción para Usar Email y Móvil en la App Comerciante",
        "intro": "Elige si tu correo electrónico y número de móvil también pueden usarse para identificarte en la App Comerciante.",
        "check_terms": "Acepta los <strong>Términos y Condiciones</strong>",
        "check_security": "Política de Seguridad que indica que solo un usuario está permitido por dispositivo: <em>\"Acepto que inscribir un nuevo cliente eliminará la cuenta existente vinculada a este dispositivo.\"</em>"
      }
    },
    "success_callout_title": "¡Cuenta Creada!",
    "success_callout_body": "Una vez que veas la pantalla de confirmación, tu cuenta está lista. Ahora puedes proceder a configurar tu perfil y configurar tu billetera."
  },

  "first_login": {
    "heading": "Primer Inicio y Configuración",
    "intro": "Después de crear tu cuenta, serás guiado a través del asistente de configuración inicial. Esto es lo que puedes esperar:",
    "profile_heading": "Configuración de Perfil",
    "profile_steps": {
      "1": {
        "title": "Agrega tus datos personales",
        "content": "Ingresa tu nombre completo tal como aparece en tu identificación oficial. Opcionalmente, agrega una foto de perfil para identificación fácil durante transferencias P2P."
      },
      "2": {
        "title": "Configura la seguridad",
        "content": "Configura tu método de autenticación preferido:",
        "pin": "<strong>Código PIN</strong> — Establece un PIN de 6 dígitos para acceso rápido",
        "biometric": "<strong>Biométrico</strong> — Habilita Face ID o autenticación por huella dactilar",
        "recommend": "Recomendamos habilitar ambos para máxima seguridad"
      },
      "3": {
        "title": "Habilita las notificaciones",
        "content_pre": "Permite las notificaciones push para recibir confirmaciones de pago instantáneas, alertas de seguridad y ofertas promocionales. Puedes personalizar las preferencias de notificación más tarde en ",
        "settings_link": "Configuración",
        "content_post": "."
      }
    },
    "wallet_heading": "Configuración de Billetera",
    "wallet_steps": {
      "1": {
        "title": "Personaliza tu perfil",
        "content": "Establece una foto de perfil para tu cuenta de billetera."
      },
      "2": {
        "title": "Gestión de Preferencias de Notificación",
        "content": "Puedes activar/desactivar una opción de notificación, según tus propias preferencias."
      },
      "3": {
        "title": "Completa la configuración",
        "content": "Toca <strong>Finalizar Configuración</strong> para llegar a tu panel de billetera. ¡Estás listo para empezar a realizar pagos!"
      }
    },
    "tip_callout_title": "Consejo: Completa la Verificación Pronto",
    "tip_callout_body": "El proceso de verificación puede tomar entre 24 y 48 horas. Es aconsejable completar el perfil lo antes posible para obtener acceso completo a las funciones de mPay Wallet."
  },

