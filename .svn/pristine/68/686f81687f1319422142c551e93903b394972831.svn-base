      "faq": "FAQs"
    }
  },
  "wallet_management": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumidor",
      "current": "Gestión de billetera"
    },
    "title": "Gestión de billetera",
    "subtitle": "Aprenda a consultar su saldo, añadir fondos, retirar dinero y entender sus límites de transacción.",
    "overview": {
      "title": "Su billetera MPay",
      "body": "Su billetera mPay es una billetera digital segura que almacena sus fondos y le permite realizar pagos, transferir dinero y administrar sus finanzas, todo desde su teléfono inteligente."
    },
    "balance": {
      "heading": "Consultar su saldo",
      "intro": "El saldo de su billetera siempre es visible en la pantalla de inicio de la aplicación mPay. Aquí tiene todo lo que necesita saber sobre cómo ver y entender su saldo.",
      "demo": {
        "label": "Saldo disponible",
        "currency": "Florines antillanos (XCG)",
        "topup": "Recargar",
        "withdraw": "Retirar",
        "history": "Historial"
      },
      "how_to_title": "Cómo ver su saldo",
      "steps": {
        "1": {
          "title": "Abra la aplicación MPay",
          "desc": "Inicie la aplicación mPay Consumer en su dispositivo. Su saldo aparece de forma destacada en la pantalla de inicio."
        },
        "2": {
          "title": "Ver el saldo disponible",
          "desc": "Su saldo disponible se muestra en la parte superior de la pantalla. Esta es la cantidad que puede gastar o transferir inmediatamente."
        },
        "3": {
          "title": "Cambiar la visibilidad del saldo",
          "desc": "Toque el <strong>icono del ojo</strong> para ocultar o mostrar su saldo para mayor privacidad cuando esté en público."
        }
      },
      "callout": "Las <strong>transacciones pendientes</strong> pueden reducir temporalmente su saldo disponible. Los montos pendientes se muestran por separado debajo de su saldo principal."
    },
    "topup": {
      "heading": "Métodos de recarga",
      "intro": "Añada fondos a su billetera MPay utilizando cualquiera de los siguientes métodos. Cada método tiene diferentes tiempos de procesamiento y cargos.",
      "methods": {
        "bank": {
          "title": "Transferencia bancaria",
          "desc": "Transfiera fondos desde cualquier banco local a su cuenta de billetera mPay mediante procesamiento de pago instantáneo. Seguro y rápido.",
          "time": "Instantáneo"
        },
        "wallet": {
          "title": "De billetera a billetera",
          "desc": "Cargue instantáneamente su cuenta de billetera pidiendo a otro cliente de mPay que le envíe dinero y pagándole en efectivo.",
          "time": "Instantáneo"
        },
        "agent": {
          "title": "Agente de efectivo",
          "desc": "Visite un comercio autorizado de mPay cerca de usted para depositar efectivo en su billetera. Presente su código QR de mPay al comerciante.",
          "time": "Instantáneo"
        }
      }
    },
    "withdraw": {
      "heading": "Retiros",
      "intro": "Retire fondos de su billetera a su cuenta bancaria vinculada. MPay admite retiros instantáneos a los principales bancos locales.",
      "callout": "<strong>Importante:</strong> mPay cumple con las políticas del Banco Central de Curazao. Asegúrese de que los detalles de la cuenta bancaria sean precisos y correctos antes de la transacción para evitar cualquier retraso."
    },
    "limits": {
      "heading": "Límites de transacción",
      "intro1": "mPay impone límites de transacción para proteger su cuenta. Sus límites dependen de muchos factores, como el tipo de cliente (consumidor o comercio), y se calculan en base a una acumulación diaria, mensual y anual.",
      "intro2": "Aquí tiene una tabla de límites de ejemplo (estos son controlados por la Red mPay)",
      "table": {
        "type": "Tipo de transacción",
        "consumer": "Consumidor",
        "merchant": "Comercio",
        "cashier": "Cajero",
        "scan_pay": "Escanear para pagar",
        "pay_bills": "Pagar facturas",
        "pay_email": "Pagar por correo",
        "pay_mobile": "Pagar por móvil",
        "transfer_bank": "Transferir al banco",
        "managed_by": "Gestionado por<br>el propietario del comercio"
      },
      "how_to_increase": "Cómo aumentar sus límites",
      "callout_view": "<strong>Vea sus límites actuales:</strong> Vaya a <strong>Configuración del perfil → Límites de la billetera</strong> para ver su límite actual, uso y límites restantes para el día/mes.",
      "callout_increase": "<strong>¿Aumentar su límite?</strong> Póngase en contacto con el soporte de mPay para esta solicitud; está sujeta a revisión y aprobación."
    },
    "faq": {
      "heading": "Preguntas frecuentes",
      "q1": "¿Cuánto tiempo tarda en aparecer mi recarga?",
      "a1": "Las recargas con tarjeta aparecen instantáneamente. Las transferencias bancarias suelen tardar de 1 a 2 días hábiles, dependiendo de su banco. Las recargas por agente de efectivo también son instantáneas una vez confirmadas por el agente. Recibirá una notificación push tan pronto como se acrediten los fondos.",
      "q2": "¿Puedo retirar dinero a la cuenta bancaria de otra persona?",
      "a2": "No. Por razones de seguridad, los retiros solo pueden hacerse a cuentas bancarias registradas a nombre del mismo titular de la cuenta MPay. Este es un requisito regulatorio para prevenir el fraude y el lavado de dinero. Si necesita enviar dinero a otra persona, utilice la función de <strong>Transferencia P2P</strong> en su lugar.",
      "q3": "¿Qué sucede si excedo mi límite de transacción?",
      "a3": "La transacción será rechazada y verá un mensaje de error explicando que ha alcanzado su límite. Puede esperar a que el límite se reinicie (los límites diarios se reinician a la medianoche UTC, los mensuales el primero de cada mes) o mejorar su nivel de verificación para obtener límites más altos.",
      "q4": "¿Hay algún cargo por mantener un saldo en la billetera?",
      "a4": "No. No hay cargos mensuales, de mantenimiento ni por inactividad para su billetera MPay. Su saldo sigue siendo suyo. Los únicos cargos que pueden aplicarse son para ciertos métodos de recarga (recargas con tarjeta de crédito) y retiros exprés/instantáneos.",
      "q5": "¿Puedo configurar recargas periódicas/automáticas?",
      "a5": "¡Sí! Vaya a <strong>Configuración → Recarga automática</strong> para configurar la reposición automática del saldo. Puede establecer un umbral de saldo mínimo y un monto de recarga. Cuando su saldo caiga por debajo del umbral, MPay recargará automáticamente desde su fuente de financiación preferida.",
      "q6": "¿Qué pasa con mi saldo si pierdo mi teléfono?",
      "a6": "Su saldo está seguro; se almacena de forma segura en los servidores de MPay, no en su dispositivo. Si pierde su teléfono, comuníquese inmediatamente con el soporte de mPay para congelar su cuenta. Luego, cuando tenga un nuevo dispositivo, inicie sesión con sus credenciales y se restaurará todo su saldo. Active el borrado remoto en su teléfono como precaución adicional."
    },
    "pagination": {
      "prev": "Anterior",
      "prev_title": "Realización de pagos",
      "next": "Siguiente",
      "next_title": "Transferencias P2P"
    },
    "toc": {
      "title": "En esta página",
      "balance": "Consultar su saldo",
      "topup": "Métodos de recarga",
      "withdraw": "Retiros",
      "limits": "Límites de transacción",
      "faq": "Preguntas frecuentes"
    }
  },
