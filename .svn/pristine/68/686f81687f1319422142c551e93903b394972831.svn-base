  "settings": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consumidor",
      "settings_security": "Ajustes y Seguridad"
    },
    "title": "Ajustes y Seguridad",
    "subtitle": "Aprende cómo configurar los ajustes de tu Billetera de Consumidor MPay, gestionar preferencias de seguridad, habilitar la autenticación biométrica y proteger tu cuenta con funciones de seguridad avanzadas.",
    "visual": {
      "title": "Tu Seguridad es Importante",
      "body": "MPay utiliza cifrado de nivel bancario y múltiples capas de seguridad para mantener tu billetera y transacciones seguras. Configura estos ajustes para maximizar tu protección."
    },
    "pin": {
      "heading": "Gestión de PIN",
      "intro": "Tu PIN de transacción es un código de 6 dígitos utilizado para autorizar pagos y operaciones de cuenta sensibles. Es independiente del bloqueo de pantalla de tu dispositivo y proporciona una capa adicional de seguridad.",
      "setting_heading": "Configuración de tu PIN",
      "setting_intro": "Cuando configures tu billetera mPay por primera vez, se te pedirá que crees un PIN de transacción. Sigue estos pasos:",
      "steps": {
        "1": {
          "title": "Navegar a Ajustes de Seguridad",
          "desc": "Abre el menú de la aplicación y toca <strong>Ajustes de Perfil</strong> → <strong>Seguridad</strong> → <strong>Cambiar PIN</strong>."
        },
        "2": {
          "title": "Ingresar un PIN de 6 Dígitos",
          "desc": "Elige un PIN que puedas recordar pero que no sea fácil de adivinar. Evita números secuenciales como <code>123456</code> o dígitos repetidos como <code>111111</code>."
        },
        "3": {
          "title": "Confirmar tu PIN",
          "desc": "Vuelve a ingresar tu PIN para confirmar. El sistema verificará que ambas entradas coincidan antes de guardar."
        },
        "4": {
          "title": "PIN Guardado con Éxito",
          "desc": "Tu PIN ahora está activo. Lo usarás para aprobar transacciones, transferencias y cambios en la cuenta."
        }
      },
      "changing_heading": "Cambiar tu PIN",
      "changing_intro": "Para cambiar tu PIN existente, primero deberás verificar tu PIN actual:",
      "changing_steps": {
        "1": {
          "title": "Ir a Ajustes → Seguridad → Cambiar PIN",
          "desc": "Navega a la sección de gestión de PIN en tus ajustes de seguridad."
        },
        "2": {
          "title": "Ingresar PIN Actual",
          "desc": "Verifica tu identidad ingresando tu PIN actual de 6 dígitos."
        },
        "3": {
          "title": "Ingresar y Confirmar Nuevo PIN",
          "desc": "Escribe tu nuevo PIN y confírmalo. Tu nuevo PIN entra en vigor de inmediato."
        }
      },
      "tips_title": "Consejos de Seguridad para el PIN",
      "tips_body": "Nunca compartas tu PIN con nadie, incluido el personal de soporte de MPay. MPay nunca te pedirá tu PIN por teléfono, correo electrónico o SMS. Tras 5 intentos fallidos de PIN, tu cuenta se bloqueará temporalmente durante 30 minutos.",
      "forgot_title": "¿Olvidaste tu PIN?",
      "forgot_body": "Si olvidas tu PIN de transacción, toca <strong>\"Olvidé mi PIN\"</strong> en la pantalla de entrada de PIN. Deberás verificar tu identidad a través de tu correo electrónico o número de teléfono registrado para restablecerlo."
    },
    "biometric": {
      "heading": "Autenticación Biométrica",
      "intro": "Habilita la autenticación por huella dactilar o Face ID para un acceso rápido y seguro a tu billetera. El inicio de sesión biométrico añade comodidad manteniendo una seguridad sólida.",
      "methods": {
        "fingerprint": {
          "title": "Huella Dactilar",
          "desc": "Usa tu huella dactilar registrada para un acceso rápido a la billetera y la aprobación de transacciones.",
          "badge": "Más Común"
        },
        "faceid": {
          "title": "Face ID",
          "desc": "Auténticate con reconocimiento facial para una experiencia fluida sin manos.",
          "badge": "Recomendado"
        }
      },
      "enabling_heading": "Habilitar Inicio de Sesión Biométrico",
      "steps": {
        "1": {
          "title": "Abrir Ajustes de Seguridad",
          "desc": "Ve a <strong>Ajustes</strong> → <strong>Seguridad</strong> → <strong>Autenticación Biométrica</strong>."
        },
        "2": {
          "title": "Activar Inicio de Sesión Biométrico",
          "desc": "Activa el interruptor de autenticación biométrica. Tu dispositivo debe tener al menos una huella dactilar o Face ID registrado."
        },
        "3": {
          "title": "Verificar con PIN",
          "desc": "Ingresa tu PIN de transacción para confirmar el cambio. Esto garantiza que solo tú puedas habilitar la biometría."
        },
        "4": {
          "title": "Probar tu Biometría",
          "desc": "Se te pedirá que escanees tu huella dactilar o cara para verificar que funciona correctamente."
        }
      },
      "toggles": {
        "access": "Inicio de Sesión Biométrico para Acceso a la Billetera",
        "transactions": "Aprobación Biométrica para Transacciones"
      },
      "requirements_title": "Requisitos del Dispositivo",
      "requirements_body": "La autenticación biométrica requiere un dispositivo compatible con biometría registrada. Si tu dispositivo no admite biometría, esta opción no estará disponible. Siempre puedes recurrir a la autenticación por PIN."
    },
    "notifications": {
      "heading": "Ajustes de Notificaciones",
      "intro": "Configura cómo y cuándo MPay te envía alertas sobre transacciones, eventos de seguridad y actividad de la cuenta. Mantener las notificaciones habilitadas te ayuda a supervisar tu cuenta en tiempo real.",
      "channels_heading": "Canales de Notificación Disponibles",
      "channels": {
        "push": {
          "title": "Notificaciones Push",
          "desc": "Alertas en tiempo real entregadas directamente a tu dispositivo. Recomendado para alertas de transacciones y notificaciones de seguridad."
        },
        "email": {
          "title": "Notificaciones por Correo Electrónico",
          "desc": "Notificaciones detalladas enviadas a tu dirección de correo electrónico registrada. Incluye recibos de transacciones y resúmenes mensuales."
        },
        "sms": {
          "title": "Alertas por SMS",
          "desc": "Alertas críticas por mensaje de texto. Se utilizan para transacciones de alto valor y eventos de seguridad cuando el push no está disponible."
        }
      },
      "types_heading": "Tipos de Alerta Configurables",
      "types": {
        "transaction": "<strong>Alertas de Transacción</strong> — Cada pago enviado o recibido",
        "promotional": "<strong>Promocional</strong> — Noticias, ofertas y anuncios de funciones",
        "summary": "<strong>Resumen Semanal</strong> — Resumen semanal de gastos y actividad"
      },
      "pro_tip_title": "Consejo Profesional",
      "pro_tip_body": "Recomendamos mantener habilitadas en todo momento las <strong>Alertas de Transacción</strong> y las <strong>Alertas de Seguridad</strong>. Estas te ayudan a detectar rápidamente actividad no autorizada en tu cuenta.",
      "managing_heading": "Gestionar Notificaciones",
      "managing_body": "Para ajustar tus preferencias de notificación, navega a <strong>Ajustes</strong> → <strong>Notificaciones</strong>. Usa los interruptores para habilitar o deshabilitar cada tipo de notificación por canal. Los cambios surten efecto de inmediato.",
      "toggles": {
        "transaction": "Alertas de Transacción (Push)",
        "security": "Alertas de Seguridad (Push + Correo Electrónico)",
        "promotional": "Notificaciones Promocionales"
      }
    },
    "privacy": {
      "heading": "Ajustes de Privacidad",
      "intro": "MPay te da el control total sobre tus datos personales y preferencias de privacidad. Gestiona cómo se utiliza, comparte y almacena tu información.",
      "controls_heading": "Controles de Privacidad",
      "controls": {
        "visibility": {
          "title": "Visibilidad del Perfil",
          "desc": "Controla quién puede ver tu nombre mostrado y foto de perfil al enviar o recibir pagos."
        },
        "analytics": {
          "title": "Analítica y Datos de Uso",
          "desc": "Elige si deseas compartir datos de uso anonimizados para ayudar a mejorar la experiencia MPay."
        },
        "location": {
          "title": "Datos de Ubicación",
          "desc": "Gestiona el acceso a la ubicación. Se utiliza para la detección de fraudes y funciones de comercios cercanos."
        },
        "contacts": {
          "title": "Acceso a Contactos",
          "desc": "Permite que MPay acceda a tus contactos para facilitar las transferencias P2P. Totalmente opcional."
        }
      },
      "data_heading": "Gestión de Datos",
      "data_intro": "Tienes derecho a acceder, exportar y eliminar tus datos personales en cualquier momento:",
      "data_options": {
        "export": {
          "title": "Exportar Datos",
          "desc": "Descarga una copia de todos tus datos personales e historial de transacciones"
        },
        "activity": {
          "title": "Registro de Actividad",
          "desc": "Revisa un registro completo de la actividad de la cuenta y eventos de acceso"
        },
        "delete": {
          "title": "Eliminar Cuenta",
          "desc": "Elimina permanentemente tu cuenta y todos los datos asociados"
        }
      },
      "deletion_title": "Eliminación de Cuenta",
      "deletion_body": "La eliminación de la cuenta es permanente y no se puede deshacer. Antes de eliminarla, asegúrate de que el saldo de tu billetera sea cero y que todas las transacciones pendientes se hayan completado. Los requisitos regulatorios pueden exigirnos conservar ciertos registros de transacciones hasta por 7 años.",
      "policy_heading": "Política de Privacidad",
      "policy_body": "Para obtener detalles completos sobre cómo MPay recopila, utiliza y protege tus datos, consulta nuestra <a onclick=\"load_page('privacy_policy')\" tabindex=\"0\" style=\"color: var(--color-primary, #2563eb); cursor: pointer; text-decoration: underline;\">Política de Privacidad</a>."
    },
    "faq": {
      "heading": "Preguntas frecuentes",
      "questions": {
        "1": {
          "q": "¿Qué pasa si olvido mi PIN de transacción?",
          "a": "Toca \"Olvidé mi PIN\" en la pantalla de entrada de PIN. Deberás verificar tu identidad a través de su correo electrónico o número de teléfono registrado. Se te enviará un enlace de restablecimiento de PIN. Tras la verificación, puedes establecer un nuevo PIN de 6 dígitos. Tu cuenta puede estar restringida temporalmente durante el proceso de restablecimiento por seguridad."
        },
        "2": {
          "q": "¿Puedo usar tanto la huella dactilar como Face ID?",
          "a": "Solo puedes usar el método biométrico admitido por tu dispositivo. La mayoría de los dispositivos admiten o bien la huella dactilar o bien Face ID, no ambos simultáneamente. Si tu dispositivo admite ambos, puedes elegir cuál usar como método biométrico principal en los ajustes de seguridad."
        },
        "3": {
          "q": "¿Cómo recupero mi cuenta si pierdo mi dispositivo 2FA?",
          "a": "Usa uno de tus códigos de respaldo para iniciar sesión y desactivar el 2FA. Si no tienes códigos de respaldo, contacta con el soporte de MPay con tu correo electrónico registrado y una identificación emitida por el gobierno para verificar tu identidad. El proceso de recuperación suele tardar entre 24 y 48 horas por razones de seguridad."
        },
        "4": {
          "q": "¿Por qué no recibo notificaciones push?",
          "a": "Primero, verifica que las notificaciones estén habilitadas tanto en los ajustes de la aplicación MPay como en los ajustes del sistema de tu dispositivo. En Android, asegúrate de que la aplicación no esté restringida por la optimización de la batería. En iOS, verifica los ajustes del Centro de notificaciones. Si las notificaciones siguen sin funcionar, intenta cerrar la sesión y volver a entrar, o reinstalar la aplicación."
        },
        "5": {
          "q": "¿Puedo descargar mi historial de transacciones?",
          "a": "¡Sí! Ve a <strong>Ajustes → Privacidad → Exportar Datos</strong> para descargar una copia completa de tu historial de transacciones. Puedes exportar en formato CSV o PDF. La exportación se enviará a tu dirección de correo electrónico registrada y suele llegar en pocos minutos."
        },
        "6": {
          "q": "¿Está mi PIN almacenado en los servidores de MPay?",
          "a": "No. Tu PIN nunca se almacena en texto plano. MPay utiliza un hash unidireccional fuerte (bcrypt) para almacenar una versión hasheada de tu PIN. Esto significa que incluso los empleados de MPay no pueden ver tu PIN real. Toda la verificación del PIN ocurre de forma segura en el servidor comparando los hashes."
        }
      }
    },
