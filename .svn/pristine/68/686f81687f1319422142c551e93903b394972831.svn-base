      "intro_body": "Envíe dinero a cualquier persona en la <b>Red mPay</b> en segundos. Puede enviar por nombre de usuario, número de teléfono o código QR; lo que le resulte más cómodo."
    },
    "send_email_mobile": {
      "title": "Enviar por correo electrónico o número móvil",
      "intro": "La forma más nueva de enviar dinero es buscando al destinatario por su <b>correo electrónico</b> o <b>número móvil</b> de mPay.",
      "steps": {
        "1": {
          "title": "Inicie \"Pagar por correo o Pagar por móvil\"",
