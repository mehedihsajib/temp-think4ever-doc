    "common_issues": {
      "title": "Veelvoorkomende Problemen",
      "desc": "Hieronder vindt u de meest voorkomende problemen en hun stapsgewijze oplossingen.",
      "issue1": {
        "title": "Kan geen Verbinding maken met Server",
        "summary": "App toont \"Verbindingsfout\" of het laden duurt te lang.",
        "causes": "Mogelijke Oorzaken",
        "cause1": "Onstabiele internetverbinding (Wi-Fi of mobiele data)",
        "cause2": "mPay Netwerkservers kunnen in onderhoud zijn",
        "cause3": "VPN- of proxy-interferentie",
        "cause4": "Verouderde app-versie",
        "solution": "Oplossing",
        "step1": "Controleer uw internetverbinding door een webpagina in uw browser te openen.",
        "step2": "Schakel de vliegtuigmodus in en uit en probeer het opnieuw.",
        "step3": "Schakel eventuele VPN- of proxydiensten tijdelijk uit.",
        "step4": "Update de mPay Consumenten Portefeuille app vanuit uw app store.",
        "step5": "Als het probleem aanhoudt, controleer dan de <a href=\"#\" style=\"color:#2563eb;\">mPay Statuspagina</a> voor lopende incidenten.",
        "callout": "Serveronderhoud duurt doorgaans 15-30 minuten en wordt gepland tijdens daluren (02:00 — 04:00 lokale tijd)."
      },
      "issue2": {
        "title": "QR-code Scant Niet",
        "summary": "Camera kan QR-codes van handelaren niet detecteren of lezen.",
        "causes": "Mogelijke Oorzaken",
        "cause1": "Cameratoestemming niet verleend aan de app",
        "cause2": "Slechte lichtomstandigheden",
        "cause3": "Beschadigde of wazige QR-code",
        "cause4": "Cameralens is vuil of geblokkeerd",
        "solution": "Oplossing",
        "step1": "Ga naar <strong>Instellingen → App-machtigingen</strong> en zorg ervoor dat cameratoegang is ingeschakeld voor mPay.",
        "step2": "Reinig uw cameralens met een zachte doek.",
        "step3": "Zorg voor voldoende verlichting — gebruik de zaklantaarnschakelaar in de scannerweergave.",
        "step4": "Houd uw telefoon stil, ongeveer 15-30 cm van de QR-code.",
        "step5": "Als de QR-code op een scherm staat, verminder dan de schittering door de hoek aan te passen.",
        "callout": "Als de QR-code beschadigd of corrupt lijkt, vraag de handelaar dan om een nieuwe te genereren."
      },
      "issue3": {
        "title": "NFC-betaling Mislukt",
        "summary": "Tikken-om-te-betalen niet gedetecteerd of transactie wordt niet voltooid.",
        "causes": "Mogelijke Oorzaken",
        "cause1": "NFC is uitgeschakeld op uw apparaat",
        "cause2": "Telefoonhoesje blokkeert de NFC-antenne",
        "cause3": "Apparaat niet correct op de terminal geplaatst",
        "cause4": "Onvoldoende portefeuillesaldo",
        "solution": "Oplossing",
        "step1": "Schakel NFC in bij de instellingen van uw telefoon: <span class=\"ctr-code\">Instellingen → Verbonden apparaten → NFC</span>",
        "step2": "Verwijder dikke telefoonhoesjes of metalen accessoires die NFC kunnen blokkeren.",
        "step3": "Houd de achterkant van uw telefoon 2-3 seconden plat tegen de terminal.",
        "step4": "Zorg ervoor dat uw portefeuille voldoende saldo heeft voor de transactie.",
        "callout": "De locatie van de NFC-antenne varieert per telefoonmodel. De meeste Android-telefoons hebben deze in het middenboven-gedeelte van de achterkant. iPhones gebruiken de bovenrand."
      },
      "issue4": {
        "title": "Biometrisch Inloggen Werkt Niet",
        "summary": "Vingerafdruk- of gezichtsherkenning slaagt er niet in te authenticeren.",
        "causes": "Mogelijke Oorzaken",
        "cause1": "Biometrische gegevens gewijzigd op het apparaat (nieuwe vingerafdruk toegevoegd)",
        "cause2": "Biometrische hardwaresensor vuil of beschadigd",
        "cause3": "Biometrische toestemming ingetrokken voor de app",
        "solution": "Oplossing",
        "step1": "Log in met uw PIN-code als back-up.",
        "step2": "Ga naar <strong>mPay Instellingen → Beveiliging → Biometrisch Inloggen</strong> en schakel het opnieuw in.",
        "step3": "Indien gevraagd, registreer uw biometrische gegevens opnieuw.",
        "step4": "Reinig de vingerafdruksensor of zorg ervoor dat gezichtsherkenning een duidelijke zichtlijn heeft."
      },
      "issue5": {
