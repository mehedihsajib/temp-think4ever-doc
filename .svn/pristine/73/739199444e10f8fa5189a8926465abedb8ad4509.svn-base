    "title": "Instellingen & Beveiliging",
    "subtitle": "Leer hoe u de instellingen van uw mPay Consumenten Portefeuille configureert, beveiligingsvoorkeuren beheert, biometrische authenticatie inschakelt en uw account beschermt met geavanceerde beveiligingsfuncties.",
    "visual": {
      "title": "Uw Beveiliging is Belangrijk",
      "body": "mPay gebruikt encryptie van bankniveau en meerdere beveiligingslagen om uw portefeuille en transacties veilig te houden. Configureer deze instellingen voor maximale bescherming."
    },
    "pin": {
      "heading": "PIN-beheer",
      "intro": "Uw transactie-PIN is een 6-cijferige code die wordt gebruikt om betalingen en gevoelige accountbewerkingen te autoriseren. Deze staat los van de vergrendeling van uw apparaat en biedt een extra beveiligingslaag.",
      "setting_heading": "Uw PIN Instellen",
      "setting_intro": "Wanneer u uw mPay-portefeuille voor het eerst configureert, wordt u gevraagd een transactie-PIN aan te maken. Volg deze stappen:",
      "steps": {
        "1": {
          "title": "Navigeer naar Beveiligingsinstellingen",
          "desc": "Open het app-menu en tik op <strong>Profielinstellingen</strong> → <strong>Beveiliging</strong> → <strong>PIN Wijzigen</strong>."
        },
        "2": {
          "title": "Voer een 6-cijferige PIN in",
          "desc": "Kies een PIN die u kunt onthouden, maar die niet gemakkelijk te raden is. Vermijd opeenvolgende getallen zoals <code>123456</code> of herhalende cijfers zoals <code>111111</code>."
        },
        "3": {
          "title": "Bevestig uw PIN",
          "desc": "Voer uw PIN opnieuw in om te bevestigen. Het systeem zal controleren of beide invoerpogingen overeenkomen voordat deze worden opgeslagen."
        },
        "4": {
          "title": "PIN Succesvol Opgeslagen",
          "desc": "Uw PIN is nu actief. U gebruikt deze om transacties, overboekingen en accountwijzigingen goed te keuren."
        }
      },
      "changing_heading": "Uw PIN Wijzigen",
      "changing_intro": "Om uw bestaande PIN te wijzigen, moet u eerst uw huidige PIN verifiëren:",
      "changing_steps": {
        "1": {
          "title": "Ga naar Instellingen → Beveiliging → PIN Wijzigen",
          "desc": "Navigeer naar de sectie PIN-beheer in uw beveiligingsinstellingen."
        },
        "2": {
          "title": "Voer Huidige PIN in",
          "desc": "Verifieer uw identiteit door uw huidige 6-cijferige PIN in te voeren."
        },
        "3": {
          "title": "Nieuwe PIN Invoeren & Bevestigen",
          "desc": "Typ uw nieuwe PIN en bevestig deze. Uw nieuwe PIN wordt onmiddellijk van kracht."
        }
      },
      "tips_title": "Veiligheidstips voor PIN",
      "tips_body": "Deel uw PIN nooit met iemand, ook niet met de medewerkers van mPay-ondersteuning. mPay zal u nooit naar uw PIN vragen via telefoon, e-mail of SMS. Na 5 mislukte PIN-pogingen wordt uw account tijdelijk geblokkeerd voor 30 minuten.",
      "forgot_title": "Uw PIN Vergeten?",
      "forgot_body": "Als u uw transactie-PIN bent vergeten, tikt u op <strong>\"PIN vergeten\"</strong> op het PIN-invoerscherm. U moet uw identiteit verifiëren via uw geregistreerde e-mailadres of telefoonnummer om deze te resetten."
    },
    "biometric": {
      "heading": "Biometrische Authenticatie",
      "intro": "Schakel vingerafdruk- of Face ID-authenticatie in voor snelle en veilige toegang tot uw portefeuille. Biometrisch inloggen voegt gemak toe met behoud van sterke beveiliging.",
      "methods": {
        "fingerprint": {
          "title": "Vingerafdruk",
          "desc": "Gebruik uw geregistreerde vingerafdruk voor snelle toegang tot de portefeuille en goedkeuring van transacties.",
          "badge": "Meest voorkomend"
        },
        "faceid": {
          "title": "Face ID",
          "desc": "Authentiseren met gezichtsherkenning voor een naadloze handsfree ervaring.",
          "badge": "Aanbevolen"
        }
      },
      "enabling_heading": "Biometrisch Inloggen Inschakelen",
      "steps": {
        "1": {
          "title": "Beveiligingsinstellingen Openen",
          "desc": "Ga naar <strong>Instellingen</strong> → <strong>Beveiliging</strong> → <strong>Biometrische Authenticatie</strong>."
        },
        "2": {
          "title": "Biometrisch Inloggen Omschakelen",
          "desc": "Zet de schakelaar voor biometrische authenticatie aan. Uw apparaat moet ten minste één geregistreerde vingerafdruk of Face ID hebben."
        },
        "3": {
          "title": "Verifiëren met PIN",
          "desc": "Voer uw transactie-PIN in om de wijziging te bevestigen. Dit zorgt ervoor dat alleen u biometrie kunt inschakelen."
        },
        "4": {
          "title": "Uw Biometrie Testen",
          "desc": "U wordt gevraagd uw vingerafdruk of gezicht te scannen om te controleren of het correct werkt."
        }
      },
      "toggles": {
        "access": "Biometrisch inloggen voor toegang tot portefeuille",
        "transactions": "Biometrische goedkeuring voor transacties"
      },
      "requirements_title": "Apparaatvereisten",
      "requirements_body": "Biometrische authenticatie vereist een compatibel apparaat met geregistreerde biometrie. Als uw apparaat geen biometrie ondersteunt, is deze optie niet beschikbaar. U kunt altijd terugvallen op PIN-authenticatie."
    },
    "notifications": {
      "heading": "Meldingsinstellingen",
      "intro": "Configureer hoe en wanneer mPay u waarschuwingen stuurt over transacties, beveiligingsgebeurtenissen en accountactiviteit. Door meldingen ingeschakeld te houden, kunt u uw account in real-time controleren.",
      "channels_heading": "Beschikbare Meldingskanalen",
      "channels": {
        "push": {
          "title": "Pushmeldingen",
          "desc": "Real-time waarschuwingen die direct op uw apparaat worden afgeleverd. Aanbevolen voor transactie-alerts en beveiligingsmeldingen."
        },
        "email": {
          "title": "E-mailmeldingen",
          "desc": "Gedetailleerde meldingen verzonden naar uw geregistreerde e-mailadres. Inclusief transactiebewijzen en maandelijkse overzichten."
        },
        "sms": {
          "title": "SMS-alerts",
          "desc": "Kritieke waarschuwingen via tekstbericht. Gebruikt voor transacties met hoge waarde en beveiligingsgebeurtenissen wanneer push niet beschikbaar is."
        }
      },
      "types_heading": "Configureerbare Beltoontypen",
      "types": {
        "transaction": "<strong>Transactie-alerts</strong> — Elke verzonden of ontvangen betaling",
        "promotional": "<strong>Promotioneel</strong> — Nieuws, aanbiedingen en aankondigingen van functies",
        "summary": "<strong>Wekelijks overzicht</strong> — Wekelijks overzicht van bestedingen en activiteit"
      },
      "pro_tip_title": "Pro-tip",
      "pro_tip_body": "We raden aan om <strong>Transactie-alerts</strong> en <strong>Beveiligingsalerts</strong> te allen tijde ingeschakeld te houden. Hiermee kunt u ongeoorloofde activiteiten op uw account snel detecteren.",
      "managing_heading": "Meldingen Beheren",
      "managing_body": "Om uw meldingsvoorkeuren aan te passen, gaat u naar <strong>Instellingen</strong> → <strong>Meldingen</strong>. Gebruik de schakelaars om elk meldingstype per kanaal in of uit te schakelen. Wijzigingen worden onmiddellijk van kracht.",
      "toggles": {
        "transaction": "Transactie-alerts (Push)",
        "security": "Beveiligingsalerts (Push + E-mail)",
        "promotional": "Promotionele meldingen"
      }
    },
    "privacy": {
      "heading": "Privacyinstellingen",
      "intro": "mPay geeft u volledige controle over uw persoonlijke gegevens en privacyvoorkeuren. Beheer hoe uw informatie wordt gebruikt, gedeeld en opgeslagen.",
      "controls_heading": "Privacyregelaars",
      "controls": {
        "visibility": {
          "title": "Profielzichtbaarheid",
          "desc": "Bepaal wie uw weergavenaam en profielfoto kan zien bij het verzenden of ontvangen van betalingen."
        },
        "analytics": {
          "title": "Analyse- & Gebruiksgegevens",
          "desc": "Kies of u geanonimiseerde gebruiksgegevens wilt delen om de mPay-ervaring te helpen verbeteren."
        },
        "location": {
          "title": "Locatiegegevens",
          "desc": "Beheer toegang tot locatiegegevens. Wordt gebruikt voor fraudedetectie en functies voor handelaren in de buurt."
        },
        "contacts": {
          "title": "Toegang tot Contacten",
          "desc": "Sta mPay toe om toegang te krijgen tot uw contacten voor eenvoudige P2P-overboekingen. Volledig optioneel."
        }
      },
      "data_heading": "Gegevensbeheer",
      "data_intro": "U heeft het recht om op elk moment toegang te krijgen tot uw persoonlijke gegevens, deze te exporteren en te verwijderen:",
      "data_options": {
        "export": {
          "title": "Gegevens Exporteren",
          "desc": "Download een kopie van al uw persoonlijke gegevens en transactiegeschiedenis"
        },
        "activity": {
          "title": "Activiteitenlogboek",
          "desc": "Bekijk een volledig logboek van accountactiviteiten en toegangsgebeurtenissen"
        },
        "delete": {
          "title": "Account Verwijderen",
          "desc": "Verwijder permanent uw account en alle bijbehorende gegevens"
        }
      },
      "deletion_title": "Account Verwijderen",
      "deletion_body": "Het verwijderen van een account is permanent en kan niet ongedaan worden gemaakt. Zorg er voor het verwijderen voor dat uw portefeuillesaldo nul is en alle openstaande transacties zijn voltooid. Wettelijke vereisten kunnen ons verplichten om bepaalde transactiegegevens tot 7 jaar te bewaren.",
      "policy_heading": "Privacybeleid",
      "policy_body": "Voor volledige details over hoe mPay uw gegevens verzamelt, gebruikt en beschermt, raadpleegt u ons <a onclick=\"load_page('privacy_policy')\" tabindex=\"0\" style=\"color: var(--color-primary, #2563eb); cursor: pointer; text-decoration: underline;\">Privacybeleid</a>."
    },
    "faq": {
      "heading": "Veelgestelde Vragen",
      "questions": {
        "1": {
          "q": "Wat gebeurt er als ik mijn transactie-PIN ben vergeten?",
          "a": "Tik op \"PIN vergeten\" op het PIN-invoerscherm. U moet uw identiteit verifiëren via uw geregistreerde e-mailadres of telefoonnummer. Er wordt een link voor het resetten van de PIN naar u verzonden. Na verificatie kunt u een nieuwe 6-cijferige PIN instellen. Uw account kan tijdens het resetproces tijdelijk worden beperkt uit veiligheidsoverwegingen."
        },
        "2": {
          "q": "Kan ik zowel vingerafdruk als Face ID gebruiken?",
          "a": "U kunt alleen de biometrische methode gebruiken die door uw apparaat wordt ondersteund. De meeste apparaten ondersteunen ofwel vingerafdruk of Face ID, niet beide tegelijkertijd. Als uw apparaat beide ondersteunt, kunt u in de beveiligingsinstellingen kiezen welke u als primaire biometrische methode wilt gebruiken."
        },
        "3": {
          "q": "Hoe kan ik mijn account herstellen als ik mijn 2FA-apparaat verlies?",
          "a": "Gebruik een van uw back-upcodes om in te loggen en 2FA uit te schakelen. Als u geen back-upcodes heeft, neem dan contact op met de mPay-ondersteuning met uw geregistreerde e-mailadres en een door de overheid uitgegeven identiteitsbewijs voor identiteitsverificatie. Het herstelproces duurt om veiligheidsredenen doorgaans 24-48 uur."
        },
        "4": {
          "q": "Waarom ontvang ik geen pushmeldingen?",
          "a": "Controleer eerst of meldingen zijn ingeschakeld in zowel de mPay-app-instellingen als de systeeminstellingen van uw apparaat. Zorg er op Android voor dat de app niet wordt beperkt door batterijoptimalisatie. Controleer op iOS de instellingen van het Berichtencentrum. Als meldingen nog steeds niet werken, probeer dan uit en weer in te loggen, of de app opnieuw te installeren."
        },
        "5": {
          "q": "Kan ik mijn transactiegeschiedenis downloaden?",
          "a": "Ja! Ga naar <strong>Instellingen → Privacy → Gegevens Exporteren</strong> om een volledige kopie van uw transactiegeschiedenis te downloaden. U kunt exporteren in CSV- of PDF-formaat. De export wordt verzonden naar uw geregistreerde e-mailadres en komt meestal binnen enkele minuten aan."
        },
        "6": {
          "q": "Wordt mijn PIN opgeslagen op mPay-servers?",
          "a": "Nee. Uw PIN wordt nooit in duidelijke tekst opgeslagen. mPay gebruikt sterke eenrichtings-hashing (bcrypt) om een gehashte versie van uw PIN op te slaan. Dit betekent dat zelfs medewerkers van mPay uw werkelijke PIN niet kunnen zien. Alle PIN-verificatie gebeurt veilig aan de serverzijde door hashes te vergelijken."
        }
      }
    },
