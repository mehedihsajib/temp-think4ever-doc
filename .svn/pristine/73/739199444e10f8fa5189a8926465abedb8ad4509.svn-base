  "wallet_management": {
    "breadcrumb": {
      "docs": "Docs",
      "consumer": "Consument",
      "current": "Portefeuille Beheer"
    },
    "title": "Portefeuille Beheer",
    "subtitle": "Leer hoe u uw saldo controleert, geld toevoegt, geld opneemt en uw transactielimieten begrijpt.",
    "overview": {
      "title": "Uw mPay Portefeuille",
      "body": "Uw mPay-portefeuille is een beveiligde digitale portefeuille die uw geld bewaart en u in staat stelt betalingen te doen, geld over te maken en uw financiën te beheren — allemaal vanaf uw smartphone."
    },
    "balance": {
      "heading": "Uw Saldo Controleren",
      "intro": "Uw portefeuillesaldo is altijd zichtbaar op het startscherm van de mPay-app. Hier is alles wat u moet weten over het bekijken en begrijpen van uw saldo.",
      "demo": {
        "label": "Beschikbaar Saldo",
        "currency": "Antilliaanse Guldens (XCG)",
        "topup": "Opwaarderen",
        "withdraw": "Opnemen",
        "history": "Geschiedenis"
      },
      "how_to_title": "Hoe u uw Saldo Bekijkt",
      "steps": {
        "1": {
          "title": "Open de mPay-app",
          "desc": "Start de mPay Consumenten-app op uw apparaat. Uw saldo verschijnt prominent op het startscherm."
        },
        "2": {
          "title": "Bekijk Beschikbaar Saldo",
          "desc": "Uw beschikbare saldo wordt bovenaan het scherm weergegeven. Dit is het bedrag dat u direct kunt uitgeven of overmaken."
        },
        "3": {
          "title": "Zichtbaarheid van Saldo Omschakelen",
          "desc": "Tik op het <strong>oog-icoon</strong> om uw saldo te verbergen of te tonen voor privacy wanneer u in het openbaar bent."
        }
      },
      "callout": "<strong>In behandeling zijnde transacties</strong> kunnen uw beschikbare saldo tijdelijk verlagen. Bedragen in behandeling worden apart weergegeven onder uw hoofdsaldo."
    },
    "topup": {
      "heading": "Opwaardeermethoden",
      "intro": "Voeg geld toe aan uw mPay-portefeuille met een van de volgende methoden. Elke methode heeft verschillende verwerkingstijden en kosten.",
      "methods": {
        "bank": {
          "title": "Bankoverschrijving",
          "desc": "Maak geld over van lokale banken naar uw mPay-portefeuille via Instant Payment verwerking. Veilig en snel.",
          "time": "Direct"
        },
        "wallet": {
          "title": "Portefeuille naar Portefeuille",
          "desc": "Laad direct uw portefeuille op door een andere mPay-klant te vragen u geld te sturen en hen contant te betalen.",
          "time": "Direct"
        },
        "agent": {
          "title": "Contant Agent",
          "desc": "Bezoek een erkende mPay-handelaar bij u in de buurt om contant geld in uw portefeuille te storten. Toon uw mPay QR-code aan de handelaar.",
          "time": "Direct"
        }
      }
    },
    "withdraw": {
      "heading": "Opnames",
      "intro": "Neem geld op uit uw portefeuille naar uw gekoppelde bankrekening. mPay ondersteunt directe opnames naar grote lokale banken.",
      "callout": "<strong>Belangrijk:</strong> mPay houdt zich aan het beleid van de Centrale Bank van Curaçao. Zorg ervoor dat de bankrekeninggegevens nauwkeurig en correct zijn vóór de transactie om vertragingen te voorkomen."
    },
    "limits": {
      "heading": "Transactielimieten",
      "intro1": "mPay handhaaft transactielimieten om uw account te beschermen. Uw limieten hangen af van vele factoren, zoals het type klant (Consument of Handelaar), en worden berekend op basis van dagelijkse, maandelijkse en jaarlijkse accumulatie.",
      "intro2": "Hier is een voorbeeldtabel met limieten (deze worden beheerd door het mPay-netwerk)",
      "table": {
        "type": "Transactietype",
        "consumer": "Consument",
        "merchant": "Handelaar",
        "cashier": "Kassier",
        "scan_pay": "Scannen om te Betalen",
        "pay_bills": "Facturen Betalen",
        "pay_email": "Betalen via E-mail",
        "pay_mobile": "Betalen via Mobiel",
        "transfer_bank": "Overboeken naar Bank",
        "managed_by": "Beheerd door<br>Handelaarseigenaar"
      },
      "how_to_increase": "Hoe u uw Limieten Kunt Verhogen",
      "callout_view": "<strong>Bekijk uw huidige limieten:</strong> Ga naar <strong>Profielinstellingen → Portefeuillelimieten</strong> om uw huidige limiet, gebruik en resterende limieten voor de dag/maand te zien.",
      "callout_increase": "<strong>Uw limiet verhogen?</strong> Neem contact op met mPay Support voor dit verzoek; dit is onderworpen aan beoordeling en goedkeuring."
    },
    "faq": {
      "heading": "Veelgestelde Vragen",
      "q1": "Hoe lang duurt het voordat mijn opwaardering verschijnt?",
      "a1": "Kaartopwaarderingen verschijnen direct. Bankoverschrijvingen duren doorgaans 1-2 werkdagen, afhankelijk van uw bank. Opwaarderingen via contant-agenten zijn ook direct zodra ze door de agent zijn bevestigd. U ontvangt een pushmelding zodra het geld is bijgeschreven.",
      "q2": "Kan ik geld opnemen naar de bankrekening van iemand anders?",
      "a2": "Nee. Om beveiligingsredenen kunnen opnames alleen worden gedaan naar bankrekeningen die op dezelfde naam staan geregistreerd als uw mPay-account. Dit is een wettelijke vereiste om fraude en witwassen te voorkomen. Als u geld naar iemand anders moet sturen, gebruik dan de functie <strong>P2P Overboeking</strong>.",
      "q3": "Wat gebeurt er als ik mijn transactielimiet overschrijd?",
      "a3": "De transactie wordt geweigerd en u ziet een foutmelding waarin wordt uitgelegd dat u uw limiet heeft bereikt. U kunt wachten tot de limiet wordt gereset (dagelijkse limieten worden om middernacht UTC gereset, maandelijkse limieten op de 1e van elke maand) of uw verificatieniveau verhogen voor hogere limieten.",
      "q4": "Zijn er kosten verbonden aan het aanhouden van een portefeuillesaldo?",
      "a4": "Nee. Er zijn geen maandelijkse kosten, administratiekosten of inactiviteitskosten voor uw mPay-portefeuille. Uw saldo blijft van u. De enige kosten die van toepassing kunnen zijn, zijn voor bepaalde opwaardeermethoden (creditcard) en spoedopnames.",
      "q5": "Kan ik terugkerende/automatische opwaarderingen instellen?",
      "a5": "Ja! Ga naar <strong>Instellingen → Automatisch Opwaarderen</strong> om automatische saldo-aanvulling te configureren. U kunt een drempelbedrag voor het minimale saldo en een opwaardeerbedrag instellen. Wanneer uw saldo onder de drempel zakt, zal mPay automatisch opwaarderen vanaf uw voorkeursbron.",
      "q6": "Wat gebeurt er met mijn saldo als ik mijn telefoon verlies?",
      "a6": "Uw saldo is veilig — het wordt veilig opgeslagen op mPay-servers, niet op uw apparaat. Als u uw telefoon verliest, neem dan onmiddellijk contact op met mPay-ondersteuning om uw account te bevriezen. Wanneer u een nieuw apparaat heeft, logt u in met uw gegevens en wordt uw volledige saldo hersteld. Schakel wissen op afstand in op uw telefoon als extra voorzorgsmaatregel."
    },
    "pagination": {
      "prev": "Vorige",
      "prev_title": "Betalingen Doen",
      "next": "Volgende",
      "next_title": "P2P Overboekingen"
    },
