    "title": "Betalingen Doen",
    "subtitle": "Leer hoe u snel en veilig betalingen kunt doen met de mPay Consumenten Portefeuille. Of u nu een QR-code scant, de uwe laat zien of tikt met NFC — betalen is nog nooit zo eenvoudig geweest.",
    "method_cards": {
      "qr": {
        "title": "QR-code Betalingen",
        "body": "Scan of toon een QR-code om direct betalingen te doen bij elke mPay-handelaar."
      },
      "nfc": {
        "title": "NFC Tap-to-Pay",
        "body": "Houd uw telefoon gewoon bij de terminal voor een contactloze betalingservaring."
      }
    },
    "scan_qr": {
      "heading": "QR-codes Scannen",
      "intro": "De meest voorkomende manier om te betalen is door de QR-code van een handelaar te scannen. Dit proces duurt slechts enkele seconden en verwerkt uw betaling veilig via het mPay-netwerk.",
      "how_to_title": "Hoe u Scant om te Betalen",
      "steps": {
        "1": {
          "title": "Tik op \"Scan om te Betalen\"",
          "body": "Tik vanaf het startscherm op het <strong>Scannen om te Betalen icoon</strong> in de sectie <b>Geld Verzenden</b>."
        },
        "2": {
          "title": "Scan de QR-code van de Ontvanger",
          "body": "Richt uw camera op de QR-code van de ontvanger. Eenmaal gescand, worden de gegevens van de ontvanger automatisch ingevuld in het Scan om te Betalen-formulier."
        },
        "3": {
          "title": "Bedrag Invoeren en Bevestigen",
          "body": "Voer het bedrag van de overboeking in, controleer de details en bevestig met uw PIN of biometrische authenticatie."
        },
        "4": {
          "title": "Overboeking Voltooid",
          "body": "U ziet een bevestigingsscherm met een transactie <b>referentienummer.</b> <p>De ontvanger wordt direct op de hoogte gesteld.</p>"
        }
      },
      "visual_label": "Lijn de QR-code uit binnen het kader",
      "tip_title": "Tip: Snelkoppeling voor Betalen",
      "tip_body": "U kunt de QR-scanner ook rechtstreeks starten door dubbel op het mPay-icoon op uw startscherm te tikken, of door de snelkoppeling \"Scannen\" in de widget van het meldingenvenster te gebruiken."
    },
    "show_qr": {
      "heading": "Uw QR-code Tonen",
      "intro": "Sommige handelaren scannen liever uw QR-code met hun terminal of apparaat. In dit geval toont u gewoon uw persoonlijke betalings-QR-code zodat zij deze kunnen scannen.",
      "how_to_title": "Hoe u uw QR-code Toont",
      "steps": {
        "1": {
          "title": "Open uw Betalingscode",
          "body": "Tik op <strong>\"Betalen\"</strong> op het startscherm en selecteer vervolgens <strong>\"Mijn QR-code Tonen\"</strong>. Uw persoonlijke betalings-QR-code wordt weergegeven."
        },
        "2": {
          "title": "Aan de Handelaar Tonen",
          "body": "Houd uw telefoon stil terwijl de QR-code zichtbaar is. De handelaar scant deze met zijn mPay-terminal of apparaatcamera."
        },
        "3": {
          "title": "Bevestigen op uw Apparaat",
          "body": "Nadat de handelaar heeft gescand en het bedrag heeft ingevoerd, ontvangt u een pushmelding. Bevestig het betalingsbedrag en authentiseer om te voltooien."
        }
      },
      "visual_label": "Toon dit aan de handelaar",
      "security_title": "Beveiligingsopmerking",
      "security_body": "Uw betalings-QR-code wordt om de 60 seconden vernieuwd voor de veiligheid. Deel nooit een screenshot van uw QR-code. Toon deze alleen bij het verkooppunt wanneer u een betaling doet."
    },
    "nfc_tap": {
      "heading": "NFC Tap-to-Pay",
      "intro": "Als uw apparaat NFC ondersteunt en de handelaar een NFC-terminal heeft, kunt u betalen door simpelweg uw telefoon tegen hun betalingsapparaat te tikken — scannen is niet nodig.",
      "how_to_title": "Hoe u NFC-betalingen Gebruikt",
      "steps": {
        "1": {
          "title": "Schakel NFC in",
          "body": "Zorg ervoor dat NFC is ingeschakeld in uw telefooninstellingen en in de mPay-app onder <strong>Instellingen → Betalingsmethoden → NFC-betalingen</strong>."
        },
        "2": {
          "title": "Dichtbij Terminal Houden",
          "body": "Wanneer de terminal van de handelaar het bedrag toont, houdt u de achterkant van uw telefoon (bij de NFC-antenne) binnen 4 cm van de betalingsterminal."
        },
        "3": {
          "title": "Authentiseren",
          "body": "Een trilling of toon bevestigt de verbinding. Authentiseer met biometrie of uw PIN. De betaling wordt in minder dan 2 seconden verwerkt."
        },
        "4": {
          "title": "Betaling Voltooid",
          "body": "U ziet een groen vinkje en ontvangt zowel een in-app melding als een optioneel SMS-bewijs."
        }
      },
      "visual_phone": "Uw Telefoon",
      "visual_terminal": "Betalingsterminal",
      "antenna_title": "Locatie NFC-antenne",
      "antenna_body": "De NFC-antenne bevindt zich meestal bovenaan in het midden van de achterkant van uw telefoon. Verwijder dikke hoesjes als u problemen heeft met verbinden."
    },
    "confirmation": {
      "heading": "Betalingsbevestiging",
      "intro": "Na elke succesvolle betaling ontvangt u direct een bevestiging met transactiegegevens. Dit dient als uw digitale bewijs.",
      "receipt_title": "Wat is Inbegrepen in uw Bewijs",
