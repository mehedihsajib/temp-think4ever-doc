  "requirements": {
    "heading": "Systeemvereisten",
    "intro": "Zorg er voor het downloaden voor dat uw apparaat voldoet aan de minimale vereisten:",
    "ios": {
      "name": "iOS",
      "desc": "iOS 15.0 of hoger. Compatibel met iPhone 8 en nieuwer. Ongeveer 85 MB opslagruimte vereist."
    },
    "android": {
      "name": "Android",
      "desc": "Android 10.0 (API level 29) of hoger. Ongeveer 60 MB opslagruimte vereist."
    },
    "nfc_callout_title": "NFC Vereiste",
    "nfc_callout_body": "Voor tap-to-pay functionaliteit moet uw apparaat over NFC-hardware beschikken. De meeste moderne smartphones (iPhone 7+ en Android met NFC) ondersteunen deze functie."
  },
  "download": {
    "heading": "Downloaden & Installeren",
    "intro": "De mPay Consumenten Portefeuille is gratis beschikbaar in beide grote app stores. Kies hieronder uw platform:",
    "ios_btn": "App Store",
    "ios_btn_pre": "Download in de",
    "android_btn": "Google Play",
    "android_btn_pre": "Ontdek het op",
    "install_steps_heading": "Installatiestappen",
    "steps": {
      "1": {
        "title": "Open uw app store",
        "content": "Open de <strong>App Store</strong> (iOS) or <strong>Google Play Store</strong> (Android) op uw apparaat."
      },
      "2": {
        "title": "Zoek naar mPay Wallet",
        "content": "Typ <code>mPay Consumer Wallet</code> in de zoekbalk. Zoek naar de officiële app met het mPay-logo and \"mPay Network\" als ontwikkelaar."
      },
      "3": {
        "title": "Downloaden en installeren",
        "content": "Tik op <strong>Download</strong> (iOS) of <strong>Installeren</strong> (Android). De app wordt automatisch gedownload en geïnstalleerd. Mogelijk wordt u gevraagd om u te authenticeren met uw apparaatwachtwoord, Face ID of vingerafdruk."
      },
      "4": {
        "title": "Open de app",
        "content": "Tik na de installatie op <strong>Openen</strong> of zoek het mPay-icoon op uw startscherm. De app start met het welkomstscherm."
      }
    },
    "verify_callout_title": "Verifieer de Ontwikkelaar",
    "verify_callout_body": "Verifieer altijd of de ontwikkelaar vermeld staat als \"mPay Network\" voordat u downloadt. Installeer geen apps van onofficiële bronnen."
  },
  "signup": {
    "heading": "Aanmelden",
    "intro": "Uw mPay-account aanmaken is snel en eenvoudig. U heeft een geldig telefoonnummer and e-mailadres nodig.",
    "steps": {
      "1": {
        "title": "Bent u een bestaande mPay-klant?",
        "content": "Op het welkomstscherm wordt u gevraagd of u <strong>\"Een bestaande klant bent?\"</strong>. Voor nieuwe klanten tikt u op de knop <strong>NEE</strong>. Als u al een account heeft, selecteert u de knop <strong>JA</strong>."
      },
      "2": {
        "title": "Nieuw Consumenten Registratieformulier",
        "content": "De gebruiker wordt naar het <strong>Nieuwe Consument Registreren</strong> formulier geleid."
      },
      "3": {
        "title": "Vereiste Klantinformatie",
        "content": "De <strong>Gebruikers-ID</strong>, het <strong>E-mailadres</strong>, en het <strong>Mobiele Nummer</strong> moeten uniek zijn voor elke klant.",
        "info_callout": "Tijdens de indiening van de registratie verifieert het systeem of de <strong>Gebruikers-ID</strong>, het <strong>E-mailadres</strong> en het <strong>Mobiele Nummer</strong> al in gebruik zijn door bestaande mPay-klanten."
      },
      "4": {
        "title": "Vul alle verplichte velden in",
        "intro": "Voer uw basisinformatie in:",
        "field_name": "<strong>Voor- en Achternaam</strong> — Zoals vermeld op uw identiteitsbewijs",
        "field_email": "<strong>E-mailadres</strong> — Een geldig e-mailadres voor meldingen en herstel",
        "field_mobile": "<strong>Mobiel Nummer</strong> — Moet een geldig mobiel nummer zijn dat SMS ontvangt voor verificatie",
        "field_referral": "<strong>Referral Code</strong> — Optioneel veld voor de verwijzingscode van de verwijzende mPay-klant."
      },
      "5": {
        "title": "Akkoord gaan met de voorwaarden",
        "intro": "Er zijn twee verplichte selectievakjes die geaccepteerd moeten worden voordat de registratie kan worden voortgezet:",
        "check_terms": "Accepteer de <strong>Algemene Voorwaarden</strong>",
        "check_security": "Beveiligingsbeleid dat slechts één gebruiker per apparaat toestaat, waarin staat: <em>\"Ik ga ermee akkoord dat het registreren van een nieuwe klant het bestaande account dat aan dit apparaat is gekoppeld, zal verwijderen.\"</em>"
      },
      "6": {
        "title": "Optie om E-mail en Mobiel te Gebruiken in de Handelaar App",
        "intro": "Kies of uw e-mailadres en mobiele nummer ook gebruikt kunnen worden om u te identificeren in de Handelaar App.",
        "check_terms": "Accepteer de <strong>Algemene Voorwaarden</strong>",
        "check_security": "Beveiligingsbeleid dat slechts één gebruiker per apparaat toestaat, waarin staat: <em>\"Ik ga ermee akkoord dat het registreren van een nieuwe klant het bestaande account dat aan dit apparaat is gekoppeld, zal verwijderen.\"</em>"
      }
    },
    "success_callout_title": "Account Aangemaakt!",
    "success_callout_body": "Zodra u het bevestigingsscherm ziet, is uw account klaar. U kunt nu doorgaan met het instellen van uw profiel en uw portefeuille configureren."
  },
