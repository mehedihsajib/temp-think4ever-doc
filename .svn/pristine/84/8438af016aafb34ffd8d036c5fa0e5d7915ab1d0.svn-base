    "scan_qr": {
      "heading": "Scansionare Codici QR",
      "how_to_title": "Come fare lo Scan to Pay",
      "steps": {
        "1": {
          "title": "Tocca \"Scan to Pay\"",
          "body": "Sulla home, sezione <b>Invia Denaro</b>."
        },
        "2": {
          "title": "Scansiona il QR",
          "body": "Inquadra il codice del destinatario."
        },
