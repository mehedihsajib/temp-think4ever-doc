<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Admin - Changelog Editor</title>
        <link href="css/theme.css" rel="stylesheet" type="text/css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="assets/css/global.css">
        <link rel="stylesheet" href="assets/css/admin_changelog_editor.css">
        <style>/* Basic reset for preview consistency */body { margin: 0; padding: 0; font-family: sans-serif; }</style>
    </head>
    <body>
        <div class="admin-changelog-editor">
            <!-- Skip to content -->
            <a href="#main-content" class="sr-only" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">Skip to main content</a>
            <!-- Sidebar Overlay (mobile) -->
            <div class="sidebar-overlay" id="ace_sidebar_overlay" aria-hidden="true"></div>
            <!-- Admin Sidebar -->
            <aside class="admin-sidebar" id="ace_sidebar" role="navigation" aria-label="Admin navigation">
                <div class="admin-sidebar-header">
                    <img src="https://dev.think4ever.com/uifiles/20260311/ed3d2c21991e3bef5e069713af9fa6ca/only_m_with_white_bg_logo.png" alt="MPay Network logo"/>
                    <span class="admin-brand">MPay</span>
                    <span class="admin-badge">Admin</span>
                </div>
                <nav class="admin-sidebar-nav">
                    <div class="nav-section-label">Overview</div>
                    <a class="admin-nav-link" onclick="load_page('admin_dashboard')" role="button" tabindex="0"> <i class="fa-solid fa-grid-2"></i> Dashboard </a>
                    <div class="nav-section-label">Content</div>
                    <a class="admin-nav-link" onclick="load_page('admin_comment_moderation')" role="button" tabindex="0"> <i class="fa-solid fa-comments"></i> Comments </a>
                    <a class="admin-nav-link" onclick="load_page('admin_feedback_viewer')" role="button" tabindex="0"> <i class="fa-solid fa-message"></i> Feedback </a>
                    <a class="admin-nav-link active" aria-current="page"> <i class="fa-solid fa-clock-rotate-left"></i> Changelog </a>
                    <div class="nav-section-label">Blog</div>
                    <a class="admin-nav-link" onclick="load_page('blog_listing')" role="button" tabindex="0"> <i class="fa-solid fa-newspaper"></i> Posts </a>
                    <div class="nav-section-label">Settings</div>
                    <a class="admin-nav-link" role="button" tabindex="0"> <i class="fa-solid fa-gear"></i> Settings </a>
                </nav>
                <div class="admin-sidebar-footer">
                    <a class="admin-nav-link" onclick="load_page('index')" role="button" tabindex="0"> <i class="fa-solid fa-arrow-left"></i> Back to Site </a>
                    <a class="admin-nav-link" onclick="load_page('admin_login')" role="button" tabindex="0"> <i class="fa-solid fa-right-from-bracket"></i> Logout </a>
                </div>
            </aside>
            <!-- Main Content -->
            <div class="admin-main-content">
                <!-- Topbar -->
                <header class="admin-topbar">
                    <div class="admin-topbar-left">
                        <button class="admin-mobile-toggle" id="ace_mobile_toggle" aria-label="Toggle sidebar menu">
                            <i class="fa-solid fa-bars"></i>
                        </button>
                        <nav class="admin-breadcrumb" aria-label="Breadcrumb">
                            <a onclick="load_page('admin_dashboard')">Admin</a>
                            <span class="breadcrumb-sep">/</span>
                            <span class="breadcrumb-current">Changelog Editor</span>
                        </nav>
                    </div>
                    <div class="admin-topbar-right">
                        <div class="admin-topbar-avatar" aria-label="Admin user">A</div>
                    </div>
                </header>
                <!-- Page Content -->
                <main id="main-content" class="admin-page-content">
                    <!-- Page Header -->
                    <div class="page-header">
                        <div class="page-header-left">
                            <h1 id="ace_title">Changelog Editor</h1>
                            <p>Create and manage release notes for Merchant and Consumer wallets</p>
                        </div>
                        <div class="page-header-actions">
                            <button class="btn btn-secondary" id="ace_back_dashboard" onclick="load_page('admin_dashboard')">
                                <i class="fa-solid fa-arrow-left"></i> Dashboard
                            </button>
                            <button class="btn btn-primary" id="ace_new_btn">
                                <i class="fa-solid fa-plus"></i> New Release Entry
                            </button>
                        </div>
                    </div>
                    <!-- Stats Strip -->
                    <div class="stats-strip">
                        <div class="stat-card">
                            <div class="stat-icon blue">
                                <i class="fa-solid fa-list"></i>
                            </div>
                            <div class="stat-info">
                                <h3 id="ace_stat_total">0</h3>
                                <p>Total Entries</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon green">
                                <i class="fa-solid fa-circle-check"></i>
                            </div>
                            <div class="stat-info">
                                <h3 id="ace_stat_published">0</h3>
                                <p>Published</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon amber">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </div>
                            <div class="stat-info">
                                <h3 id="ace_stat_drafts">0</h3>
                                <p>Drafts</p>
                            </div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-icon purple">
                                <i class="fa-solid fa-calendar"></i>
                            </div>
                            <div class="stat-info">
                                <h3 id="ace_stat_this_month">0</h3>
                                <p>This Month</p>
                            </div>
                        </div>
                    </div>
                    <!-- Filter Bar -->
                    <div class="filter-bar">
                        <div class="search-box">
                            <i class="fa-solid fa-search"></i>
                            <input type="text" id="ace_search_input" placeholder="Search by version or description..." aria-label="Search changelog entries"/>
                        </div>
                        <select class="filter-select" id="ace_filter_wallet" aria-label="Filter by wallet type">
                            <option value="all">All Wallets</option>
                            <option value="merchant">Merchant Wallet</option>
                            <option value="consumer">Consumer Wallet</option>
                            <option value="both">Both Wallets</option>
                        </select>
                    </div>
                    <!-- Entries Table -->
                    <div class="entries-container" id="ace_entries_list">
                        <div class="entries-table-wrapper" id="ace_table_wrapper">
                            <table class="entries-table" role="table">
                                <thead>
                                    <tr>
                                        <th scope="col">Version / Date</th>
                                        <th scope="col">Wallet</th>
                                        <th scope="col">Tags</th>
                                        <th scope="col">Description</th>
                                        <th scope="col">Status</th>
                                        <th scope="col">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="ace_entries_tbody">
                                    <!-- Dynamically populated -->
                                </tbody>
                            </table>
                        </div>
                        <!-- Empty State -->
                        <div class="empty-state" id="ace_empty_state" style="display:none;">
                            <i class="fa-solid fa-clock-rotate-left"></i>
                            <h3>No changelog entries found</h3>
                            <p>Create your first release entry or adjust your filters.</p>
                            <button class="btn btn-primary" onclick="document.getElementById('ace_new_btn').click()">
                                <i class="fa-solid fa-plus"></i> Create Entry
                            </button>
                        </div>
                        <!-- Table Footer -->
                        <div class="table-footer" id="ace_table_footer">
                            <span id="ace_entries_count">Showing 0 entries</span>
                            <div class="pagination">
                                <button disabled aria-label="Previous page">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>
                                <button class="active">1</button>
                                <button disabled aria-label="Next page">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
            <!-- Edit/Create Modal -->
            <div class="modal-overlay" id="ace_edit_modal" role="dialog" aria-modal="true" aria-labelledby="ace_modal_title">
                <div class="modal">
                    <div class="modal-header">
                        <h2 id="ace_modal_title">New Changelog Entry</h2>
                        <button class="modal-close" data-action="close-modal" aria-label="Close dialog">
                            <i class="fa-solid fa-times"></i>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label" for="ace_version">Version Number <span class="required">*</span>
                                </label>
                                <input type="text" class="form-input" id="ace_version" placeholder="e.g., v2.4.0" required/>
                                <div class="form-error" id="ace_version_error">Version number is required.</div>
                                <div class="form-help">Use semantic versioning (e.g., v2.1.0)</div>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="ace_release_date">Release Date <span class="required">*</span>
                                </label>
                                <input type="date" class="form-input" id="ace_release_date" required/>
                                <div class="form-error" id="ace_date_error">Release date is required.</div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="ace_wallet_type">Wallet Type</label>
                            <select class="form-input" id="ace_wallet_type">
                                <option value="both">Both Wallets</option>
                                <option value="merchant">Merchant Wallet</option>
                                <option value="consumer">Consumer Wallet</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label" id="ace_tags_label">Change Tags</label>
                            <div class="tag-select-container" role="group" aria-labelledby="ace_tags_label">
                                <div class="tag-select-option" data-tag="feature" role="checkbox" aria-checked="false" tabindex="0">
                                    <i class="fa-solid fa-sparkles"></i> New Feature
                                </div>
                                <div class="tag-select-option" data-tag="bugfix" role="checkbox" aria-checked="false" tabindex="0">
                                    <i class="fa-solid fa-bug"></i> Bug Fix
                                </div>
                                <div class="tag-select-option" data-tag="improvement" role="checkbox" aria-checked="false" tabindex="0">
                                    <i class="fa-solid fa-arrow-up"></i> Improvement
                                </div>
                                <div class="tag-select-option" data-tag="breaking" role="checkbox" aria-checked="false" tabindex="0">
                                    <i class="fa-solid fa-triangle-exclamation"></i> Breaking Change
                                </div>
                                <div class="tag-select-option" data-tag="security" role="checkbox" aria-checked="false" tabindex="0">
                                    <i class="fa-solid fa-shield-halved"></i> Security
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="ace_description">Release Description <span class="required">*</span>
                            </label>
                            <textarea class="form-input" id="ace_description" placeholder="Describe the changes in this release...\n\n### New Features\n- Feature description\n\n### Bug Fixes\n- Fix description" rows="8"></textarea>
                            <div class="form-error" id="ace_desc_error">Release description is required.</div>
                            <div class="markdown-hint">
                                <i class="fa-brands fa-markdown"></i> Markdown formatting supported
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <div class="modal-footer-left">
                            <button class="btn btn-danger btn-sm" id="ace_delete_btn" style="display:none;" onclick="window.aceDeleteFromModal()">
                                <i class="fa-solid fa-trash"></i> Delete
                            </button>
                        </div>
                        <div class="modal-footer-right">
                            <button class="btn btn-ghost" data-action="close-modal">Cancel</button>
                            <button class="btn btn-secondary" id="ace_save_draft_btn">
                                <i class="fa-solid fa-file-pen"></i> Save as Draft
                            </button>
                            <button class="btn btn-primary" id="ace_save_btn">
                                <i class="fa-solid fa-check"></i> Publish Entry
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Delete Confirmation Modal -->
            <div class="modal-overlay" id="ace_delete_modal" role="dialog" aria-modal="true" aria-labelledby="delete_modal_title">
                <div class="modal" style="max-width: 440px;">
                    <div class="modal-header">
                        <h2 id="delete_modal_title">Confirm Deletion</h2>
                        <button class="modal-close" data-action="close-delete-modal" aria-label="Close dialog">
                            <i class="fa-solid fa-times"></i>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="delete-confirm-content">
                            <div class="delete-icon">
                                <i class="fa-solid fa-trash"></i>
                            </div>
                            <h3>Delete this entry?</h3>
                            <p>You are about to permanently delete changelog entry <span class="version-highlight" id="ace_delete_version"></span>. This action cannot be undone.</p>
                        </div>
                    </div>
                    <div class="modal-footer" style="justify-content: center;">
                        <div class="modal-footer-right">
                            <button class="btn btn-ghost" data-action="close-delete-modal">Cancel</button>
                            <button class="btn btn-danger" id="ace_confirm_delete_btn">
                                <i class="fa-solid fa-trash"></i> Delete Entry
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Toast Container -->
            <div class="toast-container" id="ace_toast_container" aria-live="polite"></div>
        </div>
        <script src="assets/js/navigation.js"></script>
        <script src="assets/js/admin_changelog_editor.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    </body>
</html>