                    <!-- Page Title -->
                    <h1 class="cd-page-title" id="cdHomeTitle">Consumer Wallet Documentation</h1>
                    <!-- Overview Section -->
                    <section class="cd-overview" id="cdHomeOverview" aria-labelledby="overview-heading">
                        <p class="cd-overview-text">
          Welcome to the <strong>MPay Network Consumer Wallet</strong> documentation. The Consumer Wallet is your all-in-one mobile payment solution, enabling you to make fast, secure payments at any MPay-enabled merchant, send money to friends and family, and manage your finances with ease. </p>
                        <p class="cd-overview-text">
          Whether you're paying at a coffee shop via QR code, tapping your phone for an NFC payment, or sending money to a friend across the country, the Consumer Wallet has you covered. This documentation will guide you through everything from your first download to advanced features. </p>
                        <!-- Key Features Callout -->
                        <div class="cd-key-features">
                            <h3 id="overview-heading"><i class="fa fa-star" aria-hidden="true"></i> Key Features</h3>
                            <ul>
                                <li>
                                    <i class="fa fa-check-circle" aria-hidden="true"></i> QR Code Payments
                                </li>
                                <li>
                                    <i class="fa fa-check-circle" aria-hidden="true"></i> NFC Tap-to-Pay
                                </li>
                                <li>
                                    <i class="fa fa-check-circle" aria-hidden="true"></i> Person-to-Person Transfers
                                </li>
                                <li>
                                    <i class="fa fa-check-circle" aria-hidden="true"></i> Wallet Top-up &amp; Withdrawal
                                </li>
                                <li>
                                    <i class="fa fa-check-circle" aria-hidden="true"></i> Transaction History &amp; Receipts
                                </li>
                                <li>
                                    <i class="fa fa-check-circle" aria-hidden="true"></i> Multi-layer Security
                                </li>
                                <li>
                                    <i class="fa fa-check-circle" aria-hidden="true"></i> Instant Notifications
                                </li>
                                <li>
                                    <i class="fa fa-check-circle" aria-hidden="true"></i> Biometric Authentication
                                </li>
                            </ul>
                        </div>
                    </section>
                    <!-- Quick Start Section -->
                    <section class="cd-quick-start" aria-labelledby="quickstart-heading">
                        <h2 class="cd-section-title" id="quickstart-heading">Quick Start</h2>
                        <p style="font-size:0.9375rem;color:#334155;line-height:1.6;margin:0 0 20px;">Get up and running with MPay Consumer Wallet in just a few steps:</p>
                        <div class="cd-steps">
                            <div class="cd-step">
                                <div class="cd-step-indicator">
                                    <div class="cd-step-number">1</div>
                                    <div class="cd-step-line"></div>
                                </div>
                                <div class="cd-step-content">
                                    <h4>Download &amp; Install</h4>
                                    <p>Get the MPay Consumer Wallet from the App Store or Google Play Store.</p>
                                </div>
                            </div>
                            <div class="cd-step">
                                <div class="cd-step-indicator">
                                    <div class="cd-step-number">2</div>
                                    <div class="cd-step-line"></div>
                                </div>
                                <div class="cd-step-content">
                                    <h4>Create Your Account</h4>
                                    <p>Sign up with your phone number and complete the quick verification process.</p>
                                </div>
                            </div>
                            <div class="cd-step">
                                <div class="cd-step-indicator">
                                    <div class="cd-step-number">3</div>
                                    <div class="cd-step-line"></div>
                                </div>
                                <div class="cd-step-content">
                                    <h4>Fund Your Wallet</h4>
                                    <p>Add money to your wallet via bank transfer, debit card, or other supported methods.</p>
                                </div>
                            </div>
                            <div class="cd-step">
                                <div class="cd-step-indicator">
                                    <div class="cd-step-number">4</div>
                                </div>
                                <div class="cd-step-content">
                                    <h4>Start Paying</h4>
                                    <p>Scan a QR code or tap your phone at any MPay-enabled merchant to pay instantly.</p>
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Explore Documentation -->                     
                    <section aria-labelledby="explore-heading">
                        <h2 class="cd-section-title" id="explore-heading">Explore Documentation</h2>
                        <div class="cd-cards-grid">
                            <!-- Getting Started Card -->
