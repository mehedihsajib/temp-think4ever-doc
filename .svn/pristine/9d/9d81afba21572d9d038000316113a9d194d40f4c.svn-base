                                <div class="cd-doc-card-arrow">Learn more <i class="fa fa-arrow-right" aria-hidden="true"></i>
                                </div>
                            </div>
                            <!-- Making Payments Card -->
                            <div class="cd-doc-card" id="cdHomePaymentsLink" data-navigate="consumer_making_payments" tabindex="0" role="link" aria-label="Making Payments - Pay with QR codes and NFC tap-to-pay">
                                <div class="cd-doc-card-icon">
                                    <i class="fa fa-credit-card" aria-hidden="true"></i>
                                </div>
                                <h3 class="cd-doc-card-title">Making Payments</h3>
                                <p class="cd-doc-card-desc">Learn how to pay at merchants using QR code scanning, NFC tap-to-pay, and other supported payment methods.</p>
                                <div class="cd-doc-card-arrow">Learn more <i class="fa fa-arrow-right" aria-hidden="true"></i>
                                </div>
                            </div>
                            <!-- Wallet Management Card -->
                            <div class="cd-doc-card" id="cdHomeWalletLink" data-navigate="consumer_wallet_management" tabindex="0" role="link" aria-label="Wallet Management - Manage balance, top-up, and withdrawals">
                                <div class="cd-doc-card-icon">
                                    <i class="fa fa-coins" aria-hidden="true"></i>
                                </div>
                                <h3 class="cd-doc-card-title">Wallet Management</h3>
                                <p class="cd-doc-card-desc">Manage your wallet balance, top-up with various methods, withdraw funds, and view transaction history.</p>
                                <div class="cd-doc-card-arrow">Learn more <i class="fa fa-arrow-right" aria-hidden="true"></i>
                                </div>
                            </div>
                            <!-- P2P Transfers Card -->
                            <div class="cd-doc-card" id="cdHomeP2pLink" data-navigate="consumer_p2p_transfers" tabindex="0" role="link" aria-label="P2P Transfers - Send money to friends and family">
                                <div class="cd-doc-card-icon">
                                    <i class="fa fa-exchange-alt" aria-hidden="true"></i>
                                </div>
                                <h3 class="cd-doc-card-title">P2P Transfers</h3>
                                <p class="cd-doc-card-desc">Send and receive money from other MPay users instantly. Split bills, request payments, and manage contacts.</p>
                                <div class="cd-doc-card-arrow">Learn more <i class="fa fa-arrow-right" aria-hidden="true"></i>
                                </div>
                            </div>
                            <!-- Settings & Security Card -->
                            <div class="cd-doc-card" id="cdHomeSettingsLink" data-navigate="consumer_settings" tabindex="0" role="link" aria-label="Settings & Security - Configure app settings and security preferences">
                                <div class="cd-doc-card-icon">
                                    <i class="fa fa-shield-alt" aria-hidden="true"></i>
                                </div>
                                <h3 class="cd-doc-card-title">Settings &amp; Security</h3>
                                <p class="cd-doc-card-desc">Configure notification preferences, enable biometric login, manage security settings, and protect your account.</p>
                                <div class="cd-doc-card-arrow">Learn more <i class="fa fa-arrow-right" aria-hidden="true"></i>
                                </div>
                            </div>
                            <!-- Troubleshooting Card -->
                            <div class="cd-doc-card" id="cdHomeTroubleshootingLink" data-navigate="consumer_troubleshooting" tabindex="0" role="link" aria-label="Troubleshooting - Common issues and solutions">
                                <div class="cd-doc-card-icon">
                                    <i class="fa fa-life-ring" aria-hidden="true"></i>
                                </div>
                                <h3 class="cd-doc-card-title">Troubleshooting</h3>
                                <p class="cd-doc-card-desc">Find solutions to common issues, error codes, payment failures, and get help when something doesn't work as expected.</p>
                                <div class="cd-doc-card-arrow">Learn more <i class="fa fa-arrow-right" aria-hidden="true"></i>
                                </div>
                            </div>
                        </div>
                    </section>
