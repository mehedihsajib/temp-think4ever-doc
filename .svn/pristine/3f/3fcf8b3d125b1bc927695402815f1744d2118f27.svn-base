<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Admin - Comment Moderation</title>
        <link href="css/theme.css" rel="stylesheet" type="text/css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="assets/css/global.css">
        <link rel="stylesheet" href="assets/css/admin_comment_moderation.css">
        <style>/* Basic reset for preview consistency */body { margin: 0; padding: 0; font-family: sans-serif; }</style>
    </head>
    <body>
        <div class="admin-comment-moderation">
            <!-- Skip to content -->
            <a href="#acm-main-content" class="sr-only" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">Skip to main content</a>
            <!-- Sidebar Toggle (Mobile) -->
            <button class="admin-sidebar-toggle" id="admin_sidebar_toggle" aria-label="Toggle sidebar navigation">
                <i class="fa-solid fa-bars"></i>
            </button>
            <!-- Sidebar Overlay -->
            <div class="admin-sidebar-overlay" id="admin_sidebar_overlay"></div>
            <!-- Admin Sidebar -->
            <aside class="admin-sidebar" id="admin_sidebar" role="navigation" aria-label="Admin navigation">
                <div class="admin-sidebar-header">
                    <img src="https://dev.think4ever.com/uifiles/20260311/ed3d2c21991e3bef5e069713af9fa6ca/only_m_with_white_bg_logo.png" alt="MPay Logo">
                    <div style="display:flex;flex-direction:column;gap:4px;">
                        <span>MPay Network</span>
                        <span class="admin-label">Admin Panel</span>
                    </div>
                </div>
                <nav class="admin-sidebar-nav">
                    <div class="admin-nav-section">
                        <div class="admin-nav-section-label">Overview</div>
                        <a class="admin-nav-link" onclick="load_page('admin_dashboard')"> <i class="fa-solid fa-gauge-high"></i>
          Dashboard </a>
                    </div>
                    <div class="admin-nav-section">
                        <div class="admin-nav-section-label">Content</div>
                        <a class="admin-nav-link active" onclick="load_page('admin_comment_moderation')"> <i class="fa-solid fa-comments"></i>
          Comment Moderation </a>
                        <a class="admin-nav-link" onclick="load_page('admin_feedback_viewer')"> <i class="fa-solid fa-message"></i>
          Feedback </a>
                        <a class="admin-nav-link" onclick="load_page('admin_changelog_editor')"> <i class="fa-solid fa-clock-rotate-left"></i>
          Changelog Editor </a>
                    </div>
                    <div class="admin-nav-section">
                        <div class="admin-nav-section-label">Quick Links</div>
                        <a class="admin-nav-link" onclick="load_page('index')"> <i class="fa-solid fa-globe"></i>
          View Site </a>
                        <a class="admin-nav-link" onclick="load_page('blog_listing')"> <i class="fa-solid fa-newspaper"></i>
          Blog </a>
                    </div>
                </nav>
                <div class="admin-sidebar-footer">
                    <a onclick="load_page('admin_login')"> <i class="fa-solid fa-right-from-bracket"></i>
        Sign Out </a>
                </div>
            </aside>
            <!-- Main Content -->
            <div class="admin-main">
                <!-- Top Bar -->
                <header class="admin-topbar">
                    <div class="admin-topbar-left">
                        <nav class="admin-breadcrumb" aria-label="Breadcrumb">
                            <a onclick="load_page('admin_dashboard')">Admin</a>
                            <span class="separator">/</span>
                            <span class="current">Comment Moderation</span>
                        </nav>
                    </div>
                    <div class="admin-topbar-right">
                        <div class="admin-avatar" title="Admin User" aria-label="Admin user avatar">AD</div>
                    </div>
                </header>
                <!-- Content Area -->
                <main class="admin-content" id="acm-main-content">
                    <!-- Page Header -->
                    <div class="acm-header">
                        <div class="acm-header-left">
                            <h1 id="acm_title"><i class="fa-solid fa-comments" style="color:#2563eb;margin-right:8px;"></i>Comment Moderation</h1>
                            <p>Review, approve, and manage blog comments across all posts.</p>
                        </div>
                        <div class="acm-header-actions">
                            <button class="btn btn-outline" id="acm_back_dashboard" onclick="load_page('admin_dashboard')">
                                <i class="fa-solid fa-arrow-left"></i>
                                Back to Dashboard
                            </button>
                        </div>
                    </div>
                    <!-- Stats Cards -->
                    <div class="acm-stats">
                        <div class="acm-stat-card">
                            <div class="acm-stat-icon pending">
                                <i class="fa-solid fa-clock"></i>
                            </div>
                            <div class="acm-stat-info">
                                <h3 id="stat_pending">0</h3>
                                <span>Pending</span>
                            </div>
                        </div>
                        <div class="acm-stat-card">
                            <div class="acm-stat-icon approved">
                                <i class="fa-solid fa-circle-check"></i>
                            </div>
                            <div class="acm-stat-info">
                                <h3 id="stat_approved">0</h3>
                                <span>Approved</span>
                            </div>
                        </div>
                        <div class="acm-stat-card">
                            <div class="acm-stat-icon rejected">
                                <i class="fa-solid fa-circle-xmark"></i>
                            </div>
                            <div class="acm-stat-info">
                                <h3 id="stat_rejected">0</h3>
                                <span>Rejected</span>
                            </div>
                        </div>
                        <div class="acm-stat-card">
                            <div class="acm-stat-icon total">
                                <i class="fa-solid fa-comments"></i>
                            </div>
                            <div class="acm-stat-info">
                                <h3 id="stat_total">0</h3>
                                <span>Total</span>
                            </div>
                        </div>
                    </div>
                    <!-- Filters -->
                    <div class="acm-filters">
                        <div class="acm-filter-group">
                            <label for="acm_filter_status">Status</label>
                            <select id="acm_filter_status" aria-label="Filter by status">
                                <option value="all">All Statuses</option>
                                <option value="pending">Pending</option>
                                <option value="approved">Approved</option>
                                <option value="rejected">Rejected</option>
                            </select>
                        </div>
                        <div class="acm-filter-group">
                            <label for="acm_filter_post">Blog Post</label>
                            <select id="acm_filter_post" aria-label="Filter by blog post">
                                <option value="all">All Posts</option>
                            </select>
                        </div>
                        <div class="acm-filter-group" style="flex:2;">
                            <label for="acm_search">Search</label>
                            <div class="search-input-wrapper">
                                <i class="fa-solid fa-magnifying-glass"></i>
                                <input type="text" id="acm_search" placeholder="Search by author, email, or content..." aria-label="Search comments">
                            </div>
                        </div>
                    </div>
                    <!-- Bulk Actions Bar -->
                    <div class="acm-bulk-bar hidden" id="acm_bulk_bar" role="status" aria-live="polite">
                        <div class="acm-bulk-bar-left">
                            <i class="fa-solid fa-check-double" style="color:#2563eb;"></i>
                            <span id="acm_selected_count">0 comments selected</span>
                        </div>
                        <div class="acm-bulk-bar-actions">
                            <button class="btn btn-success btn-sm" id="acm_bulk_approve">
                                <i class="fa-solid fa-check"></i>
                                Bulk Approve
                            </button>
                            <button class="btn btn-danger btn-sm" id="acm_bulk_reject">
                                <i class="fa-solid fa-xmark"></i>
                                Bulk Reject
                            </button>
                        </div>
                    </div>
                    <!-- Comments Table -->
                    <div class="acm-table-container" id="acm_comment_table">
                        <table class="acm-table" role="table">
                            <thead>
                                <tr>
                                    <th class="checkbox-cell">
                                        <input type="checkbox" id="acm_select_all" aria-label="Select all comments on this page">
                                    </th>
                                    <th>Author</th>
                                    <th>Post</th>
                                    <th>Rating</th>
                                    <th>Comment</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="acm_table_body">
                                <!-- Populated by JS -->
                            </tbody>
                        </table>
                    </div>
                    <!-- Pagination -->
                    <div class="acm-pagination" id="acm_pagination" aria-label="Pagination">
                        <div class="acm-pagination-info" id="acm_pagination_info">Showing 0 of 0 comments</div>
                        <div class="acm-pagination-controls" id="acm_pagination_controls">
                            <!-- Populated by JS -->
                        </div>
                    </div>
                </main>
            </div>
            <!-- Comment Detail Modal -->
            <div class="acm-modal-overlay" id="acm_comment_detail_modal" role="dialog" aria-modal="true" aria-labelledby="modal_title">
                <div class="acm-modal" id="acm_comment_detail">
                    <div class="acm-modal-header">
                        <h2 id="modal_title">Comment Details</h2>
                        <button class="modal-close" onclick="document.getElementById('acm_comment_detail_modal').classList.remove('active')" aria-label="Close modal">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                    <div class="acm-modal-body">
                        <div class="acm-modal-meta">
                            <div class="acm-modal-meta-item">
                                <span class="meta-label">Author</span>
                                <span class="meta-value" id="modal_author_name">—</span>
                            </div>
                            <div class="acm-modal-meta-item">
                                <span class="meta-label">Email</span>
                                <span class="meta-value" id="modal_author_email">—</span>
                            </div>
                            <div class="acm-modal-meta-item">
                                <span class="meta-label">Blog Post</span>
                                <span class="meta-value"><a id="modal_post_title" href="#">—</a></span>
                            </div>
                            <div class="acm-modal-meta-item">
                                <span class="meta-label">Date</span>
                                <span class="meta-value" id="modal_date">—</span>
                            </div>
                            <div class="acm-modal-meta-item">
                                <span class="meta-label">Rating</span>
                                <span class="meta-value"> <div class="acm-modal-rating" id="modal_rating"></div> </span>
                            </div>
                            <div class="acm-modal-meta-item">
                                <span class="meta-label">Status</span>
                                <span class="meta-value" id="modal_status">—</span>
                            </div>
                        </div>
                        <div class="acm-modal-comment-content">
                            <h4>Full Comment</h4>
                            <p id="modal_comment_text">—</p>
                        </div>
                    </div>
                    <div class="acm-modal-footer">
                        <button class="btn btn-ghost" onclick="document.getElementById('acm_comment_detail_modal').classList.remove('active')">
                            Close
</button>
                        <button class="btn btn-danger btn-sm" id="modal_delete_btn">
                            <i class="fa-solid fa-trash-can"></i>
                            Delete
                        </button>
                        <button class="btn btn-danger btn-sm" id="modal_reject_btn" style="background:#ef4444;border-color:#ef4444;">
                            <i class="fa-solid fa-xmark"></i>
                            Reject
                        </button>
                        <button class="btn btn-success btn-sm" id="modal_approve_btn">
                            <i class="fa-solid fa-check"></i>
                            Approve
                        </button>
                    </div>
                </div>
            </div>
            <!-- Delete Confirmation Modal -->
            <div class="acm-modal-overlay acm-confirm-modal" id="acm_delete_confirm_modal" role="alertdialog" aria-modal="true" aria-labelledby="delete_confirm_title">
                <div class="acm-modal">
                    <div class="acm-modal-body" style="padding:32px;">
                        <div class="acm-confirm-body">
                            <div class="acm-confirm-icon">
                                <i class="fa-solid fa-trash-can"></i>
                            </div>
                            <h3 id="delete_confirm_title">Delete Comment?</h3>
                            <p>Are you sure you want to permanently delete the comment by <strong id="delete_confirm_author">—</strong>? This action cannot be undone.</p>
                            <div class="acm-confirm-footer">
                                <button class="btn btn-outline" onclick="document.getElementById('acm_delete_confirm_modal').classList.remove('active')">
                                    Cancel
</button>
                                <button class="btn btn-danger" id="delete_confirm_btn">
                                    <i class="fa-solid fa-trash-can"></i>
                                    Delete Permanently
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Toast Container -->
            <div class="acm-toast-container" id="acm_toast_container" aria-live="polite" aria-atomic="true"></div>
        </div>
        <script src="assets/js/navigation.js"></script>
        <script src="assets/js/admin_comment_moderation.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    </body>
</html>