            </li>
            <li>
              <a class="cgs-toc-link" data-target="sec-faq" data-i18n="toc.faq"
                >FAQ</a
              >
            </li>
          </ul>
        </aside>
      </div>
      <!-- Scroll to top -->
      <button
        class="cgs-scroll-top"
        id="cgsScrollTop"
        aria-label="Scroll to top"
      >
        <i class="fa fa-arrow-up"></i>
      </button>
    </div>
    <div id="docFooter"></div>
    <script src="assets/js/navigation.js"></script>
