                            </li>
                            <li>
                                <a onclick="load_page('consumer_account_setup')" href="javascript:void(0)"><i class="fa fa-user-circle" aria-hidden="true"></i> Account Setup</a>
                            </li>
                        </ul>
                    </div>
                    <div class="cwm-sidebar-section">
                        <p class="cwm-sidebar-label">Using Your Wallet</p>
                        <ul class="cwm-sidebar-links">
                            <li>
                                <a onclick="load_page('consumer_making_payments')" href="javascript:void(0)"><i class="fa fa-credit-card" aria-hidden="true"></i> Making Payments</a>
                            </li>
                            <li>
                                <a class="active" onclick="load_page('consumer_wallet_management')" href="javascript:void(0)"><i class="fa fa-wallet" aria-hidden="true"></i> Wallet Management</a>
                            </li>
                            <li>
                                <a onclick="load_page('consumer_p2p_transfers')" href="javascript:void(0)"><i class="fa fa-exchange-alt" aria-hidden="true"></i> QR Transactions</a>
                            </li>
                        </ul>
                    </div>
                    <div class="cwm-sidebar-section">
                        <p class="cwm-sidebar-label">Settings & Help</p>
                        <ul class="cwm-sidebar-links">
                            <li>
                                <a onclick="load_page('consumer_settings')" href="javascript:void(0)"><i class="fa fa-cog" aria-hidden="true"></i> Settings & Security</a>
                            </li>
                            <li>
                                <a onclick="load_page('consumer_troubleshooting')" href="javascript:void(0)"><i class="fa fa-life-ring" aria-hidden="true"></i> Troubleshooting</a>
                            </li>
                        </ul>
                    </div>
                </nav>
            </aside>
            <!-- Mobile Sidebar Toggle -->
            <button class="cwm-sidebar-toggle" id="cwm-sidebar-toggle" aria-label="Toggle navigation menu" aria-expanded="false">
                <i class="fa fa-bars" aria-hidden="true"></i>
            </button>
            <!-- Main Content -->
            <div class="cwm-main">
                <div class="cwm-content-wrapper" id="cwm-main-content">
                    <!-- Breadcrumb -->
                    <nav class="cwm-breadcrumb" aria-label="Breadcrumb">
                        <a onclick="load_page('landing_page')" href="javascript:void(0)">Docs</a>
                        <span class="separator"><i class="fa fa-chevron-right" aria-hidden="true"></i></span>
                        <a onclick="load_page('consumer_docs_home')" href="javascript:void(0)">Consumer</a>
                        <span class="separator"><i class="fa fa-chevron-right" aria-hidden="true"></i></span>
                        <span class="current">Wallet Management</span>
                    </nav>
                    <!-- Page Title -->
                    <h1 class="cwm-page-title">Wallet Management</h1>
                    <p class="cwm-page-subtitle">Learn how to check your balance, add funds, withdraw money, and understand your transaction limits.</p>
                    <hr class="cwm-title-divider">
                    <!-- Wallet Overview Card -->
                    <div class="cwm-wallet-overview cwm-animate-in">
                        <div class="cwm-wallet-overview-inner">
                            <div class="cwm-wallet-icon-container">
                                <i class="fa fa-wallet" aria-hidden="true"></i>
                            </div>
                            <div class="cwm-wallet-overview-text">
                                <h3>Your MPay Wallet</h3>
                                <p>Your mPay wallet is a secure digital wallet that stores your funds and allows you to make payments, transfer money, and manage your finances &#8212; all from your smartphone.</p>
                            </div>
                        </div>
                    </div>
                    <!-- Section: Checking Balance -->
                    <section class="cwm-section" id="cwm_content_balance">
                        <h2 class="cwm-section-heading" id="checking-balance"> <i class="fa fa-eye heading-icon" aria-hidden="true"></i>Checking Your Balance </h2>
                        <p class="cwm-section-intro">Your wallet balance is always visible on the home screen of the mPay app. Here&apos;s everything you need to know about viewing and understanding your balance.</p>
                        <!-- Balance Demo -->
                        <div class="cwm-balance-demo">
                            <button class="cwm-balance-toggle" id="cwm-balance-toggle" aria-label="Hide balance">
                                <i class="fa fa-eye" aria-hidden="true"></i>
                            </button>
                            <div class="cwm-balance-demo-header">Available Balance</div>
                            <div class="cwm-balance-demo-amount" id="cwm-balance-amount">XCG 2,458.50</div>
                            <div class="cwm-balance-demo-currency">Antillean Guilders (XCG)</div>
                            <div class="cwm-balance-demo-actions">
                                <button class="cwm-balance-btn cwm-balance-btn-topup" aria-label="Top up wallet">
                                    <i class="fa fa-plus-circle" aria-hidden="true"></i>
                                    Top Up
                                </button>
                                <button class="cwm-balance-btn cwm-balance-btn-withdraw" aria-label="Withdraw funds">
                                    <i class="fa fa-arrow-circle-down" aria-hidden="true"></i>
                                    Withdraw
                                </button>
                                <button class="cwm-balance-btn cwm-balance-btn-history" aria-label="View transaction history">
                                    <i class="fa fa-history" aria-hidden="true"></i>
                                    History
                                </button>
                            </div>
                        </div>
                        <h3 class="cwm-subsection-heading">How to View Your Balance</h3>
                        <div class="cwm-steps">
                            <div class="cwm-step">
                                <span class="cwm-step-dot">1</span>
                                <p class="cwm-step-title">Open the MPay App</p>
                                <p class="cwm-step-desc">Launch the mPay Consumer app on your device. Your balance appears prominently on the home screen.</p>
                            </div>
                            <div class="cwm-step">
                                <span class="cwm-step-dot">2</span>
                                <p class="cwm-step-title">View Available Balance</p>
                                <p class="cwm-step-desc">Your available balance is displayed at the top of the screen. This is the amount you can spend or transfer immediately.</p>
                            </div>
                            <div class="cwm-step">
                                <span class="cwm-step-dot">3</span>
                                <p class="cwm-step-title">Toggle Balance Visibility</p>
                                <p class="cwm-step-desc">Tap the <strong>eye icon</strong> (<i class="fa fa-eye" aria-hidden="true"></i>) to hide or show your balance for privacy when in public.</p>
                            </div>
                        </div>
                        <div class="cwm-callout cwm-callout-info">
                            <span class="cwm-callout-icon"><i class="fa fa-info-circle" aria-hidden="true"></i></span>
                            <div>
                                <strong>Pending transactions</strong> may temporarily reduce your available balance. Pending amounts are shown separately below your main balance.
                            </div>
                        </div>
                    </section>
                    <!-- Section: Top-Up Methods -->
                    <section class="cwm-section" id="cwm_content_topup">
                        <h2 class="cwm-section-heading" id="topup-methods"> <i class="fa fa-plus-circle heading-icon" aria-hidden="true"></i>Top-Up Methods </h2>
                        <p class="cwm-section-intro">Add funds to your MPay wallet using any of the following methods. Each method has different processing times and fees.</p>
                        <div class="cwm-method-cards">
                            <div class="cwm-method-card">
                                <div class="cwm-method-card-icon">
                                    <i class="fa fa-university" aria-hidden="true"></i>
                                </div>
                                <h4>Bank Transfer</h4>
                                <p>Transfer funds from any local banks to your mPay wallet account via Instant Payment processing. Safe and fast.</p>
                                <p></p>
                                <div class="cwm-method-time">
                                    <i class="fa fa-bolt" aria-hidden="true"></i> Instant
                                </div>
                            </div>
                            <div class="cwm-method-card">
                                <div class="cwm-method-card-icon">
                                    <i class="fa fa-credit-card" aria-hidden="true"></i>
                                </div>
                                <h4>Wallet to Wallet</h4>
                                <p>Instantly load your wallet account by asking another mPay customer to send you money and pay them cash.</p>
                                <div class="cwm-method-time">
                                    <i class="fa fa-bolt" aria-hidden="true"></i> Instant
                                </div>
                            </div>
                            <div class="cwm-method-card">
                                <div class="cwm-method-card-icon">
                                    <i class="fa fa-store" aria-hidden="true"></i>
                                </div>
                                <h4>Cash Agent</h4>
                                <p>Visit an authorized mPay merchant near you to deposit cash into your wallet. Present your mPay QR code to the merchant.</p>
                                <div class="cwm-method-time">
                                    <i class="fa fa-bolt" aria-hidden="true"></i> Instant
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Section: Withdrawals -->
                    <section class="cwm-section" id="cwm_content_withdraw">
                        <!-- Withdrawal Flow -->
                        <div class="cwm-table-container">
</div>
                        <div class="cwm-callout cwm-callout-danger">
                            <span class="cwm-callout-icon"><i class="fa fa-exclamation-circle" aria-hidden="true"></i></span>
                            <div>
                                <strong>Important:</strong>&nbsp;mPay adheres to Curaçao Central Bank policies. Ensure bank account details are accurate and correct prior the transaction to avoid any delay.
                            </div>
                        </div>
                    </section>
                    <!-- Section: Transaction Limits -->
                    <section class="cwm-section" id="cwm_content_limits">
                        <h2 class="cwm-section-heading" id="transaction-limits"> <i class="fa fa-tachometer-alt heading-icon" aria-hidden="true"></i>Transaction Limits </h2>
                        <p class="cwm-section-intro">mPay enforces transaction limits to protect your account. Your limits depend on many factors like customer type(Consumer or Merchant) and is calculated on a daily, monthly and annual accumulation. </p>
                        <p class="cwm-section-intro">Here&apos;s a sample table limit(these are controlled by mPay Network)</p>
                        <div class="cwm-table-container">
                            <table class="cwm-table" aria-label="Transaction limits by tier">
                                <thead>
                                    <tr>
                                        <th scope="col">Transaction Type</th>
                                        <th scope="col"><span class="cwm-badge cwm-badge-basic">Consumer</span></th>
                                        <th scope="col"><span class="cwm-badge cwm-badge-verified">Merchant</span></th>
                                        <th scope="col"><span class="cwm-badge cwm-badge-premium">Cashier</span></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>Scan to Pay</strong></td>
                                        <td>XCG 10,000</td>
                                        <td>XCG 10,000</td>
                                        <td>Managed by<br>Merchant Owner</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Pay Bills</strong></td>
                                        <td>XCG 5,000</td>
                                        <td>XCG 10,000</td>
                                        <td><p>Managed by<br>Merchant Owner</p></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Pay to E-mail</strong></td>
                                        <td>XCG 10,000</td>
                                        <td>XCG 50,000</td>
                                        <td><p>Managed by<br>Merchant Owner</p></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Pay to Mobile</strong></td>
                                        <td>XCG 10,000</td>
                                        <td>XCG 50,000</td>
                                        <td><p>Managed by<br>Merchant Owner</p></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Transfer to Bank</strong></td>
                                        <td>XCG 50,000</td>
                                        <td>XCG 100,000</td>
                                    </tr>
                                    <tr>
</tr>
                                </tbody>
                            </table>
                        </div>
                        <h3 class="cwm-subsection-heading">How to Increase Your Limits</h3>
                        <div class="cwm-callout cwm-callout-info">
                            <span class="cwm-callout-icon"><i class="fa fa-info-circle" aria-hidden="true"></i></span>
                            <div>
                                <strong>View your current limits:</strong> Go to <strong>Profile Settings &rarr; Wallet Limits</strong> to see your current limit, usage, and remaining limits for the day/month.
                            </div>
                        </div>
                        <div class="cwm-callout cwm-callout-warning">
                            <span class="cwm-callout-icon"><i class="fa fa-exclamation-triangle" aria-hidden="true"></i></span>
                            <div>
                                <strong>Increasing your limit?</strong>&nbsp;Contact mPay Support for this request and is subject for review and approval.
                            </div>
                        </div>
                    </section>
                    <!-- Section: FAQ -->
                    <section class="cwm-faq-section" id="cwm_faq_accordion">
                        <h2 class="cwm-section-heading cwm-faq-heading" id="faq"> <i class="fa fa-question-circle heading-icon" aria-hidden="true"></i>Frequently Asked Questions </h2>
                        <div class="cwm-accordion" role="region" aria-label="Wallet management FAQ">
                            <div class="cwm-accordion-item">
                                <div class="cwm-accordion-panel" id="faq-1" role="region">
                                    <div class="cwm-accordion-panel-inner">
                                        Card top-ups appear instantly. Bank transfers typically take 1–2 business days, depending on your bank. Cash agent top-ups are also instant once confirmed by the agent. You'll receive a push notification as soon as the funds are credited.
</div>
                                </div>
                            </div>
                            <div class="cwm-accordion-item">
                                <div class="cwm-accordion-panel" id="faq-2" role="region">
                                    <div class="cwm-accordion-panel-inner">
                                        No. For security reasons, withdrawals can only be made to bank accounts registered in the same name as your MPay account. This is a regulatory requirement to prevent fraud and money laundering. If you need to send money to someone else, use the <strong>P2P Transfer</strong> feature instead.
                                    </div>
                                </div>
                            </div>
                            <div class="cwm-accordion-item">
                                <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-3">
                                    <span>What happens if I exceed my transaction limit?</span>
                                    <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
                                </button>
                                <div class="cwm-accordion-panel" id="faq-3" role="region">
                                    <div class="cwm-accordion-panel-inner">
                                        The transaction will be declined, and you'll see an error message explaining that you've reached your limit. You can either wait for the limit to reset (daily limits reset at midnight UTC, monthly limits on the 1st of each month) or upgrade your verification tier to get higher limits.
</div>
                                </div>
                            </div>
                            <div class="cwm-accordion-item">
                                <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-4">
                                    <span>Is there a fee for maintaining a wallet balance?</span>
                                    <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
                                </button>
                                <div class="cwm-accordion-panel" id="faq-4" role="region">
                                    <div class="cwm-accordion-panel-inner">
                                        No. There are no monthly fees, maintenance charges, or inactivity fees for your MPay wallet. Your balance stays yours. The only fees that may apply are for certain top-up methods (credit card top-ups) and express/instant withdrawals.
</div>
                                </div>
                            </div>
                            <div class="cwm-accordion-item">
                                <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-5">
                                    <span>Can I set up recurring/automatic top-ups?</span>
                                    <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
                                </button>
                                <div class="cwm-accordion-panel" id="faq-5" role="region">
                                    <div class="cwm-accordion-panel-inner">
                                        Yes! Go to <strong>Settings → Auto Top-Up</strong> to configure automatic balance replenishment. You can set a minimum balance threshold and a top-up amount. When your balance drops below the threshold, MPay will automatically top up from your preferred funding source.
                                    </div>
                                </div>
                            </div>
                            <div class="cwm-accordion-item">
                                <button class="cwm-accordion-trigger" aria-expanded="false" aria-controls="faq-6">
                                    <span>What happens to my balance if I lose my phone?</span>
                                    <i class="fa fa-chevron-down cwm-accordion-chevron" aria-hidden="true"></i>
                                </button>
                                <div class="cwm-accordion-panel" id="faq-6" role="region">
                                    <div class="cwm-accordion-panel-inner">
                                        Your balance is safe — it's stored securely on MPay servers, not on your device. If you lose your phone, immediately contact MPay support to freeze your account. Then, when you get a new device, log in with your credentials and your full balance will be restored. Enable remote wipe on your phone as an extra precaution.
</div>
                                </div>
                            </div>
                        </div>
                    </section>
                    <!-- Prev/Next Navigation -->
                    <div class="cwm-prev-next" id="cwm_prev_next">
                        <a class="cwm-pn-card prev" onclick="load_page('consumer_making_payments')" href="javascript:void(0)" aria-label="Go to previous page: Making Payments"> <span class="cwm-pn-label"><i class="fa fa-arrow-left" aria-hidden="true"></i> Previous</span> <span class="cwm-pn-title">Making Payments</span> </a>
                        <a class="cwm-pn-card next" onclick="load_page('consumer_p2p_transfers')" href="javascript:void(0)" aria-label="Go to next page: P2P Transfers"> <span class="cwm-pn-label">Next <i class="fa fa-arrow-right" aria-hidden="true"></i></span> <span class="cwm-pn-title">P2P Transfers</span> </a>
                    </div>
                </div>
                <!-- Table of Contents (Right Side) -->
                <aside class="cwm-toc" role="navigation" aria-label="Table of contents">
                    <p class="cwm-toc-title">On This Page</p>
                    <ul class="cwm-toc-list">
                        <li>
                            <a href="#checking-balance" class="active">Checking Your Balance</a>
                        </li>
                        <li>
                            <a href="#topup-methods">Top-Up Methods</a>
                        </li>
                        <li>
                            <a href="#withdrawals">Withdrawals</a>
                        </li>
                        <li>
                            <a href="#transaction-limits">Transaction Limits</a>
                        </li>
                        <li>
                            <a href="#faq">FAQ</a>
                        </li>
                    </ul>
                </aside>
            </div>
            <!-- Scroll to Top -->
            <button class="cwm-scroll-top" id="cwm-scroll-top" aria-label="Scroll to top">
                <i class="fa fa-arrow-up" aria-hidden="true"></i>
            </button>
        </div>
        <script src="assets/js/navigation.js"></script>
        <script src="assets/js/consumer_wallet_management.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    </body>
</html>