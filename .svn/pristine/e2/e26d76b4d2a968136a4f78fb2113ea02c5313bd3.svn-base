        <link rel="stylesheet" href="assets/css/global.css">
        <link rel="stylesheet" href="assets/css/consumer_wallet_management.css">
        <style>/* Basic reset for preview consistency */body { margin: 0; padding: 0; font-family: sans-serif; }</style>
    </head>
    <body>
        <div class="cwm-docs-layout">
            <!-- Skip to content -->
            <a href="#cwm-main-content" class="sr-only" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">Skip to main content</a>
            <!-- Mobile Sidebar Overlay -->
            <div class="cwm-sidebar-overlay" id="cwm-sidebar-overlay" aria-hidden="true"></div>
            <!-- Sidebar -->
            <aside class="cwm-sidebar" id="cwm-sidebar" role="navigation" aria-label="Consumer documentation navigation">
                <nav>
                    <div class="cwm-sidebar-section">
                        <p class="cwm-sidebar-label">Getting Started</p>
                        <ul class="cwm-sidebar-links">
                            <li>
                                <a onclick="load_page('consumer_docs_home')" href="javascript:void(0)"><i class="fa fa-home" aria-hidden="true"></i> Overview</a>
                            </li>
                            <li>
