/* Consumer Wallet Docs Home - Page Specific CSS */

.consumer-docs-home {
  display: flex;
  min-height: 100vh;
  flex-direction: column;
}

.consumer-docs-layout {
  display: flex;
  flex: 1;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
}

/* Sidebar Styles */
.cd-sidebar {
  width: 280px;
  min-width: 280px;
  border-right: 1px solid var(--color-border, #bfdbfe);
  background: var(--color-surface, #eff6ff);
  position: sticky;
  top: 65px;
  height: calc(100vh - 80px);
  overflow-y: auto;
  padding: 24px 0;
  scrollbar-width: thin;
  scrollbar-color: #bfdbfe transparent;
}

.cd-sidebar {
  padding-left: 36px !important;
}

.cd-sidebar::-webkit-scrollbar {
  width: 4px;
}

.cd-sidebar::-webkit-scrollbar-track {
  background: transparent;
}

.cd-sidebar::-webkit-scrollbar-thumb {
  background: #bfdbfe;
  border-radius: 4px;
}

.cd-sidebar-header {
  padding: 0 20px 16px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
  margin-bottom: 16px;
}

.cd-sidebar-header h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--color-primary, #2563eb);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 8px;
}

.cd-sidebar-header h3 i {
  font-size: 1rem;
}

.cd-sidebar-section {
  margin-bottom: 8px;
}

.cd-sidebar-section-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 12px 20px 6px;
  display: block;
}

.cd-sidebar-nav {
  list-style: none;
  padding: 0;
  margin: 0;
}

.cd-sidebar-nav li {
  padding: 0 12px;
}

.cd-sidebar-nav li a {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 12px;
  font-family: 'Inter', sans-serif;
  font-size: 0.875rem;
  color: #334155;
  text-decoration: none;
  border-radius: 8px;
  transition: all 150ms ease;
  cursor: pointer;
  line-height: 1.5;
}

.cd-sidebar-nav li a:hover {
  background: rgba(37, 99, 235, 0.06);
  color: var(--color-primary, #2563eb);
}

.cd-sidebar-nav li a.active {
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-primary, #2563eb);
  font-weight: 600;
}

.cd-sidebar-nav li a i {
  font-size: 0.875rem;
  width: 18px;
  text-align: center;
  flex-shrink: 0;
  opacity: 0.7;
}

.cd-sidebar-nav li a.active i {
  opacity: 1;
}

/* Mobile sidebar toggle */
.cd-sidebar-toggle {
  display: none;
  position: fixed;
  bottom: 24px;
  left: 24px;
  z-index: 100;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--color-primary, #2563eb);
  color: #fff;
  border: none;
  cursor: pointer;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  font-size: 1.125rem;
  transition: all 200ms ease;
  align-items: center;
  justify-content: center;
}

.cd-sidebar-toggle:hover {
  background: var(--color-primary-dark, #1d4ed8);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
}

.cd-sidebar-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  z-index: 199;
}

/* Main Content */
.cd-main-content {
  flex: 1;
  min-width: 0;
  padding: 32px 48px 64px;
  max-width: 900px;
}

/* Version Banner */
.cd-version-banner {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 8px;
  margin-bottom: 24px;
  font-size: 0.875rem;
  color: #334155;
}

.cd-version-banner i {
  color: var(--color-primary, #2563eb);
  font-size: 1rem;
}

.cd-version-banner .version-tag {
  display: inline-flex;
  align-items: center;
  padding: 2px 10px;
  background: var(--color-primary, #2563eb);
  color: #fff;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.cd-version-banner a {
  color: var(--color-primary, #2563eb);
  text-decoration: none;
  font-weight: 500;
}

.cd-version-banner a:hover {
  text-decoration: underline;
}

/* Breadcrumb */
.cd-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  font-size: 0.875rem;
  flex-wrap: wrap;
}

.cd-breadcrumb a {
  color: #64748b;
  text-decoration: none;
  transition: color 150ms ease;
}

.cd-breadcrumb a:hover {
  color: var(--color-primary, #2563eb);
}

.cd-breadcrumb .separator {
  color: #94a3b8;
  font-size: 0.75rem;
}

.cd-breadcrumb .current {
  color: var(--color-primary, #2563eb);
  font-weight: 500;
}

/* Page Title */
.cd-page-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 2.25rem;
  font-weight: 800;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.025em;
  line-height: 1.25;
  margin: 0 0 16px;
  padding-bottom: 20px;
  border-bottom: 2px solid var(--color-border, #bfdbfe);
}

/* Overview Section */
.cd-overview {
  margin-bottom: 48px;
}

.cd-overview-text {
  font-family: 'Inter', sans-serif;
  font-size: 1.125rem;
  color: #334155;
  line-height: 1.7;
  margin: 0 0 24px;
}

.cd-overview-text:last-child {
  margin-bottom: 0;
}

/* Key Features Callout */
.cd-key-features {
  background: var(--color-surface, #eff6ff);
  border: 1px solid var(--color-border, #bfdbfe);
  border-left: 4px solid var(--color-primary, #2563eb);
  border-radius: 8px;
  padding: 20px 24px;
  margin: 24px 0 0;
}

.cd-key-features h3 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.cd-key-features h3 i {
  color: var(--color-primary, #2563eb);
}

.cd-key-features ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px 24px;
}

.cd-key-features ul li {
  font-size: 0.9375rem;
  color: #334155;
  display: flex;
  align-items: center;
  gap: 8px;
  line-height: 1.5;
}

.cd-key-features ul li i {
  color: var(--color-success, #22c55e);
  font-size: 0.75rem;
  flex-shrink: 0;
}

/* Section Title */
.cd-section-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  letter-spacing: -0.015em;
  margin: 0 0 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--color-border, #bfdbfe);
}

/* Doc Cards Grid */
.cd-cards-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-bottom: 48px;
}

.cd-doc-card {
  background: #fff;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 12px;
  padding: 24px;
  cursor: pointer;
  transition: all 250ms ease;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.cd-doc-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--color-primary, #2563eb);
  transform: scaleX(0);
  transition: transform 250ms ease;
  transform-origin: left;
}

.cd-doc-card:hover {
  border-color: rgba(37, 99, 235, 0.3);
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.1);
}

.cd-doc-card:hover::before {
  transform: scaleX(1);
}

.cd-doc-card:focus-visible {
  outline: 2px solid var(--color-primary, #2563eb);
  outline-offset: 2px;
}

.cd-doc-card-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  background: var(--color-surface, #eff6ff);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  font-size: 1.125rem;
  color: var(--color-primary, #2563eb);
  transition: all 200ms ease;
}

.cd-doc-card:hover .cd-doc-card-icon {
  background: var(--color-primary, #2563eb);
  color: #fff;
}

.cd-doc-card-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1.0625rem;
  font-weight: 700;
  color: var(--color-text, #1e3a8a);
  margin: 0 0 8px;
  line-height: 1.3;
}

.cd-doc-card-desc {
  font-family: 'Inter', sans-serif;
  font-size: 0.875rem;
  color: #64748b;
  line-height: 1.6;
  margin: 0;
  flex: 1;
}

.cd-doc-card-arrow {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 16px;
  font-size: 0.8125rem;
  font-weight: 600;
  color: var(--color-primary, #2563eb);
  opacity: 0;
  transform: translateX(-8px);
  transition: all 200ms ease;
}

.cd-doc-card:hover .cd-doc-card-arrow {
  opacity: 1;
  transform: translateX(0);
}

/* Prev/Next Navigation */
.cd-prev-next {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 48px;
  padding-top: 32px;
  border-top: 1px solid var(--color-border, #bfdbfe);
}

.cd-prev-next-btn {
  display: flex;
  flex-direction: column;
  padding: 16px 20px;
  border: 1px solid var(--color-border, #bfdbfe);
  border-radius: 10px;
  background: #fff;
  cursor: pointer;
  transition: all 200ms ease;
  text-decoration: none;
}

.cd-prev-next-btn:hover {
  border-color: var(--color-primary, #2563eb);
  background: var(--color-surface, #eff6ff);
  box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
}

.cd-prev-next-btn:focus-visible {
  outline: 2px solid var(--color-primary, #2563eb);
  outline-offset: 2px;
}

.cd-prev-next-btn.next {
  text-align: right;
  align-items: flex-end;
}

.cd-prev-next-btn.prev {
  text-align: left;
  align-items: flex-start;
}

.cd-prev-next-label {
  font-size: 0.75rem;
  font-weight: 600;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 4px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.cd-prev-next-title {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-primary, #2563eb);
}

/* Quick Start Steps */
.cd-quick-start {
  margin-bottom: 48px;
}

.cd-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
  margin-top: 20px;
}

.cd-step {
  display: flex;
  gap: 16px;
  position: relative;
  padding-bottom: 24px;
}

.cd-step:last-child {
  padding-bottom: 0;
}

.cd-step-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.cd-step-number {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: var(--color-primary, #2563eb);
  color: #fff;
  font-size: 0.8125rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.cd-step-line {
  width: 2px;
  flex: 1;
  background: var(--color-border, #bfdbfe);
  margin-top: 4px;
}

.cd-step:last-child .cd-step-line {
  display: none;
}

.cd-step-content h4 {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text, #1e3a8a);
  margin: 4px 0 4px;
}

.cd-step-content p {
  font-size: 0.875rem;
  color: #64748b;
  line-height: 1.6;
  margin: 0;
}

/* Responsive */
@media (max-width: 1024px) {
  .cd-sidebar {
    width: 240px;
    min-width: 240px;
  }

  .cd-main-content {
    padding: 24px 32px 48px;
  }
}

@media (max-width: 768px) {
  .cd-sidebar {
    position: fixed;
    top: 0;
    left: -300px;
    width: 280px;
    min-width: 280px;
    height: 100vh;
    z-index: 200;
    transition: left 300ms ease;
    box-shadow: none;
  }

  .cd-sidebar.open {
    left: 0;
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.15);
  }

  .cd-sidebar-overlay.active {
    display: block;
  }

  .cd-sidebar-toggle {
    display: flex;
  }

  .cd-main-content {
    padding: 20px 16px 48px;
  }

  .cd-page-title {
    font-size: 1.75rem;
  }

  .cd-cards-grid {
    grid-template-columns: 1fr;
  }

  .cd-key-features ul {
    grid-template-columns: 1fr;
  }

  .cd-prev-next {
    grid-template-columns: 1fr;
  }

  .cd-prev-next-btn.next {
    text-align: left;
    align-items: flex-start;
  }

  .cd-overview-text {
    font-size: 1rem;
  }
}

@media (max-width: 480px) {
  .cd-page-title {
    font-size: 1.5rem;
  }

  .cd-doc-card {
    padding: 18px;
  }
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .cd-doc-card,
  .cd-doc-card::before,
  .cd-doc-card-icon,
  .cd-doc-card-arrow,
  .cd-prev-next-btn,
  .cd-sidebar,
  .cd-sidebar-toggle {
    transition: none !important;
  }

  .cd-doc-card:hover {
    transform: none;
  }

  .cd-sidebar-toggle:hover {
    transform: none;
  }
}
